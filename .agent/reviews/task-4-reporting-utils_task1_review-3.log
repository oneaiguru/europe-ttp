{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_33bd6d58a4924ca4b22f5a29","type":"tool_result","content":"1\tfrom __future__ import absolute_import\n2\t\n3\timport os\n4\timport logging\n5\timport hashlib\n6\timport numpy as np\n7\timport json\n8\timport cloudstorage as gcs\n9\tfrom google.appengine.api import app_identity\n10\t\n11\timport constants\n12\t\n13\t# creating enumerations using class \n14\tclass ReportingStatus:\n15\t    SUBMITTED = 'submitted'\n16\t    FILLED = 'filled'\n17\t    IN_PROGRESS = 'in progress'\n18\t    PENDING = 'pending'\n19\t    COMPLETE = 'complete'\n20\t    COMPLETE_LIFETIME = 'complete (lifetime)'\n21\t    INCOMPLETE = 'incomplete'\n22\t\n23\t\n24\t#[START get_reporting_status]\n25\tdef get_reporting_status(form_type, is_form_submitted, is_form_complete, no_of_submitted_evals=0, no_of_lifetime_submitted_evals=0):\n26\t    if is_form_submitted:\n27\t        _app_status = ReportingStatus.SUBMITTED\n28\t    elif is_form_complete:\n29\t        _app_status = ReportingStatus.FILLED\n30\t    else:\n31\t        _app_status = ReportingStatus.IN_PROGRESS\n32\t\n33\t    _eval_status = ReportingStatus.INCOMPLETE\n34\t    if form_type == 'ttc_application':\n35\t        if no_of_submitted_evals >= 3:\n36\t            _eval_status = ReportingStatus.COMPLETE\n37\t            if is_form_submitted:\n38\t                _app_status = ReportingStatus.COMPLETE\n39\t        elif no_of_lifetime_submitted_evals >= 3:\n40\t            _eval_status = ReportingStatus.COMPLETE_LIFETIME\n41\t            if is_form_submitted:\n42\t                _app_status = ReportingStatus.COMPLETE_LIFETIME\n43\t    elif form_type == 'post_ttc_self_evaluation_form':\n44\t        if no_of_submitted_evals >= 1:\n45\t            _eval_status = ReportingStatus.SUBMITTED\n46\t            if is_form_submitted:\n47\t                _app_status = ReportingStatus.COMPLETE\n48\t    elif form_type == 'post_sahaj_ttc_self_evaluation_form':\n49\t        if no_of_submitted_evals >= 1:\n50\t            _eval_status = ReportingStatus.SUBMITTED\n51\t            if is_form_submitted:\n52\t                _app_status = ReportingStatus.COMPLETE\n53\t    \n54\t    return _app_status, _eval_status\n55\t#[END get_reporting_status]\n56\t\n57\t#[START get_ttc_list]\n58\tdef get_ttc_list():\n59\t    source_file = constants.FORM_CONFIG_LOCATION + 'ttc_country_and_dates.json'    \n60\t    _f = gcs.open(source_file)\n61\t    _contents = _f.read()\n62\t    _f.close()\n63\t    ttc_list_raw = json.loads(_contents)\n64\t    ttc_list = {}\n65\t    for i, ttc in enumerate(ttc_list_raw):\n66\t        ttc_list[ttc[\"value\"]] = ttc\n67\t    return ttc_list\n68\t#[END get_ttc_list]\n69\t"}]},"parent_tool_use_id":null,"session_id":"31ffcb08-54be-40b8-8766-59c17ad1d0c9","uuid":"4d9caf84-d138-4ce1-a339-987def7699a1","timestamp":"2026-04-06T09:53:07.769Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/Downloads/europe-ttp-master@44c225683f8/reporting/reporting_utils.py","content":"from __future__ import absolute_import\n\nimport os\nimport logging\nimport hashlib\nimport numpy as np\nimport json\nimport cloudstorage as gcs\nfrom google.appengine.api import app_identity\n\nimport constants\n\n# creating enumerations using class \nclass ReportingStatus:\n    SUBMITTED = 'submitted'\n    FILLED = 'filled'\n    IN_PROGRESS = 'in progress'\n    PENDING = 'pending'\n    COMPLETE = 'complete'\n    COMPLETE_LIFETIME = 'complete (lifetime)'\n    INCOMPLETE = 'incomplete'\n\n\n#[START get_reporting_status]\ndef get_reporting_status(form_type, is_form_submitted, is_form_complete, no_of_submitted_evals=0, no_of_lifetime_submitted_evals=0):\n    if is_form_submitted:\n        _app_status = ReportingStatus.SUBMITTED\n    elif is_form_complete:\n        _app_status = ReportingStatus.FILLED\n    else:\n        _app_status = ReportingStatus.IN_PROGRESS\n\n    _eval_status = ReportingStatus.INCOMPLETE\n    if form_type == 'ttc_application':\n        if no_of_submitted_evals >= 3:\n            _eval_status = ReportingStatus.COMPLETE\n            if is_form_submitted:\n                _app_status = ReportingStatus.COMPLETE\n        elif no_of_lifetime_submitted_evals >= 3:\n            _eval_status = ReportingStatus.COMPLETE_LIFETIME\n            if is_form_submitted:\n                _app_status = ReportingStatus.COMPLETE_LIFETIME\n    elif form_type == 'post_ttc_self_evaluation_form':\n        if no_of_submitted_evals >= 1:\n            _eval_status = ReportingStatus.SUBMITTED\n            if is_form_submitted:\n                _app_status = ReportingStatus.COMPLETE\n    elif form_type == 'post_sahaj_ttc_self_evaluation_form':\n        if no_of_submitted_evals >= 1:\n            _eval_status = ReportingStatus.SUBMITTED\n            if is_form_submitted:\n                _app_status = ReportingStatus.COMPLETE\n    \n    return _app_status, _eval_status\n#[END get_reporting_status]\n\n#[START get_ttc_list]\ndef get_ttc_list():\n    source_file = constants.FORM_CONFIG_LOCATION + 'ttc_country_and_dates.json'    \n    _f = gcs.open(source_file)\n    _contents = _f.read()\n    _f.close()\n    ttc_list_raw = json.loads(_contents)\n    ttc_list = {}\n    for i, ttc in enumerate(ttc_list_raw):\n        ttc_list[ttc[\"value\"]] = ttc\n    return ttc_list\n#[END get_ttc_list]\n","numLines":69,"startLine":1,"totalLines":69}}}
