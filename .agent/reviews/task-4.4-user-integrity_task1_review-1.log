{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_4223822888874067908544ad","type":"tool_result","content":"1\timport { readJson, readText, writeJson, writeText, listFiles, GCS_PATHS } from '../gcs';\n2\timport { getTtcList, getReportingStatus } from './reporting-utils';\n3\t\n4\tconst DATA_RETENTION_DAYS = 730;\n5\tconst KEY = 'integrity';\n6\t\n7\t/* eslint-disable @typescript-eslint/no-explicit-any */\n8\t\n9\t/** Recursively convert Set instances to Arrays for JSON serialization. */\n10\tfunction convertSetsToArrays(obj: any): void {\n11\t  if (!obj || typeof obj !== 'object') return;\n12\t  if (obj instanceof Set) return; // handled by parent\n13\t  if (Array.isArray(obj)) {\n14\t    obj.forEach(convertSetsToArrays);\n15\t  } else {\n16\t    for (const key of Object.keys(obj)) {\n17\t      if (obj[key] instanceof Set) {\n18\t        obj[key] = Array.from(obj[key]);\n19\t      } else {\n20\t        convertSetsToArrays(obj[key]);\n21\t      }\n22\t    }\n23\t  }\n24\t}\n25\t\n26\t/**\n27\t * Port of Integrity.load_user_integrity() (Python lines 80-357).\n28\t * Reads all user data, compares enrolled people and organized courses\n29\t * across applicants to find duplicates/matches.\n30\t */\n31\texport async function loadUserIntegrity(): Promise<void> {\n32\t  const reportingFields: Record<string, string | string[]> = {\n33\t    'i_fname': '',\n34\t    'i_lname': '',\n35\t    'i_enrolled_people': '',\n36\t    'i_org_courses': [\n37\t      'i_org_course_from_date',\n38\t      'i_org_course_to_date',\n39\t      'i_org_course_leadteacher',\n40\t      'i_org_course_city',\n41\t      'i_org_course_state',\n42\t      'i_org_course_leadteacher',\n43\t    ],\n44\t  };\n45\t\n46\t  const ttcList = await getTtcList();\n47\t\n48\t  // Load existing integrity data or start fresh\n49\t  let userDataByEmail: any = {};\n50\t  try {\n51\t    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n52\t  } catch {\n53\t    // File doesn't exist ye