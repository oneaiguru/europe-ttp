p[c1fi];\n   190\t      const c1d = c1?.data || {};\n   191\t\n   192\t      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n   193\t      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n   194\t      const c1n = c1fn + ' ' + c1ln;\n   195\t\n   196\t      for (const c2e of Object.keys(userDataByEmail)) {\n   197\t        if (c1e === c2e) continue;\n   198\t\n   199\t        const c2TtcApp = userDataByEmail[c2e]['ttc_application'];\n   200\t        if (!c2TtcApp) continue;\n   201\t\n   202\t        for (const c2fi of Object.keys(c2TtcApp)) {\n   203\t          const c2 = c2TtcApp[c2fi];\n   204\t          const c2d = c2?.data || {};\n   205\t\n   206\t          const c2fn = (c2d.i_fname || '').trim().toLowerCase();\n   207\t          const c2ln = (c2d.i_lname || '').trim().toLowerCase();\n   208\t          const c2n = c2fn + ' ' + c2ln;\n   209\t\n   210\t          if (c1n === c2n) continue;\n   211\t\n   212\t          // Enrolled people matching\n   213\t          const c1Enrolled = c1d.i_enrolled_people;\n   214\t          const c2Enrolled = c2d.i_enrolled_people;\n   215\t\n   216\t          if (Array.isArray(c1Enrolled) && Array.isArray(c2Enrolled)) {\n   217\t            for (const c1en of c1Enrolled) {\n   218\t              for (const c2en of c2Enrolled) {\n   219\t                let isMatched = false;\n   220\t                const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n   221\t                const ee2 = (c2en.i_enrollment_email || '').trim().toLowerCase();\n   222\t                const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n   223\t                const en2 = (c2en.i_enrollment_name || '').trim().toLowerCase();\n   224\t                const ec1 = (c1en.i_enrollment_city || '').trim().toLowerCase();\n   225\t                const ec2 = (c2en.i_enrollment_city || '').trim().toLowerCase();\n   226\t                const es1 = (c1en.i_enrollment_state || '').trim().toLowerCase();\n   227\t                const es2 = (c2en.i_enrollment_state || '').trim().toLowerCase();\n   228\t\n   229\t                if (ee1.includes('@') && ee1 === ee2) isMatched = true;\n   230\t                if (en1 === en2 && ec1 === ec2 && es1 === es2) isMatched = true;\n   231\t\n   232\t                if (isMatched) {\n   233\t                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n   234\t                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n   235\t                  }\n   236\t                  if (!('enrolled_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n   237\t                    userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'] = {};\n   238\t                  }\n   239\t                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'];\n   240\t                  if (!(c2e in matches)) {\n   241\t                    matches[c2e] = new Set<string>();\n   242\t                  }\n   243\t                  matches[c2e].add(`${en2} <${ee2}>`);\n   244\t                }\n   245\t              }\n   246\t            }\n   247\t          }\n   248\t\n   249\t          // Org course matching — port of Python lines 285-337\n   250\t          const c1OrgCourses = c1d.i_org_courses;\n   251\t          const c2OrgCourses = c2d.i_org_courses;\n   252\t\n   253\t          if (Array.isArray(c1OrgCourses) && Array.isArray(c2OrgCourses)) {\n   254\t            for (const c1oc of c1OrgCourses) {\n   255\t              const ofd1 = (c1oc.i_org_course_from_date || '').trim();\n   256\t              const otd1 = (c1oc.i_org_course_to_date || '').trim();\n   257\t              const oc1 = (c1oc.i_org_course_city || '').trim().toLowerCase();\n   258\t              const os1 = (c1oc.i_org_course_state || '').trim().toLowerCase();\n   259\t              const olt1 = (c1oc.i_org_course_leadteacher || '').trim().toLowerCase();\n   260\t\n   261\t              const re1 = olt1.match(/^[^a-z]{0,3}([