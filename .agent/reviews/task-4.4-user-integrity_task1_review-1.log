etadata = ttcList[fd.form_instance_page_data.i_ttc_country_and_dates] || {};\n114\t        }\n115\t\n116\t        // Filter data to whitelisted fields only\n117\t        if (fd.data) {\n118\t          const fdData: any = {};\n119\t          for (const [q, qa] of Object.entries(fd.data)) {\n120\t            if (q in reportingFields) {\n121\t              let qa2 = qa;\n122\t              const fieldSpec = reportingFields[q];\n123\t              if (qa && typeof qa === 'object' && !Array.isArray(qa) && Array.isArray(fieldSpec)) {\n124\t                qa2 = {};\n125\t                for (const [tq, tqa] of Object.entries(qa as any)) {\n126\t                  if (fieldSpec.includes(tq)) {\n127\t                    (qa2 as any)[tq] = tqa;\n128\t                  }\n129\t                }\n130\t              }\n131\t              fdData[q] = qa2;\n132\t            }\n133\t          }\n134\t          fd.data = fdData;\n135\t        }\n136\t\n137\t        // Extract instance key and optional email — port of Python lines 197-209\n138\t        let fiEmail: string | null = null;\n139\t        let fi: string;\n140\t        if (fiRaw.includes('-')) {\n141\t          const fiArr = fiRaw.split('-');\n142\t          if (!fiArr[1].includes('@')) {\n143\t            fiEmail = fiArr[0];\n144\t            fi = fiArr[1];\n145\t          } else {\n146\t            fi = fiArr[0];\n147\t            fiEmail = fiArr[1];\n148\t          }\n149\t        } else {\n150\t          fi = fiRaw;\n151\t        }\n152\t\n153\t        // Store in userDataByEmail\n154\t        if (!(ue in userDataByEmail)) userDataByEmail[ue] = {};\n155\t        if (!(ft in userDataByEmail[ue])) {\n156\t          userDataByEmail[ue][ft] = {};\n157\t          userDataByEmail[ue][ft][KEY] = {};\n158\t        }\n159\t        if (!(fi in userDataByEmail[ue][ft])) userDataByEmail[ue][ft][fi] = {};\n160\t\n161\t        if (fiEmail) {\n162\t          userDataByEmail[ue][ft][fi][fiEmail] = fd;\n163\t        } else {\n164\t    