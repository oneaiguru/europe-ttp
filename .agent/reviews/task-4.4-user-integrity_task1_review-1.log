            let isMatched = false;\n   266\t                const ofd2 = (c2oc.i_org_course_from_date || '').trim();\n   267\t                const otd2 = (c2oc.i_org_course_to_date || '').trim();\n   268\t                const oc2 = (c2oc.i_org_course_city || '').trim().toLowerCase();\n   269\t                const os2 = (c2oc.i_org_course_state || '').trim().toLowerCase();\n   270\t                const olt2 = (c2oc.i_org_course_leadteacher || '').trim().toLowerCase();\n   271\t\n   272\t                const re2 = olt2.match(/^[^a-z]{0,3}([a-z]+ [a-z]+)/i);\n   273\t                const oltn2 = re2 ? re2[1] : '';\n   274\t\n   275\t                if (\n   276\t                  (ofd1 === ofd2 || otd1 === otd2) &&\n   277\t                  oc1 === oc2 &&\n   278\t                  os1 === os2 &&\n   279\t                  oltn1 &&\n   280\t                  oltn2 &&\n   281\t                  (oltn1 === oltn2 || olt1.includes(oltn2) || olt2.includes(oltn1))\n   282\t                ) {\n   283\t                  isMatched = true;\n   284\t                }\n   285\t\n   286\t                if (isMatched) {\n   287\t                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n   288\t                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n   289\t                  }\n   290\t                  if (!('org_course_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n   291\t                    userDataByEmail[c1e]['ttc_application'][KEY]['org_course_matches'] = {};\n   292\t                  }\n   293\t                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['org_course_matches'];\n   294\t                  if (!(c2e in matches)) {\n   295\t                    matches[c2e] = new Set<string>();\n   296\t                  }\n   297\t                  matches[c2e].add(`${ofd2} - ${otd2} (${oc2}, ${os2} - ${oltn2})`);\n   298\t                }\n   299\t              }\n   300\t            }\n   301\t          }\n   302\t        }\n   303\t      }\n   304\t    }\n   305\t  }\n   306\t\n   307\t  // Convert Sets to Arrays for JSON serialization\n   308\t  convertSetsToArrays(userDataByEmail);\n   309\t\n   310\t  await writeJson(GCS_PATHS.USER_INTEGRITY_BY_USER, userDataByEmail);\n   311\t}\n   312\t\n   313\t/**\n   314\t * Port of Integrity.post_load_user_integrity() (Python lines 359-400).\n   315\t * Generates CSV of applicants and their enrolled people.\n   316\t */\n   317\texport async function postLoadUserIntegrity(): Promise<void> {\n   318\t  let userDataByEmail: any = {};\n   319\t  try {\n   320\t    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n   321\t  } catch {\n   322\t    // File doesn't exist\n   323\t  }\n   324\t\n   325\t  let enrolledCSV = 'Applicant Name,Applicant Email,Enrolled Name,Enrolled Email\\n';\n   326\t\n   327\t  for (const c1e of Object.keys(userDataByEmail)) {\n   328\t    const ttcApp = userDataByEmail[c1e]['ttc_application'];\n   329\t    if (!ttcApp) continue;\n   330\t\n   331\t    for (const c1fi of Object.keys(ttcApp)) {\n   332\t      if (c1fi === 'default') continue;\n   333\t\n   334\t      const c1 = ttcApp[c1fi];\n   335\t      const c1d = c1?.data || {};\n   336\t\n   337\t      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n   338\t      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n   339\t      const c1n = c1fn + ' ' + c1ln;\n   340\t\n   341\t      enrolledCSV += `${c1n},${c1e},,\\n`;\n   342\t\n   343\t      const enrolledPeople = c1d.i_enrolled_people;\n   344\t      if (Array.isArray(enrolledPeople)) {\n   345\t        for (const c1en of enrolledPeople) {\n   346\t          const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n   347\t          const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n   348\t          enrolledCSV += `,,${en1},${ee1}\\n`;\n   349\t        }\n   350\t      }\n   351\t    }\n   352\t  }\n   353\t\n   354\t  // Normalize unicode to ASCII — port of unicodedata.normalize('NFKD', ...).encode('ascii', 'ignore')\n   355\t  enrolledCSV = enrolledCSV.normalize('NFKD').replace(/[\\u0300-\\u036f]/g, '');\n   356\t\n   357\t  await writeText(GCS_PATHS.APPLICANT_ENROLLED_LIST, enrolledCSV);\n   358\t}\n   359\t\n   360\t/**\n   361\t * Port of Integrity.get_user_integrity_by_user() (Python lines 74-78).\n   362\t * Reads the integrity JSON from GCS.\n   363\t */\n   364\texport async function getUserIntegrityByUser(): Promise<unknown> {\n   365\t  return readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n   366\t}\n```\n\n---\n\n**File 2: `/Users/m/ttp-split-experiment/app/integrity/user-integrity/load/route.ts`**\n\n```\n     1\timport { requireAdminOrCron } from '@/app/utils/auth-middleware';\n     2\timport { getUserIntegrityByUser } from '@/app/utils/reporting/user-integrity';\n     3\t\n     4\texport async function GET(request: Request): Promise<Response> {\n     5\t  const auth = await requireAdminOrCron(request);\n     6\t  if (auth instanceof Response) return auth;\n     7\t\n     8\t  const data = await getUserIntegrityByUser();\n     9\t  return new Response(JSON.stringify(data), {\n    10\t    headers: { 'content-type': 'text/plain' },\n    11\t  });\n    12\t}\n```\n\n---\n\n**File 3: `/Users/m/ttp-split-experiment/app/jobs/integrity/user-integrity/load/route.ts`**\n\n```\n     1\timport { requireAdminOrCron, requireAdmin } from '@/app/utils/auth-middleware';\n     2\timport { loadUserIntegrity } from '@/app/utils/reporting/user-integrity';\n     3\t\n     4\texport async function GET(request: Request): Promise<Response> {\n     5\t  const auth = await requireAdminOrCron(request);\n     6\t  if (auth instanceof Response) return auth;\n     7\t\n     8\t  await loadUserIntegrity();\n     9\t  return Response.json({ ok: true });\n    10\t}\n    11\t\n    12\texport async function POST(request: Request): Promise<Response> {\n    13\t  const auth = await requireAdmin(request);\n    14\t  if (auth instanceof Response) return auth;\n    15\t\n    16\t  await loadUserIntegrity();\n    17\t  return Response.json({ ok: true });\n    18\t}\n```\n\n---\n\n**File 4: `/Users/m/ttp-split-experiment/app/jobs/integrity/user-integrity/postload/route.ts`**\n\n```\n     1\timport { requireAdminOrCron, requireAdmin } from '@/app/utils/auth-middleware';\n     2\timport { postLoadUserIntegrity } from '@/app/utils/reporting/user-integrity';\n     3\t\n     4\texport async function GET(request: Request): Promise<Response> {\n     5\t  const auth = await requireAdminOrCron(request);\n     6\t  if (auth instanceof Response) return auth;\n     7\t\n     8\t  await postLoadUserIntegrity();\n     9\t  return Response.json({ ok: true });\n    10\t}\n    11\t\n    12\texport async function POST(request: Request): Promise<Response> {\n    13\t  const auth = await requireAdmin(request);\n    14\t  if (auth instanceof Response) return auth;\n    15\t\n    16\t  await postLoadUserIntegrity();\n    17\t  return Response.json({ ok: true });\n    18\t}\n```\n\n---\n\n**File 5: `/Users/m/ttp-split-experiment/app/integrity/user-integrity/get-by-user/route.ts`**\n\n```\n     1\timport { requireAdminOrCron, requireAdmin } from '@/app/utils/auth-middleware';\n     2\timport { loadUserIntegrity } from '@/app/utils/reporting/user-integrity';\n     3\t\n     4\texport async function GET(request: Request): Promise<Response> {\n     5\t  const auth = await requireAdminOrCron(request);\n     6\t  if (auth instanceof Response) return auth;\n     7\t\n     8\t  await loadUserIntegrity();\n     9\t  return Response.json({ ok: true });\n    10\t}\n    11\t\n    12\texport async function POST(request: Request): Promise<Response> {\n    13\t  const auth = await requireAdmin(request);\n    14\t  if (auth instanceof Response) return auth;\n    15\t\n    16\t  await loadUserIntegrity();\n    17\t  return Response.json({ ok: true });\n    18\t}\n```\n\n---\n\n**File 6: `/Users/m/Downloads/europe-ttp-master@44c225683f8/reporting/user_integrity.py`**\n\n```\n     1\t\n     2\tfrom __future__ import absolute_import\n     3\t\n     4\timport os\n     5\timport urllib\n     6\timport unicodedata\n     7\timport logging\n     8\timport base64\n     9\timport hashlib\n    10\timport json\n    11\timport re\n    12\tfrom datetime import tzinfo, timedelta, datetime\n    13\t\n    14\tfrom google.appengine.api import users\n    15\tfrom google.appengine.ext import ndb\n    16\tfrom google.appengine.api import app_identity\n    17\tfrom google.appengine.api import mail\n    18\tfrom google.appengine.api import images\n    19\tfrom google.appengine.ext import blobstore\n    20\t\n    21\timport jinja2\n    22\timport webapp2\n    23\t\n    24\timport cloudstorage as gcs\n    25\t\n    26\timport constants\n    27\tfrom pyutils import dt_utils\n    28\tfrom pyutils import utils, Utils\n    29\tfrom reporting import reporting_utils\n    30\tfrom db import ControlParameters\n    31\t\n    32\t# import gc\n    33\t\n    34\tclass Integrity(webapp2.RequestHandler):\n    35\t    KEY = 'integrity'\n    36\t\n    37\t    def get(self):\n    38\t        try:\n    39\t            is_cron = self.request.headers['X-Appengine-Cron']\n    40\t        except Exception as e:\n    41\t            is_cron = False\n    42\t\n    43\t        user = users.get_current_user()\n    44\t        if user:\n    45\t            user_email_addr = user.email()\n    46\t        else:\n    47\t            user_email_addr = \"\"\n    48\t\n    49\t        if not is_cron and user_email_addr not in constants.LIST_OF_ADMINS:\n    50\t            self.response.write(\"<b>UN-AUTHORIZED</b>\")\n    51\t        else:\n    52\t            if self.request.path == '/integrity/user-integrity/get-by-user':\n    53\t                self.response.write(self.get_user_integrity_by_user())\n    54\t            elif self.request.path in ('/integrity/user-integrity/load', '/jobs/integrity/user-integrity/load'):\n    55\t                self.load_user_integrity()\n    56\t            elif self.request.path in ('/integrity/user-integrity/postload', '/jobs/integrity/user-integrity/postload'):\n    57\t                self.post_load_user_integrity()\n    58\t\n    59\t    def post(self):\n    60\t        user = users.get_current_user()\n    61\t        if user:\n    62\t            user_email_addr = user.email()\n    63\t        else:\n    64\t            user_email_addr = \"\"\n    65\t\n    66\t        if user_email_addr not in constants.LIST_OF_ADMINS:\n    67\t            self.response.write(\"<b>UN-AUTHORIZED</b>\")\n    68\t        else:\n    69\t            if self.request.path in ('/integrity/user-integrity/load', '/jobs/integrity/user-integrity/load'):\n    70\t                self.load_user_integrity()\n    71\t            elif self.request.path in ('/integrity/user-integrity/postload', '/jobs/integrity/user-integrity/postload'):\n    72\t                self.post_load_user_integrity()\n    73\t\n    74\t    def get_user_integrity_by_user(self):\n    75\t        _f = gcs.open(constants.USER_INTEGRITY_BY_USER)\n    76\t        _contents = _f.read()\n    77\t        _f.close()\n    78\t        return _contents\n    79\t\n    80\t    def load_user_integrity(self):\n    81\t        reporting_fields = {\n    82\t            'i_fname': '',\n    83\t            'i_lname': '',\n    84\t            'i_enrolled_people': '',\n    85\t            'i_org_courses': [\n    86\t                'i_org_course_from_date',\n    87\t                'i_org_course_to_date',\n    88\t                'i_org_course_leadteacher',\n    89\t                'i_org_course_city',\n    90\t                'i_org_course_state',\n    91\t                'i_org_course_leadteacher',\n    92\t            ],\n    93\t        }\n    94\t\n    95\t        ttc_list = reporting_utils.get_ttc_list()\n    96\t\n    97\t        min_updated_datetime = None\n    98\t        cparams = ControlParameters.fetch()\n    99\t        if cparams:\n   100\t            min_updated_datetime = cparams.user_integrity_last_update_datetime\n   101\t            if min_updated_datetime:\n   102\t                logging.info('[load_user_integrity] user_integrity_last_update_datetime = ' + min_updated_datetime.strftime('%Y-%m-%d %H:%M:%S'))\n   103\t            else:\n   104\t                logging.info('[load_user_integrity] user_integrity_last_update_datetime = NONE')\n   105\t        try:\n   106\t            _f = gcs.stat(constants.USER_INTEGRITY_BY_USER)\n   107\t            file_updated_datetime = datetime.fromtimestamp(_f.st_ctime)\n   108\t            if not min_updated_datetime:\n   109\t                min_updated_datetime = (file_updated_datetime - timedelta(hours=1))\n   110\t                logging.error('[load_user_integrity] Did not find param for \"user_integrity_last_update_datetime\". Setting default from update date of ' + constants.USER_INTEGRITY_BY_USER)\n   111\t            else:\n   112\t                if file_updated_datetime < min_updated_datetime:\n   113\t                    min_updated_datetime = (file_updated_datetime - timedelta(hours=1))\n   114\t            _f = gcs.open(constants.USER_INTEGRITY_BY_USER)\n   115\t            _user_data_by_email = json.loads(_f.read())\n   116\t            _f.close()\n   117\t        except gcs.NotFoundError:\n   118\t            logging.info('[load_user_integrity] Failed to load the data from old user_integrity')\n   119\t            logging.info('[load_user_integrity] Initializing user with empty dictionary')\n   120\t            _user_data_by_email = {}\n   121\t            min_updated_datetime = None\n   122\t\n   123\t        if min_updated_datetime:\n   124\t            logging.info('[load_user_integrity] user_integrity_last_update_datetime = ' + min_updated_datetime.strftime('%Y-%m-%d %H:%M:%S'))\n   125\t\n   126\t        current_datetime = datetime.now()\n   127\t        _user_files = Utils.list_files(\n   128\t            # prefix=constants.USER_CONFIG_FOLDER,\n   129\t            prefix=constants.USER_CONFIG_LOCATION,\n   130\t            min_updated_datetime=min_updated_datetime,\n   131\t        )\n   132\t\n   133\t        # _user_files = gcs.listbucket(constants.USER_CONFIG_LOCATION)\n   134\t        # _user_data_by_email = {}\n   135\t        for _f in _user_files:\n   136\t            if _f.filename.endswith('.json') and not '/summary/' in _f.filename and not '/integrity/' in _f.filename:\n   137\t                # logging.info('[load_user_integrity] Reading file ' + _f.filename)\n   138\t                gcs_file = gcs.open(_f.filename)\n   139\t                _contents = gcs_file.read()\n   140\t                if _contents and _contents.strip() != '':\n   141\t                    _ud = json.loads(_contents)\n   142\t                    _ue = _ud.get('email', '')\n   143\t                    gcs_file.close()\n   144\t                    if 'form_data' in _ud:\n   145\t                        for _ft in _ud['form_data']:\n   146\t                            if _ft != 'ttc_application':\n   147\t                                continue\n   148\t                            for _fi_raw in _ud['form_data'][_ft]:\n   149\t                                if _fi_raw != 'default':\n   150\t                                    _fd = _ud['form_data'][_ft][_fi_raw]\n   151\t                                    _fd['form_instance'] = _fi_raw\n   152\t                                    if 'last_update_datetime' in _fd:\n   153\t                                        _fd['last_update_datetime_est'] = dt_utils.utc_to_timezone(\n   154\t                                            datetime.strptime(\n   155\t                                                _fd['last_update_datetime'], \n   156\t                                                \"%Y-%m-%d %H:%M:%S\"\n   157\t                                            ), \n   158\t                                            dt_utils.Eastern\n   159\t                                        ).strftime(\"%Y-%m-%d %H:%M:%S\")\n   160\t\n   161\t                                    if _fd['last_update_datetime_est'] < datetime.strftime(datetime.now() - timedelta(constants.DATA_RETENTION_DAYS), \"%Y-%m-%d %H:%M:%S\"):\n   162\t                                        continue\n   163\t\n   164\t                                    # [START] [reporting_fields] Processing application status\n   165\t                                    app_status, eval_status = reporting_utils.get_reporting_status(\n   166\t                                        _ft, \n   167\t                                        _fd.get('is_form_submitted', False),\n   168\t                                        _fd.get('is_form_complete', False),\n   169\t                                    )\n   170\t                                    # [END] [reporting_fields] Processing application status\n   171\t\n   172\t                                    # [START] [photo_url] Setting photo public URL\n   173\t                                    # [END] [photo_url] Setting photo public URL\n   174\t\n   175\t                                    # [START] [reporting_fields] Processing form_instance_page_data\n   176\t                                    if 'form_instance_page_data' in _fd and 'i_ttc_country_and_dates' in _fd['form_instance_page_data']:\n   177\t                                        _fd['ttc_metadata'] = ttc_list.get(_fd['form_instance_page_data']['i_ttc_country_and_dates'], {})\n   178\t                                    # [END] [reporting_fields] Processing form_instance_page_data\n   179\t\n   180\t                                    # [START] [reporting_fields] Processing all answers\n   181\t                                    if 'data' in _fd:\n   182\t                                        _fd_data = {}\n   183\t                                        for _q, _qa in _fd['data'].items():\n   184\t                                            # Storing only whitelisted fields\n   185\t                                            if _q in reporting_fields:\n   186\t                                                _qa2 = _qa\n   187\t                                                if isinstance(_qa, dict) and isinstance(reporting_fields[_q], list):\n   188\t                                                    _qa2 = {}\n   189\t                                                    for _tq, _tqa in _qa.items():\n   190\t                                                        if _tq in reporting_fields[_q]:\n   191\t                                                            _qa2[_tq] = _tqa\n   192\t                                                _fd_data[_q] = _qa2\n   193\t\n   194\t                                        _fd['data'] = _fd_data\n   195\t                                    # [END] [reporting_fields] Processing all answers\n   196\t\n   197\t                                    _fi_email = None\n   198\t                                    if '-' in _fi_raw:\n   199\t                                        _fi_arr = _fi_raw.split('-')\n   200\t                                        # Checking against 2nd value, since sometimes people enter names instead of emails\n   201\t                                        # That can throw off this logic. So in such cases we just take the first value as the email.\n   202\t                                        if '@' not in _fi_arr[1]:\n   203\t                                            _fi_email = _fi_arr[0]\n   204\t                                            _fi = _fi_arr[1]\n   205\t                                        else:\n   206\t                                            _fi = _fi_arr[0]\n   207\t                                            _fi_email = _fi_arr[1]\n   208\t                                    else:\n   209\t                                        _fi = _fi_raw\n   210\t\n   211\t                                    if _ue not in _user_