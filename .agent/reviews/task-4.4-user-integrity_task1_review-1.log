{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_1381f2f086f844abae680674","type":"tool_result","content":"1\t\n2\tfrom __future__ import absolute_import\n3\t\n4\timport os\n5\timport urllib\n6\timport unicodedata\n7\timport logging\n8\timport base64\n9\timport hashlib\n10\timport json\n11\timport re\n12\tfrom datetime import tzinfo, timedelta, datetime\n13\t\n14\tfrom google.appengine.api import users\n15\tfrom google.appengine.ext import ndb\n16\tfrom google.appengine.api import app_identity\n17\tfrom google.appengine.api import mail\n18\tfrom google.appengine.api import images\n19\tfrom google.appengine.ext import blobstore\n20\t\n21\timport jinja2\n22\timport webapp2\n23\t\n24\timport cloudstorage as gcs\n25\t\n26\timport constants\n27\tfrom pyutils import dt_utils\n28\tfrom pyutils import utils, Utils\n29\tfrom reporting import reporting_utils\n30\tfrom db import ControlParameters\n31\t\n32\t# import gc\n33\t\n34\tclass Integrity(webapp2.RequestHandler):\n35\t    KEY = 'integrity'\n36\t\n37\t    def get(self):\n38\t        try:\n39\t            is_cron = self.request.headers['X-Appengine-Cron']\n40\t        except Exception as e:\n41\t            is_cron = False\n42\t\n43\t        user = users.get_current_user()\n44\t        if user:\n45\t            user_email_addr = user.email()\n46\t        else:\n47\t            user_email_addr = \"\"\n48\t\n49\t        if not is_cron and user_email_addr not in constants.LIST_OF_ADMINS:\n50\t            self.response.write(\"<b>UN-AUTHORIZED</b>\")\n51\t        else:\n52\t            if self.request.path == '/integrity/user-integrity/get-by-user':\n53\t                self.response.write(self.get_user_integrity_by_user())\n54\t            elif self.request.path in ('/integrity/user-integrity/load', '/jobs/integrity/user-integrity/load'):\n55\t                self.load_user_integrity()\n56\t            elif self.request.path in ('/integrity/user-integrity/postload', '/jobs/integrity/user-integrity/postload'):\n57\t                self.post_load_user_integrity()\n58\t\n59\t    def post(self):\n60\t        user = users.get_current_user()\n61\t        if user:\n62\t            user_email_addr = user.email()\n63\t        else:\n64\t            user_email_addr = \"\"\n65\t\n66\t        if user_email_addr not in constants.LIST_OF_ADMINS:\n67\t            self.response.write(\"<b>UN-AUTHORIZED</b>\")\n68\t        else:\n69\t            if self.request.path in ('/integrity/user-integrity/load', '/jobs/integrity/user-integrity/load'):\n70\t                self.load_user_integrity()\n71\t            elif self.request.path in ('/integrity/user-integrity/postload', '/jobs/integrity/user-integrity/postload'):\n72\t                self.post_load_user_integrity()\n73\t\n74\t    def get_user_integrity_by_user(self):\n75\t        _f = gcs.open(constants.USER_INTEGRITY_BY_USER)\n76\t        _contents = _f.read()\n77\t        _f.close()\n78\t        return _contents\n79\t\n80\t    def load_user_integrity(self):\n81\t        reporting_fields = {\n82\t            'i_fname': '',\n83\t            'i_lname': '',\n84\t            'i_enrolled_people': '',\n85\t            'i_org_courses': [\n86\t                'i_org_course_from_date',\n87\t                'i_org_course_to_date',\n88\t                'i_org_course_leadteacher',\n89\t                'i_org_course_city',\n90\t                'i_org_course_state',\n91\t                'i_org_course_leadteacher',\n92\t            ],\n93\t        }\n94\t\n95\t        ttc_list = reporting_utils.get_ttc_list()\n96\t\n97\t        min_updated_datetime = None\n98\t        cparams = ControlParameters.fetch()\n99\t        if cparams:\n100\t            min_updated_datetime = cparams.user_integrity_last_update_datetime\n101\t            if min_updated_datetime:\n102\t                logging.info('[load_user_integrity] user_integrity_last_update_datetime = ' + min_updated_datetime.strftime('%Y-%m-%d %H:%M:%S'))\n103\t            else:\n104\t                logging.info('[load_user_integrity] user_integrity_last_update_datetime = NONE')\n105\t        try:\n106\t            _f = gcs.stat(constants.USER_INTEGRITY_BY_USER)\n107\t            file_updated_datetime = datetime.fromtimestamp(_f.st_ctime)\n108\t            if not min_updated_datetime:\n109\t                min_updated_datetime = (file_updated_datetime - timedelta(hours=1))\n110\t                logging.error('[load_user_integrity] Did not find param for \"user_integrity_last_update_datetime\". Setting default from update date of ' + constants.USER_INTEGRITY_BY_USER)\n111\t            else:\n112\t                if file_updated_datetime < min_updated_datetime:\n113\t                    min_updated_datetime = (file_updated_datetime - timedelta(hours=1))\n114\t            _f = gcs.open(constants.USER_INTEGRITY_BY_USER)\n115\t            _user_data_by_email = json.loads(_f.read())\n116\t            _f.close()\n117\t        except gcs.NotFoundError:\n118\t            logging.info('[load_user_integrity] Failed to load the data from old user_integrity')\n119\t            logging.info('[load_user_integrity] Initializing user with empty dictionary')\n120\t            _user_data_by_email = {}\n121\t            min_updated_datetime = None\n122\t\n123\t        if min_updated_datetime:\n124\t            logging.info('[load_user_integrity] user_integrity_last_update_datetime = ' + min_updated_datetime.strftime('%Y-%m-%d %H:%M:%S'))\n125\t\n126\t        current_datetime = datetime.now()\n127\t        _user_files = Utils.list_files(\n128\t            # prefix=constants.USER_CONFIG_FOLDER,\n129\t            prefix=constants.USER_CONFIG_LOCATION,\n130\t            min_updated_datetime=min_updated_datetime,\n131\t        )\n132\t\n133\t        # _user_files = gcs.listbucket(constants.USER_CONFIG_LOCATION)\n134\t        # _user_data_by_email = {}\n135\t        for _f in _user_files:\n136\t            if _f.filename.endswith('.json') and not '/summary/' in _f.filename and not '/integrity/' in _f.filename:\n137\t                # logging.info('[load_user_integrity] Reading file ' + _f.filename)\n138\t                gcs_file = gcs.open(_f.filename)\n139\t                _contents = gcs_file.read()\n140\t                if _contents and _contents.strip() != '':\n141\t                    _ud = json.loads(_contents)\n142\t                    _ue = _ud.get('email', '')\n143\t                    gcs_file.close()\n144\t                    if 'form_data' in _ud:\n145\t                        for _ft in _ud['form_data']:\n146\t                            if _ft != 'ttc_application':\n147\t                                continue\n148\t                            for _fi_raw in _ud['form_data'][_ft]:\n149\t                                if _fi_raw != 'default':\n150\t                                    _fd = _ud['form_data'][_ft][_fi_raw]\n151\t                                    _fd['form_instance'] = _fi_raw\n152\t                                    if 'last_update_datetime' in _fd:\n153\t                                        _fd['last_update_datetime_est'] = dt_utils.utc_to_timezone(\n154\t                                            datetime.strptime(\n155\t                                                _fd['last_update_datetime'], \n156\t                                                \"%Y-%m-%d %H:%M:%S\"\n157\t                                            ), \n158\t                                            dt_utils.Eastern\n159\t                                        ).strftime(\"%Y-%m-%d %H:%M:%S\")\n160\t\n161\t                                    if _fd['last_update_datetime_est'] < datetime.strftime(datetime.now() - timedelta(constants.DATA_RETENTION_DAYS), \"%Y-%m-%d %H:%M:%S\"):\n162\t                                        continue\n163\t\n164\t                                    # [START] [reporting_fields] Processing application status\n165\t                                    app_status, eval_status = reporting_utils.get_reporting_status(\n166\t                                        _ft, \n167\t                                        _fd.get('is_form_submitted', False),\n168\t                                        _fd.get('is_form_complete', False),\n169\t                                    )\n170\t                                    # [END] [reporting_fields] Processing application status\n171\t\n172\t                                    # [START] [photo_url] Setting photo public URL\n173\t                                    # [END] [photo_url] Setting photo public URL\n174\t\n175\t                                    # [START] [reporting_fields] Processing form_instance_page_data\n176\t                                    if 'form_instance_page_data' in _fd and 'i_ttc_country_and_dates' in _fd['form_instance_page_data']:\n177\t                                        _fd['ttc_metadata'] = ttc_list.get(_fd['form_instance_page_data']['i_ttc_country_and_dates'], {})\n178\t                                    # [END] [reporting_fields] Processing form_instance_page_data\n179\t\n180\t                                    # [START] [reporting_fields] Processing all answers\n181\t                                    if 'data' in _fd:\n182\t                                        _fd_data = {}\n183\t                                        for _q, _qa in _fd['data'].items():\n184\t                                            # Storing only whitelisted fields\n185\t                                            if _q in reporting_fields:\n186\t                                                _qa2 = _qa\n187\t                                                if isinstance(_qa, dict) and isinstance(reporting_fields[_q], list):\n188\t                                                    _qa2 = {}\n189\t                                                    for _tq, _tqa in _qa.items():\n190\t                                                        if _tq in reporting_fields[_q]:\n191\t                                                            _qa2[_tq] = _tqa\n192\t                                                _fd_data[_q] = _qa2\n193\t\n194\t                                        _fd['data'] = _fd_data\n195\t                                    # [END] [reporting_fields] Processing all answers\n196\t\n197\t                                    _fi_email = None\n198\t                                    if '-' in _fi_raw:\n199\t                                        _fi_arr = _fi_raw.split('-')\n200\t                                        # Checking against 2nd value, since sometimes people enter names instead of emails\n201\t                                        # That can throw off this logic. So in such cases we just take the first value as the email.\n202\t                                        if '@' not in _fi_arr[1]:\n203\t                                            _fi_email = _fi_arr[0]\n204\t                                            _fi = _fi_arr[1]\n205\t                                        else:\n206\t                                            _fi = _fi_arr[0]\n207\t                                            _fi_email = _fi_arr[1]\n208\t                                    else:\n209\t                                        _fi = _fi_raw\n210\t\n211\t                                    if _ue not in _user_data_by_email:\n212\t                                        _user_data_by_email[_ue] = {}\n213\t                                    if _ft not in _user_data_by_email[_ue]:\n214\t                                        _user_data_by_email[_ue][_ft] = {}\n215\t                                        _user_data_by_email[_ue][_ft][Integrity.KEY] = {}\n216\t                                    if _fi not in _user_data_by_email[_ue][_ft]:\n217\t                                        _user_data_by_email[_ue][_ft][_fi] = {}\n218\t\n219\t                                    if _fi_email:\n220\t                                        _user_data_by_email[_ue][_ft][_fi][_fi_email] = _fd\n221\t                                    else:\n222\t                                        _user_data_by_email[_ue][_ft][_fi] = _fd\n223\t\n224\t\n225\t        # [START KEYRESET] Clearing past evaluation assignments\n226\t        for _e in _user_data_by_email:\n227\t            if 'ttc_application' in _user_data_by_email[_e]:\n228\t                _user_data_by_email[_e]['ttc_application'][Integrity.KEY]['enrolled_matches'] = {}\n229\t                _user_data_by_email[_e]['ttc_application'][Integrity.KEY]['org_course_matches'] = {}\n230\t        # [END KEYRESET]\n231\t\n232\t        # logging.info('[load_user_integrity] Processing data')\n233\t\n234\t        # logging.info('[load_user_integrity] Processing applications')\n235\t        for _c1e in _user_data_by_email:\n236\t            for _c1fi in _user_data_by_email[_c1e].get('ttc_application', {}):\n237\t                if _c1fi == 'default':\n238\t                    continue\n239\t                # logging.info('[load_user_integrity] Processing application for ' + _c1e)\n240\t                _c1 = _user_data_by_email[_c1e]['ttc_application'][_c1fi]\n241\t                _c1d = _c1.get('data', {})\n242\t                _c1fn = _c1d.get('i_fname','').strip().lower()\n243\t                _c1ln = _c1d.get('i_lname','').strip().lower()\n244\t                _c1n = _c1fn + \" \" + _c1ln\n245\t\n246\t                for _c2e in _user_data_by_email:\n247\t                    if _c1e == _c2e:\n248\t                        continue\n249\t                    # logging.info('[load_user_integrity][' + _c1e + '] Comparing against application for: ' + _c2e)\n250\t                    for _c2fi in _user_data_by_email[_c2e].get('ttc_application', {}):\n251\t                        _c2 = _user_data_by_email[_c2e]['ttc_application'][_c2fi]\n252\t                        _c2d = _c2.get('data', {})\n253\t                        _c2fn = _c2d.get('i_fname','').strip().lower()\n254\t                        _c2ln = _c2d.get('i_lname','').strip().lower()\n255\t                        _c2n = _c2fn + \" \" + _c2ln\n256\t\n257\t                        if _c1n == _c2n:\n258\t                            continue\n259\t\n260\t                        for _c1en in _c1d.get('i_enrolled_people', {}):\n261\t                            for _c2en in _c2d.get('i_enrolled_people', {}):\n262\t                                is_matched = False\n263\t                                _ee1 = _c1en['i_enrollment_email'].strip().lower()\n264\t                                _ee2 = _c2en['i_enrollment_email'].strip().lower()\n265\t                                _en1 = _c1en['i_enrollment_name'].strip().lower()\n266\t                                _en2 = _c2en['i_enrollment_name'].strip().lower()\n267\t                                _ec1 = _c1en['i_enrollment_city'].strip().lower()\n268\t                                _ec2 = _c2en['i_enrollment_city'].strip().lower()\n269\t                                _es1 = _c1en['i_enrollment_state'].strip().lower()\n270\t                                _es2 = _c2en['i_enrollment_state'].strip().lower()\n271\t                                if '@' in _ee1 and _ee1 == _ee2:\n272\t                                    is_matched = True\n273\t                                if _en1 == _en2 and _ec1 == _ec2 and _es1 == _es2:\n274\t                                    is_matched = True\n275\t\n276\t                                if is_matched:\n277\t                                    if Integrity.KEY not in _user_data_by_email[_c1e]['ttc_application']:\n278\t                                        _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY] = {}\n279\t                                    if 'enrolled_matches' not in _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]:\n280\t                                        _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['enrolled_matches'] = {}\n281\t                                    if _c2e not in _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['enrolled_matches']:\n282\t                                        _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['enrolled_matches'][_c2e] = set()\n283\t                                    _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['enrolled_matches'][_c2e].add(\"{_en2} <{_ee2}>\".format(**locals()))\n284\t\n285\t                        for _c1en in _c1d.get('i_org_courses', {}):\n286\t                            _ofd1 = _c1en['i_org_course_from_date'].strip()\n287\t                            _otd1 = _c1en['i_org_course_to_date'].strip()\n288\t                            _ot1 = _c1en['i_org_course_leadteacher'].strip().lower()\n289\t                            _oc1 = _c1en['i_org_course_city'].strip().lower()\n290\t                            _os1 = _c1en['i_org_course_state'].strip().lower()\n291\t\n292\t                            _olt1 = _c1en[\"i_org_course_leadteacher\"].strip().lower()\n293\t                            _re = re.search(\"^[^a-z]{0,3}([a-z]+ [a-z]+)\", _olt1, re.IGNORECASE)\n294\t                            if _re:\n295\t                                _oltn1 = _re.group(1)\n296\t                            else:\n297\t                                _oltn1 = ''\n298\t\n299\t                            for _c2en in _c2d.get('i_org_courses', {}):\n300\t                                is_matched = False\n301\t                                _ofd2 = _c2en['i_org_course_from_date'].strip()\n302\t                                _otd2 = _c2en['i_org_course_to_date'].strip()\n303\t                                _ot2 = _c2en['i_org_course_leadteacher'].strip().lower()\n304\t                                _oc2 = _c2en['i_org_course_city'].strip().lower()\n305\t                                _os2 = _c2en['i_org_course_state'].strip().lower()\n306\t\n307\t                                _olt2 = _c2en[\"i_org_course_leadteacher\"].strip().lower()\n308\t                                _re = re.search(\"^[^a-z]{0,3}([a-z]+ [a-z]+)\", _olt2, re.IGNORECASE)\n309\t                                if _re:\n310\t                                    _oltn2 = _re.group(1)\n311\t                                else:\n312\t                                    _oltn2 = ''\n313\t\n314\t                                if (\n315\t                                    # _oc1 != 'online' and\n316\t                                    # _os1 != 'online' and\n317\t                                    (_ofd1 == _ofd2 or _otd1 == _otd2) and \n318\t                                    _oc1 == _oc2 and \n319\t                                    _os1 == _os2 and\n320\t                                    _oltn1 and\n321\t                                    _oltn2 and\n322\t                                    (\n323\t                                        _oltn1 == _oltn2 or\n324\t                                        _oltn1 in _olt2 or\n325\t                                        _oltn2 in _olt1\n326\t                                    )\n327\t                                ):\n328\t                                    is_matched = True\n329\t\n330\t                                if is_matched:\n331\t                                    if Integrity.KEY not in _user_data_by_email[_c1e]['ttc_application']:\n332\t                                        _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY] = {}\n333\t                                    if 'org_course_matches' not in _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]:\n334\t                                        _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['org_course_matches'] = {}\n335\t                                    if _c2e not in _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['org_course_matches']:\n336\t                                        _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['org_course_matches'][_c2e] = set()\n337\t                                    _user_data_by_email[_c1e]['ttc_application'][Integrity.KEY]['org_course_matches'][_c2e].add(\"{_ofd2} - {_otd2} ({_oc2}, {_os2} - {_oltn2})\".format(**locals()))\n338\t\n339\t        # ----------------------------------------------------------------------------------------\n340\t        write_retry_params = gcs.RetryParams(backoff_factor=1.1)\n341\t        _f = gcs.open(\n342\t            constants.USER_INTEGRITY_BY_USER,\n343\t            'w',\n344\t            content_type='text/plain',\n345\t            options={'x-goog-meta-foo': 'foo',\n346\t            'x-goog-meta-bar': 'bar'},\n347\t            retry_params=write_retry_params\n348\t        )\n349\t        _f.write(json.dumps(_user_data_by_email, default=utils.json_dumps_set_default))\n350\t        _f.close()\n351\t\n352\t        ControlParameters.create(\n353\t            {\n354\t                'user_integrity_last_update_datetime': current_datetime,\n355\t            }\n356\t        )\n357\t    # ----------------------------------------------------------------------------------------\n358\t\n359\t    def post_load_user_integrity(self):\n360\t        try:\n361\t            _f = gcs.open(constants.USER_INTEGRITY_BY_USER)\n362\t            _user_data_by_email = json.loads(_f.read())\n363\t            _f.close()\n364\t        except gcs.NotFoundError:\n365\t            logging.info('[post_load_user_integrity] Failed to load the data from old user_integrity')\n366\t            logging.info('[post_load_user_integrity] Initializing user with empty dictionary')\n367\t            _user_data_by_email = {}\n368\t\n369\t        enrolledCSV = \"Applicant Name,Applicant Email,Enrolled Name,Enrolled Email\\n\"\n370\t        for _c1e in _user_data_by_email:\n371\t            for _c1fi in _user_data_by_email[_c1e].get('ttc_application', {}):\n372\t                if _c1fi == 'default':\n373\t                    continue\n374\t                logging.info('[post_load_user_integrity] Processing application for ' + _c1e)\n375\t                _c1 = _user_data_by_email[_c1e]['ttc_application'][_c1fi]\n376\t                _c1d = _c1.get('data', {})\n377\t                _c1fn = _c1d.get('i_fname','').strip().lower()\n378\t                _c1ln = _c1d.get('i_lname','').strip().lower()\n379\t                _c1n = _c1fn + \" \" + _c1ln\n380\t                enrolledCSV += u\"{_c1n},{_c1e},,\\n\".format(**locals())\n381\t                for _c1en in _c1d.get('i_enrolled_people', {}):\n382\t                    _ee1 = _c1en['i_enrollment_email'].strip().lower()\n383\t                    _en1 = _c1en['i_enrollment_name'].strip().lower()\n384\t                    enrolledCSV += u\",,{_en1},{_ee1}\\n\".format(**locals())\n385\t\n386\t        write_retry_params = gcs.RetryParams(backoff_factor=1.1)\n387\t        _fecsv = gcs.open(\n388\t            constants.APPLICANT_ENROLLED_LIST,\n389\t            'w',\n390\t            content_type='text/plain',\n391\t            options={'x-goog-meta-foo': 'foo',\n392\t            'x-goog-meta-bar': 'bar'},\n393\t            retry_params=write_retry_params\n394\t        )\n395\t        import unicodedata\n396\t        enrolledCSV = unicodedata.normalize('NFKD', enrolledCSV).encode('ascii', 'ignore')\n397\t        _fecsv.write(enrolledCSV)\n398\t        # logging.info('[load_user_integrity] Processing applications')\n399\t        _fecsv.close()\n400\t    # ----------------------------------------------------------------------------------------\n401\t\n402\t#[END Integrity]\n403\t\n404\tapp = webapp2.WSGIApplication(\n405\t    [\n406\t        ('/integrity/user-integrity/load', Integrity),\n407\t        ('/integrity/user-integrity/get-by-user', Integrity),\n408\t        ('/jobs/integrity/user-integrity/load', Integrity),\n409\t        ('/jobs/integrity/user-integrity/postload', Integrity),\n410\t    ],\n411\t    debug=True\n412\t)\n413\t\n414\t"}]},"parent_tool_use_id":"call_bbd4d8c44323424db78a9699","session_id":"21355242-1684-4e3c-9ce8-56c7e7070b09","uuid":"52923944-b104-4823-9308-c3b2cf3f4dbf","timestamp":"2026-04-06T11:42:12.168Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_4d36c2a7a41544dfa2bbe053","type":"tool_result","content":"1\timport { readJson, readText, writeJson, writeText, listFiles, GCS_PATHS } from '../gcs';\n2\timport { getTtcList, getReportingStatus } from './reporting-utils';\n3\t\n4\tconst DATA_RETENTION_DAYS = 730;\n5\tconst KEY = 'integrity';\n6\t\n7\t/* eslint-disable @typescript-eslint/no-explicit-any */\n8\t\n9\t/** Recursively convert Set instances to Arrays for JSON serialization. */\n10\tfunction convertSetsToArrays(obj: any): void {\n11\t  if (!obj || typeof obj !== 'object') return;\n12\t  if (obj instanceof Set) return; // handled by parent\n13\t  if (Array.isArray(obj)) {\n14\t    obj.forEach(convertSetsToArrays);\n15\t  } else {\n16\t    for (const key of Object.keys(obj)) {\n17\t      if (obj[key] instanceof Set) {\n18\t        obj[key] = Array.from(obj[key]);\n19\t      } else {\n20\t        convertSetsToArrays(obj[key]);\n21\t      }\n22\t    }\n23\t  }\n24\t}\n25\t\n26\t/**\n27\t * Port of Integrity.load_user_integrity() (Python lines 80-357).\n28\t * Reads all user data, compares enrolled people and organized courses\n29\t * across applicants to find duplicates/matches.\n30\t */\n31\texport async function loadUserIntegrity(): Promise<void> {\n32\t  const reportingFields: Record<string, string | string[]> = {\n33\t    'i_fname': '',\n34\t    'i_lname': '',\n35\t    'i_enrolled_people': '',\n36\t    'i_org_courses': [\n37\t      'i_org_course_from_date',\n38\t      'i_org_course_to_date',\n39\t      'i_org_course_leadteacher',\n40\t      'i_org_course_city',\n41\t      'i_org_course_state',\n42\t      'i_org_course_leadteacher',\n43\t    ],\n44\t  };\n45\t\n46\t  const ttcList = await getTtcList();\n47\t\n48\t  // Load existing integrity data or start fresh\n49\t  let userDataByEmail: any = {};\n50\t  try {\n51\t    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n52\t  } catch {\n53\t    // File doesn't exist yet\n54\t  }\n55\t\n56\t  // List all user JSON files\n57\t  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX);\n58\t  const now = new Date();\n59\t\n60\t  for (const file of userFiles) {\n61\t    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n62\t      continue;\n63\t    }\n64\t\n65\t    let contents: string;\n66\t    try {\n67\t      contents = await readText(file.name);\n68\t    } catch {\n69\t      continue;\n70\t    }\n71\t\n72\t    if (!contents || contents.trim() === '') continue;\n73\t\n74\t    let ud: any;\n75\t    try {\n76\t      ud = JSON.parse(contents);\n77\t    } catch {\n78\t      continue;\n79\t    }\n80\t\n81\t    const ue: string = ud.email || '';\n82\t    if (!ue) continue;\n83\t    if (!ud.form_data) continue;\n84\t\n85\t    for (const ft of Object.keys(ud.form_data)) {\n86\t      if (ft !== 'ttc_application') continue;\n87\t\n88\t      for (const fiRaw of Object.keys(ud.form_data[ft])) {\n89\t        if (fiRaw === 'default') continue;\n90\t\n91\t        const fd: any = { ...ud.form_data[ft][fiRaw] };\n92\t        fd.form_instance = fiRaw;\n93\t\n94\t        // Check retention (skip old records) — port of Python line 161\n95\t        if (fd.last_update_datetime) {\n96\t          const cutoffDate = new Date(now);\n97\t          cutoffDate.setDate(cutoffDate.getDate() - DATA_RETENTION_DAYS);\n98\t          const lastUpdate = new Date(fd.last_update_datetime);\n99\t          if (lastUpdate < cutoffDate) continue;\n100\t        }\n101\t\n102\t        // Reporting status\n103\t        const [appStatus, evalStatus] = getReportingStatus(\n104\t          ft,\n105\t          fd.is_form_submitted || false,\n106\t          fd.is_form_complete || false,\n107\t        );\n108\t        fd.app_status = appStatus;\n109\t        fd.eval_status = evalStatus;\n110\t\n111\t        // TTC metadata\n112\t        if (fd.form_instance_page_data?.i_ttc_country_and_dates) {\n113\t          fd.ttc_metadata = ttcList[fd.form_instance_page_data.i_ttc_country_and_dates] || {};\n114\t        }\n115\t\n116\t        // Filter data to whitelisted fields only\n117\t        if (fd.data) {\n118\t          const fdData: any = {};\n119\t          for (const [q, qa] of Object.entries(fd.data)) {\n120\t            if (q in reportingFields) {\n121\t              let qa2 = qa;\n122\t              const fieldSpec = reportingFields[q];\n123\t              if (qa && typeof qa === 'object' && !Array.isArray(qa) && Array.isArray(fieldSpec)) {\n124\t                qa2 = {};\n125\t                for (const [tq, tqa] of Object.entries(qa as any)) {\n126\t                  if (fieldSpec.includes(tq)) {\n127\t                    (qa2 as any)[tq] = tqa;\n128\t                  }\n129\t                }\n130\t              }\n131\t              fdData[q] = qa2;\n132\t            }\n133\t          }\n134\t          fd.data = fdData;\n135\t        }\n136\t\n137\t        // Extract instance key and optional email — port of Python lines 197-209\n138\t        let fiEmail: string | null = null;\n139\t        let fi: string;\n140\t        if (fiRaw.includes('-')) {\n141\t          const fiArr = fiRaw.split('-');\n142\t          if (!fiArr[1].includes('@')) {\n143\t            fiEmail = fiArr[0];\n144\t            fi = fiArr[1];\n145\t          } else {\n146\t            fi = fiArr[0];\n147\t            fiEmail = fiArr[1];\n148\t          }\n149\t        } else {\n150\t          fi = fiRaw;\n151\t        }\n152\t\n153\t        // Store in userDataByEmail\n154\t        if (!(ue in userDataByEmail)) userDataByEmail[ue] = {};\n155\t        if (!(ft in userDataByEmail[ue])) {\n156\t          userDataByEmail[ue][ft] = {};\n157\t          userDataByEmail[ue][ft][KEY] = {};\n158\t        }\n159\t        if (!(fi in userDataByEmail[ue][ft])) userDataByEmail[ue][ft][fi] = {};\n160\t\n161\t        if (fiEmail) {\n162\t          userDataByEmail[ue][ft][fi][fiEmail] = fd;\n163\t        } else {\n164\t          userDataByEmail[ue][ft][fi] = fd;\n165\t        }\n166\t      }\n167\t    }\n168\t  }\n169\t\n170\t  // [KEYRESET] Clear past matches — port of Python lines 226-230\n171\t  for (const e of Object.keys(userDataByEmail)) {\n172\t    if ('ttc_application' in userDataByEmail[e]) {\n173\t      if (!(KEY in userDataByEmail[e]['ttc_application'])) {\n174\t        userDataByEmail[e]['ttc_application'][KEY] = {};\n175\t      }\n176\t      userDataByEmail[e]['ttc_application'][KEY]['enrolled_matches'] = {};\n177\t      userDataByEmail[e]['ttc_application'][KEY]['org_course_matches'] = {};\n178\t    }\n179\t  }\n180\t\n181\t  // Enrolled people matching (O(n²)) — port of Python lines 235-283\n182\t  for (const c1e of Object.keys(userDataByEmail)) {\n183\t    const c1TtcApp = userDataByEmail[c1e]['ttc_application'];\n184\t    if (!c1TtcApp) continue;\n185\t\n186\t    for (const c1fi of Object.keys(c1TtcApp)) {\n187\t      if (c1fi === 'default') continue;\n188\t\n189\t      const c1 = c1TtcApp[c1fi];\n190\t      const c1d = c1?.data || {};\n191\t\n192\t      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n193\t      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n194\t      const c1n = c1fn + ' ' + c1ln;\n195\t\n196\t      for (const c2e of Object.keys(userDataByEmail)) {\n197\t        if (c1e === c2e) continue;\n198\t\n199\t        const c2TtcApp = userDataByEmail[c2e]['ttc_application'];\n200\t        if (!c2TtcApp) continue;\n201\t\n202\t        for (const c2fi of Object.keys(c2TtcApp)) {\n203\t          const c2 = c2TtcApp[c2fi];\n204\t          const c2d = c2?.data || {};\n205\t\n206\t          const c2fn = (c2d.i_fname || '').trim().toLowerCase();\n207\t          const c2ln = (c2d.i_lname || '').trim().toLowerCase();\n208\t          const c2n = c2fn + ' ' + c2ln;\n209\t\n210\t          if (c1n === c2n) continue;\n211\t\n212\t          // Enrolled people matching\n213\t          const c1Enrolled = c1d.i_enrolled_people;\n214\t          const c2Enrolled = c2d.i_enrolled_people;\n215\t\n216\t          if (Array.isArray(c1Enrolled) && Array.isArray(c2Enrolled)) {\n217\t            for (const c1en of c1Enrolled) {\n218\t              for (const c2en of c2Enrolled) {\n219\t                let isMatched = false;\n220\t                const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n221\t                const ee2 = (c2en.i_enrollment_email || '').trim().toLowerCase();\n222\t                const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n223\t                const en2 = (c2en.i_enrollment_name || '').trim().toLowerCase();\n224\t                const ec1 = (c1en.i_enrollment_city || '').trim().toLowerCase();\n225\t                const ec2 = (c2en.i_enrollment_city || '').trim().toLowerCase();\n226\t                const es1 = (c1en.i_enrollment_state || '').trim().toLowerCase();\n227\t                const es2 = (c2en.i_enrollment_state || '').trim().toLowerCase();\n228\t\n229\t                if (ee1.includes('@') && ee1 === ee2) isMatched = true;\n230\t                if (en1 === en2 && ec1 === ec2 && es1 === es2) isMatched = true;\n231\t\n232\t                if (isMatched) {\n233\t                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n234\t                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n235\t                  }\n236\t                  if (!('enrolled_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n237\t                    userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'] = {};\n238\t                  }\n239\t                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'];\n240\t                  if (!(c2e in matches)) {\n241\t                    matches[c2e] = new Set<string>();\n242\t                  }\n243\t                  matches[c2e].add(`${en2} <${ee2}>`);\n244\t                }\n245\t              }\n246\t            }\n247\t          }\n248\t\n249\t          // Org course matching — port of Python lines 285-337\n250\t          const c1OrgCourses = c1d.i_org_courses;\n251\t          const c2OrgCourses = c2d.i_org_courses;\n252\t\n253\t          if (Array.isArray(c1OrgCourses) && Array.isArray(c2OrgCourses)) {\n254\t            for (const c1oc of c1OrgCourses) {\n255\t              const ofd1 = (c1oc.i_org_course_from_date || '').trim();\n256\t              const otd1 = (c1oc.i_org_course_to_date || '').trim();\n257\t              const oc1 = (c1oc.i_org_course_city || '').trim().toLowerCase();\n258\t              const os1 = (c1oc.i_org_course_state || '').trim().toLowerCase();\n259\t              const olt1 = (c1oc.i_org_course_leadteacher || '').trim().toLowerCase();\n260\t\n261\t              const re1 = olt1.match(/^[^a-z]{0,3}([a-z]+ [a-z]+)/i);\n262\t              const oltn1 = re1 ? re1[1] : '';\n263\t\n264\t              for (const c2oc of c2OrgCourses) {\n265\t                let isMatched = false;\n266\t                const ofd2 = (c2oc.i_org_course_from_date || '').trim();\n267\t                const otd2 = (c2oc.i_org_course_to_date || '').trim();\n268\t                const oc2 = (c2oc.i_org_course_city || '').trim().toLowerCase();\n269\t                const os2 = (c2oc.i_org_course_state || '').trim().toLowerCase();\n270\t                const olt2 = (c2oc.i_org_course_leadteacher || '').trim().toLowerCase();\n271\t\n272\t                const re2 = olt2.match(/^[^a-z]{0,3}([a-z]+ [a-z]+)/i);\n273\t                const oltn2 = re2 ? re2[1] : '';\n274\t\n275\t                if (\n276\t                  (ofd1 === ofd2 || otd1 === otd2) &&\n277\t                  oc1 === oc2 &&\n278\t                  os1 === os2 &&\n279\t                  oltn1 &&\n280\t                  oltn2 &&\n281\t                  (oltn1 === oltn2 || olt1.includes(oltn2) || olt2.includes(oltn1))\n282\t                ) {\n283\t                  isMatched = true;\n284\t                }\n285\t\n286\t                if (isMatched) {\n287\t                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n288\t                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n289\t                  }\n290\t                  if (!('org_course_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n291\t                    userDataByEmail[c1e]['ttc_application'][KEY]['org_course_matches'] = {};\n292\t                  }\n293\t                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['org_course_matches'];\n294\t                  if (!(c2e in matches)) {\n295\t                    matches[c2e] = new Set<string>();\n296\t                  }\n297\t                  matches[c2e].add(`${ofd2} - ${otd2} (${oc2}, ${os2} - ${oltn2})`);\n298\t                }\n299\t              }\n300\t            }\n301\t          }\n302\t        }\n303\t      }\n304\t    }\n305\t  }\n306\t\n307\t  // Convert Sets to Arrays for JSON serialization\n308\t  convertSetsToArrays(userDataByEmail);\n309\t\n310\t  await writeJson(GCS_PATHS.USER_INTEGRITY_BY_USER, userDataByEmail);\n311\t}\n312\t\n313\t/**\n314\t * Port of Integrity.post_load_user_integrity() (Python lines 359-400).\n315\t * Generates CSV of applicants and their enrolled people.\n316\t */\n317\texport async function postLoadUserIntegrity(): Promise<void> {\n318\t  let userDataByEmail: any = {};\n319\t  try {\n320\t    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n321\t  } catch {\n322\t    // File doesn't exist\n323\t  }\n324\t\n325\t  let enrolledCSV = 'Applicant Name,Applicant Email,Enrolled Name,Enrolled Email\\n';\n326\t\n327\t  for (const c1e of Object.keys(userDataByEmail)) {\n328\t    const ttcApp = userDataByEmail[c1e]['ttc_application'];\n329\t    if (!ttcApp) continue;\n330\t\n331\t    for (const c1fi of Object.keys(ttcApp)) {\n332\t      if (c1fi === 'default') continue;\n333\t\n334\t      const c1 = ttcApp[c1fi];\n335\t      const c1d = c1?.data || {};\n336\t\n337\t      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n338\t      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n339\t      const c1n = c1fn + ' ' + c1ln;\n340\t\n341\t      enrolledCSV += `${c1n},${c1e},,\\n`;\n342\t\n343\t      const enrolledPeople = c1d.i_enrolled_people;\n344\t      if (Array.isArray(enrolledPeople)) {\n345\t        for (const c1en of enrolledPeople) {\n346\t          const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n347\t          const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n348\t          enrolledCSV += `,,${en1},${ee1}\\n`;\n349\t        }\n350\t      }\n351\t    }\n352\t  }\n353\t\n354\t  // Normalize unicode to ASCII — port of unicodedata.normalize('NFKD', ...).encode('ascii', 'ignore')\n355\t  enrolledCSV = enrolledCSV.normalize('NFKD').replace(/[\\u0300-\\u036f]/g, '');\n356\t\n357\t  await writeText(GCS_PATHS.APPLICANT_ENROLLED_LIST, enrolledCSV);\n358\t}\n359\t\n360\t/**\n361\t * Port of Integrity.get_user_integrity_by_user() (Python lines 74-78).\n362\t * Reads the integrity JSON from GCS.\n363\t */\n364\texport async function getUserIntegrityByUser(): Promise<unknown> {\n365\t  return readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n366\t}\n367\t"}]},"parent_tool_use_id":"call_bbd4d8c44323424db78a9699","session_id":"21355242-1684-4e3c-9ce8-56c7e7070b09","uuid":"d141a073-2bae-42ec-8baa-f7423a02e10b","timestamp":"2026-04-06T11:42:12.169Z"}
