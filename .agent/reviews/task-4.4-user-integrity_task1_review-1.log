\t      'i_org_course_leadteacher',\n    43\t    ],\n    44\t  };\n    45\t\n    46\t  const ttcList = await getTtcList();\n    47\t\n    48\t  // Load existing integrity data or start fresh\n    49\t  let userDataByEmail: any = {};\n    50\t  try {\n    51\t    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n    52\t  } catch {\n    53\t    // File doesn't exist yet\n    54\t  }\n    55\t\n    56\t  // List all user JSON files\n    57\t  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX);\n    58\t  const now = new Date();\n    59\t\n    60\t  for (const file of userFiles) {\n    61\t    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n    62\t      continue;\n    63\t    }\n    64\t\n    65\t    let contents: string;\n    66\t    try {\n    67\t      contents = await readText(file.name);\n    68\t    } catch {\n    69\t      continue;\n    70\t    }\n    71\t\n    72\t    if (!contents || contents.trim() === '') continue;\n    73\t\n    74\t    let ud: any;\n    75\t    try {\n    76\t      ud = JSON.parse(contents);\n    77\t    } catch {\n    78\t      continue;\n    79\t    }\n    80\t\n    81\t    const ue: string = ud.email || '';\n    82\t    if (!ue) continue;\n    83\t    if (!ud.form_data) continue;\n    84\t\n    85\t    for (const ft of Object.keys(ud.form_data)) {\n    86\t      if (ft !== 'ttc_application') continue;\n    87\t\n    88\t      for (const fiRaw of Object.keys(ud.form_data[ft])) {\n    89\t        if (fiRaw === 'default') continue;\n    90\t\n    91\t        const fd: any = { ...ud.form_data[ft][fiRaw] };\n    92\t        fd.form_instance = fiRaw;\n    93\t\n    94\t        // Check retention (skip old records) — port of Python line 161\n    95\t        if (fd.last_update_datetime) {\n    96\t          const cutoffDate = new Date(now);\n    97\t          cutoffDate.setDate(cutoffDate.getDate() - DATA_RETENTION_DAYS);\n    98\t          const last