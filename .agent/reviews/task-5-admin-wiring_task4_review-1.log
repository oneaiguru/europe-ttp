{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_79c15c737c0d4af38aa22ea7","type":"tool_result","content":"1\timport { readJson, writeJson, GCS_PATHS } from './gcs';\n2\t\n3\t// Re-export GCS_PATHS for convenience\n4\texport { GCS_PATHS };\n5\t\n6\t/** Convert truthy string values to boolean (ported from pyutils/utils.py str2bool) */\n7\tfunction str2bool(value: unknown): boolean {\n8\t  if (!value || typeof value !== 'string') return false;\n9\t  return ['1', 'y', 't', 'true'].includes(value.toLowerCase());\n10\t}\n11\t\n12\t/** Format current UTC time as YYYY-MM-DD HH:MM:SS (matches Python strftime) */\n13\tfunction utcNowFormatted(): string {\n14\t  const d = new Date();\n15\t  const pad = (n: number) => String(n).padStart(2, '0');\n16\t  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}`;\n17\t}\n18\t\n19\tinterface FormInstance {\n20\t  data: Record<string, unknown>;\n21\t  form_instance_page_data: Record<string, unknown>;\n22\t  form_instance_display: string;\n23\t  is_agreement_accepted: boolean;\n24\t  is_form_submitted: boolean;\n25\t  send_confirmation_to_candidate: boolean;\n26\t  is_form_complete: boolean;\n27\t  last_update_datetime: string;\n28\t}\n29\t\n30\tinterface UserJSON {\n31\t  username?: string;\n32\t  email?: string;\n33\t  name?: string;\n34\t  photo_file?: string;\n35\t  photo_url?: string;\n36\t  current_evaluation_id?: string;\n37\t  form_data?: Record<string, Record<string, FormInstance>>;\n38\t  is_profile_complete?: Record<string, boolean>;\n39\t  home_country?: string;\n40\t  config?: Record<string, unknown>;\n41\t}\n42\t\n43\texport class TTCPortalUser {\n44\t  username = '';\n45\t  email = '';\n46\t  name = '';\n47\t  photoFile = '';\n48\t  currentEvaluationId = '';\n49\t  formData: Record<string, Record<string, FormInstance>> = {};\n50\t  isProfileComplete: Record<string, boolean> = {};\n51\t  homeCountry = '';\n52\t  config: Record<string, unknown> = {};\n53\t\n54\t  private constructor() {}\n55\t\n56\t  /** Async factory — loads user data from GCS */\n57\t  static async create(email: string): Promise<TTCPortalUser> {\n58\t    const user = new TTCPortalUser();\n59\t    await user.loadUserData(email);\n60\t    return user;\n61\t  }\n62\t\n63\t  private initializeUser(data: UserJSON): void {\n64\t    this.username = data.username ?? '';\n65\t    this.email = data.email ?? this.email ?? '';\n66\t    this.name = data.name ?? '';\n67\t    this.photoFile = data.photo_file ?? '';\n68\t    this.currentEvaluationId = data.current_evaluation_id ?? '';\n69\t    this.formData = data.form_data ?? {};\n70\t    this.isProfileComplete = data.is_profile_complete ?? {};\n71\t    this.homeCountry = data.home_country ?? '';\n72\t    this.config = data.config ?? {};\n73\t  }\n74\t\n75\t  private async loadUserData(email: string): Promise<void> {\n76\t    this.email = email;\n77\t    try {\n78\t      const data = await readJson(\n79\t        GCS_PATHS.USER_CONFIG_PREFIX + email + '.json',\n80\t      ) as UserJSON;\n81\t      this.initializeUser(data);\n82\t    } catch (e: unknown) {\n83\t      // GCS NotFoundError — initialize with empty data (Python lines 316-319)\n84\t      if (e && typeof e === 'object' && 'code' in e && (e as { code: number }).code === 404) {\n85\t        this.initializeUser({ email });\n86\t      } else if (e instanceof Error && e.message?.includes('No such object')) {\n87\t        this.initializeUser({ email });\n88\t      } else {\n89\t        throw e;\n90\t      }\n91\t    }\n92\t  }\n93\t\n94\t  async saveUserData(): Promise<void> {\n95\t    await writeJson(\n96\t      GCS_PATHS.USER_CONFIG_PREFIX + this.email + '.json',\n97\t      this.toJSON(),\n98\t    );\n99\t  }\n100\t\n101\t  private toJSON(): UserJSON {\n102\t    return {\n103\t      username: this.username,\n104\t      email: this.email,\n105\t      name: this.name,\n106\t      photo_file: this.photoFile,\n107\t      current_evaluation_id: this.currentEvaluationId,\n108\t      form_data: this.formData,\n109\t      is_profile_complete: this.isProfileComplete,\n110\t      home_country: this.homeCountry,\n111\t      config: this.config,\n112\t    };\n113\t  }\n114\t\n115\t  setFormData(\n116\t    formType: string,\n117\t    formInstance: string | null | undefined,\n118\t    data: Record<string, unknown>,\n119\t    pageData: Record<string, unknown>,\n120\t    display: string,\n121\t  ): void {\n122\t    let instance = 'default';\n123\t    if (formInstance && formInstance.trim() !== '') {\n124\t      instance = formInstance;\n125\t    }\n126\t\n127\t    let form: Partial<FormInstance> = {};\n128\t    if (formType in this.formData && instance in this.formData[formType]) {\n129\t      form = this.formData[formType][instance];\n130\t    }\n131\t\n132\t    form.data = data;\n133\t    form.form_instance_page_data = pageData;\n134\t    form.form_instance_display = display;\n135\t\n136\t    // Completeness check — any null or empty string field means incomplete\n137\t    let isComplete = true;\n138\t    for (const key of Object.keys(data)) {\n139\t      const val = data[key];\n140\t      if (val == null || String(val).trim() === '') {\n141\t        isComplete = false;\n142\t        break;\n143\t      }\n144\t    }\n145\t\n146\t    form.is_agreement_accepted = str2bool(data['i_agreement_accepted']);\n147\t    form.is_form_submitted = str2bool(data['i_form_submitted']);\n148\t    form.send_confirmation_to_candidate = str2bool(data['i_send_confirmation_to_candidate']);\n149\t\n150\t    // Name extraction\n151\t    if ('i_name' in data) {\n152\t      this.name = String(data['i_name']).trim();\n153\t    } else {\n154\t      const fname = String(data['i_fname'] ?? '').trim();\n155\t      const lname = String(data['i_lname'] ?? '').trim();\n156\t      this.name = fname + ' ' + lname;\n157\t    }\n158\t\n159\t    form.is_form_complete = isComplete;\n160\t    if (formType.includes('profile')) {\n161\t      this.isProfileComplete[formType] = isComplete;\n162\t    }\n163\t    form.last_update_datetime = utcNowFormatted();\n164\t\n165\t    if (!(formType in this.formData)) {\n166\t      this.formData[formType] = {};\n167\t    }\n168\t    this.formData[formType][instance] = form as FormInstance;\n169\t\n170\t    // Last stored form is stored in default as well for easy retrieval\n171\t    if (instance !== 'default') {\n172\t      this.formData[formType]['default'] = form as FormInstance;\n173\t    }\n174\t\n175\t    // Email sending is deferred to Phase 6 — skip send_submission_emails\n176\t  }\n177\t\n178\t  getFormData(formType: string, formInstance: string | null | undefined): Record<string, unknown> {\n179\t    let instance = 'default';\n180\t    if (formInstance && formInstance.trim() !== '') {\n181\t      instance = formInstance;\n182\t    }\n183\t    if (formType in this.formData && instance in this.formData[formType]) {\n184\t      return this.formData[formType][instance].data;\n185\t    }\n186\t    return {};\n187\t  }\n188\t\n189\t  getFormInstances(formType: string): Record<string, { page_data: Record<string, unknown>; display: string }> {\n190\t    const instances: Record<string, { page_data: Record<string, unknown>; display: string }> = {};\n191\t    if (formType in this.formData) {\n192\t      for (const key of Object.keys(this.formData[formType])) {\n193\t        if (key !== 'default') {\n194\t          instances[key] = {\n195\t            page_data: this.formData[formType][key].form_instance_page_data ?? {},\n196\t            display: this.formData[formType][key].form_instance_display ?? key,\n197\t          };\n198\t        }\n199\t      }\n200\t    }\n201\t    return instances;\n202\t  }\n203\t\n204\t  isFormSubmitted(formType: string, formInstance: string | null | undefined): boolean {\n205\t    let instance = 'default';\n206\t    if (formInstance && formInstance.trim() !== '') {\n207\t      instance = formInstance;\n208\t    }\n209\t    if (formType in this.formData && instance in this.formData[formType]) {\n210\t      return this.formData[formType][instance].is_form_submitted ?? false;\n211\t    }\n212\t    return false;\n213\t  }\n214\t\n215\t  isFormComplete(formType: string, formInstance: string | null | undefined): boolean {\n216\t    let instance = 'default';\n217\t    if (formInstance && formInstance.trim() !== '') {\n218\t      instance = formInstance;\n219\t    }\n220\t    if (formType in this.formData && instance in this.formData[formType]) {\n221\t      return this.formData[formType][instance].is_form_complete ?? false;\n222\t    }\n223\t    return false;\n224\t  }\n225\t\n226\t  setConfig(params: Record<string, unknown>): void {\n227\t    this.config = { ...this.config, ...params };\n228\t    if ('i_home_country' in params) {\n229\t      this.setHomeCountry(String(params['i_home_country']));\n230\t    }\n231\t  }\n232\t\n233\t  getConfig(): Record<string, unknown> {\n234\t    return this.config;\n235\t  }\n236\t\n237\t  setHomeCountry(country: string): void {\n238\t    this.homeCountry = country;\n239\t    this.config['i_home_country'] = country;\n240\t  }\n241\t\n242\t  getHomeCountry(): string {\n243\t    return this.homeCountry;\n244\t  }\n245\t\n246\t  getEmail(): string {\n247\t    return this.email;\n248\t  }\n249\t}\n250\t"}]},"parent_tool_use_id":null,"session_id":"a5435e6a-d4e5-45d2-bbb5-9eb27f15a589","uuid":"1409cfe0-426f-4a46-8ee4-b0cf886382c1","timestamp":"2026-04-06T13:57:18.761Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/ttc-portal-user.ts","content":"import { readJson, writeJson, GCS_PATHS } from './gcs';\n\n// Re-export GCS_PATHS for convenience\nexport { GCS_PATHS };\n\n/** Convert truthy string values to boolean (ported from pyutils/utils.py str2bool) */\nfunction str2bool(value: unknown): boolean {\n  if (!value || typeof value !== 'string') return false;\n  return ['1', 'y', 't', 'true'].includes(value.toLowerCase());\n}\n\n/** Format current UTC time as YYYY-MM-DD HH:MM:SS (matches Python strftime) */\nfunction utcNowFormatted(): string {\n  const d = new Date();\n  const pad = (n: number) => String(n).padStart(2, '0');\n  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}`;\n}\n\ninterface FormInstance {\n  data: Record<string, unknown>;\n  form_instance_page_data: Record<string, unknown>;\n  form_instance_display: string;\n  is_agreement_accepted: boolean;\n  is_form_submitted: boolean;\n  send_confirmation_to_candidate: boolean;\n  is_form_complete: boolean;\n  last_update_datetime: string;\n}\n\ninterface UserJSON {\n  username?: string;\n  email?: string;\n  name?: string;\n  photo_file?: string;\n  photo_url?: string;\n  current_evaluation_id?: string;\n  form_data?: Record<string, Record<string, FormInstance>>;\n  is_profile_complete?: Record<string, boolean>;\n  home_country?: string;\n  config?: Record<string, unknown>;\n}\n\nexport class TTCPortalUser {\n  username = '';\n  email = '';\n  name = '';\n  photoFile = '';\n  currentEvaluationId = '';\n  formData: Record<string, Record<string, FormInstance>> = {};\n  isProfileComplete: Record<string, boolean> = {};\n  homeCountry = '';\n  config: Record<string, unknown> = {};\n\n  private constructor() {}\n\n  /** Async factory — loads user data from GCS */\n  static async create(email: string): Promise<TTCPortalUser> {\n    const user = new TTCPortalUser();\n    await user.loadUserData(email);\n    return user;\n  }\n\n  private initializeUser(data: UserJSON): void {\n    this.username = data.username ?? '';\n    this.email = data.email ?? this.email ?? '';\n    this.name = data.name ?? '';\n    this.photoFile = data.photo_file ?? '';\n    this.currentEvaluationId = data.current_evaluation_id ?? '';\n    this.formData = data.form_data ?? {};\n    this.isProfileComplete = data.is_profile_complete ?? {};\n    this.homeCountry = data.home_country ?? '';\n    this.config = data.config ?? {};\n  }\n\n  private async loadUserData(email: string): Promise<void> {\n    this.email = email;\n    try {\n      const data = await readJson(\n        GCS_PATHS.USER_CONFIG_PREFIX + email + '.json',\n      ) as UserJSON;\n      this.initializeUser(data);\n    } catch (e: unknown) {\n      // GCS NotFoundError — initialize with empty data (Python lines 316-319)\n      if (e && typeof e === 'object' && 'code' in e && (e as { code: number }).code === 404) {\n        this.initializeUser({ email });\n      } else if (e instanceof Error && e.message?.includes('No such object')) {\n        this.initializeUser({ email });\n      } else {\n        throw e;\n      }\n    }\n  }\n\n  async saveUserData(): Promise<void> {\n    await writeJson(\n      GCS_PATHS.USER_CONFIG_PREFIX + this.email + '.json',\n      this.toJSON(),\n    );\n  }\n\n  private toJSON(): UserJSON {\n    return {\n      username: this.username,\n      email: this.email,\n      name: this.name,\n      photo_file: this.photoFile,\n      current_evaluation_id: this.currentEvaluationId,\n      form_data: this.formData,\n      is_profile_complete: this.isProfileComplete,\n      home_country: this.homeCountry,\n      config: this.config,\n    };\n  }\n\n  setFormData(\n    formType: string,\n    formInstance: string | null | undefined,\n    data: Record<string, unknown>,\n    pageData: Record<string, unknown>,\n    display: string,\n  ): void {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n\n    let form: Partial<FormInstance> = {};\n    if (formType in this.formData && instance in this.formData[formType]) {\n      form = this.formData[formType][instance];\n    }\n\n    form.data = data;\n    form.form_instance_page_data = pageData;\n    form.form_instance_display = display;\n\n    // Completeness check — any null or empty string field means incomplete\n    let isComplete = true;\n    for (const key of Object.keys(data)) {\n      const val = data[key];\n      if (val == null || String(val).trim() === '') {\n        isComplete = false;\n        break;\n      }\n    }\n\n    form.is_agreement_accepted = str2bool(data['i_agreement_accepted']);\n    form.is_form_submitted = str2bool(data['i_form_submitted']);\n    form.send_confirmation_to_candidate = str2bool(data['i_send_confirmation_to_candidate']);\n\n    // Name extraction\n    if ('i_name' in data) {\n      this.name = String(data['i_name']).trim();\n    } else {\n      const fname = String(data['i_fname'] ?? '').trim();\n      const lname = String(data['i_lname'] ?? '').trim();\n      this.name = fname + ' ' + lname;\n    }\n\n    form.is_form_complete = isComplete;\n    if (formType.includes('profile')) {\n      this.isProfileComplete[formType] = isComplete;\n    }\n    form.last_update_datetime = utcNowFormatted();\n\n    if (!(formType in this.formData)) {\n      this.formData[formType] = {};\n    }\n    this.formData[formType][instance] = form as FormInstance;\n\n    // Last stored form is stored in default as well for easy retrieval\n    if (instance !== 'default') {\n      this.formData[formType]['default'] = form as FormInstance;\n    }\n\n    // Email sending is deferred to Phase 6 — skip send_submission_emails\n  }\n\n  getFormData(formType: string, formInstance: string | null | undefined): Record<string, unknown> {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n    if (formType in this.formData && instance in this.formData[formType]) {\n      return this.formData[formType][instance].data;\n    }\n    return {};\n  }\n\n  getFormInstances(formType: string): Record<string, { page_data: Record<string, unknown>; display: string }> {\n    const instances: Record<string, { page_data: Record<string, unknown>; display: string }> = {};\n    if (formType in this.formData) {\n      for (const key of Object.keys(this.formData[formType])) {\n        if (key !== 'default') {\n          instances[key] = {\n            page_data: this.formData[formType][key].form_instance_page_data ?? {},\n            display: this.formData[formType][key].form_instance_display ?? key,\n          };\n        }\n      }\n    }\n    return instances;\n  }\n\n  isFormSubmitted(formType: string, formInstance: string | null | undefined): boolean {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n    if (formType in this.formData && instance in this.formData[formType]) {\n      return this.formData[formType][instance].is_form_submitted ?? false;\n    }\n    return false;\n  }\n\n  isFormComplete(formType: string, formInstance: string | null | undefined): boolean {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n    if (formType in this.formData && instance in this.formData[formType]) {\n      return this.formData[formType][instance].is_form_complete ?? false;\n    }\n    return false;\n  }\n\n  setConfig(params: Record<string, unknown>): void {\n    this.config = { ...this.config, ...params };\n    if ('i_home_country' in params) {\n      this.setHomeCountry(String(params['i_home_country']));\n    }\n  }\n\n  getConfig(): Record<string, unknown> {\n    return this.config;\n  }\n\n  setHomeCountry(country: string): void {\n    this.homeCountry = country;\n    this.config['i_home_country'] = country;\n  }\n\n  getHomeCountry(): string {\n    return this.homeCountry;\n  }\n\n  getEmail(): string {\n    return this.email;\n  }\n}\n","numLines":250,"startLine":1,"totalLines":250}}}
