9\t  return request.headers.get('x-appengine-cron') === 'true';\n170\t}\n171\t\n172\t/**\n173\t * Check page permission (port of admin.py:140-155 check_permissions).\n174\t */\n175\tfunction checkPermissions(email: string, page: string): boolean {\n176\t  const perms = LIST_OF_ADMIN_PERMISSIONS[email];\n177\t  if (!perms) return false;\n178\t  return perms.report_permissions.includes(page);\n179\t}\n180\t\n181\t/**\n182\t * Checks authenticated user. Returns { email } on success or 401 Response on failure.\n183\t */\n184\texport async function requireAuth(request: Request): Promise<AuthResult> {\n185\t  const email = await getAuthenticatedUser(request);\n186\t  if (!email) {\n187\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n188\t  }\n189\t  return { email };\n190\t}\n191\t\n192\t/**\n193\t * Checks user is in LIST_OF_ADMINS (no page-specific permission).\n194\t */\n195\texport async function requireAdmin(request: Request): Promise<AuthResult> {\n196\t  const email = await getAuthenticatedUser(request);\n197\t  if (!email) {\n198\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n199\t  }\n200\t  if (!LIST_OF_ADMINS.has(email)) {\n201\t    return Response.json({ error: 'Admin access required' }, { status: 403 });\n202\t  }\n203\t  return { email };\n204\t}\n205\t\n206\t/**\n207\t * Checks user has permission for a specific page.\n208\t */\n209\texport async function requireAdminForPage(request: Request, page: string): Promise<AuthResult> {\n210\t  const email = await getAuthenticatedUser(request);\n211\t  if (!email) {\n212\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n213\t  }\n214\t  if (!checkPermissions(email, page)) {\n215\t    return Response.json({ error: 'Permission denied' }, { status: 403 });\n216\t  }\n217\t  return { email };\n218\t}\n219\t\n220\t/**\n221\t * Checks user has permission for ANY of the listed pages.\n222\t */\n223\texport async function requireAdminAnyOf(request: Request, pages: string[]): Promise<AuthResult> {\n224\t  const email = await getAuthenticatedUser(request);\n225\t  if (!email) {\n226\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n227\t  }\n228\t  if (!pages.some(page => checkPermissions(email, page))) {\n229\t    return Response.json({ error: 'Permission denied' }, { status: 403 });\n230\t  }\n231\t  return { email };\n232\t}\n233\t\n234\t/**\n235\t * Checks admin list OR cron header.\n236\t */\n237\texport async function requireAdminOrCron(request: Request): Promise<AuthResult> {\n238\t  if (isCronRequest(request)) {\n239\t    return { email: 'cron' };\n240\t  }\n241\t  const email = await getAuthenticatedUser(request);\n242\t  if (!email) {\n243\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n244\t  }\n245\t  if (!LIST_OF_ADMINS.has(email)) {\n246\t    return Response.json({ error: 'Admin access required' }, { status: 403 });\n247\t  }\n248\t  return { email };\n249\t}\n250\t\n251\t/**\n252\t * Checks admin with any-of page permission OR cron header.\n253\t */\n254\texport async function requireAdminAnyOfOrCron(request: Request, pages: string[]): Promise<AuthResult> {\n255\t  if (isCronRequest(request)) {\n256\t    return { email: 'cron' };\n257\t  }\n258\t  const email = await getAuthenticatedUser(request);\n259\t  if (!email) {\n260\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n261\t  }\n262\t  if (!pages.some(page => checkPermissions(email, page))) {\n263\t    return Response.json({ error: 'Permission denied' }, { status: 403 });\n264\t  }\n265\t  return { email };\n266\t}\n267\t\n268\texport { LIST_OF_ADMINS, LIST_OF_ADMIN_PERMISSIONS, ROUTE_TO_PAGE_KEY };\n269\t"}]},"parent_tool_use_id":null,"session_id":"7bce7c5c-6dd0-45fc-b12b-defebd6c574d","uuid":"edb07382-2433-4d89-b51f-e4121c6e9245","timestamp":"2026-04-06T13:37:59.304Z","tool_use_result":{"type":"text","file":{"file