{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_e58f72db5de94df4a8a1e4cf","type":"tool_result","content":"1\timport { setAdminConfig } from '../../../../utils/admin-config';\n2\timport { requireAdminForPage } from '../../../../utils/auth-middleware';\n3\t\n4\texport async function POST(request: Request): Promise<Response> {\n5\t  const auth = await requireAdminForPage(request, 'admin_settings.html');\n6\t  if (auth instanceof Response) return auth;\n7\t\n8\t  // Settings page sends form-urlencoded via jQuery $.post(), not JSON\n9\t  const contentType = request.headers.get('content-type') || '';\n10\t  let configParams: Record<string, unknown>;\n11\t\n12\t  if (contentType.includes('application/json')) {\n13\t    const body = await request.json() as Record<string, unknown>;\n14\t    configParams = body.config_params as Record<string, unknown>;\n15\t  } else {\n16\t    // Form-urlencoded: config_params is a JSON string field\n17\t    const formData = await request.formData();\n18\t    const raw = formData.get('config_params');\n19\t    if (typeof raw !== 'string') {\n20\t      return Response.json({ error: 'config_params required' }, { status: 400 });\n21\t    }\n22\t    configParams = JSON.parse(raw) as Record<string, unknown>;\n23\t  }\n24\t\n25\t  if (!configParams || typeof configParams !== 'object') {\n26\t    return Response.json({ error: 'config_params must be an object' }, { status: 400 });\n27\t  }\n28\t\n29\t  await setAdminConfig(configParams);\n30\t  return Response.json({ ok: true });\n31\t}\n32\t"}]},"parent_tool_use_id":null,"session_id":"091c07a1-d14b-4cea-92df-7688c08d19fa","uuid":"9b04d3cf-17dd-447b-a609-bc4942942346","timestamp":"2026-04-06T10:25:38.655Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/api/admin/admin/set-config/route.ts","content":"import { setAdminConfig } from '../../../../utils/admin-config';\nimport { requireAdminForPage } from '../../../../utils/auth-middleware';\n\nexport async function POST(request: Request): Promise<Response> {\n  const auth = await requireAdminForPage(request, 'admin_settings.html');\n  if (auth instanceof Response) return auth;\n\n  // Settings page sends form-urlencoded via jQuery $.post(), not JSON\n  const contentType = request.headers.get('content-type') || '';\n  let configParams: Record<string, unknown>;\n\n  if (contentType.includes('application/json')) {\n    const body = await request.json() as Record<string, unknown>;\n    configParams = body.config_params as Record<string, unknown>;\n  } else {\n    // Form-urlencoded: config_params is a JSON string field\n    const formData = await request.formData();\n    const raw = formData.get('config_params');\n    if (typeof raw !== 'string') {\n      return Response.json({ error: 'config_params required' }, { status: 400 });\n    }\n    configParams = JSON.parse(raw) as Record<string, unknown>;\n  }\n\n  if (!configParams || typeof configParams !== 'object') {\n    return Response.json({ error: 'config_params must be an object' }, { status: 400 });\n  }\n\n  await setAdminConfig(configParams);\n  return Response.json({ ok: true });\n}\n","numLines":32,"startLine":1,"totalLines":32}}}
