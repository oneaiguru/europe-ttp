9\t  return request.headers.get('x-appengine-cron') === 'true';\n170\t}\n171\t\n172\t/**\n173\t * Check page permission (port of admin.py:140-155 check_permissions).\n174\t */\n175\tfunction checkPermissions(email: string, page: string): boolean {\n176\t  const perms = LIST_OF_ADMIN_PERMISSIONS[email];\n177\t  if (!perms) return false;\n178\t  return perms.report_permissions.includes(page);\n179\t}\n180\t\n181\t/**\n182\t * Checks authenticated user. Returns { email } on success or 401 Response on failure.\n183\t */\n184\texport async function requireAuth(request: Request): Promise<AuthResult> {\n185\t  const email = await getAuthenticatedUser(request);\n186\t  if (!email) {\n187\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n188\t  }\n189\t  return { email };\n190\t}\n191\t\n192\t/**\n193\t * Checks user is in LIST_OF_ADMINS (no page-specific permission).\n194\t */\n195\texport async function requireAdmin(request: Request): Promise<AuthResult> {\n196\t  const email = await getAuthenticatedUser(request);\n197\t  if (!email) {\n198\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n199\t  }\n200\t  if (!LIST_OF_ADMINS.has(email)) {\n201\t    return Response.json({ error: 'Admin access required' }, { status: 403 });\n202\t  }\n203\t  return { email };\n204\t}\n205\t\n206\t/**\n207\t * Checks user has permission for a specific page.\n208\t */\n209\texport async function requireAdminForPage(request: Request, page: string): Promise<AuthResult> {\n210\t  const email = await getAuthenticatedUser(request);\n211\t  if (!email) {\n212\t    return Response.json({ error: 'Authentication required' }, { status: 401 });\n213\t  }\n214\t  if (!checkPermissions(email, page)) {\n215\t    return Response.json({ error: 'Permission denied' }, { status: 403 });\n216\t  }\n217\t  return { email };\n218\t}\n219\t\n220\t/**\n221\t * Checks user has permission for ANY of the listed pages.\n222\t */\n223\texport async functio