{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_ea0258c2d2144e21ac374a0e","type":"tool_result","content":"1\timport { readJson, writeJson, GCS_PATHS } from './gcs';\n2\t\n3\t// Re-export GCS_PATHS for convenience\n4\texport { GCS_PATHS };\n5\t\n6\t/** Convert truthy string values to boolean (ported from pyutils/utils.py str2bool) */\n7\tfunction str2bool(value: unknown): boolean {\n8\t  if (!value || typeof value !== 'string') return false;\n9\t  return ['1', 'y', 't', 'true'].includes(value.toLowerCase());\n10\t}\n11\t\n12\t/** Format current UTC time as YYYY-MM-DD HH:MM:SS (matches Python strftime) */\n13\tfunction utcNowFormatted(): string {\n14\t  const d = new Date();\n15\t  const pad = (n: number) => String(n).padStart(2, '0');\n16\t  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}`;\n17\t}\n18\t\n19\tinterface FormInstance {\n20\t  data: Record<string, unknown>;\n21\t  form_instance_page_data: Record<string, unknown>;\n22\t  form_instance_display: string;\n23\t  is_agreement_accepted: boolean;\n24\t  is_form_submitted: boolean;\n25\t  send_confirmation_to_candidate: boolean;\n26\t  is_form_complete: boolean;\n27\t  last_update_datetime: string;\n28\t}\n29\t\n30\tinterface UserJSON {\n31\t  username?: string;\n32\t  email?: string;\n33\t  name?: string;\n34\t  photo_file?: string;\n35\t  photo_url?: string;\n36\t  current_evaluation_id?: string;\n37\t  form_data?: Record<string, Record<string, FormInstance>>;\n38\t  is_profile_complete?: Record<string, boolean>;\n39\t  home_country?: string;\n40\t  config?: Record<string, unknown>;\n41\t}\n42\t\n43\texport class TTCPortalUser {\n44\t  username = '';\n45\t  email = '';\n46\t  name = '';\n47\t  photoFile = '';\n48\t  currentEvaluationId = '';\n49\t  formData: Record<string, Record<string, FormInstance>> = {};\n50\t  isProfileComplete: Record<string, boolean> = {};\n51\t  homeCountry = '';\n52\t  config: Record<string, unknown> = {};\n53\t\n54\t  private constructor() {}\n55\t\n56\t  /** Async factory — loads user data from GCS */\n57\t  static async create(email: string): Promise<TTCPortalUser> {\n58\t    const user = new TTCPortalUser();\n59\t    await user.loadUserData(email);\n60\t    return user;\n61\t  }\n62\t\n63\t  private initializeUser(data: UserJSON): void {\n64\t    this.username = data.username ?? '';\n65\t    this.email = data.email ?? this.email ?? '';\n66\t    this.name = data.name ?? '';\n67\t    this.photoFile = data.photo_file ?? '';\n68\t    this.currentEvaluationId = data.current_evaluation_id ?? '';\n69\t    this.formData = data.form_data ?? {};\n70\t    this.isProfileComplete = data.is_profile_complete ?? {};\n71\t    this.homeCountry = data.home_country ?? '';\n72\t    this.config = data.config ?? {};\n73\t  }\n74\t\n75\t  private async loadUserData(email: string): Promise<void> {\n76\t    this.email = email;\n77\t    try {\n78\t      const data = await readJson(\n79\t        GCS_PATHS.USER_CONFIG_PREFIX + email + '.json',\n80\t      ) as UserJSON;\n81\t      this.initializeUser(data);\n82\t    } catch (e: unknown) {\n83\t      // GCS NotFoundError — initialize with empty data (Python lines 316-319)\n84\t      if (e && typeof e === 'object' && 'code' in e && (e as { code: number }).code === 404) {\n85\t        this.initializeUser({ email });\n86\t      } else if (e instanceof Error && e.message?.includes('No such object')) {\n87\t        this.initializeUser({ email });\n88\t      } else {\n89\t        throw e;\n90\t      }\n91\t    }\n92\t  }\n93\t\n94\t  async saveUserData(): Promise<void> {\n95\t    await writeJson(\n96\t      GCS_PATHS.USER_CONFIG_PREFIX + this.email + '.json',\n97\t      this.toJSON(),\n98\t    );\n99\t  }\n100\t\n101\t  private toJSON(): UserJSON {\n102\t    return {\n103\t      username: this.username,\n104\t      email: this.email,\n105\t      name: this.name,\n106\t      photo_file: this.photoFile,\n107\t      current_evaluation_id: this.currentEvaluationId,\n108\t      form_data: this.formData,\n109\t      is_profile_complete: this.isProfileComplete,\n110\t      home_country: this.homeCountry,\n111\t      config: this.config,\n112\t    };\n113\t  }\n114\t\n115\t  setFormData(\n116\t    formType: string,\n117\t    formInstance: string | null | undefined,\n118\t    data: Record<string, unknown>,\n119\t    pageData: Record<string, unknown>,\n120\t    display: string,\n121\t  ): void {\n122\t    let instance = 'default';\n123\t    if (formInstance && formInstance.trim() !== '') {\n124\t      instance = formInstance;\n125\t    }\n126\t\n127\t    let form: Partial<FormInstance> = {};\n128\t    if (formType in this.formData && instance in this.formData[formType]) {\n129\t      form = this.formData[formType][instance];\n130\t    }\n131\t\n132\t    form.data = data;\n133\t    form.form_instance_page_data = pageData;\n134\t    form.form_instance_display = display;\n135\t\n136\t    // Completeness check — any null or empty string field means incomplete\n137\t    let isComplete = true;\n138\t    for (const key of Object.keys(data)) {\n139\t      const val = data[key];\n140\t      if (val == null || String(val).trim() === '') {\n141\t        isComplete = false;\n142\t        break;\n143\t      }\n144\t    }\n145\t\n146\t    form.is_agreement_accepted = str2bool(data['i_agreement_accepted']);\n147\t    form.is_form_submitted = str2bool(data['i_form_submitted']);\n148\t    form.send_confirmation_to_candidate = str2bool(data['i_send_confirmation_to_candidate']);\n149\t\n150\t    // Name extraction\n151\t    if ('i_name' in data) {\n152\t      this.name = String(data['i_name']).trim();\n153\t    } else {\n154\t      const fname = String(data['i_fname'] ?? '').trim();\n155\t      const lname = String(data['i_lname'] ?? '').trim();\n156\t      this.name = fname + ' ' + lname;\n157\t    }\n158\t\n159\t    form.is_form_complete = isComplete;\n160\t    if (formType.includes('profile')) {\n161\t      this.isProfileComplete[formType] = isComplete;\n162\t    }\n163\t    form.last_update_datetime = utcNowFormatted();\n164\t\n165\t    if (!(formType in this.formData)) {\n166\t      this.formData[formType] = {};\n167\t    }\n168\t    this.formData[formType][instance] = form as FormInstance;\n169\t\n170\t    // Last stored form is stored in default as well for easy retrieval\n171\t    if (instance !== 'default') {\n172\t      this.formData[formType]['default'] = form as FormInstance;\n173\t    }\n174\t\n175\t    // Email sending is deferred to Phase 6 — skip send_submission_emails\n176\t  }\n177\t\n178\t  getFormData(formType: string, formInstance: string | null | undefined): Record<string, unknown> {\n179\t    let instance = 'default';\n180\t    if (formInstance && formInstance.trim() !== '') {\n181\t      instance = formInstance;\n182\t    }\n183\t    if (formType in this.formData && instance in this.formData[formType]) {\n184\t      return this.formData[formType][instance].data;\n185\t    }\n186\t    return {};\n187\t  }\n188\t\n189\t  getFormInstances(formType: string): Record<string, { page_data: Record<string, unknown>; display: string }> {\n190\t    const instances: Record<string, { page_data: Record<string, unknown>; display: string }> = {};\n191\t    if (formType in this.formData) {\n192\t      for (const key of Object.keys(this.formData[formType])) {\n193\t        if (key !== 'default') {\n194\t          instances[key] = {\n195\t            page_data: this.formData[formType][key].form_instance_page_data ?? {},\n196\t            display: this.formData[formType][key].form_instance_display ?? key,\n197\t          };\n198\t        }\n199\t      }\n200\t    }\n201\t    return instances;\n202\t  }\n203\t\n204\t  isFormSubmitted(formType: string, formInstance: string | null | undefined): boolean {\n205\t    let instance = 'default';\n206\t    if (formInstance && formInstance.trim() !== '') {\n207\t      instance = formInstance;\n208\t    }\n209\t    if (formType in this.formData && instance in this.formData[formType]) {\n210\t      return this.formData[formType][instance].is_form_submitted ?? false;\n211\t    }\n212\t    return false;\n213\t  }\n214\t\n215\t  isFormComplete(formType: string, formInstance: string | null | undefined): boolean {\n216\t    let instance = 'default';\n217\t    if (formInstance && formInstance.trim() !== '') {\n218\t      instance = formInstance;\n219\t    }\n220\t    if (formType in this.formData && instance in this.formData[formType]) {\n221\t      return this.formData[formType][instance].is_form_complete ?? false;\n222\t    }\n223\t    return false;\n224\t  }\n225\t\n226\t  setConfig(params: Record<string, unknown>): void {\n227\t    this.config = { ...this.config, ...params };\n228\t    if ('i_home_country' in params) {\n229\t      this.setHomeCountry(String(params['i_home_country']));\n230\t    }\n231\t  }\n232\t\n233\t  getConfig(): Record<string, unknown> {\n234\t    return this.config;\n235\t  }\n236\t\n237\t  setHomeCountry(country: string): void {\n238\t    this.homeCountry = country;\n239\t    this.config['i_home_country'] = country;\n240\t  }\n241\t\n242\t  getHomeCountry(): string {\n243\t    return this.homeCountry;\n244\t  }\n245\t\n246\t  getEmail(): string {\n247\t    return this.email;\n248\t  }\n249\t}\n250\t"}]},"parent_tool_use_id":null,"session_id":"c47860c9-886d-45a4-8588-6f96430eddc4","uuid":"91f8ee3e-d54c-4d0a-84a8-618ec9ac8967","timestamp":"2026-04-06T10:25:56.406Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/ttc-portal-user.ts","content":"import { readJson, writeJson, GCS_PATHS } from './gcs';\n\n// Re-export GCS_PATHS for convenience\nexport { GCS_PATHS };\n\n/** Convert truthy string values to boolean (ported from pyutils/utils.py str2bool) */\nfunction str2bool(value: unknown): boolean {\n  if (!value || typeof value !== 'string') return false;\n  return ['1', 'y', 't', 'true'].includes(value.toLowerCase());\n}\n\n/** Format current UTC time as YYYY-MM-DD HH:MM:SS (matches Python strftime) */\nfunction utcNowFormatted(): string {\n  const d = new Date();\n  const pad = (n: number) => String(n).padStart(2, '0');\n  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}`;\n}\n\ninterface FormInstance {\n  data: Record<string, unknown>;\n  form_instance_page_data: Record<string, unknown>;\n  form_instance_display: string;\n  is_agreement_accepted: boolean;\n  is_form_submitted: boolean;\n  send_confirmation_to_candidate: boolean;\n  is_form_complete: boolean;\n  last_update_datetime: string;\n}\n\ninterface UserJSON {\n  username?: string;\n  email?: string;\n  name?: string;\n  photo_file?: string;\n  photo_url?: string;\n  current_evaluation_id?: string;\n  form_data?: Record<string, Record<string, FormInstance>>;\n  is_profile_complete?: Record<string, boolean>;\n  home_country?: string;\n  config?: Record<string, unknown>;\n}\n\nexport class TTCPortalUser {\n  username = '';\n  email = '';\n  name = '';\n  photoFile = '';\n  currentEvaluationId = '';\n  formData: Record<string, Record<string, FormInstance>> = {};\n  isProfileComplete: Record<string, boolean> = {};\n  homeCountry = '';\n  config: Record<string, unknown> = {};\n\n  private constructor() {}\n\n  /** Async factory — loads user data from GCS */\n  static async create(email: string): Promise<TTCPortalUser> {\n    const user = new TTCPortalUser();\n    await user.loadUserData(email);\n    return user;\n  }\n\n  private initializeUser(data: UserJSON): void {\n    this.username = data.username ?? '';\n    this.email = data.email ?? this.email ?? '';\n    this.name = data.name ?? '';\n    this.photoFile = data.photo_file ?? '';\n    this.currentEvaluationId = data.current_evaluation_id ?? '';\n    this.formData = data.form_data ?? {};\n    this.isProfileComplete = data.is_profile_complete ?? {};\n    this.homeCountry = data.home_country ?? '';\n    this.config = data.config ?? {};\n  }\n\n  private async loadUserData(email: string): Promise<void> {\n    this.email = email;\n    try {\n      const data = await readJson(\n        GCS_PATHS.USER_CONFIG_PREFIX + email + '.json',\n      ) as UserJSON;\n      this.initializeUser(data);\n    } catch (e: unknown) {\n      // GCS NotFoundError — initialize with empty data (Python lines 316-319)\n      if (e && typeof e === 'object' && 'code' in e && (e as { code: number }).code === 404) {\n        this.initializeUser({ email });\n      } else if (e instanceof Error && e.message?.includes('No such object')) {\n        this.initializeUser({ email });\n      } else {\n        throw e;\n      }\n    }\n  }\n\n  async saveUserData(): Promise<void> {\n    await writeJson(\n      GCS_PATHS.USER_CONFIG_PREFIX + this.email + '.json',\n      this.toJSON(),\n    );\n  }\n\n  private toJSON(): UserJSON {\n    return {\n      username: this.username,\n      email: this.email,\n      name: this.name,\n      photo_file: this.photoFile,\n      current_evaluation_id: this.currentEvaluationId,\n      form_data: this.formData,\n      is_profile_complete: this.isProfileComplete,\n      home_country: this.homeCountry,\n      config: this.config,\n    };\n  }\n\n  setFormData(\n    formType: string,\n    formInstance: string | null | undefined,\n    data: Record<string, unknown>,\n    pageData: Record<string, unknown>,\n    display: string,\n  ): void {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n\n    let form: Partial<FormInstance> = {};\n    if (formType in this.formData && instance in this.formData[formType]) {\n      form = this.formData[formType][instance];\n    }\n\n    form.data = data;\n    form.form_instance_page_data = pageData;\n    form.form_instance_display = display;\n\n    // Completeness check — any null or empty string field means incomplete\n    let isComplete = true;\n    for (const key of Object.keys(data)) {\n      const val = data[key];\n      if (val == null || String(val).trim() === '') {\n        isComplete = false;\n        break;\n      }\n    }\n\n    form.is_agreement_accepted = str2bool(data['i_agreement_accepted']);\n    form.is_form_submitted = str2bool(data['i_form_submitted']);\n    form.send_confirmation_to_candidate = str2bool(data['i_send_confirmation_to_candidate']);\n\n    // Name extraction\n    if ('i_name' in data) {\n      this.name = String(data['i_name']).trim();\n    } else {\n      const fname = String(data['i_fname'] ?? '').trim();\n      const lname = String(data['i_lname'] ?? '').trim();\n      this.name = fname + ' ' + lname;\n    }\n\n    form.is_form_complete = isComplete;\n    if (formType.includes('profile')) {\n      this.isProfileComplete[formType] = isComplete;\n    }\n    form.last_update_datetime = utcNowFormatted();\n\n    if (!(formType in this.formData)) {\n      this.formData[formType] = {};\n    }\n    this.formData[formType][instance] = form as FormInstance;\n\n    // Last stored form is stored in default as well for easy retrieval\n    if (instance !== 'default') {\n      this.formData[formType]['default'] = form as FormInstance;\n    }\n\n    // Email sending is deferred to Phase 6 — skip send_submission_emails\n  }\n\n  getFormData(formType: string, formInstance: string | null | undefined): Record<string, unknown> {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n    if (formType in this.formData && instance in this.formData[formType]) {\n      return this.formData[formType][instance].data;\n    }\n    return {};\n  }\n\n  getFormInstances(formType: string): Record<string, { page_data: Record<string, unknown>; display: string }> {\n    const instances: Record<string, { page_data: Record<string, unknown>; display: string }> = {};\n    if (formType in this.formData) {\n      for (const key of Object.keys(this.formData[formType])) {\n        if (key !== 'default') {\n          instances[key] = {\n            page_data: this.formData[formType][key].form_instance_page_data ?? {},\n            display: this.formData[formType][key].form_instance_display ?? key,\n          };\n        }\n      }\n    }\n    return instances;\n  }\n\n  isFormSubmitted(formType: string, formInstance: string | null | undefined): boolean {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n    if (formType in this.formData && instance in this.formData[formType]) {\n      return this.formData[formType][instance].is_form_submitted ?? false;\n    }\n    return false;\n  }\n\n  isFormComplete(formType: string, formInstance: string | null | undefined): boolean {\n    let instance = 'default';\n    if (formInstance && formInstance.trim() !== '') {\n      instance = formInstance;\n    }\n    if (formType in this.formData && instance in this.formData[formType]) {\n      return this.formData[formType][instance].is_form_complete ?? false;\n    }\n    return false;\n  }\n\n  setConfig(params: Record<string, unknown>): void {\n    this.config = { ...this.config, ...params };\n    if ('i_home_country' in params) {\n      this.setHomeCountry(String(params['i_home_country']));\n    }\n  }\n\n  getConfig(): Record<string, unknown> {\n    return this.config;\n  }\n\n  setHomeCountry(country: string): void {\n    this.homeCountry = country;\n    this.config['i_home_country'] = country;\n  }\n\n  getHomeCountry(): string {\n    return this.homeCountry;\n  }\n\n  getEmail(): string {\n    return this.email;\n  }\n}\n","numLines":250,"startLine":1,"totalLines":250}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_9b971d5ccd8a4e6a8d20b336","type":"tool_result","content":"1\t// @google-cloud/storage is an optionalDependency — use dynamic import() so the module\n2\t// loads without crashing when the package isn't installed (e.g., local dev without GCS).\n3\t// Lazy singleton pattern: first call to getStorage() does the import and caches.\n4\t\n5\tlet storageInstance: InstanceType<typeof import('@google-cloud/storage').Storage> | null = null;\n6\t\n7\tasync function getStorage() {\n8\t  if (storageInstance) return storageInstance;\n9\t  try {\n10\t    const { Storage } = await import('@google-cloud/storage');\n11\t    storageInstance = new Storage();\n12\t    return storageInstance;\n13\t  } catch {\n14\t    throw new Error('GCS not available — install @google-cloud/storage');\n15\t  }\n16\t}\n17\t\n18\tfunction getBucketName(): string {\n19\t  const name = process.env.GCS_BUCKET_NAME;\n20\t  if (!name) throw new Error('GCS_BUCKET_NAME env var not set');\n21\t  return name;\n22\t}\n23\t\n24\t// GCS path constants (ported from constants.py lines 30-62)\n25\texport const GCS_PATHS = {\n26\t  USER_CONFIG_PREFIX: 'user_data/',\n27\t  USER_SUMMARY_BY_USER: 'user_data/summary/user_summary_by_user.json',\n28\t  USER_SUMMARY_BY_FORM_TYPE: 'user_data/summary/user_summary_by_form_type.json',\n29\t  USER_INTEGRITY_BY_USER: 'user_data/integrity/user_integrity_by_user.json',\n30\t  APPLICANT_ENROLLED_LIST: 'user_data/integrity/applicant_enrolled_list.csv',\n31\t  ADMIN_CONFIG: 'config/admin_config.json',\n32\t  FORM_CONFIG_PREFIX: 'config/forms/',\n33\t  TTC_COUNTRY_AND_DATES: 'config/forms/ttc_country_and_dates.json',\n34\t  TEMP_PREFIX: 'tmp/',\n35\t} as const;\n36\t\n37\texport interface FileMetadata {\n38\t  name: string;\n39\t  updated: Date;\n40\t  timeCreated: Date;\n41\t}\n42\t\n43\texport async function readJson(path: string): Promise<unknown> {\n44\t  const storage = await getStorage();\n45\t  const bucket = storage.bucket(getBucketName());\n46\t  const [contents] = await bucket.file(path).download();\n47\t  return JSON.parse(contents.toString());\n48\t}\n49\t\n50\texport async function writeJson(path: string, data: unknown): Promise<void> {\n51\t  const storage = await getStorage();\n52\t  const bucket = storage.bucket(getBucketName());\n53\t  await bucket.file(path).save(JSON.stringify(data), {\n54\t    contentType: 'text/plain',\n55\t  });\n56\t}\n57\t\n58\texport async function readText(path: string): Promise<string> {\n59\t  const storage = await getStorage();\n60\t  const bucket = storage.bucket(getBucketName());\n61\t  const [contents] = await bucket.file(path).download();\n62\t  return contents.toString();\n63\t}\n64\t\n65\texport async function writeText(path: string, content: string): Promise<void> {\n66\t  const storage = await getStorage();\n67\t  const bucket = storage.bucket(getBucketName());\n68\t  await bucket.file(path).save(content, {\n69\t    contentType: 'text/plain',\n70\t  });\n71\t}\n72\t\n73\texport async function listFiles(prefix: string, minUpdated?: Date): Promise<FileMetadata[]> {\n74\t  const storage = await getStorage();\n75\t  const bucket = storage.bucket(getBucketName());\n76\t  const [files] = await bucket.getFiles({ prefix });\n77\t\n78\t  const results: FileMetadata[] = [];\n79\t  for (const file of files) {\n80\t    const [metadata] = await file.getMetadata();\n81\t    const updated = new Date(metadata.updated as string);\n82\t    if (minUpdated && updated <= minUpdated) {\n83\t      continue;\n84\t    }\n85\t    results.push({\n86\t      name: file.name,\n87\t      updated,\n88\t      timeCreated: new Date(metadata.timeCreated as string),\n89\t    });\n90\t  }\n91\t  return results;\n92\t}\n93\t\n94\texport async function fileExists(path: string): Promise<boolean> {\n95\t  const storage = await getStorage();\n96\t  const bucket = storage.bucket(getBucketName());\n97\t  const [exists] = await bucket.file(path).exists();\n98\t  return exists;\n99\t}\n100\t\n101\texport async function getFileMetadata(path: string): Promise<FileMetadata> {\n102\t  const storage = await getStorage();\n103\t  const bucket = storage.bucket(getBucketName());\n104\t  const [metadata] = await bucket.file(path).getMetadata();\n105\t  return {\n106\t    name: metadata.name as string,\n107\t    updated: new Date(metadata.updated as string),\n108\t    timeCreated: new Date(metadata.timeCreated as string),\n109\t  };\n110\t}\n111\t"}]},"parent_tool_use_id":null,"session_id":"c47860c9-886d-45a4-8588-6f96430eddc4","uuid":"826f076c-b00f-45e3-bc78-20caac88d15e","timestamp":"2026-04-06T10:25:56.407Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/gcs.ts","content":"// @google-cloud/storage is an optionalDependency — use dynamic import() so the module\n// loads without crashing when the package isn't installed (e.g., local dev without GCS).\n// Lazy singleton pattern: first call to getStorage() does the import and caches.\n\nlet storageInstance: InstanceType<typeof import('@google-cloud/storage').Storage> | null = null;\n\nasync function getStorage() {\n  if (storageInstance) return storageInstance;\n  try {\n    const { Storage } = await import('@google-cloud/storage');\n    storageInstance = new Storage();\n    return storageInstance;\n  } catch {\n    throw new Error('GCS not available — install @google-cloud/storage');\n  }\n}\n\nfunction getBucketName(): string {\n  const name = process.env.GCS_BUCKET_NAME;\n  if (!name) throw new Error('GCS_BUCKET_NAME env var not set');\n  return name;\n}\n\n// GCS path constants (ported from constants.py lines 30-62)\nexport const GCS_PATHS = {\n  USER_CONFIG_PREFIX: 'user_data/',\n  USER_SUMMARY_BY_USER: 'user_data/summary/user_summary_by_user.json',\n  USER_SUMMARY_BY_FORM_TYPE: 'user_data/summary/user_summary_by_form_type.json',\n  USER_INTEGRITY_BY_USER: 'user_data/integrity/user_integrity_by_user.json',\n  APPLICANT_ENROLLED_LIST: 'user_data/integrity/applicant_enrolled_list.csv',\n  ADMIN_CONFIG: 'config/admin_config.json',\n  FORM_CONFIG_PREFIX: 'config/forms/',\n  TTC_COUNTRY_AND_DATES: 'config/forms/ttc_country_and_dates.json',\n  TEMP_PREFIX: 'tmp/',\n} as const;\n\nexport interface FileMetadata {\n  name: string;\n  updated: Date;\n  timeCreated: Date;\n}\n\nexport async function readJson(path: string): Promise<unknown> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [contents] = await bucket.file(path).download();\n  return JSON.parse(contents.toString());\n}\n\nexport async function writeJson(path: string, data: unknown): Promise<void> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  await bucket.file(path).save(JSON.stringify(data), {\n    contentType: 'text/plain',\n  });\n}\n\nexport async function readText(path: string): Promise<string> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [contents] = await bucket.file(path).download();\n  return contents.toString();\n}\n\nexport async function writeText(path: string, content: string): Promise<void> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  await bucket.file(path).save(content, {\n    contentType: 'text/plain',\n  });\n}\n\nexport async function listFiles(prefix: string, minUpdated?: Date): Promise<FileMetadata[]> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [files] = await bucket.getFiles({ prefix });\n\n  const results: FileMetadata[] = [];\n  for (const file of files) {\n    const [metadata] = await file.getMetadata();\n    const updated = new Date(metadata.updated as string);\n    if (minUpdated && updated <= minUpdated) {\n      continue;\n    }\n    results.push({\n      name: file.name,\n      updated,\n      timeCreated: new Date(metadata.timeCreated as string),\n    });\n  }\n  return results;\n}\n\nexport async function fileExists(path: string): Promise<boolean> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [exists] = await bucket.file(path).exists();\n  return exists;\n}\n\nexport async function getFileMetadata(path: string): Promise<FileMetadata> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [metadata] = await bucket.file(path).getMetadata();\n  return {\n    name: metadata.name as string,\n    updated: new Date(metadata.updated as string),\n    timeCreated: new Date(metadata.timeCreated as string),\n  };\n}\n","numLines":111,"startLine":1,"totalLines":111}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_1b73eee499c0492ca0a5e729","type":"tool_result","content":"1\t\n2\timport os\n3\timport urllib\n4\timport unicodedata\n5\timport logging\n6\timport base64\n7\timport hashlib\n8\timport json\n9\tfrom datetime import tzinfo, timedelta, datetime\n10\t\n11\tfrom google.appengine.api import users\n12\tfrom google.appengine.ext import ndb\n13\tfrom google.appengine.api import app_identity\n14\tfrom google.appengine.api import mail\n15\tfrom google.appengine.api import images\n16\tfrom google.appengine.ext import blobstore\n17\t\n18\timport jinja2\n19\timport webapp2\n20\t\n21\timport cloudstorage as gcs\n22\t\n23\timport constants\n24\tfrom pyutils import utils\n25\t\n26\tdef username_to_email(google_username):\n27\t    email = \"\"\n28\t    if google_username and google_username.strip() != '':\n29\t        if '@' in google_username:\n30\t            email = google_username\n31\t        else:\n32\t            email = google_username + \"@gmail.com\"\n33\t    return email\n34\t\n35\tclass TTCPortalUser:\n36\t    def set_form_data(self, f_type, f_instance, f_data, f_instance_page_data, f_instance_display):\n37\t        logging.info('[set_form_data] setting form data')\n38\t        _instance = 'default'\n39\t        if f_instance and f_instance.strip() != '':\n40\t            _instance = f_instance\n41\t\n42\t        _form = {}\n43\t        if f_type in self.form_data:\n44\t            if _instance in self.form_data[f_type]:\n45\t                _form = self.form_data[f_type][_instance]\n46\t\n47\t        logging.info('[set_form_data] form data = \\n' + json.dumps(f_data))\n48\t        _form['data'] = f_data\n49\t        _form['form_instance_page_data'] = f_instance_page_data\n50\t        _form['form_instance_display'] = f_instance_display\n51\t\n52\t        _is_form_complete = True\n53\t        for _t in f_data:\n54\t            if f_data[_t] == None or unicode(f_data[_t]).strip() == '':\n55\t                _is_form_complete = False\n56\t                break\n57\t\n58\t        _form['is_agreement_accepted'] = utils.str2bool(f_data.get('i_agreement_accepted'))\n59\t        _form['is_form_submitted'] = utils.str2bool(f_data.get('i_form_submitted'))\n60\t        _form['send_confirmation_to_candidate'] = utils.str2bool(f_data.get('i_send_confirmation_to_candidate'))\n61\t        # this is handled separately by the uploader\n62\t        # if 'i_photo_file' in f_data:\n63\t        #     self.photo_file = f_data['i_photo_file']\n64\t        #     if self.photo_file and self.photo_file.strip() != '':\n65\t        #         self.set_photo_url()\n66\t\n67\t        if 'i_name' in f_data:\n68\t            self.name = f_data.get('i_name').strip()\n69\t        else:\n70\t            self.name = f_data.get('i_fname').strip() + ' ' + f_data.get('i_lname').strip()\n71\t\n72\t        _form['is_form_complete'] = _is_form_complete\n73\t        if 'profile' in f_type:\n74\t            self.is_profile_complete[f_type] = _is_form_complete\n75\t        _form['last_update_datetime'] = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n76\t\n77\t        if f_type not in self.form_data:\n78\t            self.form_data[f_type] = {}    \n79\t        self.form_data[f_type][_instance] = _form\n80\t        # Last stored form is stored in default as well for easy retrieval\n81\t        if _instance != 'default':\n82\t            self.form_data[f_type]['default'] = _form\n83\t\n84\t        if _form['is_form_submitted']:\n85\t            try:\n86\t                self.send_submission_emails(f_type, f_instance)\n87\t            except Exception as e:\n88\t                logging.info('[set_form_data] Error returned from send_submission_emails {0}'.format(e))\n89\t            \n90\t\n91\t    def send_submission_emails(self, f_type, f_instance):\n92\t        logging.info('[send_submission_emails] called f_type = {f_type} f_instance = {f_instance}'.format(**locals()))\n93\t        _form = self.form_data[f_type][f_instance]\n94\t        _form_data = _form['data']\n95\t        _form_instance_page_data = _form['form_instance_page_data']\n96\t        _email_data = dict(_form_data)\n97\t        _email_data.update(_form_instance_page_data)\n98\t\n99\t        _questions_file = constants.FORM_CONFIG_LOCATION + self.home_country + '/' + f_type + '.json'\n100\t\n101\t        _f = gcs.open(_questions_file)\n102\t        _contents = _f.read()\n103\t        _f.close()\n104\t        _form_metadata = json.loads(_contents)\n105\t\n106\t        # _instance_data = {}\n107\t\n108\t        # for _p in form[\"pages\"]:\n109\t        #     _is_form_instance_identifier = _p.get(\"is_form_instance_identifier\", \"false\")\n110\t        #     if _is_form_instance_identifier == 'true':\n111\t        #         for _q in _p[\"questions\"]:\n112\t        #             if 'source' in _q:\n113\t        #                 _source_file = constants.FORM_CONFIG_LOCATION + _q['source']\n114\t        #                 _id = _q.get(\"id\", \"\")\n115\t        #                 if source_file:\n116\t        #                     _f = gcs.open(_source_file)\n117\t        #                     _contents = _f.read()\n118\t        #                     _f.close()\n119\t        #                     _options = json.loads(_contents)\n120\t        #                     for _o in _options:\n121\t        #                         if _o[\"value\"] == _form_data.get(_id, \"\"):\n122\t        #                             _instance_data.update(option.get(\"display_data\", {}))\n123\t        #                             break\n124\t\n125\t        if _form['is_form_submitted']:\n126\t            # [START user_confirmation_email]\n127\t            try:\n128\t                if 'user_confirmation_email' in _form_metadata:\n129\t                    _to = self.email\n130\t                    _subject = _form_metadata['user_confirmation_email']['subject'].format(**_email_data)\n131\t                            \n132\t                    _message = \"\"\"\n133\t                        <div style='{font_style}'>\n134\t                            {message}\n135\t                        </div>\n136\t                    \"\"\".format(\n137\t                        font_style=constants.EMAIL_CONFIG['FONT_STYLE'],\n138\t                        message=_form_metadata['user_confirmation_email']['message'].format(**_email_data)\n139\t                            # name=self.name,\n140\t                            # ttc_dates=_instance_data['dates'],\n141\t                            # ttc_country=_instance_data['country'],\n142\t                        # )\n143\t                    )\n144\t                                \n145\t                    utils.send_email_using_sendgrid(_to, _form_metadata['from_email'], _subject, _message)\n146\t                    logging.info('[send_submission_emails] Sent confirmation email to {to}'.format(to=_to))\n147\t            except Exception as e:\n148\t                logging.info('[send_submission_emails] Error in user_confirmation_email {0}'.format(e))\n149\t            # [END user_confirmation_email]\n150\t\n151\t            # [START owner_confirmation_email]\n152\t            try:\n153\t                if 'owner_confirmation_email' in _form_metadata:\n154\t                    _to = _form_metadata['from_email']\n155\t                    _subject = _form_metadata['owner_confirmation_email']['subject'].format(**_email_data)\n156\t\n157\t                    _message = \"\"\"\n158\t                        <div style='{font_style}'>\n159\t                            {message}\n160\t                        </div>\n161\t                    \"\"\".format(\n162\t                        font_style=constants.EMAIL_CONFIG['FONT_STYLE'],\n163\t                        message=_form_metadata['owner_confirmation_email']['message'].format(**_email_data)\n164\t                            # name=self.name,\n165\t                            # ttc_dates=_instance_data['dates'],\n166\t                            # ttc_country=_instance_data['country'],\n167\t                        # )\n168\t                    )\n169\t                                \n170\t                    utils.send_email_using_sendgrid(_to, _form_metadata['from_email'], _subject, _message)\n171\t                    logging.info('[send_submission_emails] Sent confirmation email to {to}'.format(to=_to))\n172\t            except Exception as e:\n173\t                logging.info('[send_submission_emails] Error in owner_confirmation_email {0}'.format(e))\n174\t            # [END owner_confirmation_email]\n175\t\n176\t            # [START other_confirmation_emails]\n177\t            try:\n178\t                if 'other_emails' in _form_metadata:\n179\t                    for _email_field in _form_metadata['other_emails']:\n180\t                        _email_data_arr = []\n181\t                        if _email_field in _form_data:\n182\t                            _email_data_arr = [_email_data]\n183\t                        else:\n184\t                            for _tk, _tv in _form_data.items():\n185\t                                if isinstance(_tv, list) and len(_tv) > 0 and isinstance(_tv[0], dict) and _email_field in _tv[0]:\n186\t                                    for _d in _tv:\n187\t                                        _ed = dict(_email_data)\n188\t                                        _ed.update(_d)\n189\t                                        _ed['app_id'] = constants.app_id\n190\t                                        _email_data_arr.append(_ed)\n191\t                                    break\n192\t\n193\t                        for _ed in _email_data_arr:\n194\t                            _to = _ed[_email_field]\n195\t                            _subject = _form_metadata['other_emails'][_email_field]['subject'].format(**_ed)\n196\t                                    \n197\t                            _message = \"\"\"\n198\t                                <div style='{font_style}'>\n199\t                                    {confirmation_email}\n200\t                                </div>\n201\t                            \"\"\".format(\n202\t                                font_style=constants.EMAIL_CONFIG['FONT_STYLE'],\n203\t                                confirmation_email=_form_metadata['other_emails'][_email_field]['message'].format(**_ed),\n204\t                            )\n205\t\n206\t                            utils.send_email_using_sendgrid(_to, _form_metadata['from_email'], _subject, _message)\n207\t                            logging.info('[send_submission_emails] Sent confirmation email to {to}'.format(to=_to))\n208\t            except Exception as e:\n209\t                logging.info('[send_submission_emails] Error in other_confirmation_emails {0}'.format(e))\n210\t            # [END other_confirmation_emails]\n211\t\n212\t    def get_form_data(self, f_type, f_instance):\n213\t        logging.info('[get_form_data] called f_type = {f_type} f_instance = {f_instance}'.format(**locals()))\n214\t        logging.info('[get_form_data] email = ' + self.email)\n215\t        _instance = 'default'\n216\t        _form_data = {}\n217\t        if f_instance and f_instance.strip() != '':\n218\t            _instance = f_instance\n219\t        if f_type in self.form_data and _instance in self.form_data[f_type]:\n220\t            return self.form_data[f_type][_instance]['data']\n221\t        return _form_data\n222\t\n223\t    def get_form_instances(self, f_type):\n224\t        logging.info('[get_form_instances] called f_type = {f_type}'.format(**locals()))\n225\t        _form_instances = {}\n226\t        if f_type in self.form_data:\n227\t            for _i in self.form_data[f_type]:\n228\t                if _i != 'default':\n229\t                    _form_instances[_i] = {}\n230\t                    _form_instances[_i]['page_data'] = self.form_data[f_type][_i].get('form_instance_page_data', '{}')\n231\t                    _form_instances[_i]['display'] = self.form_data[f_type][_i].get('form_instance_display', _i)\n232\t        return _form_instances\n233\t\n234\t    def is_form_submitted(self, f_type, f_instance):\n235\t        _instance = 'default'\n236\t        if f_instance and f_instance.strip() != '':\n237\t            _instance = f_instance\n238\t        if f_type in self.form_data and _instance in self.form_data[f_type]:\n239\t            return self.form_data[f_type][_instance].get('is_form_submitted', False)\n240\t        return False\n241\t\n242\t    def is_form_complete(self, f_type, f_instance):\n243\t        _instance = 'default'\n244\t        if f_instance and f_instance.strip() != '':\n245\t            _instance = f_instance\n246\t        if f_type in self.form_data and _instance in self.form_data[f_type]:\n247\t            return self.form_data[f_type][_instance].get('is_form_complete', False)\n248\t        return False\n249\t\n250\t    def is_agreement_accepted(self, f_type, f_instance):\n251\t        _instance = 'default'\n252\t        if f_instance and f_instance.strip() != '':\n253\t            _instance = f_instance\n254\t        if f_type in self.form_data and _instance in self.form_data[f_type]:\n255\t            return self.form_data[f_type][_instance].get('is_agreement_accepted', False)\n256\t        return False\n257\t\n258\t    def send_confirmation_to_candidate(self, f_type, f_instance):\n259\t        _instance = 'default'\n260\t        if f_instance and f_instance.strip() != '':\n261\t            _instance = f_instance\n262\t        if f_type in self.form_data and _instance in self.form_data[f_type]:\n263\t            return self.form_data[f_type][_instance].get('send_confirmation_to_candidate', False)\n264\t        return False\n265\t\n266\t    def set_photo_file(self, photo_file):\n267\t        self.photo_file = photo_file\n268\t\n269\t    def get_photo_file(self):\n270\t        return self.photo_file\n271\t\n272\t    def get_public_photo_url(self):\n273\t        if not hasattr(self, 'public_photo_url') or not self.public_photo_url or self.public_photo_url == \"\" or self.public_photo_url == constants.DEFAULT_PHOTO_URL:\n274\t            self.set_public_photo_url()\n275\t        return self.public_photo_url\n276\t\n277\t    def set_public_photo_url(self):\n278\t        if not hasattr(self, 'photo_file') or not self.photo_file or self.photo_file == \"\":\n279\t            self.public_photo_url = ''\n280\t        else:\n281\t            self.public_photo_url = TTCPortalUser.get_public_url_for_image(self.photo_file)\n282\t\n283\t    def set_email(self):\n284\t        self.email = username_to_email(self.username)        \n285\t\n286\t    def get_email(self):\n287\t        return self.email\n288\t\n289\t    def set_home_country(self, home_country):\n290\t        self.home_country = home_country\n291\t        self.config['i_home_country'] = home_country\n292\t\n293\t    def get_home_country(self):\n294\t        return self.home_country\n295\t\n296\t    def set_config(self, config_params):\n297\t        self.config.update(config_params)\n298\t        if 'i_home_country' in config_params:\n299\t            self.set_home_country(config_params['i_home_country'])\n300\t\n301\t    def get_config(self):\n302\t        return self.config\n303\t\n304\t    def get_is_profile_complete(self, f_type):\n305\t        if f_type in self.is_profile_complete:\n306\t            return self.is_profile_complete[f_type]\n307\t        return False\n308\t  \n309\t    def load_user_data(self, user_email):\n310\t        self.email = user_email\n311\t        try:\n312\t            _f = gcs.open(constants.USER_CONFIG_LOCATION + user_email + '.json')\n313\t            _data = _f.read()\n314\t            _f.close()\n315\t            self.initialize_user(json.loads(_data))\n316\t        except gcs.NotFoundError:\n317\t            logging.info('[load_user_data] Failed to load the data for user ' + user_email)\n318\t            logging.info('[load_user_data] Initializing user with empty dictionary')\n319\t            self.initialize_user({'email': user_email})\n320\t\n321\t    def save_user_data(self):\n322\t        try:\n323\t            _user_data = json.dumps(self.__dict__)\n324\t\n325\t            write_retry_params = gcs.RetryParams(backoff_factor=1.1)\n326\t            _f = gcs.open(\n327\t                constants.USER_CONFIG_LOCATION + self.email + '.json',\n328\t                'w',\n329\t                content_type='text/plain',\n330\t                options={'x-goog-meta-foo': 'foo',\n331\t                'x-goog-meta-bar': 'bar'},\n332\t                retry_params=write_retry_params\n333\t            )\n334\t            _f.write(_user_data)\n335\t            _f.close()\n336\t\n337\t        except gcs.Error:\n338\t            logging.info('[save_user_data] Failed to save the data for user ')\n339\t\n340\t    def initialize_user(self, data):\n341\t        logging.info('[initialize_user] called')\n342\t        self.username = data.get('username', '')\n343\t        if self.email:\n344\t            self.email = data.get('email', self.email)\n345\t        else:\n346\t            self.email = data.get('email', '')\n347\t        self.name = data.get('name', '')\n348\t        self.photo_file = data.get('photo_file', '')\n349\t        self.public_photo_url = data.get('photo_url', constants.DEFAULT_PHOTO_URL)\n350\t        self.current_evaluation_id = data.get('current_evaluation_id', '')\n351\t        self.form_data = data.get('form_data', {})\n352\t        self.is_profile_complete = data.get('is_profile_complete', {})\n353\t        self.home_country = data.get('home_country', '')\n354\t        self.config = data.get('config', {})\n355\t\n356\t    def __init__(self, user_email):\n357\t        logging.info('[TTCPortalUser __init__] called')\n358\t        self.user = None\n359\t        self.home_country = None\n360\t        self.username = None\n361\t        self.email = None\n362\t        self.name = None\n363\t        self.photo_file = None\n364\t        self.public_photo_url = None\n365\t        self.current_evaluation_id = None\n366\t        self.config = {}\n367\t        self.form_data = {}\n368\t        self.is_profile_complete = {}\n369\t        if user_email:\n370\t            self.email = user_email\n371\t            self.load_user_data(user_email)\n372\t\n373\t    @staticmethod\n374\t    def get_public_url_for_image(p_photo_file):\n375\t        if p_photo_file.strip() == \"\":\n376\t            logging.info('[get_public_url_for_image] Empty photo file')\n377\t            return \"\"\n378\t        logging.info('[get_public_url_for_image] Getting photo for ' + constants.CLOUD_STORAGE_LOCATION + p_photo_file)\n379\t        try:\n380\t            _photo_url = images.get_serving_url(\n381\t                blobstore.create_gs_key('/gs' + constants.CLOUD_STORAGE_LOCATION + p_photo_file),\n382\t                size=500,\n383\t                crop=True,\n384\t                secure_url=True\n385\t            )\n386\t        except:\n387\t            logging.info('[get_public_url_for_image] Error Getting photo')\n388\t            _photo_url = \"\"\n389\t        return _photo_url\n390\t\n391\t\n392\t\n393\t\n394\t#[START UsersService]\n395\tclass UsersService(webapp2.RequestHandler):\n396\t    def post(self):\n397\t        _user = users.get_current_user()\n398\t        if _user:\n399\t            _user_email_addr = _user.email()\n400\t            _user_logout_url = users.create_logout_url('/')\n401\t            _user_login_url = \"\"\n402\t\n403\t        if self.request.path == '/users/upload-form-data':\n404\t            _form_type = self.request.get('form_type')\n405\t            _form_instance = self.request.get('form_instance')\n406\t            _form_data = self.request.get('form_data')\n407\t            _form_instance_page_data = self.request.get('form_instance_page_data')\n408\t            _form_instance_display = self.request.get('form_instance_display')\n409\t            _user_home_country = self.request.get('user_home_country_iso')\n410\t            if not _user_home_country or _user_home_country.strip() == '':\n411\t                try:\n412\t                    _user_home_country = self.request.headers['X-AppEngine-Country']\n413\t                except Exception as e:\n414\t                    _user_home_country = ''\n415\t            _ttc_user = TTCPortalUser(_user_email_addr)\n416\t            _ttc_user.set_home_country(_user_home_country)\n417\t            # logging.info('[root] data\\n' + _form_data)\n418\t            _ttc_user.set_form_data(_form_type, _form_instance, json.loads(_form_data), json.loads(_form_instance_page_data), _form_instance_display)\n419\t            _ttc_user.save_user_data()\n420\t        elif self.request.path == '/users/set-config':\n421\t            _config_params = json.loads(self.request.get('config_params'))\n422\t            _ttc_user = TTCPortalUser(_user_email_addr)\n423\t            _ttc_user.set_config(_config_params)\n424\t            _ttc_user.save_user_data()\n425\t\n426\t\n427\t    def get(self):\n428\t        _user = users.get_current_user()\n429\t\n430\t        if self.request.path.startswith('/users/reporting/'):\n431\t            try:\n432\t                _is_cron = self.request.headers['X-Appengine-Cron']\n433\t            except Exception as e:\n434\t                _is_cron = False\n435\t\n436\t            if _user:\n437\t                _user_email_addr = _user.email()\n438\t            else:\n439\t                _user_email_addr = \"\"\n440\t\n441\t            if not _is_cron and _user_email_addr not in constants.LIST_OF_ADMINS:\n442\t                self.response.write(\"<b>UN-AUTHORIZED</b>\")\n443\t            else:\n444\t                if self.request.path == '/users/reporting/get-form-data-for-user':\n445\t                    _email = self.request.get('email')\n446\t                    _form_type = self.request.get('form_type')\n447\t                    _form_instance = self.request.get('form_instance')\n448\t                    _ttc_user = TTCPortalUser(_email)\n449\t                    self.response.write(json.dumps(_ttc_user.get_form_data(_form_type, _form_instance)))\n450\t        else:\n451\t            if _user:\n452\t                _user_email_addr = _user.email()\n453\t                _ttc_user = TTCPortalUser(_user_email_addr)\n454\t                if self.request.path == '/users/get-form-data':\n455\t                    _form_type = self.request.get('form_type')\n456\t                    _form_instance = self.request.get('form_instance')\n457\t                    self.response.write(json.dumps(_ttc_user.get_form_data(_form_type, _form_instance)))\n458\t                elif self.request.path == '/users/get-form-instances':\n459\t                    _form_type = self.request.get('form_type')\n460\t                    self.response.write(json.dumps(_ttc_user.get_form_instances(_form_type)))\n461\t                elif self.request.path == '/users/get-config':\n462\t                    self.response.write(json.dumps(_ttc_user.get_config()))\n463\t#[END UsersService]\n464\t\n465\tapp = webapp2.WSGIApplication(\n466\t    [\n467\t        ('/users/upload-form-data', UsersService),\n468\t        ('/users/get-form-data', UsersService),\n469\t        ('/users/get-form-instances', UsersService),\n470\t        ('/users/set-config', UsersService),\n471\t        ('/users/get-config', UsersService),\n472\t        ('/users/reporting/get-form-data-for-user', UsersService),\n473\t    ],\n474\t    debug=True\n475\t)\n476\t\n477\t"}]},"parent_tool_use_id":null,"session_id":"c47860c9-886d-45a4-8588-6f96430eddc4","uuid":"95ffebc0-d282-4aa0-9b24-30379d65d36c","timestamp":"2026-04-06T10:25:56.408Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/Downloads/europe-ttp-master@44c225683f8/ttc_portal_user.py","content":"\nimport os\nimport urllib\nimport unicodedata\nimport logging\nimport base64\nimport hashlib\nimport json\nfrom datetime import tzinfo, timedelta, datetime\n\nfrom google.appengine.api import users\nfrom google.appengine.ext import ndb\nfrom google.appengine.api import app_identity\nfrom google.appengine.api import mail\nfrom google.appengine.api import images\nfrom google.appengine.ext import blobstore\n\nimport jinja2\nimport webapp2\n\nimport cloudstorage as gcs\n\nimport constants\nfrom pyutils import utils\n\ndef username_to_email(google_username):\n    email = \"\"\n    if google_username and google_username.strip() != '':\n        if '@' in google_username:\n            email = google_username\n        else:\n            email = google_username + \"@gmail.com\"\n    return email\n\nclass TTCPortalUser:\n    def set_form_data(self, f_type, f_instance, f_data, f_instance_page_data, f_instance_display):\n        logging.info('[set_form_data] setting form data')\n        _instance = 'default'\n        if f_instance and f_instance.strip() != '':\n            _instance = f_instance\n\n        _form = {}\n        if f_type in self.form_data:\n            if _instance in self.form_data[f_type]:\n                _form = self.form_data[f_type][_instance]\n\n        logging.info('[set_form_data] form data = \\n' + json.dumps(f_data))\n        _form['data'] = f_data\n        _form['form_instance_page_data'] = f_instance_page_data\n        _form['form_instance_display'] = f_instance_display\n\n        _is_form_complete = True\n        for _t in f_data:\n            if f_data[_t] == None or unicode(f_data[_t]).strip() == '':\n                _is_form_complete = False\n                break\n\n        _form['is_agreement_accepted'] = utils.str2bool(f_data.get('i_agreement_accepted'))\n        _form['is_form_submitted'] = utils.str2bool(f_data.get('i_form_submitted'))\n        _form['send_confirmation_to_candidate'] = utils.str2bool(f_data.get('i_send_confirmation_to_candidate'))\n        # this is handled separately by the uploader\n        # if 'i_photo_file' in f_data:\n        #     self.photo_file = f_data['i_photo_file']\n        #     if self.photo_file and self.photo_file.strip() != '':\n        #         self.set_photo_url()\n\n        if 'i_name' in f_data:\n            self.name = f_data.get('i_name').strip()\n        else:\n            self.name = f_data.get('i_fname').strip() + ' ' + f_data.get('i_lname').strip()\n\n        _form['is_form_complete'] = _is_form_complete\n        if 'profile' in f_type:\n            self.is_profile_complete[f_type] = _is_form_complete\n        _form['last_update_datetime'] = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n\n        if f_type not in self.form_data:\n            self.form_data[f_type] = {}    \n        self.form_data[f_type][_instance] = _form\n        # Last stored form is stored in default as well for easy retrieval\n        if _instance != 'default':\n            self.form_data[f_type]['default'] = _form\n\n        if _form['is_form_submitted']:\n            try:\n                self.send_submission_emails(f_type, f_instance)\n            except Exception as e:\n                logging.info('[set_form_data] Error returned from send_submission_emails {0}'.format(e))\n            \n\n    def send_submission_emails(self, f_type, f_instance):\n        logging.info('[send_submission_emails] called f_type = {f_type} f_instance = {f_instance}'.format(**locals()))\n        _form = self.form_data[f_type][f_instance]\n        _form_data = _form['data']\n        _form_instance_page_data = _form['form_instance_page_data']\n        _email_data = dict(_form_data)\n        _email_data.update(_form_instance_page_data)\n\n        _questions_file = constants.FORM_CONFIG_LOCATION + self.home_country + '/' + f_type + '.json'\n\n        _f = gcs.open(_questions_file)\n        _contents = _f.read()\n        _f.close()\n        _form_metadata = json.loads(_contents)\n\n        # _instance_data = {}\n\n        # for _p in form[\"pages\"]:\n        #     _is_form_instance_identifier = _p.get(\"is_form_instance_identifier\", \"false\")\n        #     if _is_form_instance_identifier == 'true':\n        #         for _q in _p[\"questions\"]:\n        #             if 'source' in _q:\n        #                 _source_file = constants.FORM_CONFIG_LOCATION + _q['source']\n        #                 _id = _q.get(\"id\", \"\")\n        #                 if source_file:\n        #                     _f = gcs.open(_source_file)\n        #                     _contents = _f.read()\n        #                     _f.close()\n        #                     _options = json.loads(_contents)\n        #                     for _o in _options:\n        #                         if _o[\"value\"] == _form_data.get(_id, \"\"):\n        #                             _instance_data.update(option.get(\"display_data\", {}))\n        #                             break\n\n        if _form['is_form_submitted']:\n            # [START user_confirmation_email]\n            try:\n                if 'user_confirmation_email' in _form_metadata:\n                    _to = self.email\n                    _subject = _form_metadata['user_confirmation_email']['subject'].format(**_email_data)\n                            \n                    _message = \"\"\"\n                        <div style='{font_style}'>\n                            {message}\n                        </div>\n                    \"\"\".format(\n                        font_style=constants.EMAIL_CONFIG['FONT_STYLE'],\n                        message=_form_metadata['user_confirmation_email']['message'].format(**_email_data)\n                            # name=self.name,\n                            # ttc_dates=_instance_data['dates'],\n                            # ttc_country=_instance_data['country'],\n                        # )\n                    )\n                                \n                    utils.send_email_using_sendgrid(_to, _form_metadata['from_email'], _subject, _message)\n                    logging.info('[send_submission_emails] Sent confirmation email to {to}'.format(to=_to))\n            except Exception as e:\n                logging.info('[send_submission_emails] Error in user_confirmation_email {0}'.format(e))\n            # [END user_confirmation_email]\n\n            # [START owner_confirmation_email]\n            try:\n                if 'owner_confirmation_email' in _form_metadata:\n                    _to = _form_metadata['from_email']\n                    _subject = _form_metadata['owner_confirmation_email']['subject'].format(**_email_data)\n\n                    _message = \"\"\"\n                        <div style='{font_style}'>\n                            {message}\n                        </div>\n                    \"\"\".format(\n                        font_style=constants.EMAIL_CONFIG['FONT_STYLE'],\n                        message=_form_metadata['owner_confirmation_email']['message'].format(**_email_data)\n                            # name=self.name,\n                            # ttc_dates=_instance_data['dates'],\n                            # ttc_country=_instance_data['country'],\n                        # )\n                    )\n                                \n                    utils.send_email_using_sendgrid(_to, _form_metadata['from_email'], _subject, _message)\n                    logging.info('[send_submission_emails] Sent confirmation email to {to}'.format(to=_to))\n            except Exception as e:\n                logging.info('[send_submission_emails] Error in owner_confirmation_email {0}'.format(e))\n            # [END owner_confirmation_email]\n\n            # [START other_confirmation_emails]\n            try:\n                if 'other_emails' in _form_metadata:\n                    for _email_field in _form_metadata['other_emails']:\n                        _email_data_arr = []\n                        if _email_field in _form_data:\n                            _email_data_arr = [_email_data]\n                        else:\n                            for _tk, _tv in _form_data.items():\n                                if isinstance(_tv, list) and len(_tv) > 0 and isinstance(_tv[0], dict) and _email_field in _tv[0]:\n                                    for _d in _tv:\n                                        _ed = dict(_email_data)\n                                        _ed.update(_d)\n                                        _ed['app_id'] = constants.app_id\n                                        _email_data_arr.append(_ed)\n                                    break\n\n                        for _ed in _email_data_arr:\n                            _to = _ed[_email_field]\n                            _subject = _form_metadata['other_emails'][_email_field]['subject'].format(**_ed)\n                                    \n                            _message = \"\"\"\n                                <div style='{font_style}'>\n                                    {confirmation_email}\n                                </div>\n                            \"\"\".format(\n                                font_style=constants.EMAIL_CONFIG['FONT_STYLE'],\n                                confirmation_email=_form_metadata['other_emails'][_email_field]['message'].format(**_ed),\n                            )\n\n                            utils.send_email_using_sendgrid(_to, _form_metadata['from_email'], _subject, _message)\n                            logging.info('[send_submission_emails] Sent confirmation email to {to}'.format(to=_to))\n            except Exception as e:\n                logging.info('[send_submission_emails] Error in other_confirmation_emails {0}'.format(e))\n            # [END other_confirmation_emails]\n\n    def get_form_data(self, f_type, f_instance):\n        logging.info('[get_form_data] called f_type = {f_type} f_instance = {f_instance}'.format(**locals()))\n        logging.info('[get_form_data] email = ' + self.email)\n        _instance = 'default'\n        _form_data = {}\n        if f_instance and f_instance.strip() != '':\n            _instance = f_instance\n        if f_type in self.form_data and _instance in self.form_data[f_type]:\n            return self.form_data[f_type][_instance]['data']\n        return _form_data\n\n    def get_form_instances(self, f_type):\n        logging.info('[get_form_instances] called f_type = {f_type}'.format(**locals()))\n        _form_instances = {}\n        if f_type in self.form_data:\n            for _i in self.form_data[f_type]:\n                if _i != 'default':\n                    _form_instances[_i] = {}\n                    _form_instances[_i]['page_data'] = self.form_data[f_type][_i].get('form_instance_page_data', '{}')\n                    _form_instances[_i]['display'] = self.form_data[f_type][_i].get('form_instance_display', _i)\n        return _form_instances\n\n    def is_form_submitted(self, f_type, f_instance):\n        _instance = 'default'\n        if f_instance and f_instance.strip() != '':\n            _instance = f_instance\n        if f_type in self.form_data and _instance in self.form_data[f_type]:\n            return self.form_data[f_type][_instance].get('is_form_submitted', False)\n        return False\n\n    def is_form_complete(self, f_type, f_instance):\n        _instance = 'default'\n        if f_instance and f_instance.strip() != '':\n            _instance = f_instance\n        if f_type in self.form_data and _instance in self.form_data[f_type]:\n            return self.form_data[f_type][_instance].get('is_form_complete', False)\n        return False\n\n    def is_agreement_accepted(self, f_type, f_instance):\n        _instance = 'default'\n        if f_instance and f_instance.strip() != '':\n            _instance = f_instance\n        if f_type in self.form_data and _instance in self.form_data[f_type]:\n            return self.form_data[f_type][_instance].get('is_agreement_accepted', False)\n        return False\n\n    def send_confirmation_to_candidate(self, f_type, f_instance):\n        _instance = 'default'\n        if f_instance and f_instance.strip() != '':\n            _instance = f_instance\n        if f_type in self.form_data and _instance in self.form_data[f_type]:\n            return self.form_data[f_type][_instance].get('send_confirmation_to_candidate', False)\n        return False\n\n    def set_photo_file(self, photo_file):\n        self.photo_file = photo_file\n\n    def get_photo_file(self):\n        return self.photo_file\n\n    def get_public_photo_url(self):\n        if not hasattr(self, 'public_photo_url') or not self.public_photo_url or self.public_photo_url == \"\" or self.public_photo_url == constants.DEFAULT_PHOTO_URL:\n            self.set_public_photo_url()\n        return self.public_photo_url\n\n    def set_public_photo_url(self):\n        if not hasattr(self, 'photo_file') or not self.photo_file or self.photo_file == \"\":\n            self.public_photo_url = ''\n        else:\n            self.public_photo_url = TTCPortalUser.get_public_url_for_image(self.photo_file)\n\n    def set_email(self):\n        self.email = username_to_email(self.username)        \n\n    def get_email(self):\n        return self.email\n\n    def set_home_country(self, home_country):\n        self.home_country = home_country\n        self.config['i_home_country'] = home_country\n\n    def get_home_country(self):\n        return self.home_country\n\n    def set_config(self, config_params):\n        self.config.update(config_params)\n        if 'i_home_country' in config_params:\n            self.set_home_country(config_params['i_home_country'])\n\n    def get_config(self):\n        return self.config\n\n    def get_is_profile_complete(self, f_type):\n        if f_type in self.is_profile_complete:\n            return self.is_profile_complete[f_type]\n        return False\n  \n    def load_user_data(self, user_email):\n        self.email = user_email\n        try:\n            _f = gcs.open(constants.USER_CONFIG_LOCATION + user_email + '.json')\n            _data = _f.read()\n            _f.close()\n            self.initialize_user(json.loads(_data))\n        except gcs.NotFoundError:\n            logging.info('[load_user_data] Failed to load the data for user ' + user_email)\n            logging.info('[load_user_data] Initializing user with empty dictionary')\n            self.initialize_user({'email': user_email})\n\n    def save_user_data(self):\n        try:\n            _user_data = json.dumps(self.__dict__)\n\n            write_retry_params = gcs.RetryParams(backoff_factor=1.1)\n            _f = gcs.open(\n                constants.USER_CONFIG_LOCATION + self.email + '.json',\n                'w',\n                content_type='text/plain',\n                options={'x-goog-meta-foo': 'foo',\n                'x-goog-meta-bar': 'bar'},\n                retry_params=write_retry_params\n            )\n            _f.write(_user_data)\n            _f.close()\n\n        except gcs.Error:\n            logging.info('[save_user_data] Failed to save the data for user ')\n\n    def initialize_user(self, data):\n        logging.info('[initialize_user] called')\n        self.username = data.get('username', '')\n        if self.email:\n            self.email = data.get('email', self.email)\n        else:\n            self.email = data.get('email', '')\n        self.name = data.get('name', '')\n        self.photo_file = data.get('photo_file', '')\n        self.public_photo_url = data.get('photo_url', constants.DEFAULT_PHOTO_URL)\n        self.current_evaluation_id = data.get('current_evaluation_id', '')\n        self.form_data = data.get('form_data', {})\n        self.is_profile_complete = data.get('is_profile_complete', {})\n        self.home_country = data.get('home_country', '')\n        self.config = data.get('config', {})\n\n    def __init__(self, user_email):\n        logging.info('[TTCPortalUser __init__] called')\n        self.user = None\n        self.home_country = None\n        self.username = None\n        self.email = None\n        self.name = None\n        self.photo_file = None\n        self.public_photo_url = None\n        self.current_evaluation_id = None\n        self.config = {}\n        self.form_data = {}\n        self.is_profile_complete = {}\n        if user_email:\n            self.email = user_email\n            self.load_user_data(user_email)\n\n    @staticmethod\n    def get_public_url_for_image(p_photo_file):\n        if p_photo_file.strip() == \"\":\n            logging.info('[get_public_url_for_image] Empty photo file')\n            return \"\"\n        logging.info('[get_public_url_for_image] Getting photo for ' + constants.CLOUD_STORAGE_LOCATION + p_photo_file)\n        try:\n            _photo_url = images.get_serving_url(\n                blobstore.create_gs_key('/gs' + constants.CLOUD_STORAGE_LOCATION + p_photo_file),\n                size=500,\n                crop=True,\n                secure_url=True\n            )\n        except:\n            logging.info('[get_public_url_for_image] Error Getting photo')\n            _photo_url = \"\"\n        return _photo_url\n\n\n\n\n#[START UsersService]\nclass UsersService(webapp2.RequestHandler):\n    def post(self):\n        _user = users.get_current_user()\n        if _user:\n            _user_email_addr = _user.email()\n            _user_logout_url = users.create_logout_url('/')\n            _user_login_url = \"\"\n\n        if self.request.path == '/users/upload-form-data':\n            _form_type = self.request.get('form_type')\n            _form_instance = self.request.get('form_instance')\n            _form_data = self.request.get('form_data')\n            _form_instance_page_data = self.request.get('form_instance_page_data')\n            _form_instance_display = self.request.get('form_instance_display')\n            _user_home_country = self.request.get('user_home_country_iso')\n            if not _user_home_country or _user_home_country.strip() == '':\n                try:\n                    _user_home_country = self.request.headers['X-AppEngine-Country']\n                except Exception as e:\n                    _user_home_country = ''\n            _ttc_user = TTCPortalUser(_user_email_addr)\n            _ttc_user.set_home_country(_user_home_country)\n            # logging.info('[root] data\\n' + _form_data)\n            _ttc_user.set_form_data(_form_type, _form_instance, json.loads(_form_data), json.loads(_form_instance_page_data), _form_instance_display)\n            _ttc_user.save_user_data()\n        elif self.request.path == '/users/set-config':\n            _config_params = json.loads(self.request.get('config_params'))\n            _ttc_user = TTCPortalUser(_user_email_addr)\n            _ttc_user.set_config(_config_params)\n            _ttc_user.save_user_data()\n\n\n    def get(self):\n        _user = users.get_current_user()\n\n        if self.request.path.startswith('/users/reporting/'):\n            try:\n                _is_cron = self.request.headers['X-Appengine-Cron']\n            except Exception as e:\n                _is_cron = False\n\n            if _user:\n                _user_email_addr = _user.email()\n            else:\n                _user_email_addr = \"\"\n\n            if not _is_cron and _user_email_addr not in constants.LIST_OF_ADMINS:\n                self.response.write(\"<b>UN-AUTHORIZED</b>\")\n            else:\n                if self.request.path == '/users/reporting/get-form-data-for-user':\n                    _email = self.request.get('email')\n                    _form_type = self.request.get('form_type')\n                    _form_instance = self.request.get('form_instance')\n                    _ttc_user = TTCPortalUser(_email)\n                    self.response.write(json.dumps(_ttc_user.get_form_data(_form_type, _form_instance)))\n        else:\n            if _user:\n                _user_email_addr = _user.email()\n                _ttc_user = TTCPortalUser(_user_email_addr)\n                if self.request.path == '/users/get-form-data':\n                    _form_type = self.request.get('form_type')\n                    _form_instance = self.request.get('form_instance')\n                    self.response.write(json.dumps(_ttc_user.get_form_data(_form_type, _form_instance)))\n                elif self.request.path == '/users/get-form-instances':\n                    _form_type = self.request.get('form_type')\n                    self.response.write(json.dumps(_ttc_user.get_form_instances(_form_type)))\n                elif self.request.path == '/users/get-config':\n                    self.response.write(json.dumps(_ttc_user.get_config()))\n#[END UsersService]\n\napp = webapp2.WSGIApplication(\n    [\n        ('/users/upload-form-data', UsersService),\n        ('/users/get-form-data', UsersService),\n        ('/users/get-form-instances', UsersService),\n        ('/users/set-config', UsersService),\n        ('/users/get-config', UsersService),\n        ('/users/reporting/get-form-data-for-user', UsersService),\n    ],\n    debug=True\n)\n\n","numLines":477,"startLine":1,"totalLines":477}}}
