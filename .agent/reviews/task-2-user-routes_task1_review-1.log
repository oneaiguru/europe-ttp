t\n92\t  for (const key of Object.keys(data)) {\n93\t    if (!allowedFields.has(key)) {\n94\t      errors.push({ field: key, message: `Unknown field '${key}' is not allowed` });\n95\t    }\n96\t  }\n97\t\n98\t  if (errors.length > 0) {\n99\t    return { valid: false, errors };\n100\t  }\n101\t\n102\t  return { valid: true, errors: [], data: data as UploadFormPayload };\n103\t}\n104\t\n105\t/**\n106\t * Read and parse the request payload with security checks.\n107\t *\n108\t * Handles multiple content types (JSON, form-urlencoded, multipart/form-data)\n109\t * and enforces payload size limits to prevent DoS attacks.\n110\t *\n111\t * SECURITY NOTE: Uses stream-based body reading to enforce size limits\n112\t * regardless of content-length header presence or chunked transfer encoding.\n113\t *\n114\t * @param request - The incoming HTTP request\n115\t * @returns Parsed and typed form data payload\n116\t * @throws {Error} With message '413' if payload exceeds size limit\n117\t * @throws {Error} If payload cannot be parsed\n118\t */\n119\tasync function readPayload(request: Request): Promise<UploadFormPayload> {\n120\t  const contentType = request.headers.get('content-type') ?? '';\n121\t\n122\t  // For JSON content, use stream-based reading with size limit\n123\t  if (contentType.includes('application/json')) {\n124\t    const bodyText = await readBodyWithLimit(request, MAX_PAYLOAD_SIZE);\n125\t    try {\n126\t      return JSON.parse(bodyText) as UploadFormPayload;\n127\t    } catch {\n128\t      throw new Error('Invalid JSON body');\n129\t    }\n130\t  }\n131\t\n132\t  // For form data, require content-length for deterministic behavior (matches BDD spec),\n133\t  // but still enforce the TRUE size limit by streaming the body ourselves. This prevents\n134\t  // a client from lying about Content-Length to bypass the limit before `formData()` runs.\n135\t  if (contentType.includes('application/x-www-form-urlencoded') || contentType.includes('multipart/form-data')) {\n136