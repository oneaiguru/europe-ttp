y = '';\n52\t  config: Record<string, unknown> = {};\n53\t\n54\t  private constructor() {}\n55\t\n56\t  /** Async factory — loads user data from GCS */\n57\t  static async create(email: string): Promise<TTCPortalUser> {\n58\t    const user = new TTCPortalUser();\n59\t    await user.loadUserData(email);\n60\t    return user;\n61\t  }\n62\t\n63\t  private initializeUser(data: UserJSON): void {\n64\t    this.username = data.username ?? '';\n65\t    this.email = data.email ?? this.email ?? '';\n66\t    this.name = data.name ?? '';\n67\t    this.photoFile = data.photo_file ?? '';\n68\t    this.currentEvaluationId = data.current_evaluation_id ?? '';\n69\t    this.formData = data.form_data ?? {};\n70\t    this.isProfileComplete = data.is_profile_complete ?? {};\n71\t    this.homeCountry = data.home_country ?? '';\n72\t    this.config = data.config ?? {};\n73\t  }\n74\t\n75\t  private async loadUserData(email: string): Promise<void> {\n76\t    this.email = email;\n77\t    try {\n78\t      const data = await readJson(\n79\t        GCS_PATHS.USER_CONFIG_PREFIX + email + '.json',\n80\t      ) as UserJSON;\n81\t      this.initializeUser(data);\n82\t    } catch (e: unknown) {\n83\t      // GCS NotFoundError — initialize with empty data (Python lines 316-319)\n84\t      if (e && typeof e === 'object' && 'code' in e && (e as { code: number }).code === 404) {\n85\t        this.initializeUser({ email });\n86\t      } else if (e instanceof Error && e.message?.includes('No such object')) {\n87\t        this.initializeUser({ email });\n88\t      } else {\n89\t        throw e;\n90\t      }\n91\t    }\n92\t  }\n93\t\n94\t  async saveUserData(): Promise<void> {\n95\t    await writeJson(\n96\t      GCS_PATHS.USER_CONFIG_PREFIX + this.email + '.json',\n97\t      this.toJSON(),\n98\t    );\n99\t  }\n100\t\n101\t  private toJSON(): UserJSON {\n102\t    return {\n103\t      username: this.username,\n104\t      email: this.email,\n105\t      name: this.name,\n106\t      photo_file: this.photoFile,\n107\t      current_evaluation_id: this.currentEvaluationId,\n108\t      form_data: this.formData,\n109\t      is_profile_complete: this.isProfileComplete,\n110\t      home_country: this.homeCountry,\n111\t      config: this.config,\n112\t    };\n113\t  }\n114\t\n115\t  setFormData(\n116\t    formType: string,\n117\t    formInstance: string | null | undefined,\n118\t    data: Record<string, unknown>,\n119\t    pageData: Record<string, unknown>,\n120\t    display: string,\n121\t  ): void {\n122\t    let instance = 'default';\n123\t    if (formInstance && formInstance.trim() !== '') {\n124\t      instance = formInstance;\n125\t    }\n126\t\n127\t    let form: Partial<FormInstance> = {};\n128\t    if (formType in this.formData && instance in this.formData[formType]) {\n129\t      form = this.formData[formType][instance];\n130\t    }\n131\t\n132\t    form.data = data;\n133\t    form.form_instance_page_data = pageData;\n134\t    form.form_instance_display = display;\n135\t\n136\t    // Completeness check — any null or empty string field means incomplete\n137\t    let isComplete = true;\n138\t    for (const key of Object.keys(data)) {\n139\t      const val = data[key];\n140\t      if (val == null || String(val).trim() === '') {\n141\t        isComplete = false;\n142\t        break;\n143\t      }\n144\t    }\n145\t\n146\t    form.is_agreement_accepted = str2bool(data['i_agreement_accepted']);\n147\t    form.is_form_submitted = str2bool(data['i_form_submitted']);\n148\t    form.send_confirmation_to_candidate = str2bool(data['i_send_confirmation_to_candidate']);\n149\t\n150\t    // Name extraction\n151\t    if ('i_name' in data) {\n152\t      this.name = String(data['i_name']).trim();\n153\t    } else {\n154\t      const fname = String(data['i_fname'] ?? '').trim();\n155\t      const lname = String(data['i_lname'] ?? '').trim();\n156\t      this.name = fname + ' ' + lname;\n157\t    }\n158\t\n159\t    form.is_form_complete = isComplete;\n160\t    if (formType.includes('p