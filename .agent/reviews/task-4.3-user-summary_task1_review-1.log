\nexport async function requireAdmin(request: Request): Promise<AuthResult> {\n  const email = await getAuthenticatedUser(request);\n  if (!email) {\n    return Response.json({ error: 'Authentication required' }, { status: 401 });\n  }\n  if (!LIST_OF_ADMINS.has(email)) {\n    return Response.json({ error: 'Admin access required' }, { status: 403 });\n  }\n  return { email };\n}\n\n/**\n * Checks user has permission for a specific page.\n */\nexport async function requireAdminForPage(request: Request, page: string): Promise<AuthResult> {\n  const email = await getAuthenticatedUser(request);\n  if (!email) {\n    return Response.json({ error: 'Authentication required' }, { status: 401 });\n  }\n  if (!checkPermissions(email, page)) {\n    return Response.json({ error: 'Permission denied' }, { status: 403 });\n  }\n  return { email };\n}\n\n/**\n * Checks user has permission for ANY of the listed pages.\n */\nexport async function requireAdminAnyOf(request: Request, pages: string[]): Promise<AuthResult> {\n  const email = await getAuthenticatedUser(request);\n  if (!email) {\n    return Response.json({ error: 'Authentication required' }, { status: 401 });\n  }\n  if (!pages.some(page => checkPermissions(email, page))) {\n    return Response.json({ error: 'Permission denied' }, { status: 403 });\n  }\n  return { email };\n}\n\n/**\n * Checks admin list OR cron header.\n */\nexport async function requireAdminOrCron(request: Request): Promise<AuthResult> {\n  if (isCronRequest(request)) {\n    return { email: 'cron' };\n  }\n  const email = await getAuthenticatedUser(request);\n  if (!email) {\n    return Response.json({ error: 'Authentication required' }, { status: 401 });\n  }\n  if (!LIST_OF_ADMINS.has(email)) {\n    return Response.json({ error: 'Admin access required' }, { status: 403 });\n  }\n  return { email };\n}\n\n/**\n * Checks admin with any-of page permission OR cron header.\n */\nexport async function requireAdminAnyOfOrCron(request: Request, pages: string[]): Promise<AuthResult> {\n  if (isCronRequest(request)) {\n    return { email: 'cron' };\n  }\n  const email = await getAuthenticatedUser(request);\n  if (!email) {\n    return Response.json({ error: 'Authentication required' }, { status: 401 });\n  }\n  if (!pages.some(page => checkPermissions(email, page))) {\n    return Response.json({ error: 'Permission denied' }, { status: 403 });\n  }\n  return { email };\n}\n\nexport { LIST_OF_ADMINS, LIST_OF_ADMIN_PERMISSIONS, ROUTE_TO_PAGE_KEY };\n","numLines":269,"startLine":1,"totalLines":269}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_38bf761d93284afea3efbc32","type":"tool_result","content":"1\t// @google-cloud/storage is an optionalDependency — use dynamic import() so the module\n2\t// loads without crashing when the package isn't installed (e.g., local dev without GCS).\n3\t// Lazy singleton pattern: first call to getStorage() does the import and caches.\n4\t\n5\tlet storageInstance: InstanceType<typeof import('@google-cloud/storage').Storage> | null = null;\n6\t\n7\tasync function getStorage() {\n8\t  if (storageInstance) return storageInstance;\n9\t  try {\n10\t    const { Storage } = await import('@google-cloud/storage');\n11\t    storageInstance = new Storage();\n12\t    return storageInstance;\n13\t  } catch {\n14\t    throw new Error('GCS not available — install @google-cloud/storage');\n15\t  }\n16\t}\n17\t\n18\tfunction getBucketName(): string {\n19\t  const name = process.env.GCS_BUCKET_NAME;\n20\t  if (!name) throw new Error('GCS_BUCKET_NAME env var not set');\n21\t  return name;\n22\t}\n23\t\n24\t// GCS path constants (ported from constants.py lines 30-62)\n25\texport const GCS_PATHS = {\n26\t  USER_CONFIG_PREFIX: 'user_data/',\n27\t  USER_SUMMARY_BY_USER: 'user_data/summary/user_summary_by_user.json',\n28\t  USER_SUMMARY_BY_FORM_TYPE: 'user_data/summary/user_summary_by_form_type.json',\n29\t  USER_INTEGRITY_BY_USER: 'user_data/integrity/user_integrity_by_user.json',\n30\t  APPLICANT_ENROLLED_LIST: 'user_data/integrity/applicant_enrolled_list.csv',\n31\t  ADMIN_CONFIG: 'config/admin_config.json',\n32\t  FORM_CONFIG_PREFIX: 'config/forms/',\n33\t  TTC_COUNTRY_AND_DATES: 'config/forms/ttc_country_and_dates.json',\n34\t  TEMP_PREFIX: 'tmp/',\n35\t} as const;\n36\t\n37\texport interface FileMetadata {\n38\t  name: string;\n39\t  updated: Date;\n40\t  timeCreated: Date;\n41\t}\n42\t\n43\texport async function readJson(path: string): Promise<unknown> {\n44\t  const storage = await getStorage();\n45\t  const bucket = storage.bucket(getBucketName());\n46\t  const [contents] = await bucket.file(path).download();\n47\t  return JSON.parse(contents.toString());\n48\t}\n49\t\n50\texport async function writeJson(path: string, data: unknown): Promise<void> {\n51\t  const storage = await getStorage();\n52\t  const bucket = storage.bucket(getBucketName());\n53\t  await bucket.file(path).save(JSON.stringify(data), {\n54\t    contentType: 'text/plain',\n55\t  });\n56\t}\n57\t\n58\texport async function readText(path: string): Promise<string> {\n59\t  const storage = await getStorage();\n60\t  const bucket = storage.bucket(getBucketName());\n61\t  const [contents] = await bucket.file(path).download();\n62\t  return contents.toString();\n63\t}\n64\t\n65\texport async function writeText(path: string, content: string): Promise<void> {\n66\t  const storage = await getStorage();\n67\t  const bucket = storage.bucket(getBucketName());\n68\t  await bucket.file(path).save(content, {\n69\t    contentType: 'text/plain',\n70\t  });\n71\t}\n72\t\n73\texport async function listFiles(prefix: string, minUpdated?: Date): Promise<FileMetadata[]> {\n74\t  const storage = await getStorage();\n75\t  const bucket = storage.bucket(getBucketName());\n76\t  const [files] = await bucket.getFiles({ prefix });\n77\t\n78\t  const results: FileMetadata[] = [];\n79\t  for (const file of files) {\n80\t    const [metadata] = await file.getMetadata();"}]},"parent_tool_use_id":null,"session_id":"3af0d9ba-b901-4246-aa27-51959c42c364","uuid":"110623f5-191b-4384-8a2b-9dad8f8d6f7e","timestamp":"2026-04-06T11:33:46.610Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/gcs.ts","content":"// @google-cloud/storage is an optionalDependency — use dynamic import() so the module\n// loads without crashing when the package isn't installed (e.g., local dev without GCS).\n// Lazy singleton pattern: first call to getStorage() does the import and caches.\n\nlet storageInstance: InstanceType<typeof import('@google-cloud/storage').Storage> | null = null;\n\nasync function getStorage() {\n  if (storageInstance) return storageInstance;\n  try {\n    const { Storage } = await import('@google-cloud/storage');\n    storageInstance = new Storage();\n    return storageInstance;\n  } catch {\n    throw new Error('GCS not available — install @google-cloud/storage');\n  }\n}\n\nfunction getBucketName(): string {\n  const name = process.env.GCS_BUCKET_NAME;\n  if (!name) throw new Error('GCS_BUCKET_NAME env var not set');\n  return name;\n}\n\n// GCS path constants (ported from constants.py lines 30-62)\nexport const GCS_PATHS = {\n  USER_CONFIG_PREFIX: 'user_data/',\n  USER_SUMMARY_BY_USER: 'user_data/summary/user_summary_by_user.json',\n  USER_SUMMARY_BY_FORM_TYPE: 'user_data/summary/user_summary_by_form_type.json',\n  USER_INTEGRITY_BY_USER: 'user_data/integrity/user_integrity_by_user.json',\n  APPLICANT_ENROLLED_LIST: 'user_data/integrity/applicant_enrolled_list.csv',\n  ADMIN_CONFIG: 'config/admin_config.json',\n  FORM_CONFIG_PREFIX: 'config/forms/',\n  TTC_COUNTRY_AND_DATES: 'config/forms/ttc_country_and_dates.json',\n  TEMP_PREFIX: 'tmp/',\n} as const;\n\nexport interface FileMetadata {\n  name: string;\n  updated: Date;\n  timeCreated: Date;\n}\n\nexport async function readJson(path: string): Promise<unknown> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [contents] = await bucket.file(path).download();\n  return JSON.parse(contents.toString());\n}\n\nexport async function writeJson(path: string, data: unknown): Promise<void> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  await bucket.file(path).save(JSON.stringify(data), {\n    contentType: 'text/plain',\n  });\n}\n\nexport async function readText(path: string): Promise<string> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [contents] = await bucket.file(path).download();\n  return contents.toString();\n}\n\nexport async function writeText(path: string, content: string): Promise<void> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  await bucket.file(path).save(content, {\n    contentType: 'text/plain',\n  });\n}\n\nexport async function listFiles(prefix: string, minUpdated?: Date): Promise<FileMetadata[]> {\n  const storage = await getStorage();\n  const bucket = storage.bucket(getBucketName());\n  const [files] = await bucket.getFiles({ prefix });\n\n  const results: FileMetadata[] = [];\n  for (const file of files) {\n    const [metadata] = await file.getMetadata();","numLines":80,"startLine":1,"totalLines":111}}}
