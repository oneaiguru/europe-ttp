{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_222608274ebe43b9ac500fac","type":"tool_result","content":"1\t/**\n2\t * Port of reporting/user_summary.py — load_user_summary()\n3\t *\n4\t * Reads all user data from GCS, matches evaluations to applicants using\n5\t * Levenshtein + name decomposition, computes reporting status, and writes\n6\t * aggregated summary files.\n7\t */\n8\t\n9\timport { readJson, writeJson, listFiles, getFileMetadata, GCS_PATHS } from '../gcs';\n10\timport { getReportingStatus, getTtcList } from './reporting-utils';\n11\timport { levenshteinB } from './matching';\n12\t\n13\tconst KEY = 'reporting';\n14\tconst DATA_RETENTION_DAYS = 730;\n15\t\n16\t// Port of pyutils/utils.py str_remove_prefix\n17\tfunction strRemovePrefix(str: string, prefix: string): string {\n18\t  return str.startsWith(prefix) ? str.slice(prefix.length) : str;\n19\t}\n20\t\n21\t// UTC to Eastern timezone conversion — simplified (no DST rule replication,\n22\t// just use JS Intl for America/New_York)\n23\tfunction utcToEastern(utcStr: string): string {\n24\t  const d = new Date(utcStr + ' UTC');\n25\t  return d.toLocaleString('en-US', {\n26\t    timeZone: 'America/New_York',\n27\t    year: 'numeric', month: '2-digit', day: '2-digit',\n28\t    hour: '2-digit', minute: '2-digit', second: '2-digit',\n29\t    hour12: false,\n30\t  }).replace(/(\\d+)\\/(\\d+)\\/(\\d+),?\\s*/, '$3-$1-$2 ');\n31\t}\n32\t\n33\t// JSON serializer that converts Set to Array (port of json_dumps_set_default)\n34\tfunction jsonReplacer(_key: string, value: unknown): unknown {\n35\t  if (value instanceof Set) return Array.from(value);\n36\t  return value;\n37\t}\n38\t\n39\t// Whitelist of fields to keep in reporting output (Python lines 77-117)\n40\tconst REPORTING_FIELDS = new Set([\n41\t  'dates', 'Dates',\n42\t  'i_address_city', 'i_address_state', 'i_address_country',\n43\t  'i_cellphone', 'i_course_start', 'i_course_wishlist',\n44\t  'i_course_wishlist_artexcel', 'i_course_wishlist_hp',\n45\t  'i_course_wishlist_yes', 'i_course_wishlist_yp',\n46\t  'i_email_aol', 'i_email_other', 'i_enrollment',\n47\t  'i_fname', 'i_homephone', 'i_last1year_introtalks',\n48\t  'i_lname', 'i_name', 'i_prettc_date', 'i_prettc_location',\n49\t  'i_prettc_teacher', 'i_special_interest_groups',\n50\t  'i_ttc_country_and_dates', 'i_ttc_graduate_name',\n51\t  'i_volunteer_email', 'i_volunteer_name',\n52\t  'i_volunteer_teaching_readiness', 'i_youthteacher',\n53\t  'i_ttc_dates', 'i_ttc_location', 'i_date_of_birth',\n54\t  'i_gender', 'i_health_psychiatrist', 'i_volunteer_mental_fitness',\n55\t  'i_course_organized_count', 'i_course_assisted_count',\n56\t]);\n57\t\n58\tinterface FormInstanceData {\n59\t  data: Record<string, unknown>;\n60\t  form_instance_page_data?: Record<string, unknown>;\n61\t  form_instance?: string;\n62\t  last_update_datetime?: string;\n63\t  last_update_datetime_est?: string;\n64\t  is_form_submitted?: boolean;\n65\t  is_form_complete?: boolean;\n66\t  ttc_metadata?: Record<string, unknown>;\n67\t  email?: string;\n68\t  reporting: Record<string, unknown>;\n69\t  [key: string]: unknown;\n70\t}\n71\t\n72\ttype UserDataByEmail = Record<string, Record<string, unknown>>;\n73\t\n74\t/**\n75\t * Port of Reporting.load_user_summary()\n76\t */\n77\texport async function loadUserSummary(): Promise<void> {\n78\t  const ttcList = await getTtcList();\n79\t\n80\t  // Load existing summary (or start empty)\n81\t  let userDataByEmail: UserDataByEmail = {};\n82\t  let minUpdatedDatetime: Date | undefined;\n83\t\n84\t  try {\n85\t    const fileMeta = await getFileMetadata(GCS_PATHS.USER_SUMMARY_BY_USER);\n86\t    const fileUpdated = fileMeta.timeCreated;\n87\t    minUpdatedDatetime = new Date(fileUpdated.getTime() - 60 * 60 * 1000);\n88\t\n89\t    userDataByEmail = (await readJson(GCS_PATHS.USER_SUMMARY_BY_USER)) as UserDataByEmail;\n90\t  } catch {\n91\t    // NotFoundError — start with empty dict\n92\t    userDataByEmail = {};\n93\t    minUpdatedDatetime = undefined;\n94\t  }\n95\t\n96\t  // List user JSON files from GCS\n97\t  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX, minUpdatedDatetime);\n98\t\n99\t  const now = new Date();\n100\t  const retentionCutoff = new Date(now.getTime() - DATA_RETENTION_DAYS * 24 * 60 * 60 * 1000);\n101\t  const retentionCutoffStr = retentionCutoff.toISOString().replace('T', ' ').slice(0, 19);\n102\t\n103\t  for (const file of userFiles) {\n104\t    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n105\t      continue;\n106\t    }\n107\t\n108\t    try {\n109\t      // Re-read the raw JSON — we need to parse form_data structure\n110\t      const raw = await readJson(file.name) as Record<string, unknown>;\n111\t      if (!raw) continue;\n112\t\n113\t      const userEmail = (raw['email'] as string) || '';\n114\t\n115\t      if (!('form_data' in raw)) continue;\n116\t      const formData = raw['form_data'] as Record<string, Record<string, FormInstanceData>>;\n117\t\n118\t      for (const ft of Object.keys(formData)) {\n119\t        for (const fiRaw of Object.keys(formData[ft])) {\n120\t          if (fiRaw === 'default') continue;\n121\t\n122\t          const fd: FormInstanceData = { ...formData[ft][fiRaw] };\n123\t          fd['form_instance'] = fiRaw;\n124\t          fd[KEY] = {};\n125\t\n126\t          // Convert last_update_datetime to Eastern\n127\t          if (fd['last_update_datetime']) {\n128\t            fd['last_update_datetime_est'] = utcToEastern(fd['last_update_datetime'] as string);\n129\t          }\n130\t\n131\t          // Skip records older than retention period\n132\t          if ((fd['last_update_datetime_est'] as string) < retentionCutoffStr) {\n133\t            continue;\n134\t          }\n135\t\n136\t          // Calculate initial reporting status\n137\t          const [appStatus, evalStatus] = getReportingStatus(\n138\t            ft,\n139\t            fd['is_form_submitted'] ?? false,\n140\t            fd['is_form_complete'] ?? false,\n141\t          );\n142\t          fd[KEY]['reporting_status'] = appStatus;\n143\t          fd[KEY]['evaluations_reporting_status'] = evalStatus;\n144\t\n145\t          // Attach TTC metadata\n146\t          if (fd['form_instance_page_data'] && 'i_ttc_country_and_dates' in fd['form_instance_page_data']) {\n147\t            const ttcKey = (fd['form_instance_page_data'] as Record<string, unknown>)['i_ttc_country_and_dates'] as string;\n148\t            fd['ttc_metadata'] = ttcList[ttcKey] || {};\n149\t          }\n150\t\n151\t          // Filter data fields to reporting whitelist + count prereqs/lists\n152\t          fd[KEY]['prereq_no_count'] = 0;\n153\t          if (fd['data']) {\n154\t            const fdData: Record<string, unknown> = {};\n155\t            for (const [q, qa] of Object.entries(fd['data'])) {\n156\t              if (REPORTING_FIELDS.has(q)) {\n157\t                fdData[q] = qa;\n158\t              }\n159\t              // Count prerequisites answered as \"no\"\n160\t              if (/^i_prereq\\d+$/.test(q) && typeof qa === 'string' && qa === 'no') {\n161\t                fd[KEY]['prereq_no_count'] = (fd[KEY]['prereq_no_count'] as number) + 1;\n162\t              }\n163\t              // Count list lengths\n164\t              if (Array.isArray(qa)) {\n165\t                fd[KEY][strRemovePrefix(q, 'i_') + '_count'] = qa.length;\n166\t              }\n167\t            }\n168\t            fd['data'] = fdData;\n169\t          }\n170\t\n171\t          // Parse form_instance key for email extraction (Python lines 223-235)\n172\t          let fiEmail: string | null = null;\n173\t          let fi: string;\n174\t          if (fiRaw.includes('-')) {\n175\t            const fiArr = fiRaw.split('-');\n176\t            if (fiArr.length >= 2 && !fiArr[1].includes('@')) {\n177\t              fiEmail = fiArr[0];\n178\t              fi = fiArr[1];\n179\t            } else {\n180\t              fi = fiArr[0];\n181\t              fiEmail = fiArr[1] || null;\n182\t            }\n183\t          } else {\n184\t            fi = fiRaw;\n185\t          }\n186\t\n187\t          // Build nested structure\n188\t          if (!(userEmail in userDataByEmail)) {\n189\t            userDataByEmail[userEmail] = {};\n190\t          }\n191\t          if (!(ft in userDataByEmail[userEmail])) {\n192\t            (userDataByEmail[userEmail] as Record<string, unknown>)[ft] = {};\n193\t            ((userDataByEmail[userEmail] as Record<string, Record<string, unknown>>)[ft] as Record<string, unknown>)[KEY] = {};\n194\t          }\n195\t          const ftData = (userDataByEmail[userEmail] as Record<string, Record<string, unknown>>)[ft] as Record<string, unknown>;\n196\t          if (!(fi in ftData)) {\n197\t            ftData[fi] = {};\n198\t          }\n199\t\n200\t          if (fiEmail) {\n201\t            (ftData[fi] as Record<string, unknown>)[fiEmail] = fd;\n202\t          } else {\n203\t            ftData[fi] = fd;\n204\t          }\n205\t        }\n206\t      }\n207\t    } catch {\n208\t      continue;\n209\t    }\n210\t  }\n211\t\n212\t  // [START KEYRESET] Clear past evaluation assignments\n213\t  for (const e of Object.keys(userDataByEmail)) {\n214\t    const userEntry = userDataByEmail[e] as Record<string, Record<string, unknown>>;\n215\t    if ('ttc_application' in userEntry) {\n216\t      const ttcApp = userEntry['ttc_application'] as Record<string, unknown>;\n217\t      const ttcAppReporting = ttcApp[KEY] as Record<string, unknown>;\n218\t      ttcAppReporting['lifetime_evaluations'] = {};\n219\t      ttcAppReporting['lifetime_eval_teaching_readiness'] = {};\n220\t      ttcAppReporting['lifetime_eval_teaching_readiness_not_ready_now_count'] = 0;\n221\t      ttcAppReporting['lifetime_evaluator_ratings_below_3'] = 0;\n222\t      ttcAppReporting['lifetime_evaluations_submitted_count'] = 0;\n223\t      ttcAppReporting['lifetime_latest_evaluation_datetime_est'] = '';\n224\t\n225\t      for (const fi of Object.keys(ttcApp)) {\n226\t        const fiData = ttcApp[fi] as Record<string, unknown>;\n227\t        if (fi !== KEY && KEY in fiData) {\n228\t          const fiReporting = fiData[KEY] as Record<string, unknown>;\n229\t          fiReporting['evaluations'] = {};\n230\t          fiReporting['eval_teaching_readiness'] = {};\n231\t          fiReporting['eval_teaching_readiness_not_ready_now_count'] = 0;\n232\t          fiReporting['evaluator_ratings_below_3'] = 0;\n233\t          fiReporting['evaluations_submitted_count'] = 0;\n234\t          fiReporting['latest_evaluation_datetime_est'] = '';\n235\t        }\n236\t      }\n237\t    }\n238\t\n239\t    for (const fi of Object.keys(userEntry['ttc_evaluation'] || {})) {\n240\t      const ttcEval = (userEntry['ttc_evaluation'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n241\t      for (const ve of Object.keys(ttcEval)) {\n242\t        const veReporting = (ttcEval[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n243\t        veReporting['lifetime_reporting_matched_ttc_list'] = new Set<string>();\n244\t        veReporting['is_reporting_matched'] = 'N';\n245\t      }\n246\t    }\n247\t\n248\t    if ('post_ttc_self_evaluation_form' in userEntry) {\n249\t      const selfEval = userEntry['post_ttc_self_evaluation_form'] as Record<string, unknown>;\n250\t      const selfEvalReporting = selfEval[KEY] as Record<string, unknown>;\n251\t      selfEvalReporting['evaluations'] = {};\n252\t      selfEvalReporting['evaluations_submitted_count'] = 0;\n253\t      selfEvalReporting['latest_evaluation_datetime_est'] = '';\n254\t    }\n255\t\n256\t    for (const fi of Object.keys(userEntry['post_ttc_feedback_form'] || {})) {\n257\t      const feedback = (userEntry['post_ttc_feedback_form'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n258\t      for (const ve of Object.keys(feedback)) {\n259\t        const veReporting = (feedback[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n260\t        veReporting['is_reporting_matched'] = 'N';\n261\t      }\n262\t    }\n263\t\n264\t    if ('post_sahaj_ttc_self_evaluation_form' in userEntry) {\n265\t      const selfEval = userEntry['post_sahaj_ttc_self_evaluation_form'] as Record<string, unknown>;\n266\t      const selfEvalReporting = selfEval[KEY] as Record<string, unknown>;\n267\t      selfEvalReporting['evaluations'] = {};\n268\t      selfEvalReporting['evaluations_submitted_count'] = 0;\n269\t      selfEvalReporting['latest_evaluation_datetime_est'] = '';\n270\t    }\n271\t\n272\t    for (const fi of Object.keys(userEntry['post_sahaj_ttc_feedback_form'] || {})) {\n273\t      const feedback = (userEntry['post_sahaj_ttc_feedback_form'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n274\t      for (const ve of Object.keys(feedback)) {\n275\t        const veReporting = (feedback[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n276\t        veReporting['is_reporting_matched'] = 'N';\n277\t      }\n278\t    }\n279\t  }\n280\t  // [END KEYRESET]\n281\t\n282\t  // [START] Evaluation matching — O(n^2) loop\n283\t  for (const t of Object.keys(userDataByEmail)) {\n284\t    const userT = userDataByEmail[t] as Record<string, Record<string, unknown>>;\n285\t\n286\t    for (const fi of Object.keys(userT['ttc_evaluation'] || {})) {\n287\t      if (fi === 'default') continue;\n288\t      const ttcEvalFi = (userT['ttc_evaluation'] as Record<string, unknown>)[fi] as Record<string, unknown>;\n289\t\n290\t      for (const ve of Object.keys(ttcEvalFi)) {\n291\t        const e = ttcEvalFi[ve] as Record<string, unknown>;\n292\t        e['email'] = t;\n293\t        const ed = { ...(e['data'] as Record<string, unknown> || {}), ...(e['form_instance_page_data'] as Record<string, unknown> || {}) };\n294\t        const vn = String(ed['i_volunteer_name'] || '').trim().toLowerCase();\n295\t        const tn = String(ed['i_name'] || ''