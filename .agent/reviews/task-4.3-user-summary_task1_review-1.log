dr = user.email()\n61\t        else:\n62\t            user_email_addr = \"\"\n63\t\n64\t        if user_email_addr not in constants.LIST_OF_ADMINS:\n65\t            self.response.write(\"<b>UN-AUTHORIZED</b>\")\n66\t        else:\n67\t            if self.request.path in ('/reporting/user-summary/load', '/jobs/reporting/user-summary/load'):\n68\t                self.load_user_summary()\n69\t\n70\t    def get_user_summary_by_user(self):\n71\t        _f = gcs.open(constants.USER_SUMMARY_BY_USER)\n72\t        _contents = _f.read()\n73\t        _f.close()\n74\t        return _contents\n75\t\n76\t    def load_user_summary(self):\n77\t        reporting_fields = {\n78\t            'dates',\n79\t            'Dates',\n80\t            'i_address_city',\n81\t            'i_address_state',\n82\t            'i_address_country',\n83\t            'i_cellphone',\n84\t            'i_course_start',\n85\t            'i_course_wishlist',\n86\t            'i_course_wishlist_artexcel',\n87\t            'i_course_wishlist_hp',\n88\t            'i_course_wishlist_yes',\n89\t            'i_course_wishlist_yp',\n90\t            'i_email_aol',\n91\t            'i_email_other',\n92\t            'i_enrollment',\n93\t            'i_fname',\n94\t            'i_homephone',\n95\t            'i_last1year_introtalks',\n96\t            'i_lname',\n97\t            'i_name',\n98\t            'i_prettc_date',\n99\t            'i_prettc_location',\n100\t            'i_prettc_teacher',\n101\t            'i_special_interest_groups',\n102\t            'i_ttc_country_and_dates',\n103\t            'i_ttc_graduate_name',\n104\t            'i_volunteer_email',\n105\t            'i_volunteer_name',\n106\t            'i_volunteer_teaching_readiness',\n107\t            'i_youthteacher',\n108\t            'i_ttc_dates',\n109\t            'i_ttc_location',\n110\t            'i_course_start',\n111\t            'i_date_of_birth',\n112\t            'i_gender',\n113\t            'i_health_psychiatrist',\n114\t            'i_volunteer_mental_fitness',\n115\t            'i_course_organized_count',\n116\t            'i_course_assisted_count',\n117\t        }\n118\t\n119\t        ttc_list = reporting_utils.get_ttc_list()\n120\t\n121\t        min_updated_datetime = None\n122\t        cparams = ControlParameters.fetch()\n123\t        if cparams:\n124\t            min_updated_datetime = cparams.user_summary_last_update_datetime\n125\t            logging.info('[load_user_summary] user_summary_last_update_datetime = ' + min_updated_datetime.strftime('%Y-%m-%d %H:%M:%S'))\n126\t\n127\t        try:\n128\t            _f = gcs.stat(constants.USER_SUMMARY_BY_USER)\n129\t            file_updated_datetime = datetime.fromtimestamp(_f.st_ctime)\n130\t            if not min_updated_datetime:\n131\t                min_updated_datetime = (file_updated_datetime - timedelta(hours=1))\n132\t                logging.error('[load_user_summary] Did not find param for \"user_summary_last_update_datetime\". Setting default from update date of ' + constants.USER_SUMMARY_BY_USER)\n133\t            else:\n134\t                if file_updated_datetime < min_updated_datetime:\n135\t                    min_updated_datetime = (file_updated_datetime - timedelta(hours=1))\n136\t            _f = gcs.open(constants.USER_SUMMARY_BY_USER)\n137\t            _user_data_by_email = json.loads(_f.read())\n138\t            _f.close()\n139\t        except gcs.NotFoundError:\n140\t            logging.info('[load_user_summary] Failed to load the data from old user_summary')\n141\t            logging.info('[load_user_summary] Initializing user with empty dictionary')\n142\t            _user_data_by_email = {}\n143\t            min_updated_datetime = None\n144\t\n145\t        if min_updated_datetime:\n146\t            logging.info('[load_user_summary] user_summary_last_update_datetime = ' + min_updated_datetime.strftime('%Y-%m-%d %H:%M:%S'))\n147\t\n148\t        current_datetime = datetime.now()\n149\t        _user_files = Utils.list_files(\n150\t            # prefix=constants.USER_CONFIG_FOLDER,\n151\t            prefix=constants.USER_CONFIG_LOCATION,\n152\t            min_updated_datetime=min_updated_datetime,\n153\t        )\n154\t\n155\t        # _user_files = gcs.listbucket(constants.USER_CONFIG_LOCATION)\n156\t        # _user_data_by_email = {}\n157\t        for _f in _user_files:\n158\t            if _f.filename.endswith('.json') and not '/summary/' in _f.filename and not '/integrity/' in _f.filename:\n159\t                # logging.info('[load_user_summary] Reading file ' + _f.filename)\n160\t                gcs_file = gcs.open(_f.filename)\n161\t                _contents = gcs_file.read()\n162\t                if _contents and _contents.strip() != '':\n163\t                    _ud = json.loads(_contents)\n164\t                    _ue = _ud.get('email', '')\n165\t                    gcs_file.close()\n166\t                    if 'form_data' in _ud:\n167\t                        for _ft in _ud['form_data']:\n168\t                            for _fi_raw in _ud['form_data'][_ft]:\n169\t                                if _fi_raw != 'default':\n170\t                                    _fd = _ud['form_data'][_ft][_fi_raw]\n171\t                                    _fd['form_instance'] = _fi_raw\n172\t                                    _fd[Reporting.KEY] = {}\n173\t                                    if 'last_update_datetime' in _fd:\n174\t                                        _fd['last_update_datetime_est'] = dt_utils.utc_to_timezone(\n175\t                                            datetime.strptime(\n176\t                                                _fd['last_update_datetime'], \n177\t                                                \"%Y-%m-%d %H:%M:%S\"\n178\t                                            ), \n179\t                                            dt_utils.Eastern\n180\t                                        ).strftime(\"%Y-%m-%d %H:%M:%S\")\n181\t\n182\t                                    if _fd['last_update_datetime_est'] < datetime.strftime(datetime.now() - timedelta(constants.DATA_RETENTION_DAYS), \"%Y-%m-%d %H:%M:%S\"):\n183\t                                        continue\n184\t\n185\t                                    # [START] [reporting_fields] Processing application status\n186\t                                    app_status, eval_status = reporting_utils.get_reporting_status(\n187\t                                        _ft, \n188\t                                        _fd.get('is_form_submitted', False),\n189\t                                        _fd.get('is_form_complete', False),\n190\t                                    )\n191\t                                    _fd[Reporting.KEY]['reporting_status'] = app_status\n192\t                                    _fd[Reporting.KEY]['evaluations_reporting_status'] = eval_status\n193\t                                    # [END] [reporting_fields] Processing application status\n194\t\n195\t                                    # [START] [photo_url] Setting photo public URL\n196\t                                    # [END] [photo_url] Setting photo public URL\n197\t\n198\t                                    # [START] [reporting_fields] Processing form_instance_page_data\n199\t                                    if 'form_instance_page_data' in _fd and 'i_ttc_country_and_dates' in _fd['form_instance_page_data']:\n200\t                                        _fd['ttc_metadata'] = ttc_list.get(_fd['form_instance_page_data']['i_ttc_country_and_dates'], {})\n201\t                                    # [END] [reporting_fields] Processing form_instance_page_data\n202\t\n203\t                                    # [START] [reporting_fields] Processing all answers\n204\t                                    _fd[Reporting.KEY]['prereq_no_count'] = 0\n205\t                                    if 'data' in _fd:\n206\t                                        _fd_data = {}\n207\t                                        for _q, _qa in _fd['data'].items():\n208\t                                            # Storing only whitelisted fields\n209\t                                            if _q in reporting_fields:\n210\t                                                _fd_data[_q] = _qa\n211\t\n212\t                                            # Processing pre-requisites answered as no\n213\t                                            if re.match(r\"i_prereq[0-9]+$\", _q) is not None:\n214\t                                                if isinstance(_qa, basestring) and _qa == 'no':\n215\t                                                    _fd[Reporting.KEY]['prereq_no_count'] += 1\n216\t\n217\t                                            # Adding counts for lists\n218\t                                            if isinstance(_qa, list):\n219\t                                                _fd[Reporting.KEY][utils.str_remove_prefix(_q, 'i_') + '_count'] = len(_qa)\n220\t\n221\t                                        _fd['data'] = _fd_data\n222\t                                    # [END] [reporting_fields] Processing all answers\n223\t\n224\t                                    _fi_email = None\n225\t                                    if '-' in _fi_raw:\n226\t                                        _fi_arr = _fi_raw.split('-')\n227\t                                        # Checking against 2nd value, since sometimes people enter names instead of emails\n228\t                                        # That can throw off this logic. So in such cases we just take the first value as the email.\n229\t                                        if '@' not in _fi_arr[1]:\n230\t                                            _fi_email = _fi_arr[0]\n231\t                                            _fi = _fi_arr[1]\n232\t                                        else:\n233\t                                            _fi = _fi_arr[0]\n234\t                                            _fi_email = _fi_arr[1]\n235\t                                    else:\n236\t                                        _fi = _fi_raw\n237\t\n238\t                                    if _ue not in _user_data_by_email:\n239\t                                        _user_data_by_email[_ue] = {}\n240\t                                    if _ft not in _user_data_by_email[_ue]:\n241\t                                        _user_data_by_email[_ue][_ft] = {}\n242\t                                        _user_data_by_email[_ue][_ft][Reporting.KEY] = {}\n243\t                                    if _fi not in _user_data_by_email[_ue][_ft]:\n244\t                                        _user_data_by_email[_ue][_ft][_fi] = {}\n245\t\n246\t                                    if _fi_email:\n247\t                                        _user_data_by_email[_ue][_ft][_fi][_fi_email] = _fd\n248\t                                    else:\n249\t                                        _user_data_by_email[_ue][_ft][_fi] = _fd\n250\t                                    \n251\t                                    # gc.collect()\n252\t        \n253\t        # [START KEYRESET] Clearing past evaluation assignments\n254\t        for _e in _user_data_by_email:\n255\t            if 'ttc_application' in _user_data_by_email[_e]:\n256\t                _user_data_by_email[_e]['ttc_application'][Reporting.KEY]['lifetime_evaluations'] = {}\n257\t                _user_data_by_email[_e]['ttc_application'][Reporting.KEY]['lifetime_eval_teaching_readiness'] = {}\n258\t                _user_data_by_email[_e]['ttc_application'][Reporting.KEY]['lifetime_eval_teaching_readiness_not_ready_now_count'] = 0\n259\t                _user_data_by_email[_e]['ttc_application'][Reporting.KEY]['lifetime_evaluator_ratings_below_3'] = 0\n260\t                _user_data_by_email[_e]['ttc_application'][Reporting.KEY]['lifetime_evaluations_submitted_count'] = 0\n261\t                _user_data_by_email[_e]['ttc_application'][Reporting.KEY]['lifetime_latest_evaluation_datetime_est'] = ''\n262\t                for _fi in _user_data_by_email[_e]['ttc_application']:\n263\t                    # handling some edge cases in past where evaluation got saved as application\n264\t                    if _fi != Reporting.KEY and Reporting.KEY in _user_data_by_email[_e]['ttc_application'][_fi]:\n265\t                        _user_data_by_email[_e]['ttc_application'][_fi][Reporting.KEY]['evaluations'] = {}\n266\t                        _user_data_by_email[_e]['ttc_application'][_fi][Reporting.KEY]['eval_teaching_readiness'] = {}\n267\t                        _user_data_by_email[_e]['ttc_application'][_fi][Reporting.KEY]['eval_teaching_readiness_not_ready_now_count'] = 0\n268\t                        _user_data_by_email[_e]['ttc_application'][_fi][Reporting.KEY]['evaluator_ratings_below_3'] = 0\n269\t                        _user_data_by_email[_e]['ttc_application'][_fi][Reporting.KEY]['evaluations_submitted_count'] = 0\n270\t                        _user_data_by_email[_e]['ttc_application'][_fi][Reporting.KEY]['latest_evaluation_datetime_est'] = ''\n271\t\n272\t            for _fi in _user_data_by_email[_e].get('ttc_evaluation', {}):\n273\t                for _ve in _user_data_by_email[_e]['ttc_evaluation'][_fi]:\n274\t                    _user_data_by_email[_e]['ttc_evaluation'][_fi][_ve][Reporting.KEY]['lifetime_reporting_matched_ttc_list'] = set()\n275\t                    _user_data_by_email[_e]['ttc_evaluation'][_fi][_ve][Reporting.KEY]['is_reporting_matched'] = 'N'\n276\t\n277\t            if 'post_ttc_self_evaluation_form' in _user_data_by_email[_e]:\n278\t                _user_data_by_email[_e]['post_ttc_self_evaluation_form'][Reporting.KEY]['evaluations'] = {}\n279\t                _user_data_by_email[_e]['post_ttc_self_evaluation_form'][Reporting.KEY]['evaluations_submitted_count'] = 0\n280\t                _user_data_by_email[_e]['post_ttc_self_evaluation_form'][Reporting.KEY]['latest_evaluation_datetime_est'] = ''\n281\t\n282\t            for _fi in _user_data_by_email[_e].get('post_ttc_feedback_form', {}):\n283\t                for _ve in _user_data_by_email[_e]['post_ttc_feedback_form'][_fi]:\n284\t                    _user_data_by_email[_e]['post_ttc_feedback_form'][_fi][_ve][Reporting.KEY]['is_reporting_matched'] = 'N'\n285\t\n286\t            if 'post_sahaj_ttc_self_evaluation_form' in _user_data_by_email[_e]:\n287\t                _user_data_by_email[_e]['post_sahaj_ttc_self_evaluation_form'][Reporting.KEY]['evaluations'] = {}\n288\t                _user_data_by_email[_e]['post_sahaj_ttc_self_evaluation_form'][Reporting.KEY]['evaluations_submitted_count'] = 0\n289\t                _user_data_by_email[_e]['post_sahaj_ttc_self_evaluation_form'][Reporting.KEY]['latest_evaluation_datetime_est'] = ''\n290\t\n291\t            for _fi in _user_data_by_email[_e].get('post_sahaj_ttc_feedback_form', {}):\n292\t                for _ve in _user_data_by_email[_e]['post_sahaj_ttc_feedback_form'][_fi]:\n293\t                    _user_data_by_email[_e]['post_sahaj_ttc_feedback_form'][_fi][_ve][Reporting.KEY]['is_reporting_matched'] = 'N'\n294\t        # [END KEYRESET]\n295\t\n296\t        # logging.info('[load_user_summary] Processing data')\n297\t\n298\t        # logging.info('[load_user_summary] Processing evaluations')\n299\t        for _t in _user_data_by_email:\n300\t            for _fi in _user_data_by_email[_t].get('ttc_evaluation', {}):\n301\t                if _fi == 'default':\n302\t                    continue\n303\t                # logging.info('[load_user_summary] Processing evaluation instance: ' + _fi)\n304\t                for _ve in _user_data_by_email[_t]['ttc_evaluation'][_fi]:\n305\t                    # logging.info('[load_user_summary] Processing evaluation for: ' + _ve)\n306\t                    _e = _user_data_by_email[_t]['ttc_evaluation'][_fi][_ve]\n307\t                    # set logged in email\n308\t                    _e['email'] = _t\n309\t                    _ed = _e.get('data', {})\n310\t                    _ed.update(_e.get('form_instance_page_data', {}))\n311\t                    _vn = _ed.get('i_volunteer_name', '').strip().lower()\n312\t                    _tn = _ed.get('i_name').strip()\n313\t                    # _ve = _ed.get('i_volunteer_email', '').strip()\n314\t                    # logging.info('[load_user_summary] Processing evaluation from: ' + _t + ' for ' + _vn + ' [' + _ve + ']')\n315\t                    _user_data_by_email[_t]['ttc_evaluation'][_fi][_ve][Reporting.KEY]['is_reporting_matched'] = 'N'\n316\t                    for _c in _user_data_by_email:\n317\t                        for _afi in _user_data_by_email[_c].get('ttc_application', {}):\n318\t                            if _afi == Reporting.KEY:\n319\t                                continue\n320\t                            _a = _user_data_by_email[_c]['ttc_application'][_afi]\n321\t                            _ad = _a.get('data', {})\n322\t                            _afn = _ad.get('i_fname','').strip().lower()\n323\t                            _aln = _ad.get('i_lname','').strip().lower()\n324\t                            # If first name has two words\n325\t                            _afnArr = _afn.split()\n326\t                            if _afn and len(_afnArr) > 1:\n327\t                                # getting first word without special characters\n328\t                                _afn2 = ''.join(e for e in _afnArr[0] if e.isalnum())\n329\t                                # getting second word without special characters\n330\t                                _afn3 = ''.join(e for e in _afnArr[1] if e.isalnum())\n331\t                                # getting last name\n332\t                                _aln2 = _aln.split()[-1] if _aln else ''\n333\t                            else:\n334\t                                _afn2 = ''; _afn3 = ''; _aln2 = ''\n335\t\n336\t                            # If last name has two words\n337\t                            _alnArr = _aln.split()\n338\t                            if _aln and len(_alnArr) > 1:\n339\t                                # getting first word without special characters\n340\t                                _aln4 = ''.join(e for e in _alnArr[0] if e.isalnum())\n341\t                                # getting second word without special characters\n342\t                                _aln5 = ''.join(e for e in _alnArr[1] if e.isalnum())\n343\t                            else:\n344\t                                _aln4 = ''; _aln5 = ''\n345\t\n346\t                            # Compare only first name if the volunteer name has only one word\n347\t                            # Checking if volunteer email is valid to avoid first name only comparison where last name is in volunteer email\n348\t                            if len(_vn.split()) == 1 and '@' in _ve:\n349\t                                _an = _afn\n350\t                                # If first name has two words, also compare only against first word\n351\t                                _an2 = _afn2\n352\t                                # If first name has two words, also compare only against second word\n353\t                                _an3 = _afn3\n354\t                                _an4 = ''\n355\t                                _an5 = ''\n356\t                            else:\n357\t                                _an = (_afn + ' ' + _aln)\n358\t                                if _afn2 and _afn3 and _aln2:\n359\t                                    # If first name has two words, also compare only against first word\n360\t                                    _an2 = (_afn2 + ' ' + _aln2)\n361\t                                    # If first name has two words, also compare only against second word\n362\t                                    _an3 = (_afn3 + ' ' + _aln2)\n363\t                                else:\n364\t                                    _an2 = ''; _an3 = ''\n365\t                                if _aln4 and _aln5:\n366\t                                    # If last name has two words, also compare only against first word\n367\t                                    _an4 = (_afn + ' ' + _aln4)\n368\t                                    # If last name has two words, also compare only against second word\n369\t                                    _an5 = (_afn + ' ' + _aln5)\n370\t                                else:\n371\t                                    _an4 = ''; _an5 = ''\n372\t\n373\t                            _aea = _ad.get(\"i_email_aol\", '').strip().lower()\n374\t                            _aeo = _ad.get(\"i_email_other\", '').strip().lower()\n375\t\n376\t                            # logging.info('[load_user_summary] Checking match with candidate: ' + _an + ' / ' + _an2 + ' [' + _c + ']')\n377\t\n378\t                            if (\n379\t                                # Compare with candidates login email\n380\t                                (_ve.lower() == _c.lower()) or\n381\t\n382\t                                # Compare email address with AOL and other email addresses\n383\t                                (_aea and _ve.lower() == _aea.lower()) or\n384\t                                (_aeo and _ve.lower() == _aeo.lower()) or\n385\t\n386\t                                # Comparing against _an\n387\t                                # Compare name with allowed error of 1\n388\t                                (_vn and utils.levenshteinB(_an, _vn, 1, True)) or\n389\t                                # Compare name with name||email with allowed error of 1. Many put last name instead of email\n390\t                                (_ve and '@' not in _ve and _vn and utils.levenshteinB(_an, _vn+' '+_ve, 1, True)) or\n391\t                                # Compare name with just volunteer email with allowed error of 1. Where people have interchanged email and name.\n392\t                                (_ve and '@' not in _ve and utils.levenshteinB(_an, _ve, 1, True)) or\n393\t\n394\t                                # Comparing against _an2\n395\t                                # Compare name with allowed error of 1\n396\t                                (_an2 and _an2 != _an and _vn and utils.levenshteinB(_an2, _vn, 1, True)) or\n397\t                                # Compare name with name||email with allowed error of 1. Many put last name instead of email\n398\t                                (_an2 and _an2 != _an and _ve and '@' not in _ve and _vn and utils.levenshteinB(_an2, _vn+' '+_ve, 1, True)) or\n399\t                                # Compare name with just volunteer email with allowed error of 1. Where people have interchanged email and name.\n400\t                                (_an2 and _an2 != _an and _ve and '@' not in _ve and utils.levenshteinB(_an2, _ve, 1, True)) or\n401\t\n402\t                                # Comparing against _an3\n403\t                                # Compare name with allowed error of 1\n404\t                                (_an3 and _an3 != _an and _vn and utils.levenshteinB(_an3, _vn, 1, True)) or\n405\t                                # Compare name with name||email with allowed error of 1. Many put last name instead of email\n406\t                                (_an3 and _an3 != _an and _ve and '@' not in _ve and _vn and utils.levenshteinB(_an3, _vn+' '+_ve, 1, True)) or\n407\t                                # Compare name with just volunteer email with allowed error of 1. Where people have interchanged email and name.\n408\t                                (_an3 and _an3 != _an and _ve and '@' not in _ve and utils.levenshteinB(_an3, _ve, 1, True)) or\n409\t\n410\t                                # Comparing against _an4\n411\t                                # Compare name with allowed error of 1\n412\t                                (_an4 and _an4 != _an and _vn and utils.levenshteinB(_an4, _vn, 1, True)) or\n413\t                                # Compare name with name||email with allowed error of 1. Many put last name instead of email\n414\t                                (_an4 and _an4 != _an and _ve and '@' not in _ve and _vn and utils.levenshteinB(_an4, _vn+' '+_ve, 1, True)) or\n415\t                                # Compare name with just volunteer email with allowed error of 1. Where people have interchanged email and name.\n416\t                                (_an4 and _an4 != _an and _ve and '@' not in _ve and utils.levenshteinB(_an4, _ve, 1, True)) or\n417\t\n418\t                                # Comparing against _an5\n419\t                                # Compare name with allowed error of 1\n420\t                                (_an5 and _an5 != _an and _vn and utils.levenshteinB(_an5, _vn, 1, True)) or\n421\t                                # Compare name with name||email with allowed error of 1. Many put last name instead of email\n422\t                                (_an5 and _an5 != _an and _ve and '@' not in _ve and _vn and utils.levenshteinB(_an5, _vn+' '+_ve, 1, True)) or\n423\t                                # Compare name with just volunteer email with allowed error of 1. Where people have interchanged email and name.\n424\t                                (_an5 and _an5 != _an and _ve and '@' not in _ve and utils.levenshteinB(_an5, _ve, 1, True))\n425\t                            ):\n426\t                                # ADD to evaluations\n427\t                                if _fi == _afi:\n428\t                                    if _t not in _user_data_by_email[_c]['ttc_application'][_afi][Reporting.KEY]['evaluations']:\n429\t                                        _user_data_by_email[_c]['ttc_application'][_afi][Reporting.KEY]['evaluations'][_t] = {}\n430\t                                    if _ve not in _user_data_by_email[_c]['ttc_application'][_afi][Reporting.KEY]['evaluations'][_t]:\n431\t                                        _user_data_by_email[_c]['ttc_application'][_afi][Reporting.KEY]['evaluations'][_t][_ve] = _tn\n432\t                                        _process_current = True\n433\t                                else:\n434\t                                    _process_current = False\n435\t\n436\t                                # ADD to lifetime_evaluations\n437\t                                if _fi not in _user_data_by_email[_c]['ttc_application'][Reporting.KEY]['lifetime_evaluations']:\n438\t                                    _user_data_by_email[_c]['ttc_application'][Reporting.KEY]['lifetime_evaluations'][_fi] = {}\n439\t                                if _t not in _user_data_by_email[_c]['ttc_application'][Reporting.KEY]['lifetime_evaluations'][_fi]:\n440\t                                    _user_data_by_email[_c]['ttc_application'][Reporting.KEY]['lifetime_evaluations'][_fi][_t] = {}\n441\t                                if _ve not in _user_data_by_email[_c]['ttc_application'][Reporting.KEY]['lifetime_evaluations'][_fi][_t]:\n442\t                                    _user_data_by_email[_c]['ttc_application'][Reporting.KEY]['lifetime_evaluations'][_fi][_t][_ve] = _tn\n443\t                                    _process_lifetime = True\n444\t                                else:\n445\t                                    _process_lifetime = False\n446\t\n447\t                                # Add latest evaluation datetime\n448\t                                if 'last_update_datetime' in _e:\n449\t                                    latest_evaluation_datetime_est = dt_utils.utc_to_timezone(\n450\t                                        datetime.strptime(\n451\t                                            _e['last_update_datetime'], \n452\t                                            \"%Y-%m-%d %H:%M:%S\"\n453\t                                        ), \n454\t                                        dt_utils.Eastern\n455\t                                    ).strftime