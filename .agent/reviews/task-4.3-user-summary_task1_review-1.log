orting_status(`\nAlso 32 spaces.\n\nSo yes, the reporting status update is at the same indentation level as the `if _e.get('is_form_submitted')` statement itself, which means it's OUTSIDE the if block. It runs for every match, not just submitted ones.\n\nIn the TS version, lines 487-497 are inside the `if (e['is_form_submitted'])` block. This is wrong.\n\nNow let me plan the fix:\n\n1. Move the reporting status update (lines 487-497) outside the `if (e['is_form_submitted'])` block\n2. Restructure the `is_form_submitted` block so that `processLifetime` checks are independent from `processCurrent` checks\n\nHere's the corrected structure that matches Python:\n\n```typescript\nif (e['is_form_submitted']) {\n    if (processCurrent) {\n        afiReporting['evaluations_submitted_count'] += 1;\n    }\n    if (processLifetime) {\n        ttcAppReporting['lifetime_evaluations_submitted_count'] += 1;\n    }\n    \n    // Teaching readiness\n    const teachingReadiness = String(ed['i_volunteer_teaching_readiness'] || '');\n    if (teachingReadiness) {\n        if (processCurrent) {\n            // current TR\n        }\n        if (processLifetime) {\n            // lifetime TR\n        }\n        if (teachingReadiness !== 'ready_now') {\n            if (processCurrent) {\n                // current not_ready_now count\n            }\n            if (processLifetime) {\n                // lifetime not_ready_now count\n            }\n        }\n    }\n    \n    // Ratings\n    for (...) {\n        if (...) {\n            if (processCurrent) {\n                // current ratings\n            }\n            if (processLifetime) {\n                // lifetime ratings\n            }\n        }\n    }\n}\n\n// Reporting status update - OUTSIDE is_form_submitted check\nconst [appStatus2, evalStatus2] = getReportingStatus(\n    'ttc_application',\n    !!(a['is_form_submitted']),\n    !!(a['is_form_complete']),\n    ...);\nafiReporting2['reporting_status'] = appStatus2;\nafiReporting2