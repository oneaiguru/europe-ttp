e<Response> {\n36\t  const auth = await requireAdminOrCron(request);\n37\t  if (auth instanceof Response) return auth;\n38\t\n39\t  const data = await readJson(GCS_PATHS.USER_SUMMARY_BY_FORM_TYPE);\n40\t  return new Response(JSON.stringify(data), {\n41\t    headers: { 'content-type': 'text/plain' },\n42\t  });\n43\t}\n44\t```\n45\t\n46\t**Replace `app/api/admin/reporting/user-summary/get-by-user/route.ts`:**\n47\t```typescript\n48\timport { readJson, GCS_PATHS } from '../../../../../utils/gcs';\n49\timport { requireAdminAnyOfOrCron } from '../../../../../utils/auth-middleware';\n50\t\n51\texport async function GET(request: Request): Promise<Response> {\n52\t  const auth = await requireAdminAnyOfOrCron(request, [\n53\t    'ttc_applicants_reports.html',\n54\t    'post_ttc_course_feedback_summary.html',\n55\t    'post_sahaj_ttc_course_feedback_summary.html',\n56\t  ]);\n57\t  if (auth instanceof Response) return auth;\n58\t\n59\t  const data = await readJson(GCS_PATHS.USER_SUMMARY_BY_USER);\n60\t  return new Response(JSON.stringify(data), {\n61\t    headers: { 'content-type': 'text/plain' },\n62\t  });\n63\t}\n64\t```\n65\t\n66\t**Replace `app/api/admin/integrity/user-integrity/get-by-user/route.ts`:**\n67\t```typescript\n68\timport { readJson, GCS_PATHS } from '../../../../../utils/gcs';\n69\timport { requireAdminOrCron } from '../../../../../utils/auth-middleware';\n70\t\n71\texport async function GET(request: Request): Promise<Response> {\n72\t  const auth = await requireAdminOrCron(request);\n73\t  if (auth instanceof Response) return auth;\n74\t\n75\t  const data = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n76\t  return new Response(JSON.stringify(data), {\n77\t    headers: { 'content-type': 'text/plain' },\n78\t  });\n79\t}\n80\t```\n81\t\n82\t### Constraints\n83\t- MUST keep `text/plain` content-type — do NOT use `Response.json()`\n84\t- Remove `mock-data` imports from these 3 files only\n85\t- Do NOT touch `mock-data.ts` itself (get-config still uses it