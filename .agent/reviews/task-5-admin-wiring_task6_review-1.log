{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_a04c60b8e10c4668a16a7cac","type":"tool_result","content":"1\timport { readJson, writeJson, GCS_PATHS } from './gcs';\n2\t\n3\texport async function getAdminConfig(): Promise<Record<string, unknown>> {\n4\t  try {\n5\t    const config = await readJson(GCS_PATHS.ADMIN_CONFIG) as Record<string, unknown>;\n6\t    return (config.raw_config as Record<string, unknown>) || {};\n7\t  } catch {\n8\t    // File not found — return empty config (matching legacy admin.py:78-80)\n9\t    return {};\n10\t  }\n11\t}\n12\t\n13\texport async function setAdminConfig(configParams: Record<string, unknown>): Promise<void> {\n14\t  // Read existing config\n15\t  let config: Record<string, unknown> = {};\n16\t  try {\n17\t    config = await readJson(GCS_PATHS.ADMIN_CONFIG) as Record<string, unknown>;\n18\t  } catch {\n19\t    // File not found — start fresh\n20\t  }\n21\t\n22\t  config.raw_config = configParams;\n23\t\n24\t  // Extract whitelisted user emails (matching legacy admin.py:47-53)\n25\t  const whitelistedEmails: string[] = [];\n26\t  const whitelistedUsers = configParams.i_whitelisted_user;\n27\t  if (Array.isArray(whitelistedUsers)) {\n28\t    for (const user of whitelistedUsers) {\n29\t      if (user && typeof user === 'object' && 'i_whitelisted_user_email' in user) {\n30\t        const email = (user as Record<string, unknown>).i_whitelisted_user_email;\n31\t        if (typeof email === 'string') {\n32\t          whitelistedEmails.push(email.trim().toLowerCase());\n33\t        }\n34\t      }\n35\t    }\n36\t  }\n37\t  config.whitelisted_user_emails = whitelistedEmails;\n38\t\n39\t  await writeJson(GCS_PATHS.ADMIN_CONFIG, config);\n40\t}\n41\t"}]},"parent_tool_use_id":"call_d41afa825e354789b2412e53","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"03d3f215-fb26-463d-b9fa-e6b140ffe106","timestamp":"2026-04-06T14:51:04.878Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_95580916804a4e1ea4c91c5c","type":"tool_result","content":"1\t// @google-cloud/storage is an optionalDependency — use dynamic import() so the module\n2\t// loads without crashing when the package isn't installed (e.g., local dev without GCS).\n3\t// Lazy singleton pattern: first call to getStorage() does the import and caches.\n4\t\n5\tlet storageInstance: InstanceType<typeof import('@google-cloud/storage').Storage> | null = null;\n6\t\n7\tasync function getStorage() {\n8\t  if (storageInstance) return storageInstance;\n9\t  try {\n10\t    const { Storage } = await import('@google-cloud/storage');\n11\t    storageInstance = new Storage();\n12\t    return storageInstance;\n13\t  } catch {\n14\t    throw new Error('GCS not available — install @google-cloud/storage');\n15\t  }\n16\t}\n17\t\n18\tfunction getBucketName(): string {\n19\t  const name = process.env.GCS_BUCKET_NAME;\n20\t  if (!name) throw new Error('GCS_BUCKET_NAME env var not set');\n21\t  return name;\n22\t}\n23\t\n24\t// GCS path constants (ported from constants.py lines 30-62)\n25\texport const GCS_PATHS = {\n26\t  USER_CONFIG_PREFIX: 'user_data/',\n27\t  USER_SUMMARY_BY_USER: 'user_data/summary/user_summary_by_user.json',\n28\t  USER_SUMMARY_BY_FORM_TYPE: 'user_data/summary/user_summary_by_form_type.json',\n29\t  USER_INTEGRITY_BY_USER: 'user_data/integrity/user_integrity_by_user.json',\n30\t  APPLICANT_ENROLLED_LIST: 'user_data/integrity/applicant_enrolled_list.csv',\n31\t  ADMIN_CONFIG: 'config/admin_config.json',\n32\t  FORM_CONFIG_PREFIX: 'config/forms/',\n33\t  TTC_COUNTRY_AND_DATES: 'config/forms/ttc_country_and_dates.json',\n34\t  TEMP_PREFIX: 'tmp/',\n35\t} as const;\n36\t\n37\texport interface FileMetadata {\n38\t  name: string;\n39\t  updated: Date;\n40\t  timeCreated: Date;\n41\t}\n42\t\n43\texport async function readJson(path: string): Promise<unknown> {\n44\t  const storage = await getStorage();\n45\t  const bucket = storage.bucket(getBucketName());\n46\t  const [contents] = await bucket.file(path).download();\n47\t  return JSON.parse(contents.toString());\n48\t}\n49\t\n50\texport async function writeJson(path: string, data: unknown): Promise<void> {\n51\t  const storage = await getStorage();\n52\t  const bucket = storage.bucket(getBucketName());\n53\t  await bucket.file(path).save(JSON.stringify(data), {\n54\t    contentType: 'text/plain',\n55\t  });\n56\t}\n57\t\n58\texport async function readText(path: string): Promise<string> {\n59\t  const storage = await getStorage();\n60\t  const bucket = storage.bucket(getBucketName());\n61\t  const [contents] = await bucket.file(path).download();\n62\t  return contents.toString();\n63\t}\n64\t\n65\texport async function writeText(path: string, content: string): Promise<void> {\n66\t  const storage = await getStorage();\n67\t  const bucket = storage.bucket(getBucketName());\n68\t  await bucket.file(path).save(content, {\n69\t    contentType: 'text/plain',\n70\t  });\n71\t}\n72\t\n73\texport async function listFiles(prefix: string, minUpdated?: Date): Promise<FileMetadata[]> {\n74\t  const storage = await getStorage();\n75\t  const bucket = storage.bucket(getBucketName());\n76\t  const [files] = await bucket.getFiles({ prefix });\n77\t\n78\t  const results: FileMetadata[] = [];\n79\t  for (const file of files) {\n80\t    const [metadata] = await file.getMetadata();\n81\t    const updated = new Date(metadata.updated as string);\n82\t    if (minUpdated && updated <= minUpdated) {\n83\t      continue;\n84\t    }\n85\t    results.push({\n86\t      name: file.name,\n87\t      updated,\n88\t      timeCreated: new Date(metadata.timeCreated as string),\n89\t    });\n90\t  }\n91\t  return results;\n92\t}\n93\t\n94\texport async function fileExists(path: string): Promise<boolean> {\n95\t  const storage = await getStorage();\n96\t  const bucket = storage.bucket(getBucketName());\n97\t  const [exists] = await bucket.file(path).exists();\n98\t  return exists;\n99\t}\n100\t\n101\texport async function getFileMetadata(path: string): Promise<FileMetadata> {\n102\t  const storage = await getStorage();\n103\t  const bucket = storage.bucket(getBucketName());\n104\t  const [metadata] = await bucket.file(path).getMetadata();\n105\t  return {\n106\t    name: metadata.name as string,\n107\t    updated: new Date(metadata.updated as string),\n108\t    timeCreated: new Date(metadata.timeCreated as string),\n109\t  };\n110\t}\n111\t"}]},"parent_tool_use_id":"call_d41afa825e354789b2412e53","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"228f3e07-7fd4-4998-9b7e-0776cd54be96","timestamp":"2026-04-06T14:51:04.880Z"}
