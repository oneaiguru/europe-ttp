{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_fba4bc213efa41d69b690b40","type":"tool_result","content":"125\t      !isNaN(_application['data']['i_enrollment']) &&\n126\t      parseInt(_application['data']['i_enrollment']) >= parseInt(count_lo) &&\n127\t      parseInt(_application['data']['i_enrollment']) <= parseInt(count_hi);\n128\t  }\n129\t  if (_report === 'enrollments_list_count') {\n130\t    return _application['${rk}'].hasOwnProperty('enrolled_people_count') &&\n131\t      parseInt(_application['${rk}']['enrolled_people_count']) >= parseInt(count_lo) &&\n132\t      parseInt(_application['${rk}']['enrolled_people_count']) <= parseInt(count_hi);\n133\t  }\n134\t  if (_report === 'only_kids_courses') {\n135\t    return _application.hasOwnProperty('data') &&\n136\t      _application['data'].hasOwnProperty('i_course_wishlist_yp') &&\n137\t      _application['data']['i_course_wishlist_yp'] === false &&\n138\t      _application['data'].hasOwnProperty('i_course_wishlist_hp') &&\n139\t      _application['data']['i_course_wishlist_hp'] === false &&\n140\t      ((_application['data'].hasOwnProperty('i_course_wishlist_yes') && _application['data']['i_course_wishlist_yes'] === true) ||\n141\t       (_application['data'].hasOwnProperty('i_course_wishlist_artexcel') && _application['data']['i_course_wishlist_artexcel'] === true));\n142\t  }\n143\t  if (_report === 'no_prereq') {\n144\t    return _application['${rk}']['prereq_no_count'] > 0;\n145\t  }\n146\t  if (_report === 'not_ready' && !_show_lifetime) {\n147\t    return _application['${rk}']['eval_teaching_readiness_not_ready_now_count'] > 0;\n148\t  }\n149\t  if (_report === 'not_ready' && _show_lifetime) {\n150\t    return _applicant['${rk}']['lifetime_eval_teaching_readiness_not_ready_now_count'] > 0;\n151\t  }\n152\t  if (_report === 'less_than_3_rating' && !_show_lifetime) {\n153\t    return _application['${rk}']['evaluator_ratings_below_3'] > 0;\n154\t  }\n155\t  if (_report === 'less_than_3_rating' && _show_lifetime) {\n156\t    return _applicant['${rk}']['lifetime_evaluator_ratings_below_3'] > 0;\n157\t  }\n158\t  if (_report === 'no_of_courses_org') {\n159\t    return _application['${rk}'].hasOwnProperty('org_courses_count') &&\n160\t      _application['${rk}']['org_courses_count'] >= parseInt(count_lo) &&\n161\t      _application['${rk}']['org_courses_count'] <= parseInt(count_hi);\n162\t  }\n163\t  if (_report === 'late_vtp_30') {\n164\t    return _application['${rk}'].hasOwnProperty('prettc_date_to_deadline_days') &&\n165\t      !isEmpty(_application['${rk}']['prettc_date_to_deadline_days']) &&\n166\t      _application['${rk}']['prettc_date_to_deadline_days'] < 30;\n167\t  }\n168\t  if (_report === 'late_vtp_90') {\n169\t    return _application['${rk}'].hasOwnProperty('prettc_date_to_deadline_days') &&\n170\t      !isEmpty(_application['${rk}']['prettc_date_to_deadline_days']) &&\n171\t      _application['${rk}']['prettc_date_to_deadline_days'] < 90;\n172\t  }\n173\t  return false;\n174\t}\n175\t\n176\tfunction get_table_data() {\n177\t  var _selected_ttcs = $('#ttc_list').val() || [];\n178\t  if (_selected_ttcs.length > 1) {\n179\t    document.getElementById('show_lifetime_yes').checked = true;\n180\t  }\n181\t  var _show_lifetime = $('input[name=show_lifetime]:checked').val() !== 'no';\n182\t  var _selected_report = document.getElementById('select_report').value;\n183\t\n184\t  var applicant_data = [];\n185\t  var _unmapped_evaluations = [];\n186\t\n187\t  for (var _ae in user_data) {\n188\t    if (user_data[_ae].hasOwnProperty('ttc_application')) {\n189\t      var _applicant = user_data[_ae]['ttc_application'];\n190\t      _selected_ttcs.forEach(function(_selected_ttc) {\n191\t        if (_applicant.hasOwnProperty(_selected_ttc)) {\n192\t          var _application = _applicant[_selected_ttc];\n193\t          if ('data' in _application) {\n194\t            var _name = _application['data']['i_fname'] + ' ' + _application['data']['i_lname'];\n195\t            var _user_ttc = _application['form_instance_page_data']['i_ttc_country_and_dates'];\n196\t            var _prettc_date_str = _application['data']['i_prettc_date'];\n197\t            var _prettc_date_to_deadline_days = null;\n198\t            for (var i = 0; i < ttc_country_and_dates.length && _prettc_date_str && _prettc_date_str.trim().length === 7; i++) {\n199\t              var t = ttc_country_and_dates[i];\n200\t              if (t['value'] === _user_ttc) {\n201\t                try {\n202\t                  var _ttc_deadline = new Date(t['display_until']);\n203\t                  var _prettc_date = new Date(_prettc_date_str.substring(0,3) + '01/' + _prettc_date_str.substring(3));\n204\t                  _prettc_date_to_deadline_days = Math.round(Math.abs(_ttc_deadline - _prettc_date) / (1000*60*60*24)).toString();\n205\t                } catch(e) { _prettc_date_to_deadline_days = null; }\n206\t              }\n207\t            }\n208\t            _application['${rk}']['prettc_date_to_deadline_days'] = _prettc_date_to_deadline_days;\n209\t\n210\t            if (report_filter(_applicant, _application, _selected_report, _show_lifetime)) {\n211\t              var _age = calculateAge(_application['data']['i_date_of_birth']);\n212\t              var _show_lifetime_val = $('input[name=show_lifetime]:checked');\n213\t              var _evaluator_names = [];\n214\t              var _eval_volunteer_mental_fitness = [];\n215\t              var _eval_teaching_readiness, _evaluator_ratings_below_3;\n216\t\n217\t              var _evaluations = [];\n218\t              for (var _t in _application['${rk}']['evaluations']) {\n219\t                for (var _ae2 in _application['${rk}']['evaluations'][_t]) {\n220\t                  var _evaluation = user_data[_t]['ttc_evaluation'][_selected_ttc][_ae2];\n221\t                  _evaluations.push(_evaluation);\n222\t                }\n223\t              }\n224\t              var _lifetime_evaluations = [];\n225\t              for (var _fi in _applicant['${rk}']['lifetime_evaluations']) {\n226\t                for (var _t2 in _applicant['${rk}']['lifetime_evaluations'][_fi]) {\n227\t                  for (var _ae3 in _applicant['${rk}']['lifetime_evaluations'][_fi][_t2]) {\n228\t                    var _evaluation2 = user_data[_t2]['ttc_evaluation'][_fi][_ae3];\n229\t                    _lifetime_evaluations.push(_evaluation2);\n230\t                  }\n231\t                }\n232\t              }\n233\t\n234\t              if (_show_lifetime_val.val() === 'no') {\n235\t                for (var j = 0; j < _evaluations.length; j++) {\n236\t                  _evaluator_names.push(_evaluations[j].data.i_name);\n237\t                  _eval_volunteer_mental_fitness.push(_evaluations[j].data.i_volunteer_mental_fitness);\n238\t                }\n239\t                _eval_teaching_readiness = _application['${rk}']['eval_teaching_readiness'] || {};\n240\t                _evaluator_ratings_below_3 = _application['${rk}']['evaluator_ratings_below_3'] || '';\n241\t              } else {\n242\t                for (var k = 0; k < _lifetime_evaluations.length; k++) {\n243\t                  _evaluator_names.push(_lifetime_evaluations[k].data.i_name);\n244\t                  _eval_volunteer_mental_fitness.push(_lifetime_evaluations[k].data.i_volunteer_mental_fitness);\n245\t                }\n246\t                _eval_teaching_readiness = _applicant['${rk}']['lifetime_eval_teaching_readiness'] || {};\n247\t                _evaluator_ratings_below_3 = _applicant['${rk}']['lifetime_evaluator_ratings_below_3'] || '';\n248\t              }\n249\t\n250\t              applicant_data.push({\n251\t                name: _name, email: _ae,\n252\t                status: _application['${rk}']['reporting_status'],\n253\t                evals: _evaluations.length,\n254\t                lifetime_evals: _lifetime_evaluations.length,\n255\t                last_update_datetime: _application['last_update_date