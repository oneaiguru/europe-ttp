{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_9a22053b8f114a35b88d87e0","type":"tool_result","content":"1\timport { escapeHtml, escapeHtmlAttr } from '../../utils/html';\n2\timport {\n3\t  BUTTON_CSS,\n4\t  DATATABLE_CSS,\n5\t  DETAILS_CONTROL_CSS,\n6\t  ERROR_MESSAGE_JS,\n7\t  EXPORT_BUTTONS_JS,\n8\t  FULLSCREEN_MESSAGE_JS,\n9\t} from '../shared/datatables-helpers';\n10\t\n11\texport const INTEGRITY_REPORT_TITLE = 'Admin: TTC Integrity Report';\n12\texport const INTEGRITY_TABLE_ID = 'ttc_applicants_summary';\n13\t\n14\texport type IntegrityRenderOptions = {\n15\t  integrityKey: string;\n16\t  ttcListHtml: string;\n17\t  userSummaryLastUpdatedDatetime: string;\n18\t  userIntegrityLastUpdatedDatetime: string;\n19\t};\n20\t\n21\texport function renderIntegrityReport(options: IntegrityRenderOptions): string {\n22\t  const { integrityKey, ttcListHtml, userSummaryLastUpdatedDatetime, userIntegrityLastUpdatedDatetime } = options;\n23\t  const escapedKey = escapeHtml(integrityKey);\n24\t\n25\t  const pageStyles = `\n26\t<style>\n27\t  ${DETAILS_CONTROL_CSS}\n28\t  ${DATATABLE_CSS}\n29\t  ${BUTTON_CSS}\n30\t  table.dataTable td, .dataTables_wrapper .dataTables_scroll div.dataTables_scrollBody>table>thead>tr>td,\n31\t  .dataTables_wrapper .dataTables_scroll div.dataTables_scrollBody>table>tbody>tr>td {\n32\t    vertical-align: top;\n33\t  }\n34\t</style>`;\n35\t\n36\t  const appScript = `\n37\t<script type=\"text/javascript\">\n38\tvar user_data = undefined;\n39\tvar table = undefined;\n40\tvar forms = {};\n41\t\n42\t${FULLSCREEN_MESSAGE_JS}\n43\t\n44\t${ERROR_MESSAGE_JS}\n45\t\n46\tfunction get_user_data() {\n47\t  if (user_data) return;\n48\t  $.get(\"integrity/user-integrity/get-by-user\", {})\n49\t    .done(function(data) {\n50\t      user_data = JSON.parse(data);\n51\t      load_table_data();\n52\t    })\n53\t    .fail(function() {\n54\t      postErrorMessage(\"There was an error retrieving the integrity data.\");\n55\t    });\n56\t}\n57\t\n58\tfunction get_table_data() {\n59\t  var _selected_ttcs = $('#ttc_list').val() || [];\n60\t  var applicant_data = [];\n61\t\n62\t  for (var _ae in user_data) {\n63\t    if (user_data[_ae].hasOwnProperty('ttc_application')) {\n64\t      var _applicant = user_data[_ae]['ttc_application'];\n65\t      _selected_ttcs.forEach(function(_selected_ttc) {\n66\t        if (_applicant.hasOwnProperty(_selected_ttc)) {\n67\t          var _application = _applicant[_selected_ttc];\n68\t          if ('data' in _application) {\n69\t            var _name = _application['data']['i_fname'] + ' ' + _application['data']['i_lname'];\n70\t            var enrolled_matches_count = 0;\n71\t            if ('enrolled_matches' in _applicant['${escapedKey}']) {\n72\t              for (var _me in _applicant['${escapedKey}']['enrolled_matches']) {\n73\t                if (Object.hasOwnProperty.call(_applicant['${escapedKey}']['enrolled_matches'], _me)) {\n74\t                  var _mee = _applicant['${escapedKey}']['enrolled_matches'][_me];\n75\t                  if (Array.isArray(_mee)) enrolled_matches_count += _mee.length;\n76\t                }\n77\t              }\n78\t            }\n79\t            var org_course_matches_count = 0;\n80\t            if ('org_course_matches' in _applicant['${escapedKey}']) {\n81\t              for (var _me2 in _applicant['${escapedKey}']['org_course_matches']) {\n82\t                if (Object.hasOwnProperty.call(_applicant['${escapedKey}']['org_course_matches'], _me2)) {\n83\t                  var _mee2 = _applicant['${escapedKey}']['org_course_matches'][_me2];\n84\t                  if (Array.isArray(_mee2)) org_course_matches_count += _mee2.length;\n85\t                }\n86\t              }\n87\t            }\n88\t            if (enrolled_matches_count > 0 || org_course_matches_count > 0) {\n89\t              var enrolled_people_count = Object.keys(_application['data']['i_enrolled_people'] || {}).length;\n90\t              var org_courses_count = Object.keys(_application['data']['i_org_courses'] || {}).length;\n91\t              applicant_data.push({\n92\t                name: _name, email: _ae,\n93\t                last_update_datetime: _application['last_update_datetime_est'],\n94\t                enrolled_matches_count: enrolled_matches_count + ' / ' + enrolled_people_count,\n95\t                org_course_matches_count: org_course_matches_count + ' / ' + org_courses_count,\n96\t                enrolled_matches: _applicant['${escapedKey}']['enrolled_matches'],\n97\t                org_course_matches: _applicant['${escapedKey}']['org_course_matches'],\n98\t                form_instance: _application['form_instance']\n99\t              });\n100\t            }\n101\t          }\n102\t        }\n103\t      });\n104\t    }\n105\t  }\n106\t  return applicant_data;\n107\t}\n108\t\n109\tfunction load_table_data() {\n110\t  var applicant_data = get_table_data();\n111\t  if (table) {\n112\t    table.clear();\n113\t    table.rows.add(applicant_data);\n114\t    table.draw();\n115\t  } else {\n116\t    table = $('#${INTEGRITY_TABLE_ID}').DataTable({\n117\t      data: applicant_data,\n118\t      orderCellsTop: true,\n119\t      scrollX: true,\n120\t      iDisplayLength: 50,\n121\t      dom: 'Bfrtlip',\n122\t      buttons: ${EXPORT_BUTTONS_JS},\n123\t      columns: [\n124\t        {className:'details-control', orderable:false, data:null, defaultContent:''},\n125\t        {data:'name'}, {data:'email'}, {data:'last_update_datetime'},\n126\t        {data:'enrolled_matches_count'}, {data:'org_course_matches_count'}\n127\t      ],\n128\t      order: [[1,'asc']]\n129\t    });\n130\t\n131\t    $('#${INTEGRITY_TABLE_ID} tbody').on('click', 'td.details-control', function() {\n132\t      var tr = $(this).closest('tr');\n133\t      var row = table.row(tr);\n134\t      if (row.child.isShown()) {\n135\t        row.child.hide();\n136\t        tr.removeClass('shown');\n137\t      } else {\n138\t        row.child(format(row.data())).show();\n139\t        tr.addClass('shown');\n140\t      }\n141\t    });\n142\t\n143\t    // Search header\n144\t    $('#${INTEGRITY_TABLE_ID} thead tr').clone(true).appendTo('#${INTEGRITY_TABLE_ID} thead');\n145\t    $('#${INTEGRITY_TABLE_ID} thead tr:eq(1) th:not(:eq(0))').each(function(i) {\n146\t      $(this).html('<input class=\"table_column_search_textbox\" type=\"textbox\" placeholder=\"Search\" />');\n147\t      $('input', this).on('keyup change', function() {\n148\t        if (table.column(i + 1).search() !== this.value) {\n149\t          table.column(i + 1).search(this.value).draw();\n150\t        }\n151\t      });\n152\t    });\n153\t  }\n154\t}\n155\t\n156\tfunction view_form(form_type, email, form_instance) {\n157\t  $.get(\"reporting/user-report/get-user-application-html\",\n158\t    {email:email, form_type:form_type, form_instance:form_instance})\n159\t    .done(function(data) { postFullscreenMessage(data); })\n160\t    .fail(function() { postErrorMessage(\"There was an error retrieving the application\"); });\n161\t}\n162\t\n163\tfunction view_form_standalone(form_type, email, form_instance) {\n164\t  window.open(\"reporting/user-report/get-user-application?email=\" +\n165\t    encodeURIComponent(email) + \"&form_type=\" + encodeURIComponent(form_type) +\n166\t    \"&form_instance=\" + encodeURIComponent(form_instance));\n167\t}\n168\t\n169\tfunction format(d) {\n170\t  var _tables = '';\n171\t  var _forms = [{form_type:'ttc_application', email:d.email, form_instance:d.form_instance}];\n172\t\n173\t  if (d.email !== '') {\n174\t    var _enrolled_match_rows = '';\n175\t    for (var _mae in d.enrolled_matches) {\n176\t      var _matches = d.enrolled_matches[_mae];\n177\t      _enrolled_match_rows +=\n178\t        '<tr><td class=\"bg-white\">Matched with Applicant:</td>' +\n179\t        '<td class=\"bg-white border-r border-gray-200\">' + _mae + '</td></tr>';\n180\t      for (var i = 0; i < _matches.length; i++) {\n181\t        _enrolled_match_rows +=\n182\t          