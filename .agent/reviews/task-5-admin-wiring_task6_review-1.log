: \"Mike\" },\n          i_org_courses: { c1: \"HP Barcelona\", c2: \"YES Paris\" },\n        },\n        last_update_datetime_est: \"03/28/2026 14:30\",\n        form_instance: \"app-001\",\n      },\n      integrity: {\n        enrolled_matches: {\n          \"peter.schmidt@example.com\": [\"John (enrolled by both applicants)\"],\n        },\n        org_course_matches: {},\n      },\n    },\n  },\n  \"peter.schmidt@example.com\": {\n    ttc_application: {\n      default: {\n        data: {\n          i_fname: \"Peter\",\n          i_lname: \"Schmidt\",\n          i_enrolled_people: { p1: \"John\", p2: \"Anna\" },\n          i_org_courses: { c1: \"HP Munich\" },\n        },\n        last_update_datetime_est: \"04/01/2026 09:15\",\n        form_instance: \"app-002\",\n      },\n      integrity: {\n        enrolled_matches: {\n          \"maria.garcia@example.com\": [\"John (enrolled by both applicants)\"],\n        },\n        org_course_matches: {},\n      },\n    },\n  },\n  \"elena.popov@example.com\": {\n    ttc_application: {\n      default: {\n        data: {\n          i_fname: \"Elena\",\n          i_lname: \"Popov\",\n          i_enrolled_people: { p1: \"Claire\", p2: \"Marc\" },\n          i_org_courses: { c1: \"ArtExcel Paris\" },\n        },\n        last_update_datetime_est: \"04/03/2026 16:45\",\n        form_instance: \"app-003\",\n      },\n      integrity: {\n        enrolled_matches: {},\n        org_course_matches: {},\n      },\n    },\n  },\n};\n\n// --- Settings page: admin/get-config ---\n\nexport const MOCK_SETTINGS_DATA = {\n  i_whitelisted_user: [\n    {\n      i_whitelisted_user_name: \"Admin User\",\n      i_whitelisted_user_email: \"admin@example.com\",\n    },\n    {\n      i_whitelisted_user_name: \"Test Coordinator\",\n      i_whitelisted_user_email: \"coordinator@example.com\",\n    },\n  ],\n};\n\n// --- Post TTC Feedback: reporting/user-summary/get-by-user (filtered for post_ttc forms) ---\n\nexport const MOCK_POST_TTC_FEEDBACK_DATA: Record<string, Record<string, unknown>> = {\n  \"maria.garcia@example.com\": {\n    post_ttc_self_evaluation_form: {\n      // reporting key at top level — JS iterates _self_evaluations['reporting']['evaluations']\n      reporting: {\n        evaluations: {\n          jean_dupont: {\n            \"self-eval-001\": {\n              \"jean.dupont@example.com\": true,\n            },\n          },\n        },\n      },\n      // Form instances as sibling keys\n      \"self-eval-001\": {\n        data: {\n          i_fname: \"Maria\",\n          i_lname: \"Garcia\",\n          i_ttc_dates: \"Jan 2026 - Feb 2026\",\n          i_ttc_location: \"Barcelona Centre\",\n          i_cellphone: \"+1-555-0101\",\n          i_homephone: \"+1-555-0201\",\n          i_course_start: \"2026-01-15\",\n        },\n        reporting: {\n          reporting_status: \"complete\",\n        },\n      },\n    },\n  },\n  // Evaluator's feedback form data — accessed via user_data[evaluator_type].post_ttc_feedback_form\n  \"jean_dupont\": {\n    post_ttc_feedback_form: {\n      \"self-eval-001\": {\n        \"jean.dupont@example.com\": {\n          data: {\n            i_fname: \"Jean\",\n            i_lname: \"Dupont\",\n            i_email_aol: \"jean.dupont@example.com\",\n            i_ttc_graduate_name: \"Maria Garcia\",\n            i_ttc_graduate_email: \"maria.garcia@example.com\",\n            i_course_start: \"2026-01-15\",\n          },\n          email: \"jean.dupont@example.com\",\n          form_instance: \"feedback-001\",\n          reporting: {\n            reporting_status: \"complete\",\n            is_reporting_matched: \"Y\",\n          },\n        },\n      },\n    },\n  },\n  \"peter.schmidt@example.com\": {\n    post_ttc_self_evaluation_form: {\n      reporting: {\n        evaluations: {},\n      },\n      \"self-eval-002\": {\n        data: {\n          i_fname: \"Peter\",\n          i_lname: \"Schmidt\",\n          i_ttc_dates: \"Feb 2026 - Mar 2026\",\n          i_ttc_location: \"Munich Center\",\n          i_cellphone: \"+49-555-0102\",\n          i_homephone: \"+49-555-0202\",\n          i_course_start: \"2026-02-01\",\n        },\n        reporting: {\n          reporting_status: \"submitted\",\n        },\n      },\n    },\n  },\n};\n\n// --- Post Sahaj Feedback: same shape as Post TTC but with sahaj form keys ---\n\nexport const MOCK_POST_SAHAJ_FEEDBACK_DATA: Record<string, Record<string, unknown>> = {\n  \"james.wilson@example.com\": {\n    post_sahaj_ttc_self_evaluation_form: {\n      reporting: {\n        evaluations: {\n          anna_muller: {\n            \"sahaj-self-001\": {\n              \"anna.muller@example.com\": true,\n            },\n          },\n        },\n      },\n      \"sahaj-self-001\": {\n        data: {\n          i_fname: \"James\",\n          i_lname: \"Wilson\",\n          i_ttc_dates: \"Mar 2026\",\n          i_ttc_location: \"London Ashram\",\n          i_cellphone: \"+44-555-0104\",\n          i_homephone: \"+44-555-0204\",\n          i_course_start: \"2026-03-01\",\n        },\n        reporting: {\n          reporting_status: \"complete\",\n        },\n      },\n    },\n  },\n  \"anna_muller\": {\n    post_sahaj_ttc_feedback_form: {\n      \"sahaj-self-001\": {\n        \"anna.muller@example.com\": {\n          data: {\n            i_fname: \"Anna\",\n            i_lname: \"Müller\",\n            i_email_aol: \"anna.muller@example.com\",\n            i_ttc_graduate_name: \"James Wilson\",\n            i_ttc_graduate_email: \"james.wilson@example.com\",\n            i_course_start: \"2026-03-01\",\n          },\n          email: \"anna.muller@example.com\",\n          form_instance: \"sahaj-feedback-001\",\n          reporting: {\n            reporting_status: \"submitted\",\n            is_reporting_matched: \"Y\",\n          },\n        },\n      },\n    },\n  },\n};\n","numLines":529,"startLine":1,"totalLines":529}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_e4c777e82a5b4a7cbc3159fe","type":"tool_result","content":"1\timport { readJson, readText, writeJson, writeText, listFiles, GCS_PATHS } from '../gcs';\n2\timport { getTtcList, getReportingStatus } from './reporting-utils';\n3\t\n4\tconst DATA_RETENTION_DAYS = 730;\n5\tconst KEY = 'integrity';\n6\t\n7\t/* eslint-disable @typescript-eslint/no-explicit-any */\n8\t\n9\t/** Recursively convert Set instances to Arrays for JSON serialization. */\n10\tfunction convertSetsToArrays(obj: any): void {\n11\t  if (!obj || typeof obj !== 'object') return;\n12\t  if (obj instanceof Set) return; // handled by parent\n13\t  if (Array.isArray(obj)) {\n14\t    obj.forEach(convertSetsToArrays);\n15\t  } else {\n16\t    for (const key of Object.keys(obj)) {\n17\t      if (obj[key] instanceof Set) {\n18\t        obj[key] = Array.from(obj[key]);\n19\t      } else {\n20\t        convertSetsToArrays(obj[key]);\n21\t      }\n22\t    }\n23\t  }\n24\t}\n25\t\n26\t/**\n27\t * Port of Integrity.load_user_integrity() (Python lines 80-357).\n28\t * Reads all user data, compares enrolled people and organized courses\n29\t * across applicants to find duplicates/matches.\n30\t */\n31\texport async function loadUserIntegrity(): Promise<void> {\n32\t  const reportingFields: Record<string, string | string[]> = {\n33\t    'i_fname': '',\n34\t    'i_lname': '',\n35\t    'i_enrolled_people': '',\n36\t    'i_org_courses': [\n37\t      'i_org_course_from_date',\n38\t      'i_org_course_to_date',\n39\t      'i_org_course_leadteacher',\n40\t      'i_org_course_city',\n41\t      'i_org_course_state',\n42\t      'i_org_course_leadteacher',\n43\t    ],\n44\t  };\n45\t\n46\t  const ttcList = await getTtcList();\n47\t\n48\t  // Load existing integrity data or start fresh\n49\t  let userDataByEmail: any = {};\n50\t  try {\n51\t    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n52\t  } catch {\n53\t    // File doesn't exist yet\n54\t  }\n55\t\n56\t  // List all user JSON files\n57\t  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX);\n58\t  const now = new Date();\n59\t\n60\t  for (const file of userFiles) {\n61\t    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n62\t      continue;\n63\t    }\n64\t\n65\t    let contents: string;\n66\t    try {\n67\t      contents = await readText(file.name);\n68\t    } catch {\n69\t      continue;\n70\t    }\n71\t\n72\t    if (!contents || contents.trim() === '') continue;\n73\t\n74\t    let ud: any;\n75\t    try {\n76\t      ud = JSON.parse(contents);\n77\t    } catch {\n78\t      continue;\n79\t    }\n80\t\n81\t    const ue: string = ud.email || '';\n82\t    if (!ue) continue;\n83\t    if (!ud.form_data) continue;\n84\t\n85\t    for (const ft of Object.keys(ud.form_data)) {\n86\t      if (ft !== 'ttc_application') continue;\n87\t\n88\t      for (const fiRaw of Object.keys(ud.form_data[ft])) {\n89\t        if (fiRaw === 'default') continue;\n90\t\n91\t        const fd: any = { ...ud.form_data[ft][fiRaw] };\n92\t        fd.form_instance = fiRaw;\n93\t\n94\t        // Check retention (skip old records) — port of Python line 161\n95\t        if (fd.last_update_datetime) {\n96\t          const cutoffDate = new Date(now);\n97\t          cutoffDate.setDate(cutoffDate.getDate() - DATA_RETENTION_DAYS);\n98\t          const lastUpdate = new Date(fd.last_update_datetime);\n99\t          if (lastUpdate < cutoffDate) continue;\n100\t        }\n101\t\n102\t        // Reporting status\n103\t        const [appStatus, evalStatus] = getReportingStatus(\n104\t          ft,\n105\t          fd.is_form_submitted || false,\n106\t          fd.is_form_complete || false,\n107\t        );\n108\t        fd.app_status = appStatus;\n109\t        fd.eval_status = evalStatus;\n110\t\n111\t        // TTC metadata\n112\t        if (fd.form_instance_page_data?.i_ttc_country_and_dates) {\n113\t          fd.ttc_metadata = ttcList[fd.form_instance_page_data.i_ttc_country_and_dates] || {};\n114\t        }\n115\t\n116\t        // Filter data to whitelisted fields only\n117\t        if (fd.data) {\n118\t          const fdData: any = {};\n119\t          for (const [q, qa] of Object.entries(fd.data)) {\n120\t            if (q in reportingFields) {\n121\t              let qa2 = qa;\n122\t              const fieldSpec = reportingFields[q];\n123\t              if (qa && typeof qa === 'object' && !Array.isArray(qa) && Array.isArray(fieldSpec)) {\n124\t                qa2 = {};\n125\t                for (const [tq, tqa] of Object.entries(qa as any)) {\n126\t                  if (fieldSpec.includes(tq)) {\n127\t                    (qa2 as any)[tq] = tqa;\n128\t                  }\n129\t                }\n130\t              }\n131\t              fdData[q] = qa2;\n132\t            }\n133\t          }\n134\t          fd.data = fdData;\n135\t        }\n136\t\n137\t        // Extract instance key and optional email — port of Python lines 197-209\n138\t        let fiEmail: string | null = null;\n139\t        let fi: string;\n140\t        if (fiRaw.includes('-')) {\n141\t          const fiArr = fiRaw.split('-');\n142\t          if (!fiArr[1].includes('@')) {\n143\t            fiEmail = fiArr[0];\n144\t            fi = fiArr[1];\n145\t          } else {\n146\t            fi = fiArr[0];\n147\t            fiEmail = fiArr[1];\n148\t          }\n149\t        } else {\n150\t          fi = fiRaw;\n151\t        }\n152\t\n153\t        // Store in userDataByEmail\n154\t        if (!(ue in userDataByEmail)) userDataByEmail[ue] = {};\n155\t        if (!(ft in userDataByEmail[ue])) {\n156\t          userDataByEmail[ue][ft] = {};\n157\t          userDataByEmail[ue][ft][KEY] = {};\n158\t        }\n159\t        if (!(fi in userDataByEmail[ue][ft])) userDataByEmail[ue][ft][fi] = {};\n160\t\n161\t        if (fiEmail) {\n162\t          userDataByEmail[ue][ft][fi][fiEmail] = fd;\n163\t        } else {\n164\t          userDataByEmail[ue][ft][fi] = fd;\n165\t        }\n166\t      }\n167\t    }\n168\t  }\n169\t\n170\t  // [KEYRESET] Clear past matches — port of Python lines 226-230\n171\t  for (const e of Object.keys(userDataByEmail)) {\n172\t    if ('ttc_application' in userDataByEmail[e]) {\n173\t      if (!(KEY in userDataByEmail[e]['ttc_application'])) {\n174\t        userDataByEmail[e]['ttc_application'][KEY] = {};\n175\t      }\n176\t      userDataByEmail[e]['ttc_application'][KEY]['enrolled_matches'] = {};\n177\t      userDataByEmail[e]['ttc_application'][KEY]['org_course_matches'] = {};\n178\t    }\n179\t  }\n180\t\n181\t  // Enrolled people matching (O(n²)) — port of Python lines 235-283\n182\t  for (const c1e of Object.keys(userDataByEmail)) {\n183\t    const c1TtcApp = userDataByEmail[c1e]['ttc_application'];\n184\t    if (!c1TtcApp) continue;\n185\t\n186\t    for (const c1fi of Object.keys(c1TtcApp)) {\n187\t      if (c1fi === 'default') continue;\n188\t\n189\t      const c1 = c1TtcApp[c1fi];\n190\t      const c1d = c1?.data || {};\n191\t\n192\t      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n193\t      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n194\t      const c1n = c1fn + ' ' + c1ln;\n195\t\n196\t      for (const c2e of Object.keys(userDataByEmail)) {\n197\t        if (c1e === c2e) continue;\n198\t\n199\t        const c2TtcApp = userDataByEmail[c2e]['ttc_application'];\n200\t        if (!c2TtcApp) continue;\n201\t\n202\t        for (const c2fi of Object.keys(c2TtcApp)) {\n203\t          const c2 = c2TtcApp[c2fi];\n204\t          const c2d = c2?.data || {};\n205\t\n206\t          const c2fn = (c2d.i_fname || '').trim().toLowerCase();\n207\t          const c2ln = (c2d.i_lname || '').trim().toLowerCase();\n208\t          const c2n = c2fn + ' ' + c2ln;\n209\t\n210\t          if (c1n === c2n) continue;\n211\t\n212\t          // Enrolled people matching\n213\t          const c1Enrolled = c1d.i_enrolled_people;\n214\t          const c2Enrolled = c2d.i_enrolled_people;\n215\t\n216\t          if (Array.isArray(c1Enrolled) && Array.isArray(c2Enrolled)) {\n217\t            for (const c1en of c1Enrolled) {\n218\t              for (const c2en of c2Enrolled) {\n219\t                let isMatched = false;\n220\t                const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n221\t                const ee2 = (c2en.i_enrollment_email || '').trim().toLowerCase();\n222\t                const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n223\t                const en2 = (c2en.i_enrollment_name || '').trim().toLowerCase();\n224\t                const ec1 = (c1en.i_enrollment_city || '').trim().toLowerCase();\n225\t                const ec2 = (c2en.i_enrollment_city || '').trim().toLowerCase();\n226\t                const es1 = (c1en.i_enrollment_state || '').trim().toLowerCase();\n227\t                const es2 = (c2en.i_enrollment_state || '').trim().toLowerCase();\n228\t\n229\t                if (ee1.includes('@') && ee1 === ee2) isMatched = true;\n230\t                if (en1 === en2 && ec1 === ec2 && es1 === es2) isMatched = true;\n231\t\n232\t                if (isMatched) {\n233\t                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n234\t                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n235\t                  }\n236\t                  if (!('enrolled_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n237\t                    userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'] = {};\n238\t                  }\n239\t                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'];\n240\t                  if (!(c2e in matches)) {\n241\t                    matches[c2e] = new Set<string>();\n242\t                  }\n243\t                  matches[c2e].add(`${en2} <${ee2}>`);\n244\t                }\n245\t              }\n246\t            }\n247\t          }\n248\t\n249\t          // O