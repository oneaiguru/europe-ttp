{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_03e93f1ad7dc49228c910362","type":"tool_result","content":"130\t\n131\t    $('#${INTEGRITY_TABLE_ID} tbody').on('click', 'td.details-control', function() {\n132\t      var tr = $(this).closest('tr');\n133\t      var row = table.row(tr);\n134\t      if (row.child.isShown()) {\n135\t        row.child.hide();\n136\t        tr.removeClass('shown');\n137\t      } else {\n138\t        row.child(format(row.data())).show();\n139\t        tr.addClass('shown');\n140\t      }\n141\t    });\n142\t\n143\t    // Search header\n144\t    $('#${INTEGRITY_TABLE_ID} thead tr').clone(true).appendTo('#${INTEGRITY_TABLE_ID} thead');\n145\t    $('#${INTEGRITY_TABLE_ID} thead tr:eq(1) th:not(:eq(0))').each(function(i) {\n146\t      $(this).html('<input class=\"table_column_search_textbox\" type=\"textbox\" placeholder=\"Search\" />');\n147\t      $('input', this).on('keyup change', function() {\n148\t        if (table.column(i + 1).search() !== this.value) {\n149\t          table.column(i + 1).search(this.value).draw();\n150\t        }\n151\t      });\n152\t    });\n153\t  }\n154\t}\n155\t\n156\tfunction view_form(form_type, email, form_instance) {\n157\t  $.get(\"reporting/user-report/get-user-application-html\",\n158\t    {email:email, form_type:form_type, form_instance:form_instance})\n159\t    .done(function(data) { postFullscreenMessage(data); })\n160\t    .fail(function() { postErrorMessage(\"There was an error retrieving the application\"); });\n161\t}\n162\t\n163\tfunction view_form_standalone(form_type, email, form_instance) {\n164\t  window.open(\"reporting/user-report/get-user-application?email=\" +\n165\t    encodeURIComponent(email) + \"&form_type=\" + encodeURIComponent(form_type) +\n166\t    \"&form_instance=\" + encodeURIComponent(form_instance));\n167\t}\n168\t\n169\tfunction format(d) {\n170\t  var _tables = '';\n171\t  var _forms = [{form_type:'ttc_application', email:d.email, form_instance:d.form_instance}];\n172\t\n173\t  if (d.email !== '') {\n174\t    var _enrolled_match_rows = '';\n175\t    for (var _mae in d.enrolled_matches) {\n176\t      var _matches = d.enrolled_matches[_mae];\n177\t      _enrolled_match_rows +=\n178\t        '<tr><td class=\"bg-white\">Matched with Applicant:</td>' +\n179\t        '<td class=\"bg-white border-r border-gray-200\">' + _mae + '</td></tr>';\n180\t      for (var i = 0; i < _matches.length; i++) {\n181\t        _enrolled_match_rows +=\n182\t          '<tr><td class=\"bg-white\">' + (i+1) + '</td>' +\n183\t          '<td class=\"bg-white border-r border-gray-200\">' + _matches[i] + '</td></tr>';\n184\t      }\n185\t    }\n186\t    if (_enrolled_match_rows !== '') {\n187\t      _tables += 'Enrolled Matches: <br>' +\n188\t        '<table cellpadding=\"5\" cellspacing=\"0\" border=\"0\" class=\"border border-gray-200 bg-white p-[13px]\">' +\n189\t        _enrolled_match_rows + '</table><br>';"}]},"parent_tool_use_id":"call_6f50ddaa1a5047ae89d90e70","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"e9830aa1-e948-407a-96d5-28612beea612","timestamp":"2026-04-06T14:51:25.851Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_0c26e96edf2642188bc8af91","type":"tool_result","content":"50\t    $('#step_submit').hide();\n51\t  }\n52\t}\n53\t\n54\tfunction enableInputs() {\n55\t  $(\"input[id^=i_],textarea[id^=i_],select[id^=i_]\").prop(\"disabled\", false);\n56\t  $('#step_submit').show();\n57\t}\n58\t\n59\tfunction new_repeat_entry(id) {\n60\t  $('#' + id).append($('<option>', { value: \"new_entry\", text: \"New Entry\" }));\n61\t  $('#' + id).val(\"new_entry\");\n62\t  var input_list = repeat_question_list[id];\n63\t  for (var i = 0; i < input_list.length; i++) {\n64\t    $('#' + input_list[i]).val(\"\");\n65\t    $(\"label[for='\" + input_list[i] + \"']\").show();\n66\t    $('#' + input_list[i]).show();\n67\t    $('div[name=' + input_list[i] + ']').show();\n68\t    $('label[name=' + input_list[i] + ']').show();\n69\t  }\n70\t  $('#' + id + '_save').show();\n71\t}\n72\t\n73\tfunction remove_repeat_entry(id) {\n74\t  var _val = $('#' + id).val();\n75\t  if (_val === 'new_entry') {\n76\t    $('#' + id).val(\"summary\").change();\n77\t  } else {\n78\t    if (_val === '' || _val === 'summary') {\n79\t      postErrorMessage(\"Please select an entry from the dropdown to delete\");\n80\t      return false;\n81\t    }\n82\t    $(\"#\" + id + \" option[value='\" + _val + \"']\").remove();\n83\t    $('#' + id).val(\"summary\").change();\n84\t  }\n85\t}\n86\t\n87\tfunction save_repeat_entry(id) {\n88\t  var _val = $('#' + id).val();\n89\t  if (_val === 'new_entry') {\n90\t    var input_list = repeat_question_list[id];\n91\t    if (!checkFieldsNonEmpty(input_list)) {\n92\t      postErrorMessage(\"Please enter all details to save\");\n93\t      return false;\n94\t    }\n95\t    var _name = \"\";\n96\t    for (var i = 0; i < Math.min(input_list.length, REPEATER_DISPLAY_INPUT_CNT); i++) {\n97\t      var _n = $('#' + input_list[i]).val();\n98\t      if (_n && _n.trim() !== '') {\n99\t        if (_name !== '') _name += ' \\\\u2022 ';\n100\t        _name += _n.trim();\n101\t      }\n102\t    }\n103\t    if (_name === '') _name = 'Entry';\n104\t\n105\t    var _obj = {};\n106\t    for (var j = 0; j < input_list.length; j++) {\n107\t      if ($('#' + input_list[j]).is(':visible')) {\n108\t        var _i_val = $('#' + input_list[j]).val();\n109\t        if (_i_val) _obj[input_list[j]] = _i_val.trim();\n110\t      }\n111\t    }\n112\t    $('#' + id).append($('<option>', { value: JSON.stringify(_obj), text: _name }));\n113\t    $('#' + id).val(\"summary\").change();\n114\t    postDoneMessage(\"Entry Added\");\n115\t  }\n116\t}\n117\t\n118\tfunction getPageData() {\n119\t  var _form_data = {};\n120\t  var _repeat_questions_arr = [];\n121\t  for (var id in repeat_question_list) {\n122\t    _repeat_questions_arr.push.apply(_repeat_questions_arr, repeat_question_list[id]);\n123\t  }\n124\t  $('#${ADMIN_SETTINGS_CONTAINER_ID}').find(\"input[id^=i_],textarea[id^=i_],select[id^=i_]\").each(function() {\n125\t    var _id = $(this).attr('id');\n126\t    if (!_repeat_questions_arr.includes(_id)) {\n127\t      if ($(this).attr('form-entry-type') === 'repeater') {\n128\t        _form_data[_id] = [];\n129\t        $(this).find('option').each(function() {\n130\t          var _val = $(this).val();\n131\t          if (_val !== 'summary' && _val !== 'new_entry') {\n132\t            try { _form_data[_id].push(JSON.parse(_val)); } catch(e) {}\n133\t          }\n134\t        });\n135\t      } else {\n136\t        _form_data[_id] = $(this).val();\n137\t      }\n138\t    }\n139\t  });\n140\t  return _form_data;\n141\t}\n142\t\n143\tfunction savePage() {\n144\t  var _form_data = getPageData();\n145\t  $.post(\"admin/set-config\", { config_params: JSON.stringify(_form_data) })\n146\t    .done(function(data) {\n147\t      try {\n148\t        var params = JSON.parse(data);\n149\t        if (params.message) $('#step_post_submit_message').html(params.message);"}]},"parent_tool_use_id":"call_6f50ddaa1a5047ae89d90e70","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"9253055c-3126-48ea-a5aa-2058d5fa2ab7","timestamp":"2026-04-06T14:51:25.856Z"}
