{ email: { formType: { instance: { ...data } } } }\n667\t * _by_form_type: { formType: { instance: { email: { ...data } } } }\n668\t *\n669\t * The legacy Python backend generated by_form_type with FLAT reporting fields at\n670\t * top level (reporting_status, evaluations_reporting_status, etc.) and evaluations\n671\t * as top-level arrays of full form instances. The by_user structure uses a nested\n672\t * 'reporting' sub-key. This function flattens that key during inversion.\n673\t */\n674\tfunction invertToByFormType(byUser: UserDataByEmail): Record<string, Record<string, Record<string, unknown>>> {\n675\t  const byFormType: Record<string, Record<string, Record<string, unknown>>> = {};\n676\t\n677\t  for (const email of Object.keys(byUser)) {\n678\t    const userEntry = byUser[email] as Record<string, Record<string, unknown>>;\n679\t    for (const formType of Object.keys(userEntry)) {\n680\t      if (formType === KEY) continue; // Skip 'reporting' key at formType level\n681\t      if (!(formType in byFormType)) byFormType[formType] = {};\n682\t      const formTypeEntry = userEntry[formType] as Record<string, unknown>;\n683\t      for (const instance of Object.keys(formTypeEntry)) {\n684\t        if (instance === KEY) continue; // Skip 'reporting' key at instance level\n685\t        if (!(instance in byFormType[formType])) byFormType[formType][instance] = {};\n686\t        const instanceData = formTypeEntry[instance];\n687\t        (byFormType[formType][instance] as Record<string, unknown>)[email] =\n688\t          flattenForByFormType(instanceData, byUser, email, formType, instance);\n689\t      }\n690\t    }\n691\t  }\n692\t\n693\t  return byFormType;\n694\t}\n695\t\n696\t/**\n697\t * Flatten the 'reporting' sub-key for by_form_type view.\n698\t * Promotes reporting fields to top level, resolves evaluation references\n699\t * into full evaluation form instance arrays.\n700\t */\n701\tfunction flattenForByFormType(\n702\t  data: unknown,\n703\t  byUser: UserDataByEmail,\n704\t  parentEmail: string,\n705\t  formType: string,\n706\t  instance: string,\n707\t): unknown {\n708\t  if (typeof data !== 'object' || data === null) return data;\n709\t\n710\t  const obj = data as Record<string, unknown>;\n711\t\n712\t  // Handle fiEmail nesting: { fiEmail: { ...formData } }\n713\t  // If the object doesn't have 'data' but has exactly one key whose value has 'data',\n714\t  // unwrap one level.\n715\t  let unwrapped = obj;\n716\t  if (!('data' in obj) && !('reporting' in obj)) {\n717\t    const keys = Object.keys(obj);\n718\t    if (keys.length === 1 && typeof obj[keys[0]] === 'object' && obj[keys[0]] !== null) {\n719\t      const inner = obj[keys[0]] as Record<string, unknown>;\n720\t      if ('data' in inner || KEY in inner) {\n721\t        unwrapped = inner;\n722\t      }\n723\t    }\n724\t  }\n725\t\n726\t  if (!(KEY in unwrapped)) return unwrapped; // No reporting key to flatten\n727\t\n728\t  const reporting = unwrapped[KEY] as Record<string, unknown>;\n729\t  const result: Record<string, unknown> = {};\n730\t\n731\t  // Copy all top-level fields except 'reporting'\n732\t  for (const [k, v] of Object.entries(unwrapped)) {\n733\t    if (k !== KEY) result[k] = v;\n734\t  }\n735\t\n736\t  // Promote reporting fields to top level\n737\t  for (const [k, v] of Object.entries(reporting)) {\n738\t    if (k === 'evaluations' && formType === 'ttc_application') {\n739\t      // Convert evaluation references to array of full evaluation instances\n740\t      result['evaluations'] = resolveEvaluationReferences(v, byUser, instance);\n741\t    } else if (k === 'lifetime_evaluations') {\n742\t      // Skip — lifetime_evaluations is at formType level, resolved separately below\n743\t    } else if (k === 'lifetime_reporting_matched_ttc_list' && v instanceof Set) {\n744\t      result[k] = Array.from(v as Set<unknown>);\n745\t    } else if (k === 'evaluations_submitted_count' || k === 'latest_evaluation_datetime_est') {\n746\t      // Only promote per-instance fields, not lifetime\n747\t    } else {\n748\t      result[k] = v;\n749\t    }\n750\t  }\n751\t\n752\t  // Build lifetime_evaluations from formType-level reporting.lifetime_evaluations\n753\t  if (formType === 'ttc_application') {\n754\t    const formTypeReporting = ((byUser[parentEmail] as Record<string, Record<string, unknown>>)[formType]?.[KEY]) as Record<string, unknown> | undefined;\n755\t    if (formTypeReporting?.lifetime_evaluations) {\n756\t      result['lifetime_evaluations'] = resolveLifetimeEvaluationReferences(\n757\t        formTypeReporting.lifetime_evaluations, byUser,\n758\t      );\n759\t    }\n760\t  }\n761\t\n762\t  return result;\n763\t}\n764\t\n765\t/**\n766\t * Resolve evaluation references { evaluatorEmail: { ve: name } } into\n767\t * full evaluation form instances from the by_user ttc_evaluation data.\n768\t */\n769\tfunction resolveEvaluationReferences(\n770\t  evaluationsRef: unknown,\n771\t  byUser: UserDataByEmail,\n772\t  ttcInstance: string,\n773\t): unknown[] {\n774\t  if (!evaluationsRef || typeof evaluationsRef !== 'object') return [];\n775\t  const result: unknown[] = [];\n776\t  const ref = evaluationsRef as Record<string, unknown>;\n777\t\n778\t  for (const evaluatorEmail of Object.keys(ref)) {\n779\t    const veMap = ref[evaluatorEmail] as Record<string, unknown>;\n780\t    for (const veKey of Object.keys(veMap)) {\n781\t      const evalInstance = lookupEvaluation(byUser, evaluatorEmail, ttcInstance, veKey);\n782\t      if (evalInstance) result.push(evalInstance);\n783\t    }\n784\t  }\n785\t\n786\t  return result;\n787\t}\n788\t\n789\t/**\n790\t * Resolve lifetime evaluation references { fi: { evaluatorEmail: { ve: name } } }\n791\t * into full evaluation form instances.\n792\t */\n793\tfunction resolveLifetimeEvaluationReferences(\n794\t  lifetimeRef: unknown,\n795\t  byUser: UserDataByEmail,\n796\t): unknown[] {\n797\t  if (!lifetimeRef || typeof lifetimeRef !== 'object') return [];\n798\t  const result: unknown[] = [];\n799\t  const ref = lifetimeRef as Record<string, unknown>;\n800\t\n801\t  for (const fi of Object.keys(ref)) {\n802\t    const emailMap = ref[fi] as Record<string, unknown>;\n803\t    for (const evaluatorEmail of Object.keys(emailMap)) {\n804\t      const veMap = emailMap[evaluatorEmail] as Record<string, unknown>;\n805\t      for (const veKey of Object.keys(veMap)) {\n806\t        const evalInstance = lookupEvaluation(byUser, evaluatorEmail, fi, veKey);\n807\t        if (evalInstance) result.push(evalInstance);\n808\t      }\n809\t    }\n810\t  }\n811\t\n812\t  return result;\n813\t}\n814\t\n815\t/**\n816\t * Look up a specific evaluation form instance from the by_user data\n817\t * and flatten its reporting key for the by_form_type view.\n818\t */\n819\tfunction lookupEvaluation(\n820\t  byUser: UserDataByEmail,\n821\t  evaluatorEmail: string,\n822\t  fi: string,\n823\t  veKey: string,\n824\t): unknown | null {\n825\t  try {\n826\t    const evaluatorEntry = byUser[evaluatorEmail] as Record<string, Record<string, unknown>> | undefined;\n827\t    if (!evaluatorEntry) return null;\n828\t    const ttcEval = evaluatorEntry['ttc_evaluation'] as Record<string, unknown> | undefined;\n829\t    if (!ttcEval) return null;\n830\t    const fiEntry = ttcEval[fi] as Record<string, unknown> | undefined;\n831\t    if (!fiEntry) return null;\n832\t    const evalData = fiEntry[veKey] as Record<string, unknown> | undefined;\n833\t    if (!evalData) return null;\n834\t\n835\t    // Flatten reporting key for the evaluation instance\n836\t    if (KEY in evalData) {\n837\t      const reporting = evalData[KEY] as Record<string, unknown>;\n838\t      const flattened: Record<string, unknown> = {};\n839\t      for (const [k, v] of Object.entries(evalData)) {\n840\t        if (k !== KEY) flattened[k] = v;\n841\t      }\n842\t      for (const [k, v] of Object.entries(reporting)) {\n843\t        if (k === 'lifetime_reporting_matched_ttc_list' && v instanceof Set) {\n844\t          flattened[k] = Array.from(v as Set<unknown>);\n845\t        } else {\n846\t          flattened[k] = v;\n847\t        }\n848\t      }\n849\t      return flattened;\n850\t    }\n851\t    return evalData;\n852\t  } catch {\n853\t    return null;\n854\t  }\n855\t}\n856\t\n857\t/**\n858\t * Read the user summary by user file from GCS.\n859\t */\n860\texport async function getUserSummaryByUser(): Promise<string> {\n861\t  const data = await readJson(GCS_PATHS.USER_SUMMARY_BY_USER);\n862\t  return JSON.stringify(data);\n863\t}\n864\t"}]},"parent_tool_use_id":null,"session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"852115f3-2a26-48a6-bb99-952e74e6c002","timestamp":"2026-04-06T14:43:44.000Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/reporting/user-summary.ts","content":"/**\n * Port of reporting/user_summary.py — load_user_summary()\n *\n * Reads all user data from GCS, matches evaluations to applicants using\n * Levenshtein + name decomposition, computes reporting status, and writes\n * aggregated summary files.\n */\n\nimport { readJson, writeJson, listFiles, getFileMetadata, GCS_PATHS } from '../gcs';\nimport { getReportingStatus, getTtcList } from './reporting-utils';\nimport { levenshteinB } from './matching';\n\nconst KEY = 'reporting';\nconst DATA_RETENTION_DAYS = 730;\n\n// Port of pyutils/utils.py str_remove_prefix\nfunction strRemovePrefix(str: string, prefix: string): string {\n  return str.startsWith(prefix) ? str.slice(prefix.length) : str;\n}\n\n// UTC to Eastern timezone conversion — simplified (no DST rule replication,\n// just use JS Intl for America/New_York)\nfunction utcToEastern(utcStr: string): string {\n  const d = new Date(utcStr + ' UTC');\n  return d.toLocaleString('en-US', {\n    timeZone: 'America/New_York',\n    year: 'numeric', month: '2-digit', day: '2-digit',\n    hour: '2-digit', minute: '2-digit', second: '2-digit',\n    hour12: false,\n  }).replace(/(\\d+)\\/(\\d+)\\/(\\d+),?\\s*/, '$3-$1-$2 ');\n}\n\n// JSON serializer that converts Set to Array (port of json_dumps_set_default)\nfunction jsonReplacer(_key: string, value: unknown): unknown {\n  if (value instanceof Set) return Array.from(value);\n  return value;\n}\n\n// Whitelist of fields to keep in reporting output (Python lines 77-117)\nconst REPORTING_FIELDS = new Set([\n  'dates', 'Dates',\n  'i_address_city', 'i_address_state', 'i_address_country',\n  'i_cellphone', 'i_course_start', 'i_course_wishlist',\n  'i_course_wishlist_artexcel', 'i_course_wishlist_hp',\n  'i_course_wishlist_yes', 'i_course_wishlist_yp',\n  'i_email_aol', 'i_email_other', 'i_enrollment',\n  'i_fname', 'i_homephone', 'i_last1year_introtalks',\n  'i_lname', 'i_name', 'i_prettc_date', 'i_prettc_location',\n  'i_prettc_teacher', 'i_special_interest_groups',\n  'i_ttc_country_and_dates', 'i_ttc_graduate_name',\n  'i_volunteer_email', 'i_volunteer_name',\n  'i_volunteer_teaching_readiness', 'i_youthteacher',\n  'i_ttc_dates', 'i_ttc_location', 'i_date_of_birth',\n  'i_gender', 'i_health_psychiatrist', 'i_volunteer_mental_fitness',\n  'i_course_organized_count', 'i_course_assisted_count',\n]);\n\ninterface FormInstanceData {\n  data: Record<string, unknown>;\n  form_instance_page_data?: Record<string, unknown>;\n  form_instance?: string;\n  last_update_datetime?: string;\n  last_update_datetime_est?: string;\n  is_form_submitted?: boolean;\n  is_form_complete?: boolean;\n  ttc_metadata?: Record<string, unknown>;\n  email?: string;\n  reporting: Record<string, unknown>;\n  [key: string]: unknown;\n}\n\ntype UserDataByEmail = Record<string, Record<string, unknown>>;\n\n/**\n * Port of Reporting.load_user_summary()\n */\nexport async function loadUserSummary(): Promise<void> {\n  const ttcList = await getTtcList();\n\n  // Load existing summary (or start empty)\n  let userDataByEmail: UserDataByEmail = {};\n  let minUpdatedDatetime: Date | undefined;\n\n  try {\n    const fileMeta = await getFileMetadata(GCS_PATHS.USER_SUMMARY_BY_USER);\n    const fileUpdated = fileMeta.timeCreated;\n    minUpdatedDatetime = new Date(fileUpdated.getTime() - 60 * 60 * 1000);\n\n    userDataByEmail = (await readJson(GCS_PATHS.USER_SUMMARY_BY_USER)) as UserDataByEmail;\n  } catch {\n    // NotFoundError — start with empty dict\n    userDataByEmail = {};\n    minUpdatedDatetime = undefined;\n  }\n\n  // List user JSON files from GCS\n  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX, minUpdatedDatetime);\n\n  const now = new Date();\n  const retentionCutoff = new Date(now.getTime() - DATA_RETENTION_DAYS * 24 * 60 * 60 * 1000);\n  const retentionCutoffStr = retentionCutoff.toISOString().replace('T', ' ').slice(0, 19);\n\n  for (const file of userFiles) {\n    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n      continue;\n    }\n\n    try {\n      // Re-read the raw JSON — we need to parse form_data structure\n      const raw = await readJson(file.name) as Record<string, unknown>;\n      if (!raw) continue;\n\n      const userEmail = (raw['email'] as string) || '';\n\n      if (!('form_data' in raw)) continue;\n      const formData = raw['form_data'] as Record<string, Record<string, FormInstanceData>>;\n\n      for (const ft of Object.keys(formData)) {\n        for (const fiRaw of Object.keys(formData[ft])) {\n          if (fiRaw === 'default') continue;\n\n          const fd: FormInstanceData = { ...formData[ft][fiRaw] };\n          fd['form_instance'] = fiRaw;\n          fd[KEY] = {};\n\n          // Convert last_update_datetime to Eastern\n          if (fd['last_update_datetime']) {\n            fd['last_update_datetime_est'] = utcToEastern(fd['last_update_datetime'] as string);\n          }\n\n          // Skip records older than retention period\n          if ((fd['last_update_datetime_est'] as string) < retentionCutoffStr) {\n            continue;\n          }\n\n          // Calculate initial reporting status\n          const [appStatus, evalStatus] = getReportingStatus(\n            ft,\n            fd['is_form_submitted'] ?? false,\n            fd['is_form_complete'] ?? false,\n          );\n          fd[KEY]['reporting_status'] = appStatus;\n          fd[KEY]['evaluations_reporting_status'] = evalStatus;\n\n          // Attach TTC metadata\n          if (fd['form_instance_page_data'] && 'i_ttc_country_and_dates' in fd['form_instance_page_data']) {\n            const ttcKey = (fd['form_instance_page_data'] as Record<string, unknown>)['i_ttc_country_and_dates'] as string;\n            fd['ttc_metadata'] = ttcList[ttcKey] || {};\n          }\n\n          // Filter data fields to reporting whitelist + count prereqs/lists\n          fd[KEY]['prereq_no_count'] = 0;\n          if (fd['data']) {\n            const fdData: Record<string, unknown> = {};\n            for (const [q, qa] of Object.entries(fd['data'])) {\n              if (REPORTING_FIELDS.has(q)) {\n                fdData[q] = qa;\n              }\n              // Count prerequisites answered as \"no\"\n              if (/^i_prereq\\d+$/.test(q) && typeof qa === 'string' && qa === 'no') {\n                fd[KEY]['prereq_no_count'] = (fd[KEY]['prereq_no_count'] as number) + 1;\n              }\n              // Count list lengths\n              if (Array.isArray(qa)) {\n                fd[KEY][strRemovePrefix(q, 'i_') + '_count'] = qa.length;\n              }\n            }\n            fd['data'] = fdData;\n          }\n\n          // Parse form_instance key for email extraction (Python lines 223-235)\n          let fiEmail: string | null = null;\n          let fi: string;\n          if (fiRaw.includes('-')) {\n            const fiArr = fiRaw.split('-');\n            if (fiArr.length >= 2 && !fiArr[1].includes('@')) {\n              fiEmail = fiArr[0];\n              fi = fiArr[1];\n            } else {\n              fi = fiArr[0];\n              fiEmail = fiArr[1] || null;\n            }\n          } else {\n            fi = fiRaw;\n          }\n\n          // Build nested structure\n          if (!(userEmail in userDataByEmail)) {\n            userDataByEmail[userEmail] = {};\n          }\n          if (!(ft in userDataByEmail[userEmail])) {\n            (userDataByEmail[userEmail] as Record<string, unknown>)[ft] = {};\n            ((userDataByEmail[userEmail] as Record<string, Record<string, unknown>>)[ft] as Record<string, unknown>)[KEY] = {};\n          }\n          const ftData = (userDataByEmail[userEmail] as Record<string, Record<string, unknown>>)[ft] as Record<string, unknown>;\n          if (!(fi in ftData)) {\n            ftData[fi] = {};\n          }\n\n          if (fiEmail) {\n            (ftData[fi] as Record<string, unknown>)[fiEmail] = fd;\n          } else {\n            ftData[fi] = fd;\n          }\n        }\n      }\n    } catch {\n      continue;\n    }\n  }\n\n  // [START KEYRESET] Clear past evaluation assignments\n  for (const e of Object.keys(userDataByEmail)) {\n    const userEntry = userDataByEmail[e] as Record<string, Record<string, unknown>>;\n    if ('ttc_application' in userEntry) {\n      const ttcApp = userEntry['ttc_application'] as Record<string, unknown>;\n      const ttcAppReporting = ttcApp[KEY] as Record<string, unknown>;\n      ttcAppReporting['lifetime_evaluations'] = {};\n      ttcAppReporting['lifetime_eval_teaching_readiness'] = {};\n      ttcAppReporting['lifetime_eval_teaching_readiness_not_ready_now_count'] = 0;\n      ttcAppReporting['lifetime_evaluator_ratings_below_3'] = 0;\n      ttcAppReporting['lifetime_evaluations_submitted_count'] = 0;\n      ttcAppReporting['lifetime_latest_evaluation_datetime_est'] = '';\n\n      for (const fi of Object.keys(ttcApp)) {\n        const fiData = ttcApp[fi] as Record<string, unknown>;\n        if (fi !== KEY && KEY in fiData) {\n          const fiReporting = fiData[KEY] as Record<string, unknown>;\n          fiReporting['evaluations'] = {};\n          fiReporting['eval_teaching_readiness'] = {};\n          fiReporting['eval_teaching_readiness_not_ready_now_count'] = 0;\n          fiReporting['evaluator_ratings_below_3'] = 0;\n          fiReporting['evaluations_submitted_count'] = 0;\n          fiReporting['latest_evaluation_datetime_est'] = '';\n        }\n      }\n    }\n\n    for (const fi of Object.keys(userEntry['ttc_evaluation'] || {})) {\n      const ttcEval = (userEntry['ttc_evaluation'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n      for (const ve of Object.keys(ttcEval)) {\n        const veReporting = (ttcEval[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n        veReporting['lifetime_reporting_matched_ttc_list'] = new Set<string>();\n        veReporting['is_reporting_matched'] = 'N';\n      }\n    }\n\n    if ('post_ttc_self_evaluation_form' in userEntry) {\n      const selfEval = userEntry['post_ttc_self_evaluation_form'] as Record<string, unknown>;\n      const selfEvalReporting = selfEval[KEY] as Record<string, unknown>;\n      selfEvalReporting['evaluations'] = {};\n      selfEvalReporting['evaluations_submitted_count'] = 0;\n      selfEvalReporting['latest_evaluation_datetime_est'] = '';\n    }\n\n    for (const fi of Object.keys(userEntry['post_ttc_feedback_form'] || {})) {\n      const feedback = (userEntry['post_ttc_feedback_form'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n      for (const ve of Object.keys(feedback)) {\n        const veReporting = (feedback[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n        veReporting['is_reporting_matched'] = 'N';\n      }\n    }\n\n    if ('post_sahaj_ttc_self_evaluation_form' in userEntry) {\n      const selfEval = userEntry['post_sahaj_ttc_self_evaluation_form'] as Record<string, unknown>;\n      const selfEvalReporting = selfEval[KEY] as Record<string, unknown>;\n      selfEvalReporting['evaluations'] = {};\n      selfEvalReporting['evaluations_submitted_count'] = 0;\n      selfEvalReporting['