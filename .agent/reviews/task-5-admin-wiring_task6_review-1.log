ame || '').trim().toLowerCase();\n338\t      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n339\t      const c1n = c1fn + ' ' + c1ln;\n340\t\n341\t      enrolledCSV += `${c1n},${c1e},,\\n`;\n342\t\n343\t      const enrolledPeople = c1d.i_enrolled_people;\n344\t      if (Array.isArray(enrolledPeople)) {\n345\t        for (const c1en of enrolledPeople) {\n346\t          const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n347\t          const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n348\t          enrolledCSV += `,,${en1},${ee1}\\n`;\n349\t        }\n350\t      }\n351\t    }\n352\t  }\n353\t\n354\t  // Normalize unicode to ASCII — port of unicodedata.normalize('NFKD', ...).encode('ascii', 'ignore')\n355\t  enrolledCSV = enrolledCSV.normalize('NFKD').replace(/[\\u0300-\\u036f]/g, '');\n356\t\n357\t  await writeText(GCS_PATHS.APPLICANT_ENROLLED_LIST, enrolledCSV);\n358\t}\n359\t\n360\t/**\n361\t * Port of Integrity.get_user_integrity_by_user() (Python lines 74-78).\n362\t * Reads the integrity JSON from GCS.\n363\t */\n364\texport async function getUserIntegrityByUser(): Promise<unknown> {\n365\t  return readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n366\t}\n367\t"}]},"parent_tool_use_id":null,"session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"e6418691-55ce-4ae4-8683-2ff72b98d438","timestamp":"2026-04-06T14:43:42.817Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/reporting/user-integrity.ts","content":"import { readJson, readText, writeJson, writeText, listFiles, GCS_PATHS } from '../gcs';\nimport { getTtcList, getReportingStatus } from './reporting-utils';\n\nconst DATA_RETENTION_DAYS = 730;\nconst KEY = 'integrity';\n\n/* eslint-disable @typescript-eslint/no-explicit-any */\n\n/** Recursively convert Set instances to Arrays for JSON serialization. */\nfunction convertSetsToArrays(obj: any): void {\n  if (!obj || typeof obj !== 'object') return;\n  if (obj instanceof Set) return; // handled by parent\n  if (Array.isArray(obj)) {\n    obj.forEach(convertSetsToArrays);\n  } else {\n    for (const key of Object.keys(obj)) {\n      if (obj[key] instanceof Set) {\n        obj[key] = Array.from(obj[key]);\n      } else {\n        convertSetsToArrays(obj[key]);\n      }\n    }\n  }\n}\n\n/**\n * Port of Integrity.load_user_integrity() (Python lines 80-357).\n * Reads all user data, compares enrolled people and organized courses\n * across applicants to find duplicates/matches.\n */\nexport async function loadUserIntegrity(): Promise<void> {\n  const reportingFields: Record<string, string | string[]> = {\n    'i_fname': '',\n    'i_lname': '',\n    'i_enrolled_people': '',\n    'i_org_courses': [\n      'i_org_course_from_date',\n      'i_org_course_to_date',\n      'i_org_course_leadteacher',\n      'i_org_course_city',\n      'i_org_course_state',\n      'i_org_course_leadteacher',\n    ],\n  };\n\n  const ttcList = await getTtcList();\n\n  // Load existing integrity data or start fresh\n  let userDataByEmail: any = {};\n  try {\n    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n  } catch {\n    // File doesn't exist yet\n  }\n\n  // List all user JSON files\n  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX);\n  const now = new Date();\n\n  for (const file of userFiles) {\n    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n      continue;\n    }\n\n    let contents: string;\n    try {\n      contents = await readText(file.name);\n    } catch {\n      continue;\n    }\n\n    if (!contents || contents.trim() === '') continue;\n\n    let ud: any;\n    try {\n      ud = JSON.parse(contents);\n    } catch {\n      continue;\n    }\n\n    const ue: string = ud.email || '';\n    if (!ue) continue;\n    if (!ud.form_data) continue;\n\n    for (const ft of Object.keys(ud.form_data)) {\n      if (ft !== 'ttc_application') continue;\n\n      for (const fiRaw of Object.keys(ud.form_data[ft])) {\n        if (fiRaw === 'default') continue;\n\n        const fd: any = { ...ud.form_data[ft][fiRaw] };\n        fd.form_instance = fiRaw;\n\n        // Check retention (skip old records) — port of Python line 161\n        if (fd.last_update_datetime) {\n          const cutoffDate = new Date(now);\n          cutoffDate.setDate(cutoffDate.getDate() - DATA_RETENTION_DAYS);\n          const lastUpdate = new Date(fd.last_update_datetime);\n          if (lastUpdate < cutoffDate) continue;\n        }\n\n        // Reporting status\n        const [appStatus, evalStatus] = getReportingStatus(\n          ft,\n          fd.is_form_submitted || false,\n          fd.is_form_complete || false,\n        );\n        fd.app_status = appStatus;\n        fd.eval_status = evalStatus;\n\n        // TTC metadata\n        if (fd.form_instance_page_data?.i_ttc_country_and_dates) {\n          fd.ttc_metadata = ttcList[fd.form_instance_page_data.i_ttc_country_and_dates] || {};\n        }\n\n        // Filter data to whitelisted fields only\n        if (fd.data) {\n          const fdData: any = {};\n          for (const [q, qa] of Object.entries(fd.data)) {\n            if (q in reportingFields) {\n              let qa2 = qa;\n              const fieldSpec = reportingFields[q];\n              if (qa && typeof qa === 'object' && !Array.isArray(qa) && Array.isArray(fieldSpec)) {\n                qa2 = {};\n                for (const [tq, tqa] of Object.entries(qa as any)) {\n                  if (fieldSpec.includes(tq)) {\n                    (qa2 as any)[tq] = tqa;\n                  }\n                }\n              }\n              fdData[q] = qa2;\n            }\n          }\n          fd.data = fdData;\n        }\n\n        // Extract instance key and optional email — port of Python lines 197-209\n        let fiEmail: string | null = null;\n        let fi: string;\n        if (fiRaw.includes('-')) {\n          const fiArr = fiRaw.split('-');\n          if (!fiArr[1].includes('@')) {\n            fiEmail = fiArr[0];\n            fi = fiArr[1];\n          } else {\n            fi = fiArr[0];\n            fiEmail = fiArr[1];\n          }\n        } else {\n          fi = fiRaw;\n        }\n\n        // Store in userDataByEmail\n        if (!(ue in userDataByEmail)) userDataByEmail[ue] = {};\n        if (!(ft in userDataByEmail[ue])) {\n          userDataByEmail[ue][ft] = {};\n          userDataByEmail[ue][ft][KEY] = {};\n        }\n        if (!(fi in userDataByEmail[ue][ft])) userDataByEmail[ue][ft][fi] = {};\n\n        if (fiEmail) {\n          userDataByEmail[ue][ft][fi][fiEmail] = fd;\n        } else {\n          userDataByEmail[ue][ft][fi] = fd;\n        }\n      }\n    }\n  }\n\n  // [KEYRESET] Clear past matches — port of Python lines 226-230\n  for (const e of Object.keys(userDataByEmail)) {\n    if ('ttc_application' in userDataByEmail[e]) {\n      if (!(KEY in userDataByEmail[e]['ttc_application'])) {\n        userDataByEmail[e]['ttc_application'][KEY] = {};\n      }\n      userDataByEmail[e]['ttc_application'][KEY]['enrolled_matches'] = {};\n      userDataByEmail[e]['ttc_application'][KEY]['org_course_matches'] = {};\n    }\n  }\n\n  // Enrolled people matching (O(n²)) — port of Python lines 235-283\n  for (const c1e of Object.keys(userDataByEmail)) {\n    const c1TtcApp = userDataByEmail[c1e]['ttc_application'];\n    if (!c1TtcApp) continue;\n\n    for (const c1fi of Object.keys(c1TtcApp)) {\n      if (c1fi === 'default') continue;\n\n      const c1 = c1TtcApp[c1fi];\n      const c1d = c1?.data || {};\n\n      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n      const c1n = c1fn + ' ' + c1ln;\n\n      for (const c2e of Object.keys(userDataByEmail)) {\n        if (c1e === c2e) continue;\n\n        const c2TtcApp = userDataByEmail[c2e]['ttc_application'];\n        if (!c2TtcApp) continue;\n\n        for (const c2fi of Object.keys(c2TtcApp)) {\n          const c2 = c2TtcApp[c2fi];\n          const c2d = c2?.data || {};\n\n          const c2fn = (c2d.i_fname || '').trim().toLowerCase();\n          const c2ln = (c2d.i_lname || '').trim().toLowerCase();\n          const c2n = c2fn + ' ' + c2ln;\n\n          if (c1n === c2n) continue;\n\n          // Enrolled people matching\n          const c1Enrolled = c1d.i_enrolled_people;\n          const c2Enrolled = c2d.i_enrolled_people;\n\n          if (Array.isArray(c1Enrolled) && Array.isArray(c2Enrolled)) {\n            for (const c1en of c1Enrolled) {\n              for (const c2en of c2Enrolled) {\n                let isMatched = false;\n                const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n                const ee2 = (c2en.i_enrollment_email || '').trim().toLowerCase();\n                const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n                const en2 = (c2en.i_enrollment_name || '').trim().toLowerCase();\n                const ec1 = (c1en.i_enrollment_city || '').trim().toLowerCase();\n                const ec2 = (c2en.i_enrollment_city || '').trim().toLowerCase();\n                const es1 = (c1en.i_enrollment_state || '').trim().toLowerCase();\n                const es2 = (c2en.i_enrollment_state || '').trim().toLowerCase();\n\n                if (ee1.includes('@') && ee1 === ee2) isMatched = true;\n                if (en1 === en2 && ec1 === ec2 && es1 === es2) isMatched = true;\n\n                if (isMatched) {\n                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n                  }\n                  if (!('enrolled_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n                    userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'] = {};\n                  }\n                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['enrolled_matches'];\n                  if (!(c2e in matches)) {\n                    matches[c2e] = new Set<string>();\n                  }\n                  matches[c2e].add(`${en2} <${ee2}>`);\n                }\n              }\n            }\n          }\n\n          // Org course matching — port of Python lines 285-337\n          const c1OrgCourses = c1d.i_org_courses;\n          const c2OrgCourses = c2d.i_org_courses;\n\n          if (Array.isArray(c1OrgCourses) && Array.isArray(c2OrgCourses)) {\n            for (const c1oc of c1OrgCourses) {\n              const ofd1 = (c1oc.i_org_course_from_date || '').trim();\n              const otd1 = (c1oc.i_org_course_to_date || '').trim();\n              const oc1 = (c1oc.i_org_course_city || '').trim().toLowerCase();\n              const os1 = (c1oc.i_org_course_state || '').trim().toLowerCase();\n              const olt1 = (c1oc.i_org_course_leadteacher || '').trim().toLowerCase();\n\n              const re1 = olt1.match(/^[^a-z]{0,3}([a-z]+ [a-z]+)/i);\n              const oltn1 = re1 ? re1[1] : '';\n\n              for (const c2oc of c2OrgCourses) {\n                let isMatched = false;\n                const ofd2 = (c2oc.i_org_course_from_date || '').trim();\n                const otd2 = (c2oc.i_org_course_to_date || '').trim();\n                const oc2 = (c2oc.i_org_course_city || '').trim().toLowerCase();\n                const os2 = (c2oc.i_org_course_state || '').trim().toLowerCase();\n                const olt2 = (c2oc.i_org_course_leadteacher || '').trim().toLowerCase();\n\n                const re2 = olt2.match(/^[^a-z]{0,3}([a-z]+ [a-z]+)/i);\n                const oltn2 = re2 ? re2[1] : '';\n\n                if (\n                  (ofd1 === ofd2 || otd1 === otd2) &&\n                  oc1 === oc2 &&\n                  os1 === os2 &&\n                  oltn1 &&\n                  oltn2 &&\n                  (oltn1 === oltn2 || olt1.includes(oltn2) || olt2.includes(oltn1))\n                ) {\n                  isMatched = true;\n                }\n\n                if (isMatched) {\n                  if (!(KEY in userDataByEmail[c1e]['ttc_application'])) {\n                    userDataByEmail[c1e]['ttc_application'][KEY] = {};\n                  }\n                  if (!('org_course_matches' in userDataByEmail[c1e]['ttc_application'][KEY])) {\n                    userDataByEmail[c1e]['ttc_application'][KEY]['org_course_matches'] = {};\n                  }\n                  const matches = userDataByEmail[c1e]['ttc_application'][KEY]['org_course_matches'];\n                  if (!(c2e in matches)) {\n                    matches[c2e] = new Set<string>();\n                  }\n                  matches[c2e].add(`${ofd2} - ${otd2} (${oc2}, ${os2} - ${oltn2})`);\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n  }\n\n  // Convert Sets to Arrays for JSON serialization\n  convertSetsToArrays(userDataByEmail);\n\n  await writeJson(GCS_PATHS.USER_INTEGRITY_BY_USER, userDataByEmail);\n}\n\n/**\n * Port of Integrity.post_load_user_integrity() (Python lines 359-400).\n * Generates CSV of applicants and their enrolled people.\n */\nexport async function postLoadUserIntegrity(): Promise<void> {\n  let userDataByEmail: any = {};\n  try {\n    userDataByEmail = await readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n  } catch {\n    // File doesn't exist\n  }\n\n  let enrolledCSV = 'Applicant Name,Applicant Email,Enrolled Name,Enrolled Email\\n';\n\n  for (const c1e of Object.keys(userDataByEmail)) {\n    const ttcApp = userDataByEmail[c1e]['ttc_application'];\n    if (!ttcApp) continue;\n\n    for (const c1fi of Object.keys(ttcApp)) {\n      if (c1fi === 'default') continue;\n\n      const c1 = ttcApp[c1fi];\n      const c1d = c1?.data || {};\n\n      const c1fn = (c1d.i_fname || '').trim().toLowerCase();\n      const c1ln = (c1d.i_lname || '').trim().toLowerCase();\n      const c1n = c1fn + ' ' + c1ln;\n\n      enrolledCSV += `${c1n},${c1e},,\\n`;\n\n      const enrolledPeople = c1d.i_enrolled_people;\n      if (Array.isArray(enrolledPeople)) {\n        for (const c1en of enrolledPeople) {\n          const ee1 = (c1en.i_enrollment_email || '').trim().toLowerCase();\n          const en1 = (c1en.i_enrollment_name || '').trim().toLowerCase();\n          enrolledCSV += `,,${en1},${ee1}\\n`;\n        }\n      }\n    }\n  }\n\n  // Normalize unicode to ASCII — port of unicodedata.normalize('NFKD', ...).encode('ascii', 'ignore')\n  enrolledCSV = enrolledCSV.normalize('NFKD').replace(/[\\u0300-\\u036f]/g, '');\n\n  await writeText(GCS_PATHS.APPLICANT_ENROLLED_LIST, enrolledCSV);\n}\n\n/**\n * Port of Integrity.get_user_integrity_by_user() (Python lines 74-78).\n * Reads the integrity JSON from GCS.\n */\nexport async function getUserIntegrityByUser(): Promise<unknown> {\n  return readJson(GCS_PATHS.USER_INTEGRITY_BY_USER);\n}\n","numLines":367,"startLine":1,"totalLines":367}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_8fd0f504406f462dadc2ddc7","type":"tool_result","content":"1\t/**\n2\t * Port of reporting/user_summary.py — load_user_summary()\n3\t *\n4\t * Reads all user data from GCS, matches evaluations to applicants using\n5\t * Levenshtein + name decomposition, computes reporting status, and writes\n6\t * aggregated summary files.\n7\t */\n8\t\n9\timport { readJson, writeJson, listFiles, getFileMetadata, GCS_PATHS } from '../gcs';\n10\timport { getReportingStatus, getTtcList } from './reporting-utils';\n11\timport { levenshteinB } from './matching';\n12\t\n13\tconst KEY = 'reporting';\n14\tconst DATA_RETENTION_DAYS = 730;\n15\t\n16\t// Port of pyutils/utils.py str_remove_prefix\n17\tfunction strRemovePrefix(str: string, prefix: string): string {\n18\t  return str.startsWith(prefix) ? str.slice(prefix.length) : str;\n19\t}\n20\t\n21\t// UTC to Eastern timezone conversion — simplified (no DST rule replication,\n22\t// just use JS Intl for America/New_York)\n23\tfunction utcToEastern(utcStr: string): string {\n24\t  const d = new Date(utcStr + ' UTC');\n25\t  return d.toLocaleString('en-US', {\n26\t    timeZone: 'America/New_York',\n27\t    year: 'numeric', month: '2-digit', day: '2-digit',\n28\t    hour: '2-digit', minute: '2-digit', second: '2-digit',\n29\t    hour12: false,\n30\t  }).replace(/(\\d+)\\/(\\d+)\\/(\\d+),?\\s*/, '$3-$1-$2 ');\n31\t}\n32\t\n33\t// JSON serializer that converts Set to Array (port of json_dumps_set_default)\n34\tfunction jsonReplacer(_key: string, value: unknown): unknown {\n35\t  if (value instanceof Set) return Array.from(value);\n36\t  return value;\n37\t}\n38\t\n39\t// Whitelist of fields to keep in reporting output (Python lines 77-117)\n40\tconst REPORTING_FIELDS = new Set([\n41\t  'dates', 'Dates',\n42\t  'i_address_city', 'i_address_state', 'i_address_country',\n43\t  'i_cellphone', 'i_course_start', 'i_course_wishlist',\n44\t  'i_course_wishlist_artexcel', 'i_course_wishlist_hp',\n45\t  'i_course_wishlist_yes', 'i_course_wishlist_yp',\n46\t  'i_email_aol', 'i_email_other', 'i_enrollment',\n47\t  'i_fname', 'i_homephone', 'i_last1year_introtalks',\n48\t  'i_lname', 'i_name', 'i_prettc_date', 'i_prettc_location',\n49\t  'i_prettc_teacher', 'i_special_interest_groups',\n50\t  'i_ttc_country_and_dates', 'i_ttc_graduate_name',\n51\t  'i_volunteer_email', 'i_volunteer_name',\n52\t  'i_volunteer_teaching_readiness', 'i_youthteacher',\n53\t  'i_ttc_dates', 'i_ttc_location', 'i_date_of_birth',\n54\t  'i_gender', 'i_health_psychiatrist', 'i_volunteer_mental_fitness',\n55\t  'i_course_organized_count', 'i_course_assisted_count',\n56\t]);\n57\t\n58\tinterface FormInstanceData {\n59\t  data: Record<string, unknown>;\n60\t  form_instance_page_data?: Record<string, unknown>;\n61\t  form_instance?: string;\n62\t  last_update_datetime?: string;\n63\t  last_update_datetime_est?: string;\n64\t  is_form_submitted?: boolean;\n65\t  is_form_complete?: boolean;\n66\t  ttc_metadata?: Record<string, unknown>;\n67\t  email?: string;\n68\t  reporting: Record<string, unknown>;\n69\t  [key: string]: unknown;\n70\t}\n71\t\n72\ttype UserDataByEmail = Record<string, Record<string, unknown>>;\n73\t\n74\t/**\n75\t * Port of Reporting.load_user_summary()\n76\t */\n77\texport async function loadUserSummary(): Promise<void> {\n78\t  const ttcList = await getTtcList();\n79\t\n80\t  // Load existing summary (or start empty)\n81\t  let userDataByEmail: UserDataByEmail = {};\n82\t  let minUpdatedDatetime: Date | undefined;\n83\t\n84\t  try {\n85\t    const fileMeta = await getFileMetadata(GCS_PATHS.USER_SUMMARY_BY_USER);\n86\t    const fileUpdated = fileMeta.timeCreated;\n87\t    minUpdatedDatetime = new Date(fileUpdated.getTime() - 60 * 60 * 1000);\n88\t\n89\t    userDataByEmail = (await readJson(GCS_PATHS.USER_SUMMARY_BY_USER)) as UserDataByEmail;\n90\t  } catch {\n91\t    // NotFoundError — start with empty dict\n92\t    userDataByEmail = {};\n93\t    minUpdatedDatetime = undefined;\n94\t  }\n95\t\n96\t  // List user JSON files from GCS\n97\t  const userFiles = await listFiles(GCS_PATHS.USER_CONFIG_PREFIX, minUpdatedDatetime);\n98\t\n99\t  const now = new Date();\n100\t  const retentionCutoff = new Date(now.getTime() - DATA_RETENTION_DAYS * 24 * 60 * 60 * 1000);\n101\t  const retentionCutoffStr = retentionCutoff.toISOString().replace('T', ' ').slice(0, 19);\n102\t\n103\t  for (const file of userFiles) {\n104\t    if (!file.name.endsWith('.json') || file.name.includes('/summary/') || file.name.includes('/integrity/')) {\n105\t      continue;\n106\t    }\n107\t\n108\t    try {\n109\t      // Re-read the raw JSON — we need to parse form_data structure\n110\t      const raw = await readJson(file.name) as Record<string, unknown>;\n111\t      if (!raw) continue;\n112\t\n113\t      const userEmail = (raw['email'] as string) || '';\n114\t\n115\t      if (!('form_data' in raw)) continue;\n116\t      const formData = raw['form_data'] as Record<string, Record<string, FormInstanceData>>;\n117\t\n118\t      for (const ft of Object.keys(formData)) {\n119\t        for (const fiRaw of Object.keys(formData[ft])) {\n120\t          if (fiRaw === 'default') continue;\n121\t\n122\t          const fd: FormInstanceData = { ...formData[ft][fiRaw] };\n123\t          fd['form_instance'] = fiRaw;\n124\t          fd[KEY] = {};\n125\t\n126\t          // Convert last_update_datetime to Eastern\n127\t          if (fd['last_update_datetime']) {\n128\t            fd['last_update_datetime_est'] = utcToEastern(fd['last_update_datetime'] as string);\n129\t          }\n130\t\n131\t          // Skip records older than retention period\n132\t          if ((fd['last_update_datetime_est'] as string) < retentionCutoffStr) {\n133\t            continue;\n134\t          }\n135\t\n136\t          // Calculate initial reporting status\n137\t          const [appStatus, evalStatus] = getReportingStatus(\n138\t            ft,\n139\t            fd['is_form_submitted'] ?? false,\n140\t            fd['is_form_complete'] ?? false,\n141\t          );\n142\t          fd[KEY]['reporting_status'] = appStatus;\n143\t          fd[KEY]['evaluations_reporting_status'] = evalStatus;\n144\t\n145\t          // Attach TTC metadata\n146\t          if (fd['form_instance_page_data'] && 'i_ttc_country_and_dates' in fd['form_instance_page_data']) {\n147\t            const ttcKey = (fd['form_instance_page_data'] as Record<string, unknown>)['i_ttc_country_and_dates'] as string;\n148\t            fd['ttc_metadata'] = ttcList[ttcKey] || {};\n149\t          }\n150\t\n151\t          // Filter data fields to reporting whitelist + count prereqs/lists\n152\t          fd[KEY]['prereq_no_count'] = 0;\n153\t          if (fd['data']) {\n154\t            const fdData: Record<string, unknown> = {};\n155\t            for (const [q, qa] of Object.entries(fd['data'])) {\n156\t              if (REPORTING_FIELDS.has(q)) {\n157\t                fdData[q] = qa;\n158\t              }\n159\t              // Count prerequisites answered as \"no\"\n160\t              if (/^i_prereq\\d+$/.test(q) && typeof qa === 'string' && qa === 'no') {\n161\t                fd[KEY]['prereq_no_count'] = (fd[KEY]['prereq_no_count'] as number) + 1;\n162\t              }\n163\t              // Count list lengths\n164\t              if (Array.isArray(qa)) {\n165\t                fd[KEY][strRemovePrefix(q, 'i_') + '_count'] = qa.length;\n166\t              }\n167\t            }\n168\t            fd['data'] = fdData;\n169\t          }\n170\t\n171\t          // Parse form_instance key for email extraction (Python lines 223-235)\n172\t          let fiEmail: string | null = null;\n173\t          let fi: string;\n174\t          if (fiRaw.includes('-')) {\n175\t            const fiArr = fiRaw.split('-');\n176\t            if (fiArr.length >= 2 && !fiArr[1].includes('@')) {\n177\t              fiEmail = fiArr[0];\n178\t              fi = fiArr[1];\n179\t            } else {\n180\t              fi = fiArr[0];\n181\t              fiEmail = fiArr[1] || null;\n182\t            }\n183\t          } else {\n184\t            fi = fiRaw;\n185\t          }\n186\t\n187\t          // Build nested structure\n188\t          if (!(userEmail in userDataByEmail)) {\n189\t            userDataByEmail[userEmail] = {};\n190\t          }\n191\t          if (!(ft in userDataByEmail[userEmail])) {\n192\t            (userDataByEmail[userEmail] as Record<string, unknown>)[ft] = {};\n193\t            ((userDataByEmail[userEmail] as Record<string, Record<string, unknown>>)[ft] as Record<string, unknown>)[KEY] = {};\n194\t          }\n195\t          const ftData = (userDataByEmail[userEmail] as Record<string, Record<string, unknown>>)[ft] as Record<string, unknown>;\n196\t          if (!(fi in ftData)) {\n197\t            ftData[fi] = {};\n198\t          }\n199\t\n200\t          if (fiEmail) {\n201\t            (ftData[fi] as Record<string, unknown>)[fiEmail] = fd;\n202\t          } else {\n203\t            ftData[fi] = fd;\n204\t          }\n205\t        }\n206\t      }\n207\t    } catch {\n208\t      continue;\n209\t    }\n210\t  }\n211\t\n212\t  // [START KEYRESET] Clear past evaluation assignments\n213\t  for (const e of Object.keys(userDataByEmail)) {\n214\t    const userEntry = userDataByEmail[e] as Record<string, Record<string, unknown>>;\n215\t    if ('ttc_application' in userEntry) {\n216\t      const ttcApp = userEntry['ttc_application'] as Record<string, unknown>;\n217\t      const ttcAppReporting = ttcApp[KEY] as Record<string, unknown>;\n218\t      ttcAppReporting['lifetime_evaluations'] = {};\n219\t      ttcAppReporting['lifetime_eval_teaching_readiness'] = {};\n220\t      ttcAppReporting['lifetime_eval_teaching_readiness_not_ready_now_count'] = 0;\n221\t      ttcAppReporting['lifetime_evaluator_ratings_below_3'] = 0;\n222\t      ttcAppReporting['lifetime_evaluations_submitted_count'] = 0;\n223\t      ttcAppReporting['lifetime_latest_evaluation_datetime_est'] = '';\n224\t\n225\t      for (const fi of Object.keys(ttcApp)) {\n226\t        const fiData = ttcApp[fi] as Record<string, unknown>;\n227\t        if (fi !== KEY && KEY in fiData) {\n228\t          const fiReporting = fiData[KEY] as Record<string, unknown>;\n229\t          fiReporting['evaluations'] = {};\n230\t          fiReporting['eval_teaching_readiness'] = {};\n231\t          fiReporting['eval_teaching_readiness_not_ready_now_count'] = 0;\n232\t          fiReporting['evaluator_ratings_below_3'] = 0;\n233\t          fiReporting['evaluations_submitted_count'] = 0;\n234\t          fiReporting['latest_evaluation_datetime_est'] = '';\n235\t        }\n236\t      }\n237\t    }\n238\t\n239\t    for (const fi of Object.keys(userEntry['ttc_evaluation'] || {})) {\n240\t      const ttcEval = (userEntry['ttc_evaluation'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n241\t      for (const ve of Object.keys(ttcEval)) {\n242\t        const veReporting = (ttcEval[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n243\t        veReporting['lifetime_reporting_matched_ttc_list'] = new Set<string>();\n244\t        veReporting['is_reporting_matched'] = 'N';\n245\t      }\n246\t    }\n247\t\n248\t    if ('post_ttc_self_evaluation_form' in userEntry) {\n249\t      const selfEval = userEntry['post_ttc_self_evaluation_form'] as Record<string, unknown>;\n250\t      const selfEvalReporting = selfEval[KEY] as Record<string, unknown>;\n251\t      selfEvalReporting['evaluations'] = {};\n252\t      selfEvalReporting['evaluations_submitted_count'] = 0;\n253\t      selfEvalReporting['latest_evaluation_datetime_est'] = '';\n254\t    }\n255\t\n256\t    for (const fi of Object.keys(userEntry['post_ttc_feedback_form'] || {})) {\n257\t      const feedback = (userEntry['post_ttc_feedback_form'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n258\t      for (const ve of Object.keys(feedback)) {\n259\t        const veReporting = (feedback[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n260\t        veReporting['is_reporting_matched'] = 'N';\n261\t      }\n262\t    }\n263\t\n264\t    if ('post_sahaj_ttc_self_evaluation_form' in userEntry) {\n265\t      const selfEval = userEntry['post_sahaj_ttc_self_evaluation_form'] as Record<string, unknown>;\n266\t      const selfEvalReporting = selfEval[KEY] as Record<string, unknown>;\n267\t      selfEvalReporting['evaluations'] = {};\n268\t      selfEvalReporting['evaluations_submitted_count'] = 0;\n269\t      selfEvalReporting['latest_evaluation_datetime_est'] = '';\n270\t    }\n271\t\n272\t    for (const fi of Object.keys(userEntry['post_sahaj_ttc_feedback_form'] || {})) {\n273\t      const feedback = (userEntry['post_sahaj_ttc_feedback_form'] as Record<string, Record<string, unknown>>)[fi] as Record<string, unknown>;\n274\t      for (const ve of Object.keys(feedback)) {\n275\t        const veReporting = (feedback[ve] as Record<string, unknown>)[KEY] as Record<string, unknown>;\n276\t        veReporting['is_reporting_matched'] = 'N';\n277\t      }\n278\t    }\n279\t  }\n280\t  // [END KEYRESET]\n281\t\n282\t  // [START] Evaluation matching — O(n^2) loop\n283\t  for (const t of Object.keys(userDataByEmail)) {\n284\t    const userT = userDataByEmail[t] as Record<string, Record<string, unknown>>;\n285\t\n286\t    for (const fi of Object.keys(userT['ttc_evaluation'] || {})) {\n287\t      if (fi === 'default') continue;\n288\t      const ttcEvalFi = (userT['ttc_evaluation'] as Record<string, unknown>)[fi] as Record<string, unknown>;\n289\t\n290\t      for (const ve of Object.keys(ttcEvalFi)) {\n291\t        const e = ttcEvalFi[ve] as Record<string, unknown>;\n292\t        e['email'] = t;\n293\t        const ed = { ...(e['data'] as Record<string, unknown> || {}), ...(e['form_instance_page_data'] as Record<string, unknown> || {}) };\n294\t        const vn = String(ed['i_volunteer_name'] || '').trim().toLowerCase();\n295\t        const tn = String(ed['i_name'] || '').trim();\n296\t        (e[KEY] as Record<string, unknown>)['is_reporting_matched'] = 'N';\n297\t\n298\t        for (const c of Object.keys(userDataByEmail)) {\n299\t          const userC = userDataByEmail[c] as Record<string, Record<string, unknown>>;\n300\t          if (!('ttc_application' in userC)) continue;\n301\t          const ttcAppC = userC['ttc_application'] as Record<string, unknown>;\n302\t\n303\t          for (const afi of Object.keys(ttcAppC)) {\n304\t            if (afi === KEY) continue;\n305\t            const a = ttcAppC[afi] as Record<string, unknown>;\n306\t            const ad = (a['data'] as Record<string, unknown>) || {};\n307\t            const afn = String(ad['i_fname'] || '').trim().toLowerCase();\n308\t            const aln = String(ad['i_lname'] || '').trim().toLowerCase();\n309\t\n310\t            // Name decomposition\n311\t            const afnArr = afn.split(/\\s+/);\n312\t            let afn2 = '', afn3 = '', aln2 = '';\n313\t            if (afn && afnArr.length > 1) {\n314\t              afn2 = afnArr[0].replace(/[^a-zA-Z0-9]/g, '');\n315\t              afn3 = afnArr[1].replace(/[^a-zA-Z0-9]/g, '');\n316\t              aln2 = aln.split(/\\s+/).pop() || '';\n317\t            }\n318\t\n319\t            const alnArr = aln.split(/\\s+/);\n320\t            let aln4 = '', aln5 = '';\n321\t            if (aln && alnArr.length > 1) {\n322\t              aln4 = alnArr[0].replace(/[^a-zA-Z0-9]/g, '');\n323\t              aln5 = alnArr[1].replace(/[^a-zA-Z0-9]/g, '');\n324\t            }\n325\t\n326\t            // Determine comparison names based on volunteer name word count\n327\t            let an: string, an2: string, an3: string, an4: string, an5: string;\n328\t            if (vn.split(/\\s+/).length === 1 && ve.includes('@')) {\n329\t              an = afn;\n330\t              an2 = afn2;\n331\t              an3 = afn3;\n332\t              an4 = '';\n333\t              an5 = '';\n334\t            } else {\n335\t              an = afn + '