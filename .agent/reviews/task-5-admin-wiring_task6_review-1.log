}));\n188\t              }\n189\t              $('#' + _id).val('summary').change();\n190\t            }\n191\t          } else {\n192\t            if (_id in _form_data) {\n193\t              $(this).val(_form_data[_id]);\n194\t            }\n195\t          }\n196\t        }\n197\t      });\n198\t      enableInputs();\n199\t      postDoneMessage(\"Your settings have been retrieved\");\n200\t    })\n201\t    .fail(function() {\n202\t      postErrorMessage(\"There was an error retrieving your settings. Please refresh the page.\");\n203\t    });\n204\t}\n205\t\n206\t$(document).ready(function() {\n207\t  loadSettings();\n208\t  initializeRequiredFields();\n209\t\n210\t  for (var id in repeat_question_list) {\n211\t    $('#' + id).on('change', function() {\n212\t      var _id = $(this).attr('id');\n213\t      var _val = $(this).val();\n214\t      if (_val !== 'new_entry') {\n215\t        $(\"#\" + _id + \" option[value='new_entry']\").remove();\n216\t        var input_list = repeat_question_list[_id];\n217\t        for (var i = 0; i < input_list.length; i++) {\n218\t          $(\"label[for='\" + input_list[i] + \"']\").hide();\n219\t          $('#' + input_list[i]).hide();\n220\t          $('div[name=' + input_list[i] + ']').hide();\n221\t          $('label[name=' + input_list[i] + ']').hide();\n222\t        }\n223\t        $('#' + _id + '_save').hide();\n224\t      }\n225\t      if (_val === 'summary') {\n226\t        var _num = $(\"#\" + _id + \" option[value!='summary']\").length;\n227\t        $('#' + _id + '_count').html(_num);\n228\t        $(\"#\" + _id + \" option[value='summary']\").text(_num + ' added');\n229\t      }\n230\t    });\n231\t    $('#' + id).change();\n232\t  }\n233\t});\n234\t</script>`;\n235\t\n236\t  return `${SETTINGS_CSS}\n237\t<div class=\"max-w-7xl mx-auto p-6 space-y-6\">\n238\t  <div>\n239\t    <h1 class=\"text-2xl font-light text-gray-800\">Admin Settings</h1>\n240\t    <div class=\"text-sm text-gray-700 mt-1\">\n241\t      ${ADMIN_SETTI