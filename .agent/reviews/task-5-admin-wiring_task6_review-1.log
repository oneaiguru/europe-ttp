          if (Object.hasOwnProperty.call(_applicant['${escapedKey}']['org_course_matches'], _me2)) {\n83\t                  var _mee2 = _applicant['${escapedKey}']['org_course_matches'][_me2];\n84\t                  if (Array.isArray(_mee2)) org_course_matches_count += _mee2.length;\n85\t                }\n86\t              }\n87\t            }\n88\t            if (enrolled_matches_count > 0 || org_course_matches_count > 0) {\n89\t              var enrolled_people_count = Object.keys(_application['data']['i_enrolled_people'] || {}).length;\n90\t              var org_courses_count = Object.keys(_application['data']['i_org_courses'] || {}).length;\n91\t              applicant_data.push({\n92\t                name: _name, email: _ae,\n93\t                last_update_datetime: _application['last_update_datetime_est'],\n94\t                enrolled_matches_count: enrolled_matches_count + ' / ' + enrolled_people_count,\n95\t                org_course_matches_count: org_course_matches_count + ' / ' + org_courses_count,\n96\t                enrolled_matches: _applicant['${escapedKey}']['enrolled_matches'],\n97\t                org_course_matches: _applicant['${escapedKey}']['org_course_matches'],\n98\t                form_instance: _application['form_instance']\n99\t              });\n100\t            }\n101\t          }\n102\t        }\n103\t      });\n104\t    }\n105\t  }\n106\t  return applicant_data;\n107\t}\n108\t\n109\tfunction load_table_data() {\n110\t  var applicant_data = get_table_data();\n111\t  if (table) {\n112\t    table.clear();\n113\t    table.rows.add(applicant_data);\n114\t    table.draw();\n115\t  } else {\n116\t    table = $('#${INTEGRITY_TABLE_ID}').DataTable({\n117\t      data: applicant_data,\n118\t      orderCellsTop: true,\n119\t      scrollX: true,\n120\t      iDisplayLength: 50,\n121\t      dom: 'Bfrtlip',\n122\t      buttons: ${EXPORT_BUTTONS_JS},\n123\t      columns: [\n124\t        {className:'details-control', orderable:false, data:null, defaultContent:''},\n125\t        {data:'name'}, {data:'email'}, {data:'last_update_datetime'},\n126\t        {data:'enrolled_matches_count'}, {data:'org_course_matches_count'}\n127\t      ],\n128\t      order: [[1,'asc']]\n129\t    });"}]},"parent_tool_use_id":"call_6f50ddaa1a5047ae89d90e70","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"ece7c293-f6d9-49d8-a8af-6448ffdd6490","timestamp":"2026-04-06T14:51:15.703Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_e23fca17117e48f4af81a32f","type":"tool_result","content":"1\timport { BUTTON_CSS } from '../shared/datatables-helpers';\n2\t\n3\texport const ADMIN_SETTINGS_TITLE = 'Admin Settings';\n4\texport const ADMIN_SETTINGS_HELPER = 'Please enter settings for TTC portal';\n5\texport const ADMIN_SETTINGS_CONTAINER_ID = 'settings_page';\n6\t\n7\tconst SETTINGS_CSS = `\n8\t<style>\n9\t  ${BUTTON_CSS}\n10\t  .label_required { font-weight: 400; }\n11\t  .label_required::after { content: ' *'; color: #c62828; }\n12\t</style>`;\n13\t\n14\texport function renderAdminSettings(): string {\n15\t  const appScript = `\n16\t<script type=\"text/javascript\">\n17\tvar repeat_question_list = {\n18\t  \"i_whitelisted_user\": [\"i_whitelisted_user_name\", \"i_whitelisted_user_email\"]\n19\t};\n20\tvar REPEATER_DISPLAY_INPUT_CNT = 2;\n21\t\n22\tfunction postErrorMessage(msg) {\n23\t  var el = document.getElementById('step_post_submit_message');\n24\t  if (el) el.innerHTML = '<div class=\"text-red-600 text-sm py-2.5 px-2.5\">' + msg + '</div>';\n25\t}\n26\t\n27\tfunction postDoneMessage(msg) {\n28\t  var el = document.getElementById('step_post_submit_message');\n29\t  if (el) el.innerHTML = '<div class=\"text-green-600 text-sm py-2.5 px-2.5\">' + msg + '</div>';\n30\t}\n31\t\n32\tfunction hideLoadingIndicator() {}\n33\t\n34\tfunction checkFieldsNonEmpty(fields) {\n35\t  for (var i = 0; i < fields.length; i++) {\n36\t    var val = $('#' + fields[i]).val();\n37\t    if (!val || val.trim() === '') return false;\n38\t  }\n39\t  return true;\n40\t}\n41\t\n42\tfunction initializeRequiredFields() {}\n43\t\n44\tfunction disableInputs(is_recoverable) {\n45\t  $(\"input[id^=i_],textarea[id^=i_],select[id^=i_]\").prop(\"disabled\", true);\n46\t  if (!is_recoverable) {\n47\t    $('input[name=btns_save_submit]').remove();\n48\t    $('#step_submit').show();\n49\t  } else {\n50\t    $('#step_submit').hide();"}]},"parent_tool_use_id":"call_6f50ddaa1a5047ae89d90e70","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"c3524525-1dc4-449f-abdf-b6006b4b6cbe","timestamp":"2026-04-06T14:51:15.706Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_4a261467585848fd875d563e","type":"tool_result","content":"75\t  if (_selected_ttcs.length > 1) {\n76\t    document.getElementById('show_lifetime_yes').checked = true;\n77\t  }\n78\t  var applicant_data = [];\n79\t  var _unmapped_evaluations = [];\n80\t\n81\t  _selected_ttcs.forEach(function(_selected_ttc) {\n82\t    if (applicant_summary.hasOwnProperty('ttc_application') &&\n83\t        applicant_summary['ttc_application'].hasOwnProperty(_selected_ttc)) {\n84\t      var _applications = applicant_summary['ttc_application'][_selected_ttc];\n85\t      for (var _ae in _applications) {\n86\t        if (_applications.hasOwnProperty(_ae)) {\n87\t          var _application = _applications[_ae];\n88\t          if ('data' in _application) {\n89\t            if (!_application.hasOwnProperty('evaluations')) _application['evaluations'] = [];\n90\t            if (!_application.hasOwnProperty('lifetime_evaluations')) _application['lifetime_evaluations'] = [];\n91\t            var _name = _application['data']['i_fname'] + ' ' + _application['data']['i_lname'];\n92\t            applicant_data.push({\n93\t              name: _name, email: _ae,\n94\t              cellphone: _application['data']['i_cellphone'],\n95\t              homephone: _application['data']['i_homephone'],\n96\t              city: _application['data']['i_address_city'],\n97\t              state: _application['data']['i_address_state'],\n98\t              status: _application['reporting_status'] || '',\n99\t              evals_status: _application['evaluations_reporting_status'] || '',\n100\t              evals: _application['evaluations'].length,\n101\t              lifetime_evals: _application['lifetime_evaluations'].length,\n102\t              last_update_datetime: _application['last_update_datetime_est'],\n103\t              evaluations: _application['evaluations'],\n104\t              lifetime_evaluations: _application['lifetime_evaluations'],\n105\t              form_instance: _application['form_instance']\n106\t            });\n107\t          }\n108\t        }\n109\t      }\n110\t\n111\t      if (applicant_summary.hasOwnProperty('ttc_evaluation') &&\n112\t          applicant_summary['ttc_evaluation'].hasOwnProperty(_selected_ttc)) {\n113\t        var _evaluators = applicant_summary['ttc_evaluation'][_selected_ttc];\n114\t        for (var _te in _evaluators) {\n115\t          if (_evaluators.hasOwnProperty(_te)) {\n116\t            var _evaluations = _evaluators[_te];\n117\t            for (var _ve in _evaluations) {\n118\t              var _evaluation = _evaluations[_ve];\n119\t              if ('data' in _evaluation && 'is_reporting_matched' in _evaluation && _evaluation['is_reporting_matched'] == 'N') {\n120\t                var _matched_ttc_list = _evaluation['lifetime_reporting_matched_ttc_list'];\n121\t                if (_matched_ttc_list !== undefined) {\n122\t                  _matched_ttc_list = _matched_ttc_list.filter(function(n) { return _selected_ttcs.indexOf(n) !== -1; });\n123\t                }\n124\t                if (!_matched_ttc_list || _matched_ttc_list.length == 0) {\n125\t                  _unmapped_evaluations.push(_evaluation);\n126\t                }\n127\t              }\n128\t            }\n129\t          }\n130\t        }\n131\t      }\n132\t    }\n133\t  });\n134\t\n135\t  if (_unmapped_evaluations.length > 0) {\n136\t    applicant_data.push({\n137\t      name: 'UNMAPPED EVALUATIONS', email: '', cellphone: '', homephone: '',\n138\t      city: '', state: '', status: '', evals_status: '',\n139\t      evals: _unmapped_evaluations.length, lifetime_evals: '',\n140\t      last_update_datetime: '', evaluations: _unmapped_evaluations,\n141\t      lifetime_evaluations: [], form_instance: ''\n142\t    });\n143\t  }\n144\t  return applicant_data;\n145\t}\n146\t\n147\tfunction load_table_data() {\n148\t  var applicant_data = get_table_data();\n149\t  if (table) {"}]},"parent_tool_