r user_data = undefined;\n47\tvar table = undefined;\n48\tvar forms = {};\n49\tvar count_lo = 0;\n50\tvar count_hi = 100;\n51\t\n52\t${STATUS_COLOR_JS}\n53\t\n54\t${FULLSCREEN_MESSAGE_JS}\n55\t\n56\t${ERROR_MESSAGE_JS}\n57\t\n58\tfunction isEmpty(v) { return v === undefined || v === null || v === ''; }\n59\t\n60\tfunction dict2bullets(d) {\n61\t  if (!d || typeof d !== 'object') return '';\n62\t  var items = [];\n63\t  for (var k in d) {\n64\t    if (d.hasOwnProperty(k)) items.push(k + ': ' + d[k]);\n65\t  }\n66\t  return items.length > 0 ? '<ul class=\"mt-0 pl-4\"><li>' + items.join('</li><li>') + '</li></ul>' : '';\n67\t}\n68\t\n69\tfunction array2bullets(arr) {\n70\t  if (!arr || !Array.isArray(arr) || arr.length === 0) return '';\n71\t  return '<ul class=\"mt-0 pl-4\"><li>' + arr.join('</li><li>') + '</li></ul>';\n72\t}\n73\t\n74\tfunction calculateAge(dob) {\n75\t  if (!dob) return '';\n76\t  var d = new Date(dob);\n77\t  if (isNaN(d.getTime())) return '';\n78\t  var today = new Date();\n79\t  var age = today.getFullYear() - d.getFullYear();\n80\t  var m = today.getMonth() - d.getMonth();\n81\t  if (m < 0 || (m === 0 && today.getDate() < d.getDate())) age--;\n82\t  return age;\n83\t}\n84\t\n85\tfunction getShowHideHTML(data, idx, maxLen, showLabel, hideLabel, startCollapsed) {\n86\t  if (!data || typeof data !== 'string' || !maxLen) return data || '';\n87\t  if (data.length <= maxLen) return data;\n88\t  showLabel = showLabel || '[+]';\n89\t  hideLabel = hideLabel || '[-]';\n90\t  var short = data.substring(0, maxLen);\n91\t  if (startCollapsed) {\n92\t    return '<span id=\"short' + idx + '\">' + short + ' <a onclick=\"document.getElementById(\\\\'short' + idx + '\\\\').classList.add(\\\\'hidden\\\\');document.getElementById(\\\\'full' + idx + '\\\\').classList.remove(\\\\'hidden\\\\');\">' + showLabel + '</a></span>' +\n93\t      '<span id=\"full' + idx + '\" class=\"hidden\">' + data + ' <a onclick=\"document.getElementById(\\\\'full' + idx + '\\\\').classList.add(\\\\'hidden\\\\');document.getElementById(\\\\'short' + idx + '\\\\').classList.remove(\\\\'hidden\\\\');\">' + hideLabel + '</a></span>';\n94\t  }\n95\t  return data;\n96\t}\n97\t\n98\tfunction hideAllChildren(tr) {}\n99\tfunction showAllChildren(tr) {}\n100\t"}]},"parent_tool_use_id":null,"session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"1dbac934-9687-4704-9f45-8399e118bdfe","timestamp":"2026-04-06T14:57:14.762Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/admin/ttc_applicants_reports/render.ts","content":"import { escapeHtml, escapeHtmlAttr } from '../../utils/html';\nimport {\n  BUTTON_CSS,\n  DATATABLE_CSS,\n  DETAILS_CONTROL_CSS,\n  ERROR_MESSAGE_JS,\n  EXPORT_BUTTONS_JS,\n  FULLSCREEN_MESSAGE_JS,\n  STATUS_COLOR_JS,\n} from '../shared/datatables-helpers';\n\nexport const REPORTS_TITLE = 'Admin: TTC Report';\nexport const REPORTS_TABLE_ID = 'ttc_applicants_summary';\n\nexport type ReportsRenderOptions = {\n  reportingKey: string;\n  ttcCountryAndDates: string;\n  ttcListHtml: string;\n  userSummaryLastUpdatedDatetime: string;\n  userIntegrityLastUpdatedDatetime: string;\n};\n\nexport const REPORTS_EXTRA_HEAD_CSS = `<link rel=\"stylesheet\" href=\"https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css\">`;\nexport const REPORTS_EXTRA_CDN_JS = `<script src=\"https://code.jquery.com/ui/1.13.2/jquery-ui.min.js\"></script>`;\n\nexport function renderReports(options: ReportsRenderOptions): string {\n  const { reportingKey, ttcCountryAndDates, ttcListHtml, userSummaryLastUpdatedDatetime, userIntegrityLastUpdatedDatetime } = options;\n  const rk = escapeHtml(reportingKey);\n\n  const pageStyles = `\n<style>\n  ${DETAILS_CONTROL_CSS}\n  ${DATATABLE_CSS}\n  ${BUTTON_CSS}\n  table.dataTable td, .dataTables_wrapper .dataTables_scroll div.dataTables_scrollBody>table>thead>tr>td,\n  .dataTables_wrapper .dataTables_scroll div.dataTables_scrollBody>table>tbody>tr>td {\n    vertical-align: top;\n  }\n  .table_column_search_textbox { width: 100%; box-sizing: border-box; }\n  .display_only_text { border: none; background: transparent; font-size: 13px; }\n</style>`;\n\n  const appScript = `\n<script type=\"text/javascript\">\nvar ttc_country_and_dates = ${ttcCountryAndDates};\nvar user_data = undefined;\nvar table = undefined;\nvar forms = {};\nvar count_lo = 0;\nvar count_hi = 100;\n\n${STATUS_COLOR_JS}\n\n${FULLSCREEN_MESSAGE_JS}\n\n${ERROR_MESSAGE_JS}\n\nfunction isEmpty(v) { return v === undefined || v === null || v === ''; }\n\nfunction dict2bullets(d) {\n  if (!d || typeof d !== 'object') return '';\n  var items = [];\n  for (var k in d) {\n    if (d.hasOwnProperty(k)) items.push(k + ': ' + d[k]);\n  }\n  return items.length > 0 ? '<ul class=\"mt-0 pl-4\"><li>' + items.join('</li><li>') + '</li></ul>' : '';\n}\n\nfunction array2bullets(arr) {\n  if (!arr || !Array.isArray(arr) || arr.length === 0) return '';\n  return '<ul class=\"mt-0 pl-4\"><li>' + arr.join('</li><li>') + '</li></ul>';\n}\n\nfunction calculateAge(dob) {\n  if (!dob) return '';\n  var d = new Date(dob);\n  if (isNaN(d.getTime())) return '';\n  var today = new Date();\n  var age = today.getFullYear() - d.getFullYear();\n  var m = today.getMonth() - d.getMonth();\n  if (m < 0 || (m === 0 && today.getDate() < d.getDate())) age--;\n  return age;\n}\n\nfunction getShowHideHTML(data, idx, maxLen, showLabel, hideLabel, startCollapsed) {\n  if (!data || typeof data !== 'string' || !maxLen) return data || '';\n  if (data.length <= maxLen) return data;\n  showLabel = showLabel || '[+]';\n  hideLabel = hideLabel || '[-]';\n  var short = data.substring(0, maxLen);\n  if (startCollapsed) {\n    return '<span id=\"short' + idx + '\">' + short + ' <a onclick=\"document.getElementById(\\\\'short' + idx + '\\\\').classList.add(\\\\'hidden\\\\');document.getElementById(\\\\'full' + idx + '\\\\').classList.remove(\\\\'hidden\\\\');\">' + showLabel + '</a></span>' +\n      '<span id=\"full' + idx + '\" class=\"hidden\">' + data + ' <a onclick=\"document.getElementById(\\\\'full' + idx + '\\\\').classList.add(\\\\'hidden\\\\');document.getElementById(\\\\'short' + idx + '\\\\').classList.remove(\\\\'hidden\\\\');\">' + hideLabel + '</a></span>';\n  }\n  return data;\n}\n\nfunction hideAllChildren(tr) {}\nfunction showAllChildren(tr) {}\n","numLines":100,"startLine":1,"totalLines":651}}}
