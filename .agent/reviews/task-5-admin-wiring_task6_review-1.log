_days'},\n364\t        {data:'prettc_location'}, {data:'youthteacher'},\n365\t        {data:'course_wishlist'}, {data:'special_interest_groups'}\n366\t      ],\n367\t      columnDefs: [\n368\t        { render: function(data) { return data; }, targets: [0,1,2,3,4,5,6] },\n369\t        {\n370\t          render: function(data, type, row, meta) {\n371\t            var idx = '-' + meta.row + '-' + meta.col;\n372\t            var _view_mode = $('input[name=view_mode]:checked');\n373\t        var _content;\n374\t        if (_view_mode.val() === 'c') {\n375\t          _content = getShowHideHTML(data, idx, 19, '[+]', '[-]', true);\n376\t        } else {\n377\t          _content = getShowHideHTML(data, idx);\n378\t        }\n379\t        return \"<div class='whitespace-normal max-w-[200px]'>\" + _content + \"</div>\";\n380\t      },\n381\t      targets: '_all'\n382\t    }\n383\t      ],\n384\t      order: [[1,'asc']],\n385\t      rowCallback: function(row, data) {\n386\t        $(row).find('td:eq(3)').css('color', getStatusColor(data.status));\n387\t      },\n388\t      footerCallback: function(tfoot) {\n389\t        var api = this.api();\n390\t        var submitted = api.column(3).data().reduce(function(a, b) {\n391\t          if (b === 'submitted' || b === 'complete') a += 1;\n392\t          return a;\n393\t        }, 0);\n394\t        $(tfoot).find('th:eq(1)').html('Total Submitted Applications: ' + submitted);\n395\t      }\n396\t    });\n397\t\n398\t    $('#${REPORTS_TABLE_ID} tbody').on('click', 'td.details-control', function() {\n399\t      var tr = $(this).closest('tr');\n400\t      var row = table.row(tr);\n401\t      if (row.child.isShown()) {\n402\t        row.child.hide();\n403\t        tr.removeClass('shown');\n404\t      } else {"}]},"parent_tool_use_id":"call_6f50ddaa1a5047ae89d90e70","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"39d89489-d6a6-4f1c-bd5c-bae6c6c60ee7","timestamp":"2026-04-06T14:51:44.718Z"}
