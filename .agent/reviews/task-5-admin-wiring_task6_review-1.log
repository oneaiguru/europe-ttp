{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_cc92602ffcd34f19ab04db47","type":"tool_result","content":"40\t\n41\t    def set_admin_config(self, config_params):\n42\t        _config = self.get_raw_admin_config()\n43\t        logging.info('[set_admin_config] config_params = ' + json.dumps(config_params))\n44\t        _config.update({'raw_config': config_params})\n45\t\n46\t        # [START] whitelisted_user_emails\n47\t        if 'whitelisted_user_emails' not in _config:\n48\t            _config['whitelisted_user_emails'] = []\n49\t        if 'i_whitelisted_user' in config_params:\n50\t            if isinstance(config_params['i_whitelisted_user'], list):\n51\t                for _whitelisted_user in config_params['i_whitelisted_user']:\n52\t                    if 'i_whitelisted_user_email' in _whitelisted_user:\n53\t                        _config['whitelisted_user_emails'].append(_whitelisted_user['i_whitelisted_user_email'].strip().lower())\n54\t        # [END] whitelisted_user_emails\n55\t\n56\t        try:\n57\t            write_retry_params = gcs.RetryParams(backoff_factor=1.1)\n58\t            _f = gcs.open(\n59\t                constants.ADMIN_CONFIG_FILE,\n60\t                'w',\n61\t                content_type='text/plain',\n62\t                options={'x-goog-meta-foo': 'foo',\n63\t                'x-goog-meta-bar': 'bar'},\n64\t                retry_params=write_retry_params\n65\t            )\n66\t            _f.write(json.dumps(_config))\n67\t            _f.close()\n68\t        except gcs.Error:\n69\t            logging.error('[set_admin_config] Failed to save the system config')\n70\t\n71\t    def get_raw_admin_config(self):\n72\t        _config = {}\n73\t        try:\n74\t            _f = gcs.open(constants.ADMIN_CONFIG_FILE)\n75\t            _config = json.loads(_f.read())\n76\t            logging.info('[get_raw_admin_config] config_params = ' + json.dumps(_config))\n77\t            _f.close()\n78\t        except gcs.NotFoundError:\n79\t            logging.error('[get_raw_admin_config] Failed to load the system config')\n80\t        return _config.get('raw_config', {})\n81\t\n82\t    def get_ttc_list_html(self):\n83\t        if not self.ttc_list_html:\n84\t            options_html = \"\"\n85\t\n86\t            source_file = constants.FORM_CONFIG_LOCATION + 'ttc_country_and_dates.json'\n87\t\n88\t            user = users.get_current_user()\n89\t            if not self.user_home_country and user:"}]},"parent_tool_use_id":"call_d41afa825e354789b2412e53","session_id":"42310003-5b42-4a27-b087-b2860cdc53e2","uuid":"19d00545-62e1-499c-8f57-bbde2b02e469","timestamp":"2026-04-06T14:51:25.876Z"}
