{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_60cff1a85f874e129f602def","type":"tool_result","content":"1\t/**\n2\t * Cryptographic utilities for secure token generation and verification.\n3\t * Provides HMAC-signed tokens to prevent forgery and information leakage.\n4\t */\n5\t\n6\timport { createHmac, timingSafeEqual } from 'crypto';\n7\t\n8\t/**\n9\t * Clock skew tolerance for token timestamp validation.\n10\t *\n11\t * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n12\t * extended validity from crafted future timestamps or clock skew.\n13\t *\n14\t * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n15\t *\n16\t * @see CLOCK_SKEW_TOLERANCE in auth.ts - should match across token types\n17\t */\n18\texport const CLOCK_SKEW_TOLERANCE = 300;\n19\t\n20\t/**"}]},"parent_tool_use_id":null,"session_id":"7ccb479f-aaae-4fab-ac1e-d4455c698fb3","uuid":"b6236c73-158c-47c1-acc4-31d15577918e","timestamp":"2026-04-06T09:51:25.172Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/crypto.ts","content":"/**\n * Cryptographic utilities for secure token generation and verification.\n * Provides HMAC-signed tokens to prevent forgery and information leakage.\n */\n\nimport { createHmac, timingSafeEqual } from 'crypto';\n\n/**\n * Clock skew tolerance for token timestamp validation.\n *\n * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n * extended validity from crafted future timestamps or clock skew.\n *\n * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n *\n * @see CLOCK_SKEW_TOLERANCE in auth.ts - should match across token types\n */\nexport const CLOCK_SKEW_TOLERANCE = 300;\n\n/**","numLines":20,"startLine":1,"totalLines":269}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_7e7a21bb1ccf40ee8dfe35d2","type":"tool_result","content":"1\t/**\n2\t * Authentication utilities for API routes.\n3\t *\n4\t * Provides environment-gated authentication to support both:\n5\t * - Platform mode: Trust x-user-email header (App Engine with IAP)\n6\t * - Session mode: Validate bearer token with HMAC signature (standalone)\n7\t */\n8\t\n9\timport { createHmac, randomBytes, timingSafeEqual } from 'crypto';\n10\timport { importSPKI, jwtVerify, type KeyLike } from 'jose';\n11\timport { getSessionHmacSecret } from './crypto';\n12\t\n13\t/**\n14\t * Supported authentication modes.\n15\t */\n16\texport type AuthMode = 'platform' | 'session';\n17\t\n18\tconst EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n19\tconst DEFAULT_IAP_ISSUER = 'https://cloud.google.com/iap';\n20\t\n21\t/**\n22\t * Clock skew tolerance for token timestamp validation.\n23\t *\n24\t * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n25\t * extended validity from crafted future timestamps or clock skew.\n26\t *\n27\t * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n28\t */\n29\texport const CLOCK_SKEW_TOLERANCE = 300;\n30\t\n31\tlet cachedIapPublicKey: KeyLike | null = null;\n32\tlet cachedIapPublicKeyPem: string | null = null;\n33\tlet iapPublicKeyPromise: Promise<KeyLike | null> | null = null;\n34\tlet iapPublicKeyPromisePem: string | null = null;\n35\t\n36\tfunction isValidEmail(email: string): boolean {\n37\t  return EMAIL_REGEX.test(email);\n38\t}\n39\t\n40\tasync function getIapPublicKey(): Promise<KeyLike | null> {\n41\t  const publicKey = process.env.IAP_JWT_PUBLIC_KEY;\n42\t  if (!publicKey) {\n43\t    return null;\n44\t  }\n45\t\n46\t  if (cachedIapPublicKey && cachedIapPublicKeyPem === publicKey) {\n47\t    return cachedIapPublicKey;\n48\t  }\n49\t\n50\t  // If already fetching for the same PEM, return the existing promise to deduplicate concurrent calls\n51\t  // If PEM changed, discard old promise and start fresh\n52\t  if (iapPublicKeyPromise && iapPublicKeyPromisePem === publicKey) {\n53\t    return iapPublicKeyPromise;\n54\t  }\n55\t\n56\t  // Create and store the promise for concurrent callers to share\n57\t  // Store the PEM associated with this promise for env change detection\n58\t  iapPublicKeyPromisePem = publicKey;\n59\t  iapPublicKeyPromise = (async () => {\n60\t    try {\n61\t      const imported = await importSPKI(publicKey, 'RS256');\n62\t      cachedIapPublicKey = imported;\n63\t      cachedIapPublicKeyPem = publicKey;\n64\t      return imported;\n65\t    } catch {\n66\t      // Reset promise on failure to allow retry on next call\n67\t      iapPublicKeyPromise = null;\n68\t      iapPublicKeyPromisePem = null;\n69\t      return null;\n70\t    }\n71\t  })();\n72\t\n73\t  return iapPublicKeyPromise;\n74\t}\n75\t\n76\tasync function verifyIapJwt(assertion: string): Promise<string | null> {\n77\t  const audience = process.env.IAP_JWT_AUDIENCE;\n78\t  if (!audience) {\n79\t    return null;\n80\t  }\n81\t\n82\t  const issuer = process.env.IAP_JWT_ISSUER || DEFAULT_IAP_ISSUER;\n83\t  const publicKey = await getIapPublicKey();\n84\t  if (!publicKey) {\n85\t    return null;\n86\t  }\n87\t\n88\t  try {\n89\t    const { payload } = await jwtVerify(assertion, publicKey, {\n90\t      audience,\n91\t      issuer,\n92\t    });\n93\t\n94\t    const email = typeof payload.email === 'string' ? payload.email : null;\n95\t    if (!email || !isValidEmail(email)) {\n96\t      return null;\n97\t    }\n98\t\n99\t    return email;\n100\t  } catch {\n101\t    return null;\n102\t  }\n103\t}\n104\t\n105\t/**\n106\t * Session token payload structure (internal).\n107\t * @internal\n108\t */\n109\t// eslint-disable-next-line @typescript-eslint/no-unused-vars\n110\tinterface SessionPayload {\n111\t  typ: 'session'; // Token type marker to prevent upload-key replay\n112\t  email: string;\n113\t  timestamp: number;\n114\t  nonce: string;\n115\t}\n116\t\n117\t/**\n118\t * Get the current authentication mode from environment.\n119\t * Defaults to 'session' (fail-secure) - requires explicit opt-in for platform mode.\n120\t *\n121\t * @returns The current authentication mode\n122\t */\n123\texport function getAuthMode(): AuthMode {\n124\t  const mode = process.env.AUTH_MODE as AuthMode;\n125\t  // Default to 'session' (fail-secure) - requires explicit opt-in for platform mode\n126\t  return mode === 'platform' ? 'platform' : 'session';\n127\t}\n128\t\n129\t/**\n130\t * Get the session token max age from environment.\n131\t * Defaults to 3600 seconds (1 hour).\n132\t * Validates the value and throws if invalid.\n133\t *\n134\t * @throws {Error} If SESSION_MAX_AGE_SECONDS is set but not a valid positive integer\n135\t * @returns The session token max age in seconds\n136\t */\n137\texport function getSessionMaxAge(): number {\n138\t  const maxAge = process.env.SESSION_MAX_AGE_SECONDS;\n139\t  if (!maxAge) {\n140\t    return 3600;\n141\t  }\n142\t\n143\t  // Trim whitespace for consistent validation\n144\t  const trimmed = maxAge.trim();\n145\t\n146\t  // Empty after trim is treated as unset (use default)\n147\t  if (trimmed === '') {\n148\t    return 3600;\n149\t  }\n150\t\n151\t  // Strict format check: must be a canonical positive integer string (e.g., \"3600\", \"7200\")\n152\t  // Rejects: \"3600abc\", \"1e3\", \"\", \"  \", \"-5\", \"0\", \" 3600 \" (after trim)\n153\t  if (!/^[1-9]\\d*$/.test(trimmed)) {\n154\t    throw new Error(\n155\t      'SESSION_MAX_AGE_SECONDS must be a positive integer in canonical form (no leading zeros, no trailing characters). Got: ' + maxAge\n156\t    );\n157\t  }\n158\t\n159\t  const parsed = parseInt(trimmed, 10);\n160\t\n161\t  // Double-check (should never fail given regex above, but defend against edge cases)\n162\t  if (Number.isNaN(parsed) || parsed <= 0 || !Number.isFinite(parsed)) {\n163\t    throw new Error(\n164\t      'SESSION_MAX_AGE_SECONDS must be a positive integer. Got: ' + maxAge\n165\t    );\n166\t  }\n167\t\n168\t  // Reasonable upper bound: 30 days\n169\t  const MAX_MAX_AGE = 30 * 24 * 60 * 60; // 2,592,000 seconds\n170\t  if (parsed > MAX_MAX_AGE) {\n171\t    throw new Error(\n172\t      'SESSION_MAX_AGE_SECONDS must be at most 30 days (2,592,000 seconds). Got: ' + parsed\n173\t    );\n174\t  }\n175\t\n176\t  return parsed;\n177\t}\n178\t\n179\t/**\n180\t * Generate a cryptographically signed session token.\n181\t *\n182\t * Token format: base64url(typ + \":\" + email + \":\" + timestamp + \":\" + nonce) + \".\" + base64url(hmac)\n183\t *\n184\t * The `typ` field is included to prevent upload tokens from being replayed as session tokens.\n185\t *\n186\t * @param email - The user email to embed in the token\n187\t * @param secret - The HMAC secret key (use SESSION_HMAC_SECRET in production)\n188\t * @returns A signed session token\n189\t */\n190\texport function generateSessionToken(email: string, secret: string): string {\n191\t  const timestamp = Math.floor(Date.now() / 1000);\n192\t  const nonce = randomBytes(16).toString('base64url');\n193\t\n194\t  // Encode email to handle special characters\n195\t  const encodedEmail = Buffer.from(email).toString('base64');\n196\t\n197\t  // Create payload string with type marker\n198\t  const payloadString = `session:${encodedEmail}:${timestamp}:${nonce}`;\n199\t\n200\t  // Encode the payload\n201\t  const encodedPayload = Buffer.from(payloadString).toString('base64url');\n202\t\n203\t  // Generate HMAC signature\n204\t  const signature = createHmac('sha256', secret)\n205\t    .update(encodedPayload)\n206\t    .digest('base64url');\n207\t\n208\t  return `${encodedPayload}.${signature}`;\n209\t}\n210\t\n211\t/**\n212\t * Verify a session token signature and expiration.\n213\t *\n214\t * The token must include a `typ=session` marker to prevent upload tokens from\n215\t * being replayed as session tokens (token-type confusion defense).\n216\t *\n217\t * @param token - The signed session token to verify\n218\t * @param secret - The HMAC secret key used to sign the token\n219\t * @param maxAgeSeconds - Maximum token age in seconds (defaults to getSessionMaxAge())\n220\t * @returns The user email if valid, null if invalid or expired\n221\t */\n222\texport function verifySessionToken(\n223\t  token: string,\n224\t  secret: string,\n225\t  maxAgeSeconds?: number\n226\t): string | null {\n227\t  // Split token into payload and signature\n228\t  const lastDotIndex = token.lastIndexOf('.');\n229\t  if (lastDotIndex === -1) {\n230\t    return null;\n231\t  }\n232\t\n233\t  const encodedPayload = token.substring(0, lastDotIndex);\n234\t  const signature = token.substring(lastDotIndex + 1);\n235\t\n236\t  if (!encodedPayload || !signature) {\n237\t    return null;\n238\t  }\n239\t\n240\t  // Verify signature using constant-time comparison to prevent timing attacks\n241\t  const expectedSignature = createHmac('sha256', secret)\n242\t    .update(encodedPayload)\n243\t    .digest('base64url');\n244\t\n245\t  // Convert base64url strings to Buffers for timing-safe comparison\n246\t  const sigBuf = Buffer.from(signature, 'base64url');\n247\t  const expectedBuf = Buffer.from(expectedSignature, 'base64url');\n248\t\n249\t  // Length check is acceptable here since HMAC-SHA256 always produces 32 bytes (43 chars base64url)\n250\t  if (sigBuf.length !== expectedBuf.length) {\n251\t    return null;\n252\t  }\n253\t\n254\t  if (!timingSafeEqual(sigBuf, expectedBuf)) {\n255\t    return null; // Signature mismatch - token may have been tampered with\n256\t  }\n257\t\n258\t  // Decode payload\n259\t  let decoded: string;\n260\t  try {\n261\t    decoded = Buffer.from(encodedPayload, 'base64url').toString();\n262\t  } catch {\n263\t    return null;\n264\t  }\n265\t\n266\t  // Parse payload components (expecting 4 fields with type marker)\n267\t  const parts = decoded.split(':');\n268\t  if (parts.length !== 4) {\n269\t    return null; // Invalid payload structure - rejects old 3-field tokens without type marker\n270\t  }\n271\t\n272\t  const [typ, emailB64, timestampStr, nonce] = parts;\n273\t\n274\t  // Verify token type marker - prevents upload tokens from being replayed as session tokens\n275\t  if (typ !== 'session') {\n276\t    return null; // Wrong token type - rejects upload tokens\n277\t  }\n278\t\n279\t  // Decode email\n280\t  let email: string;\n281\t  let timestamp: number;\n282\t\n283\t  try {\n284\t    email = Buffer.from(emailB64, 'base64').toString();\n285\t    timestamp = parseInt(timestampStr, 10);\n286\t\n287\t    if (isNaN(timestamp) || !email || !nonce) {\n288\t      return null;\n289\t    }\n290\t  } catch {\n291\t    return null;\n292\t  }\n293\t\n294\t  // Check expiration (both too old and too far in the future)\n295\t  const maxAge = maxAgeSeconds ?? getSessionMaxAge();\n296\t  const now = Math.floor(Date.now() / 1000);\n297\t  const age = now - timestamp;\n298\t\n299\t  // Reject tokens older than maxAge\n300\t  if (age > maxAge) {\n301\t    return null;\n302\t  }\n303\t\n304\t  // Reject tokens with timestamps too far in the future (clock skew defense)\n305\t  // Negative age means timestamp is in the future\n306\t  if (age < -CLOCK_SKEW_TOLERANCE) {\n307\t    return null;\n308\t  }\n309\t\n310\t  return email;\n311\t}\n312\t\n313\t/**\n314\t * Extract the bearer token from the Authorization header.\n315\t *\n316\t * HTTP schemes are case-insensitive per RFC 2616 Section 3.8.\n317\t * Accepts \"Bearer\", \"bearer\", \"BEARER\", and any mixed-case variant.\n318\t *\n319\t * @param authHeader - The Authorization header value\n320\t * @returns The bearer token, or null if not present/invalid\n321\t */\n322\texport function extractBearerToken(authHeader: string | null): string | null {\n323\t  if (!authHeader) {\n324\t    return null;\n325\t  }\n326\t\n327\t  // Use regex to be tolerant of multiple spaces between \"Bearer\" and the token\n328\t  // e.g., \"Bearer    <token>\" should be valid\n329\t  const match = authHeader.match(/^bearer\\s+(.+)$/i);\n330\t  if (!match) {\n331\t    return null;\n332\t  }\n333\t\n334\t  return match[1].trim();\n335\t}\n336\t\n337\t/**\n338\t * Get the authenticated user from a request.\n339\t *\n340\t * This is the unified entry point for authentication across all API routes.\n341\t * Behavior depends on AUTH_MODE environment variable:\n342\t *\n343\t * **Platform mode** (opt-in only, AUTH_MODE=platform):\n344\t * - Requires IAP JWT verification in production (AUTH_MODE_PLATFORM_STRICT=true).\n345\t * - In production, rejects all requests without verified IAP JWT assertion (fail closed).\n346\t * - In development/testing, non-strict mode accepts x-user-email directly.\n347\t * - Safe ONLY when deployment infrastructure validates the header (e.g., App Engine IAP).\n348\t *\n349\t * **Session mode** (default, AUTH_MODE=session or unset):\n350\t * - Validates bearer token against HMAC secret.\n351\t * - Safe for standalone deployments where client controls headers.\n352\t *\n353\t * @param request - The incoming HTTP request\n354\t * @returns The authenticated user email, or null if authentication fails\n355\t */\n356\texport async function getAuthenticatedUser(request: Request): Promise<string | null> {\n357\t  const mode = getAuthMode();\n358\t\n359\t  if (mode === 'session') {\n360\t    // Session mode: Validate bearer token\n361\t    const authHeader = request.headers.get('authorization');\n362\t    const token = extractBearerToken(authHeader);\n363\t\n364\t    if (!token) {\n365\t      return null;\n366\t    }\n367\t\n368\t    const secret = getSessionHmacSecret();\n369\t    return verifySessionToken(token, secret);\n370\t  }\n371\t\n372\t  // Platform mode: Trust x-user-email header (unless strict mode is enabled)\n373\t  const headerEmail = request.headers.get('x-user-email');\n374\t\n375\t  // Security: Fail closed outside development/test unless strict mode is enabled\n376\t  // This prevents auth bypass in staging, preview, or unset NODE_ENV scenarios\n377\t  const nodeEnv = process.env.NODE_ENV;\n378\t  const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n379\t  const isStrictMode = process.env.AUTH_MODE_PLATFORM_STRICT === 'true';\n380\t\n381\t  if (!isDevelopment && !isStrictMode) {\n382\t    // Fail closed when not in explicit dev/test environment and strict mode is disabled\n383\t    // Non-strict platform mode is ONLY allowed for development/testing\n384\t    console.warn(\n385\t      'Platform mode requires AUTH_MODE_PLATFORM_STRICT=true outside development. ' +\n386\t        'Request rejected for security.'\n387\t    );\n388\t    return null;\n389\t  }\n390\t\n391\t  // Strict mode: require verified IAP JWT assertion and ignore header spoofing.\n392\t  if (isStrictMode) {\n393\t    const assertion = request.headers.get('x-goog-iap-jwt-assertion');\n394\t    if (!assertion) {\n395\t      return null;\n396\t    }\n397\t\n398\t    const verifiedEmail = await verifyIapJwt(assertion);\n399\t    if (!verifiedEmail) {\n400\t      return null;\n401\t    }\n402\t\n403\t    if (headerEmail && headerEmail !== verifiedEmail) {\n404\t      return null;\n405\t    }\n406\t\n407\t    return verifiedEmail;\n408\t  }\n409\t\n410\t  if (!headerEmail) {\n411\t    return null;\n412\t  }\n413\t\n414\t  // Basic email format validation (applies to both modes)\n415\t  if (!isValidEmail(headerEmail)) {\n416\t    return null;\n417\t  }\n418\t\n419\t  return headerEmail;\n420\t}\n421\t"}]},"parent_tool_use_id":null,"session_id":"7ccb479f-aaae-4fab-ac1e-d4455c698fb3","uuid":"f7f33937-55fe-4daf-bdf8-b6cee2f1cf2d","timestamp":"2026-04-06T09:51:25.174Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/auth.ts","content":"/**\n * Authentication utilities for API routes.\n *\n * Provides environment-gated authentication to support both:\n * - Platform mode: Trust x-user-email header (App Engine with IAP)\n * - Session mode: Validate bearer token with HMAC signature (standalone)\n */\n\nimport { createHmac, randomBytes, timingSafeEqual } from 'crypto';\nimport { importSPKI, jwtVerify, type KeyLike } from 'jose';\nimport { getSessionHmacSecret } from './crypto';\n\n/**\n * Supported authentication modes.\n */\nexport type AuthMode = 'platform' | 'session';\n\nconst EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst DEFAULT_IAP_ISSUER = 'https://cloud.google.com/iap';\n\n/**\n * Clock skew tolerance for token timestamp validation.\n *\n * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n * extended validity from crafted future timestamps or clock skew.\n *\n * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n */\nexport const CLOCK_SKEW_TOLERANCE = 300;\n\nlet cachedIapPublicKey: KeyLike | null = null;\nlet cachedIapPublicKeyPem: string | null = null;\nlet iapPublicKeyPromise: Promise<KeyLike | null> | null = null;\nlet iapPublicKeyPromisePem: string | null = null;\n\nfunction isValidEmail(email: string): boolean {\n  return EMAIL_REGEX.test(email);\n}\n\nasync function getIapPublicKey(): Promise<KeyLike | null> {\n  const publicKey = process.env.IAP_JWT_PUBLIC_KEY;\n  if (!publicKey) {\n    return null;\n  }\n\n  if (cachedIapPublicKey && cachedIapPublicKeyPem === publicKey) {\n    return cachedIapPublicKey;\n  }\n\n  // If already fetching for the same PEM, return the existing promise to deduplicate concurrent calls\n  // If PEM changed, discard old promise and start fresh\n  if (iapPublicKeyPromise && iapPublicKeyPromisePem === publicKey) {\n    return iapPublicKeyPromise;\n  }\n\n  // Create and store the promise for concurrent callers to share\n  // Store the PEM associated with this promise for env change detection\n  iapPublicKeyPromisePem = publicKey;\n  iapPublicKeyPromise = (async () => {\n    try {\n      const imported = await importSPKI(publicKey, 'RS256');\n      cachedIapPublicKey = imported;\n      cachedIapPublicKeyPem = publicKey;\n      return imported;\n    } catch {\n      // Reset promise on failure to allow retry on next call\n      iapPublicKeyPromise = null;\n      iapPublicKeyPromisePem = null;\n      return null;\n    }\n  })();\n\n  return iapPublicKeyPromise;\n}\n\nasync function verifyIapJwt(assertion: string): Promise<string | null> {\n  const audience = process.env.IAP_JWT_AUDIENCE;\n  if (!audience) {\n    return null;\n  }\n\n  const issuer = process.env.IAP_JWT_ISSUER || DEFAULT_IAP_ISSUER;\n  const publicKey = await getIapPublicKey();\n  if (!publicKey) {\n    return null;\n  }\n\n  try {\n    const { payload } = await jwtVerify(assertion, publicKey, {\n      audience,\n      issuer,\n    });\n\n    const email = typeof payload.email === 'string' ? payload.email : null;\n    if (!email || !isValidEmail(email)) {\n      return null;\n    }\n\n    return email;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Session token payload structure (internal).\n * @internal\n */\n// eslint-disable-next-line @typescript-eslint/no-unused-vars\ninterface SessionPayload {\n  typ: 'session'; // Token type marker to prevent upload-key replay\n  email: string;\n  timestamp: number;\n  nonce: string;\n}\n\n/**\n * Get the current authentication mode from environment.\n * Defaults to 'session' (fail-secure) - requires explicit opt-in for platform mode.\n *\n * @returns The current authentication mode\n */\nexport function getAuthMode(): AuthMode {\n  const mode = process.env.AUTH_MODE as AuthMode;\n  // Default to 'session' (fail-secure) - requires explicit opt-in for platform mode\n  return mode === 'platform' ? 'platform' : 'session';\n}\n\n/**\n * Get the session token max age from environment.\n * Defaults to 3600 seconds (1 hour).\n * Validates the value and throws if invalid.\n *\n * @throws {Error} If SESSION_MAX_AGE_SECONDS is set but not a valid positive integer\n * @returns The session token max age in seconds\n */\nexport function getSessionMaxAge(): number {\n  const maxAge = process.env.SESSION_MAX_AGE_SECONDS;\n  if (!maxAge) {\n    return 3600;\n  }\n\n  // Trim whitespace for consistent validation\n  const trimmed = maxAge.trim();\n\n  // Empty after trim is treated as unset (use default)\n  if (trimmed === '') {\n    return 3600;\n  }\n\n  // Strict format check: must be a canonical positive integer string (e.g., \"3600\", \"7200\")\n  // Rejects: \"3600abc\", \"1e3\", \"\", \"  \", \"-5\", \"0\", \" 3600 \" (after trim)\n  if (!/^[1-9]\\d*$/.test(trimmed)) {\n    throw new Error(\n      'SESSION_MAX_AGE_SECONDS must be a positive integer in canonical form (no leading zeros, no trailing characters). Got: ' + maxAge\n    );\n  }\n\n  const parsed = parseInt(trimmed, 10);\n\n  // Double-check (should never fail given regex above, but defend against edge cases)\n  if (Number.isNaN(parsed) || parsed <= 0 || !Number.isFinite(parsed)) {\n    throw new Error(\n      'SESSION_MAX_AGE_SECONDS must be a positive integer. Got: ' + maxAge\n    );\n  }\n\n  // Reasonable upper bound: 30 days\n  const MAX_MAX_AGE = 30 * 24 * 60 * 60; // 2,592,000 seconds\n  if (parsed > MAX_MAX_AGE) {\n    throw new Error(\n      'SESSION_MAX_AGE_SECONDS must be at most 30 days (2,592,000 seconds). Got: ' + parsed\n    );\n  }\n\n  return parsed;\n}\n\n/**\n * Generate a cryptographically signed session token.\n *\n * Token format: base64url(typ + \":\" + email + \":\" + timestamp + \":\" + nonce) + \".\" + base64url(hmac)\n *\n * The `typ` field is included to prevent upload tokens from being replayed as session tokens.\n *\n * @param email - The user email to embed in the token\n * @param secret - The HMAC secret key (use SESSION_HMAC_SECRET in production)\n * @returns A signed session token\n */\nexport function generateSessionToken(email: string, secret: string): string {\n  const timestamp = Math.floor(Date.now() / 1000);\n  const nonce = randomBytes(16).toString('base64url');\n\n  // Encode email to handle special characters\n  const encodedEmail = Buffer.from(email).toString('base64');\n\n  // Create payload string with type marker\n  const payloadString = `session:${encodedEmail}:${timestamp}:${nonce}`;\n\n  // Encode the payload\n  const encodedPayload = Buffer.from(payloadString).toString('base64url');\n\n  // Generate HMAC signature\n  const signature = createHmac('sha256', secret)\n    .update(encodedPayload)\n    .digest('base64url');\n\n  return `${encodedPayload}.${signature}`;\n}\n\n/**\n * Verify a session token signature and expiration.\n *\n * The token must include a `typ=session` marker to prevent upload tokens from\n * being replayed as session tokens (token-type confusion defense).\n *\n * @param token - The signed session token to verify\n * @param secret - The HMAC secret key used to sign the token\n * @param maxAgeSeconds - Maximum token age in seconds (defaults to getSessionMaxAge())\n * @returns The user email if valid, null if invalid or expired\n */\nexport function verifySessionToken(\n  token: string,\n  secret: string,\n  maxAgeSeconds?: number\n): string | null {\n  // Split token into payload and signature\n  const lastDotIndex = token.lastIndexOf('.');\n  if (lastDotIndex === -1) {\n    return null;\n  }\n\n  const encodedPayload = token.substring(0, lastDotIndex);\n  const signature = token.substring(lastDotIndex + 1);\n\n  if (!encodedPayload || !signature) {\n    return null;\n  }\n\n  // Verify signature using constant-time comparison to prevent timing attacks\n  const expectedSignature = createHmac('sha256', secret)\n    .update(encodedPayload)\n    .digest('base64url');\n\n  // Convert base64url strings to Buffers for timing-safe comparison\n  const sigBuf = Buffer.from(signature, 'base64url');\n  const expectedBuf = Buffer.from(expectedSignature, 'base64url');\n\n  // Length check is acceptable here since HMAC-SHA256 always produces 32 bytes (43 chars base64url)\n  if (sigBuf.length !== expectedBuf.length) {\n    return null;\n  }\n\n  if (!timingSafeEqual(sigBuf, expectedBuf)) {\n    return null; // Signature mismatch - token may have been tampered with\n  }\n\n  // Decode payload\n  let decoded: string;\n  try {\n    decoded = Buffer.from(encodedPayload, 'base64url').toString();\n  } catch {\n    return null;\n  }\n\n  // Parse payload components (expecting 4 fields with type marker)\n  const parts = decoded.split(':');\n  if (parts.length !== 4) {\n    return null; // Invalid payload structure - rejects old 3-field tokens without type marker\n  }\n\n  const [typ, emailB64, timestampStr, nonce] = parts;\n\n  // Verify token type marker - prevents upload tokens from being replayed as session tokens\n  if (typ !== 'session') {\n    return null; // Wrong token type - rejects upload tokens\n  }\n\n  // Decode email\n  let email: string;\n  let timestamp: number;\n\n  try {\n    email = Buffer.from(emailB64, 'base64').toString();\n    timestamp = parseInt(timestampStr, 10);\n\n    if (isNaN(timestamp) || !email || !nonce) {\n      return null;\n    }\n  } catch {\n    return null;\n  }\n\n  // Check expiration (both too old and too far in the future)\n  const maxAge = maxAgeSeconds ?? getSessionMaxAge();\n  const now = Math.floor(Date.now() / 1000);\n  const age = now - timestamp;\n\n  // Reject tokens older than maxAge\n  if (age > maxAge) {\n    return null;\n  }\n\n  // Reject tokens with timestamps too far in the future (clock skew defense)\n  // Negative age means timestamp is in the future\n  if (age < -CLOCK_SKEW_TOLERANCE) {\n    return null;\n  }\n\n  return email;\n}\n\n/**\n * Extract the bearer token from the Authorization header.\n *\n * HTTP schemes are case-insensitive per RFC 2616 Section 3.8.\n * Accepts \"Bearer\", \"bearer\", \"BEARER\", and any mixed-case variant.\n *\n * @param authHeader - The Authorization header value\n * @returns The bearer token, or null if not present/invalid\n */\nexport function extractBearerToken(authHeader: string | null): string | null {\n  if (!authHeader) {\n    return null;\n  }\n\n  // Use rege