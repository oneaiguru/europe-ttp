{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_6c97526fb6b04f5c9eac5dae","type":"tool_result","content":"1\t/**\n2\t * Authentication utilities for API routes.\n3\t *\n4\t * Provides environment-gated authentication to support both:\n5\t * - Platform mode: Trust x-user-email header (App Engine with IAP)\n6\t * - Session mode: Validate bearer token with HMAC signature (standalone)\n7\t */\n8\t\n9\timport { createHmac, randomBytes, timingSafeEqual } from 'crypto';\n10\timport { importSPKI, jwtVerify, type KeyLike } from 'jose';\n11\timport { getSessionHmacSecret } from './crypto';\n12\t\n13\t/**\n14\t * Supported authentication modes.\n15\t */\n16\texport type AuthMode = 'platform' | 'session';\n17\t\n18\tconst EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n19\tconst DEFAULT_IAP_ISSUER = 'https://cloud.google.com/iap';\n20\t\n21\t/**\n22\t * Clock skew tolerance for token timestamp validation.\n23\t *\n24\t * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n25\t * extended validity from crafted future timestamps or clock skew.\n26\t *\n27\t * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n28\t */\n29\texport const CLOCK_SKEW_TOLERANCE = 300;\n30\t\n31\tlet cachedIapPublicKey: KeyLike | null = null;\n32\tlet cachedIapPublicKeyPem: string | null = null;\n33\tlet iapPublicKeyPromise: Promise<KeyLike | null> | null = null;\n34\tlet iapPublicKeyPromisePem: string | null = null;\n35\t\n36\tfunction isValidEmail(email: string): boolean {\n37\t  return EMAIL_REGEX.test(email);\n38\t}\n39\t\n40\tasync function getIapPublicKey(): Promise<KeyLike | null> {\n41\t  const publicKey = process.env.IAP_JWT_PUBLIC_KEY;\n42\t  if (!publicKey) {\n43\t    return null;\n44\t  }\n45\t\n46\t  if (cachedIapPublicKey && cachedIapPublicKeyPem === publicKey) {\n47\t    return cachedIapPublicKey;\n48\t  }\n49\t\n50\t  // If already fetching for the same PEM, return the existing promise to deduplicate concurrent calls\n51\t  // If PEM changed, discard old promise and start fresh\n52\t  if (iapPublicKeyPromise && iapPublicKeyPromisePem === publicKey) {\n53\t    return iapPublicKeyPromise;\n54\t  }\n55\t\n56\t  // Create and store the promise for concurrent callers to share\n57\t  // Store the PEM associated with this promise for env change detection\n58\t  iapPublicKeyPromisePem = publicKey;\n59\t  iapPublicKeyPromise = (async () => {\n60\t    try {\n61\t      const imported = await importSPKI(publicKey, 'RS256');\n62\t      cachedIapPublicKey = imported;\n63\t      cachedIapPublicKeyPem = publicKey;\n64\t      return imported;\n65\t    } catch {\n66\t      // Reset promise on failure to allow retry on next call\n67\t      iapPublicKeyPromise = null;\n68\t      iapPublicKeyPromisePem = null;\n69\t      return null;\n70\t    }\n71\t  })();\n72\t\n73\t  return iapPublicKeyPromise;\n74\t}\n75\t\n76\tasync function verifyIapJwt(assertion: string): Promise<string | null> {\n77\t  const audience = process.env.IAP_JWT_AUDIENCE;\n78\t  if (!audience) {\n79\t    return null;\n80\t  }\n81\t\n82\t  const issuer = process.env.IAP_JWT_ISSUER || DEFAULT_IAP_ISSUER;\n83\t  const publicKey = await getIapPublicKey();\n84\t  if (!publicKey) {\n85\t    return null;\n86\t  }\n87\t\n88\t  try {\n89\t    const { payload } = await jwtVerify(assertion, publicKey, {\n90\t      audience,\n91\t      issuer,\n92\t    });\n93\t\n94\t    const email = typeof payload.email === 'string' ? payload.email : null;\n95\t    if (!email || !isValidEmail(email)) {\n96\t      return null;\n97\t    }\n98\t\n99\t    return email;\n100\t  } catch {\n101\t    return null;\n102\t  }\n103\t}\n104\t\n105\t/**\n106\t * Session token payload structure (internal).\n107\t * @internal\n108\t */\n109\t// eslint-disable-next-line @typescript-eslint/no-unused-vars\n110\tinterface SessionPayload {\n111\t  typ: 'session'; // Token type marker to prevent upload-key replay\n112\t  email: string;\n113\t  timestamp: number;\n114\t  nonce: string;\n115\t}\n116\t\n117\t/**\n118\t * Get the current authentication mode from environment.\n119\t * Defaults to 'session' (fail-secure) - requires explicit opt-in for platform mode.\n120\t *\n121\t * @returns The current authentication mode\n122\t */\n123\texport function getAuthMode(): AuthMode {\n124\t  const mode = process.env.AUTH_MODE as AuthMode;\n125\t  // Default to 'session' (fail-secure) - requires explicit opt-in for platform mode\n126\t  return mode === 'platform' ? 'platform' : 'session';\n127\t}\n128\t\n129\t/**\n130\t * Get the session token max age from environment.\n131\t * Defaults to 3600 seconds (1 hour).\n132\t * Validates the value and throws if invalid.\n133\t *\n134\t * @throws {Error} If SESSION_MAX_AGE_SECONDS is set but not a valid positive integer\n135\t * @returns The session token max age in seconds\n136\t */\n137\texport function getSessionMaxAge(): number {\n138\t  const maxAge = process.env.SESSION_MAX_AGE_SECONDS;\n139\t  if (!maxAge) {\n140\t    return 3600;\n141\t  }\n142\t\n143\t  // Trim whitespace for consistent validation\n144\t  const trimmed = maxAge.trim();\n145\t\n146\t  // Empty after trim is treated as unset (use default)\n147\t  if (trimmed === '') {\n148\t    return 3600;\n149\t  }\n150\t\n151\t  // Strict format check: must be a canonical positive integer string (e.g., \"3600\", \"7200\")\n152\t  // Rejects: \"3600abc\", \"1e3\", \"\", \"  \", \"-5\", \"0\", \" 3600 \" (after trim)\n153\t  if (!/^[1-9]\\d*$/.test(trimmed)) {\n154\t    throw new Error(\n155\t      'SESSION_MAX_AGE_SECONDS must be a positive integer in canonical form (no leading zeros, no trailing characters). Got: ' + maxAge\n156\t    );\n157\t  }\n158\t\n159\t  const parsed = parseInt(trimmed, 10);\n160\t\n161\t  // Double-check (should never fail given regex above, but defend against edge cases)\n162\t  if (Number.isNaN(parsed) || parsed <= 0 || !Number.isFinite(parsed)) {\n163\t    throw new Error(\n164\t      'SESSION_MAX_AGE_SECONDS must be a positive integer. Got: ' + maxAge\n165\t    );\n166\t  }\n167\t\n168\t  // Reasonable upper bound: 30 days\n169\t  const MAX_MAX_AGE = 30 * 24 * 60 * 60; // 2,592,000 seconds\n170\t  if (parsed > MAX_MAX_AGE) {\n171\t    throw new Error(\n172\t      'SESSION_MAX_AGE_SECONDS must be at most 30 days (2,592,000 seconds). Got: ' + parsed\n173\t    );\n174\t  }\n175\t\n176\t  return parsed;\n177\t}\n178\t\n179\t/**\n180\t * Generate a cryptographically signed session token.\n181\t *\n182\t * Token format: base64url(typ + \":\" + email + \":\" + timestamp + \":\" + nonce) + \".\" + base64url(hmac)\n183\t *\n184\t * The `typ` field is included to prevent upload tokens from being replayed as session tokens.\n185\t *\n186\t * @param email - The user email to embed in the token\n187\t * @param secret - The HMAC secret key (use SESSION_HMAC_SECRET in production)\n188\t * @returns A signed session token\n189\t */\n190\texport function generateSessionToken(email: string, secret: string): string {\n191\t  const timestamp = Math.floor(Date.now() / 1000);\n192\t  const nonce = randomBytes(16).toString('base64url');\n193\t\n194\t  // Encode email to handle special characters\n195\t  const encodedEmail = Buffer.from(email).toString('base64');\n196\t\n197\t  // Create payload string with type marker\n198\t  const payloadString = `session:${encodedEmail}:${timestamp}:${nonce}`;\n199\t\n200\t  // Encode the payload\n201\t  const encodedPayload = Buffer.from(payloadString).toString('base64url');\n202\t\n203\t  // Generate HMAC signature\n204\t  const signature = createHmac('sha256', secret)\n205\t    .update(encodedPayload)\n206\t    .digest('base64url');\n207\t\n208\t  return `${encodedPayload}.${signature}`;\n209\t}\n210\t\n211\t/**\n212\t * Verify a session token signature and expiration.\n213\t *\n214\t * The token must include a `typ=session` marker to prevent upload tokens from\n215\t * being replayed as session tokens (token-type confusion defense).\n216\t *\n217\t * @param token - The signed session token to verify\n218\t * @param secret - The HMAC secret key used to sign the token\n219\t * @param maxAgeSeconds - Maximum token age in seconds (defaults to getSessionMaxAge())\n220\t * @returns The user email if valid, null if invalid or expired\n221\t */\n222\texport function verifySessionToken(\n223\t  token: string,\n224\t  secret: string,\n225\t  maxAgeSeconds?: number\n226\t): string | null {\n227\t  // Split token into payload and signature\n228\t  const lastDotIndex = token.lastIndexOf('.');\n229\t  if (lastDotIndex === -1) {\n230\t    return null;\n231\t  }\n232\t\n233\t  const encodedPayload = token.substring(0, lastDotIndex);\n234\t  const signature = token.substring(lastDotIndex + 1);\n235\t\n236\t  if (!encodedPayload || !signature) {\n237\t    return null;\n238\t  }\n239\t\n240\t  // Verify signature using constant-time comparison to prevent timing attacks\n241\t  const expectedSignature = createHmac('sha256', secret)\n242\t    .update(encodedPayload)\n243\t    .digest('base64url');\n244\t\n245\t  // Convert base64url strings to Buffers for timing-safe comparison\n246\t  const sigBuf = Buffer.from(signature, 'base64url');\n247\t  const expectedBuf = Buffer.from(expectedSignature, 'base64url');\n248\t\n249\t  // Length check is acceptable here since HMAC-SHA256 always produces 32 bytes (43 chars base64url)\n250\t  if (sigBuf.length !== expectedBuf.length) {\n251\t    return null;\n252\t  }\n253\t\n254\t  if (!timingSafeEqual(sigBuf, expectedBuf)) {\n255\t    return null; // Signature mismatch - token may have been tampered with\n256\t  }\n257\t\n258\t  // Decode payload\n259\t  let decoded: string;\n260\t  try {\n261\t    decoded = Buffer.from(encodedPayload, 'base64url').toString();\n262\t  } catch {\n263\t    return null;\n264\t  }\n265\t\n266\t  // Parse payload components (expecting 4 fields with type marker)\n267\t  const parts = decoded.split(':');\n268\t  if (parts.length !== 4) {\n269\t    return null; // Invalid payload structure - rejects old 3-field tokens without type marker\n270\t  }\n271\t\n272\t  const [typ, emailB64, timestampStr, nonce] = parts;\n273\t\n274\t  // Verify token type marker - prevents upload tokens from being replayed as session tokens\n275\t  if (typ !== 'session') {\n276\t    return null; // Wrong token type - rejects upload tokens\n277\t  }\n278\t\n279\t  // Decode email\n280\t  let email: string;\n281\t  let timestamp: number;\n282\t\n283\t  try {\n284\t    email = Buffer.from(emailB64, 'base64').toString();\n285\t    timestamp = parseInt(timestampStr, 10);\n286\t\n287\t    if (isNaN(timestamp) || !email || !nonce) {\n288\t      return null;\n289\t    }\n290\t  } catch {\n291\t    return null;\n292\t  }\n293\t\n294\t  // Check expiration (both too old and too far in the future)\n295\t  const maxAge = maxAgeSeconds ?? getSessionMaxAge();\n296\t  const now = Math.floor(Date.now() / 1000);\n297\t  const age = now - timestamp;\n298\t\n299\t  // Reject tokens older than maxAge\n300\t  if (age > maxAge) {\n301\t    return null;\n302\t  }\n303\t\n304\t  // Reject tokens with timestamps too far in the future (clock skew defense)\n305\t  // Negative age means timestamp is in the future\n306\t  if (age < -CLOCK_SKEW_TOLERANCE) {\n307\t    return null;\n308\t  }\n309\t\n310\t  return email;\n311\t}\n312\t\n313\t/**\n314\t * Extract the bearer token from the Authorization header.\n315\t *\n316\t * HTTP schemes are case-insensitive per RFC 2616 Section 3.8.\n317\t * Accepts \"Bearer\", \"bearer\", \"BEARER\", and any mixed-case variant.\n318\t *\n319\t * @param authHeader - The Authorization header value\n320\t * @returns The bearer token, or null if not present/invalid\n321\t */\n322\texport function extractBearerToken(authHeader: string | null): string | null {\n323\t  if (!authHeader) {\n324\t    return null;\n325\t  }\n326\t\n327\t  // Use regex to be tolerant of multiple spaces between \"Bearer\" and the token\n328\t  // e.g., \"Bearer    <token>\" should be valid\n329\t  const match = authHeader.match(/^bearer\\s+(.+)$/i);\n330\t  if (!match) {\n331\t    return null;\n332\t  }\n333\t\n334\t  return match[1].trim();\n335\t}\n336\t\n337\t/**\n338\t * Get the authenticated user from a request.\n339\t *\n340\t * This is the unified entry point for authentication across all API routes.\n341\t * Behavior depends on AUTH_MODE environment variable:\n342\t *\n343\t * **Platform mode** (opt-in only, AUTH_MODE=platform):\n344\t * - Requires IAP JWT verification in production (AUTH_MODE_PLATFORM_STRICT=true).\n345\t * - In production, rejects all requests without verified IAP JWT assertion (fail closed).\n346\t * - In development/testing, non-strict mode accepts x-user-email directly.\n347\t * - Safe ONLY when deployment infrastructure validates the header (e.g., App Engine IAP).\n348\t *\n349\t * **Session mode** (default, AUTH_MODE=session or unset):\n350\t * - Validates bearer token against HMAC secret.\n351\t * - Safe for standalone deployments where client controls headers.\n352\t *\n353\t * @param request - The incoming HTTP request\n354\t * @returns The authenticated user email, or null if authentication fails\n355\t */\n356\texport async function getAuthenticatedUser(request: Request): Promise<string | null> {\n357\t  const mode = getAuthMode();\n358\t\n359\t  if (mode === 'session') {\n360\t    // Session mode: Validate bearer token\n361\t    const authHeader = request.headers.get('authorization');\n362\t    const token = extractBearerToken(authHeader);\n363\t\n364\t    if (!token) {\n365\t      return null;\n366\t    }\n367\t\n368\t    const secret = getSessionHmacSecret();\n369\t    return verifySessionToken(token, secret);\n370\t  }\n371\t\n372\t  // Platform mode: Trust x-user-email header (unless strict mode is enabled)\n373\t  const headerEmail = request.headers.get('x-user-email');\n374\t\n375\t  // Security: Fail closed outside development/test unless strict mode is enabled\n376\t  // This prevents auth bypass in staging, preview, or unset NODE_ENV scenarios\n377\t  const nodeEnv = process.env.NODE_ENV;\n378\t  const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n379\t  const isStrictMode = process.env.AUTH_MODE_PLATFORM_STRICT === 'true';\n380\t\n381\t  if (!isDevelopment && !isStrictMode) {\n382\t    // Fail closed when not in explicit dev/test environment and strict mode is disabled\n383\t    // Non-strict platform mode is ONLY allowed for development/testing\n384\t    console.warn(\n385\t      'Platform mode requires AUTH_MODE_PLATFORM_STRICT=true outside development. ' +\n386\t        'Request rejected for security.'\n387\t    );\n388\t    return null;\n389\t  }\n390\t\n391\t  // Strict mode: require verified IAP JWT assertion and ignore header spoofing.\n392\t  if (isStrictMode) {\n393\t    const assertion = request.headers.get('x-goog-iap-jwt-assertion');\n394\t    if (!assertion) {\n395\t      return null;\n396\t    }\n397\t\n398\t    const verifiedEmail = await verifyIapJwt(assertion);\n399\t    if (!verifiedEmail) {\n400\t      return null;\n401\t    }\n402\t\n403\t    if (headerEmail && headerEmail !== verifiedEmail) {\n404\t      return null;\n405\t    }\n406\t\n407\t    return verifiedEmail;\n408\t  }\n409\t\n410\t  if (!headerEmail) {\n411\t    return null;\n412\t  }\n413\t\n414\t  // Basic email format validation (applies to both modes)\n415\t  if (!isValidEmail(headerEmail)) {\n416\t    return null;\n417\t  }\n418\t\n419\t  return headerEmail;\n420\t}\n421\t"}]},"parent_tool_use_id":null,"session_id":"21b9bbd8-6878-4a2c-9d2e-2206e80b3232","uuid":"0773de7b-6307-477e-b9fe-5fad7456ad4c","timestamp":"2026-04-06T09:52:18.666Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/auth.ts","content":"/**\n * Authentication utilities for API routes.\n *\n * Provides environment-gated authentication to support both:\n * - Platform mode: Trust x-user-email header (App Engine with IAP)\n * - Session mode: Validate bearer token with HMAC signature (standalone)\n */\n\nimport { createHmac, randomBytes, timingSafeEqual } from 'crypto';\nimport { importSPKI, jwtVerify, type KeyLike } from 'jose';\nimport { getSessionHmacSecret } from './crypto';\n\n/**\n * Supported authentication modes.\n */\nexport type AuthMode = 'platform' | 'session';\n\nconst EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst DEFAULT_IAP_ISSUER = 'https://cloud.google.com/iap';\n\n/**\n * Clock skew tolerance for token timestamp validation.\n *\n * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n * extended validity from crafted future timestamps or clock skew.\n *\n * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n */\nexport const CLOCK_SKEW_TOLERANCE = 300;\n\nlet cachedIapPublicKey: KeyLike | null = null;\nlet cachedIapPublicKeyPem: string | null = null;\nlet iapPublicKeyPromise: Promise<KeyLike | null> | null = null;\nlet iapPublicKeyPromisePem: string | null = null;\n\nfunction isValidEmail(email: string): boolean {\n  return EMAIL_REGEX.test(email);\n}\n\nasync function getIapPublicKey(): Promise<KeyLike | null> {\n  const publicKey = process.env.IAP_JWT_PUBLIC_KEY;\n  if (!publicKey) {\n    return null;\n  }\n\n  if (cachedIapPublicKey && cachedIapPublicKeyPem === publicKey) {\n    return cachedIapPublicKey;\n  }\n\n  // If already fetching for the same PEM, return the existing promise to deduplicate concurrent calls\n  // If PEM changed, discard old promise and start fresh\n  if (iapPublicKeyPromise && iapPublicKeyPromisePem === publicKey) {\n    return iapPublicKeyPromise;\n  }\n\n  // Create and store the promise for concurrent callers to share\n  // Store the PEM associated with this promise for env change detection\n  iapPublicKeyPromisePem = publicKey;\n  iapPublicKeyPromise = (async () => {\n    try {\n      const imported = await importSPKI(publicKey, 'RS256');\n      cachedIapPublicKey = imported;\n      cachedIapPublicKeyPem = publicKey;\n      return imported;\n    } catch {\n      // Reset promise on failure to allow retry on next call\n      iapPublicKeyPromise = null;\n      iapPublicKeyPromisePem = null;\n      return null;\n    }\n  })();\n\n  return iapPublicKeyPromise;\n}\n\nasync function verifyIapJwt(assertion: string): Promise<string | null> {\n  const audience = process.env.IAP_JWT_AUDIENCE;\n  if (!audience) {\n    return null;\n  }\n\n  const issuer = process.env.IAP_JWT_ISSUER || DEFAULT_IAP_ISSUER;\n  const publicKey = await getIapPublicKey();\n  if (!publicKey) {\n    return null;\n  }\n\n  try {\n    const { payload } = await jwtVerify(assertion, publicKey, {\n      audience,\n      issuer,\n    });\n\n    const email = typeof payload.email === 'string' ? payload.email : null;\n    if (!email || !isValidEmail(email)) {\n      return null;\n    }\n\n    return email;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Session token payload structure (internal).\n * @internal\n */\n// eslint-disable-next-line @typescript-eslint/no-unused-vars\ninterface SessionPayload {\n  typ: 'session'; // Token type marker to prevent upload-key replay\n  email: string;\n  timestamp: number;\n  nonce: string;\n}\n\n/**\n * Get the current authentication mode from environment.\n * Defaults to 'session' (fail-secure) - requires explicit opt-in for platform mode.\n *\n * @returns The current authentication mode\n */\nexport function getAuthMode(): AuthMode {\n  const mode = process.env.AUTH_MODE as AuthMode;\n  // Default to 'session' (fail-secure) - requires explicit opt-in for platform mode\n  return mode === 'platform' ? 'platform' : 'session';\n}\n\n/**\n * Get the session token max age from environment.\n * Defaults to 3600 seconds (1 hour).\n * Validates the value and throws if invalid.\n *\n * @throws {Error} If SESSION_MAX_AGE_SECONDS is set but not a valid positive integer\n * @returns The session token max age in seconds\n */\nexport function getSessionMaxAge(): number {\n  const maxAge = process.env.SESSION_MAX_AGE_SECONDS;\n  if (!maxAge) {\n    return 3600;\n  }\n\n  // Trim whitespace for consistent validation\n  const trimmed = maxAge.trim();\n\n  // Empty after trim is treated as unset (use default)\n  if (trimmed === '') {\n    return 3600;\n  }\n\n  // Strict format check: must be a canonical positive integer string (e.g., \"3600\", \"7200\")\n  // Rejects: \"3600abc\", \"1e3\", \"\", \"  \", \"-5\", \"0\", \" 3600 \" (after trim)\n  if (!/^[1-9]\\d*$/.test(trimmed)) {\n    throw new Error(\n      'SESSION_MAX_AGE_SECONDS must be a positive integer in canonical form (no leading zeros, no trailing characters). Got: ' + maxAge\n    );\n  }\n\n  const parsed = parseInt(trimmed, 10);\n\n  // Double-check (should never fail given regex above, but defend against edge cases)\n  if (Number.isNaN(parsed) || parsed <= 0 || !Number.isFinite(parsed)) {\n    throw new Error(\n      'SESSION_MAX_AGE_SECONDS must be a positive integer. Got: ' + maxAge\n    );\n  }\n\n  // Reasonable upper bound: 30 days\n  const MAX_MAX_AGE = 30 * 24 * 60 * 60; // 2,592,000 seconds\n  if (parsed > MAX_MAX_AGE) {\n    throw new Error(\n      'SESSION_MAX_AGE_SECONDS must be at most 30 days (2,592,000 seconds). Got: ' + parsed\n    );\n  }\n\n  return parsed;\n}\n\n/**\n * Generate a cryptographically signed session token.\n *\n * Token format: base64url(typ + \":\" + email + \":\" + timestamp + \":\" + nonce) + \".\" + base64url(hmac)\n *\n * The `typ` field is included to prevent upload tokens from being replayed as session tokens.\n *\n * @param email - The user email to embed in the token\n * @param secret - The HMAC secret key (use SESSION_HMAC_SECRET in production)\n * @returns A signed session token\n */\nexport function generateSessionToken(email: string, secret: string): string {\n  const timestamp = Math.floor(Date.now() / 1000);\n  const nonce = randomBytes(16).toString('base64url');\n\n  // Encode email to handle special characters\n  const encodedEmail = Buffer.from(email).toString('base64');\n\n  // Create payload string with type marker\n  const payloadString = `session:${encodedEmail}:${timestamp}:${nonce}`;\n\n  // Encode the payload\n  const encodedPayload = Buffer.from(payloadString).toString('base64url');\n\n  // Generate HMAC signature\n  const signature = createHmac('sha256', secret)\n    .update(encodedPayload)\n    .digest('base64url');\n\n  return `${encodedPayload}.${signature}`;\n}\n\n/**\n * Verify a session token signature and expiration.\n *\n * The token must include a `typ=session` marker to prevent upload tokens from\n * being replayed as session tokens (token-type confusion defense).\n *\n * @param token - The signed session token to verify\n * @param secret - The HMAC secret key used to sign the token\n * @param maxAgeSeconds - Maximum token age in seconds (defaults to getSessionMaxAge())\n * @returns The user email if valid, null if invalid or expired\n */\nexport function verifySessionToken(\n  token: string,\n  secret: string,\n  maxAgeSeconds?: number\n): string | null {\n  // Split token into payload and signature\n  const lastDotIndex = token.lastIndexOf('.');\n  if (lastDotIndex === -1) {\n    return null;\n  }\n\n  const encodedPayload = token.substring(0, lastDotIndex);\n  const signature = token.substring(lastDotIndex + 1);\n\n  if (!encodedPayload || !signature) {\n    return null;\n  }\n\n  // Verify signature using constant-time comparison to prevent timing attacks\n  const expectedSignature = createHmac('sha256', secret)\n    .update(encodedPayload)\n    .digest('base64url');\n\n  // Convert base64url strings to Buffers for timing-safe comparison\n  const sigBuf = Buffer.from(signature, 'base64url');\n  const expectedBuf = Buffer.from(expectedSignature, 'base64url');\n\n  // Length check is acceptable here since HMAC-SHA256 always produces 32 bytes (43 chars base64url)\n  if (sigBuf.length !== expectedBuf.length) {\n    return null;\n  }\n\n  if (!timingSafeEqual(sigBuf, expectedBuf)) {\n    return null; // Signature mismatch - token may have been tampered with\n  }\n\n  // Decode payload\n  let decoded: string;\n  try {\n    decoded = Buffer.from(encodedPayload, 'base64url').toString();\n  } catch {\n    return null;\n  }\n\n  // Parse payload components (expecting 4 fields with type marker)\n  const parts = decoded.split(':');\n  if (parts.length !== 4) {\n    return null; // Invalid payload structure - rejects old 3-field tokens without type marker\n  }\n\n  const [typ, emailB64, timestampStr, nonce] = parts;\n\n  // Verify token type marker - prevents upload tokens from being replayed as session tokens\n  if (typ !== 'session') {\n    return null; // Wrong token type - rejects upload tokens\n  }\n\n  // Decode email\n  let email: string;\n  let timestamp: number;\n\n  try {\n    email = Buffer.from(emailB64, 'base64').toString();\n    timestamp = parseInt(timestampStr, 10);\n\n    if (isNaN(timestamp) || !email || !nonce) {\n      return null;\n    }\n  } catch {\n    return null;\n  }\n\n  // Check expiration (both too old and too far in the future)\n  const maxAge = maxAgeSeconds ?? getSessionMaxAge();\n  const now = Math.floor(Date.now() / 1000);\n  const age = now - timestamp;\n\n  // Reject tokens older than maxAge\n  if (age > maxAge) {\n    return null;\n  }\n\n  // Reject tokens with timestamps too far in the future (clock skew defense)\n  // Negative age means timestamp is in the future\n  if (age < -CLOCK_SKEW_TOLERANCE) {\n    return null;\n  }\n\n  return email;\n}\n\n/**\n * Extract the bearer token from the Authorization header.\n *\n * HTTP schemes are case-insensitive per RFC 2616 Section 3.8.\n * Accepts \"Bearer\", \"bearer\", \"BEARER\", and any mixed-case variant.\n *\n * @param authHeader - The Authorization header value\n * @returns The bearer token, or null if not present/invalid\n */\nexport function extractBearerToken(authHeader: string | null): string | null {\n  if (!authHeader) {\n    return null;\n  }\n\n  // Use regex to be tolerant of multiple spaces between \"Bearer\" and the token\n  // e.g., \"Bearer    <token>\" should be valid\n  const match = authHeader.match(/^bearer\\s+(.+)$/i);\n  if (!match) {\n    return null;\n  }\n\n  return match[1].trim();\n}\n\n/**\n * Get the authenticated user from a request.\n *\n * This is the unified entry point for authentication across all API routes.\n * Behavior depends on AUTH_MODE environment variable:\n *\n * **Platform mode** (opt-in only, AUTH_MODE=platform):\n * - Requires IAP JWT verification in production (AUTH_MODE_PLATFORM_STRICT=true).\n * - In production, rejects all requests without verified IAP JWT assertion (fail closed).\n * - In development/testing, non-strict mode accepts x-user-email directly.\n * - Safe ONLY when deployment infrastructure validates the header (e.g., App Engine IAP).\n *\n * **Session mode** (default, AUTH_MODE=session or unset):\n * - Validates bearer token against HMAC secret.\n * - Safe for standalone deployments where client controls headers.\n *\n * @param request - The incoming HTTP request\n * @returns The authenticated user email, or null if authentication fails\n */\nexport async function getAuthenticatedUser(request: Request): Promise<string | null> {\n  const mode = getAuthMode();\n\n  if (mode === 'session') {\n    // Session mode: Validate bearer token\n    const authHeader = request.headers.get('authorization');\n    const token = extractBearerToken(authHeader);\n\n    if (!token) {\n      return null;\n    }\n\n    const secret = getSessionHmacSecret();\n    return verifySessionToken(token, secret);\n  }\n\n  // Platform mode: Trust x-user-email header (unless strict mode is enabled)\n  const headerEmail = request.headers.get('x-user-email');\n\n  // Security: Fail closed outside development/test unless strict mode is enabled\n  // This prevents auth bypass in staging, preview, or unset NODE_ENV scenarios\n  const nodeEnv = process.env.NODE_ENV;\n  const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n  const isStrictMode = process.env.AUTH_MODE_PLATFORM_STRICT === 'true';\n\n  if (!isDevelopment && !isStrictMode) {\n    // Fail closed when not in explicit dev/test environment and strict mode is disabled\n    // Non-strict platform mode is ONLY allowed for development/testing\n    console.warn(\n      'Platform mode requires AUTH_MODE_PLATFORM_STRICT=true outside development. ' +\n        'Request rejected for security.'\n    );\n    return null;\n  }\n\n  // Strict mode: require verified IAP JWT assertion and ignore header spoofing.\n  if (isStrictMode) {\n    const assertion = request.headers.get('x-goog-iap-jwt-assertion');\n    if (!assertion) {\n      return null;\n    }\n\n    const verifiedEmail = await verifyIapJwt(assertion);\n    if (!verifiedEmail) {\n      return null;\n    }\n\n    if (headerEmail && headerEmail !== verifiedEmail) {\n      return null;\n    }\n\n    return verifiedEmail;\n  }\n\n  if (!headerEmail) {\n    return null;\n  }\n\n  // Basic email format validation (applies to both modes)\n  if (!isValidEmail(headerEmail)) {\n    return null;\n  }\n\n  return headerEmail;\n}\n","numLines":421,"startLine":1,"totalLines":421}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_f161ecaf36974d9dab8da1fa","type":"tool_result","content":"1\t/**\n2\t * Cryptographic utilities for secure token generation and verification.\n3\t * Provides HMAC-signed tokens to prevent forgery and information leakage.\n4\t */\n5\t\n6\timport { createHmac, timingSafeEqual } from 'crypto';\n7\t\n8\t/**\n9\t * Clock skew tolerance for token timestamp validation.\n10\t *\n11\t * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n12\t * extended validity from crafted future timestamps or clock skew.\n13\t *\n14\t * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n15\t *\n16\t * @see CLOCK_SKEW_TOLERANCE in auth.ts - should match across token types\n17\t */\n18\texport const CLOCK_SKEW_TOLERANCE = 300;\n19\t\n20\t/**\n21\t * Payload structure for upload tokens.\n22\t */\n23\texport interface UploadPayload {\n24\t  user: string;\n25\t  timestamp: number;\n26\t  filename: string;\n27\t}\n28\t\n29\t/**\n30\t * Generate a cryptographically signed token for upload tracking.\n31\t *\n32\t * Token format: base64url(payload) + \".\" + base64url(hmac_sha256(secret, payload))\n33\t *\n34\t * The payload is double-encoded:\n35\t * 1. Each component is base64-encoded to prevent delimiter confusion\n36\t * 2. The entire payload string is base64url-encoded\n37\t * 3. An HMAC signature is appended\n38\t *\n39\t * This prevents:\n40\t * - Token forgery (signature verification required)\n41\t * - Information leakage (payload is encoded, not plaintext)\n42\t *\n43\t * @param payload - The upload payload containing user, timestamp, and filename\n44\t * @param secret - The HMAC secret key (use environment variable in production)\n45\t * @returns A signed token in the format: encodedPayload.signature\n46\t */\n47\texport function generateUploadToken(payload: UploadPayload, secret: string): string {\n48\t  // Encode each component to base64 to handle special characters and prevent delimiter collision\n49\t  const encodedUser = Buffer.from(payload.user).toString('base64');\n50\t  const encodedFilename = Buffer.from(payload.filename).toString('base64');\n51\t\n52\t  // Create the payload string with encoded components\n53\t  const payloadString = `${encodedUser}:${payload.timestamp}:${encodedFilename}`;\n54\t\n55\t  // Double-encode the payload (base64url) for the token format\n56\t  const encodedPayload = Buffer.from(payloadString).toString('base64url');\n57\t\n58\t  // Generate HMAC signature\n59\t  const signature = createHmac('sha256', secret)\n60\t    .update(encodedPayload)\n61\t    .digest('base64url');\n62\t\n63\t  return `${encodedPayload}.${signature}`;\n64\t}\n65\t\n66\t/**\n67\t * Verify an upload token signature and decode the payload.\n68\t *\n69\t * @param token - The signed token to verify\n70\t * @param secret - The HMAC secret key used to sign the token\n71\t * @returns The decoded payload if valid, null if invalid or expired\n72\t */\n73\texport function verifyUploadToken(token: string, secret: string): UploadPayload | null {\n74\t  // Split token into payload and signature\n75\t  const lastDotIndex = token.lastIndexOf('.');\n76\t  if (lastDotIndex === -1) {\n77\t    return null; // Invalid format\n78\t  }\n79\t\n80\t  const encodedPayload = token.substring(0, lastDotIndex);\n81\t  const signature = token.substring(lastDotIndex + 1);\n82\t\n83\t  if (!encodedPayload || !signature) {\n84\t    return null;\n85\t  }\n86\t\n87\t  // Verify signature using constant-time comparison to prevent timing attacks\n88\t  const expectedSignature = createHmac('sha256', secret)\n89\t    .update(encodedPayload)\n90\t    .digest('base64url');\n91\t\n92\t  // Convert base64url strings to Buffers for timing-safe comparison\n93\t  const sigBuf = Buffer.from(signature, 'base64url');\n94\t  const expectedBuf = Buffer.from(expectedSignature, 'base64url');\n95\t\n96\t  // Length check is acceptable here since HMAC-SHA256 always produces 32 bytes (43 chars base64url)\n97\t  if (sigBuf.length !== expectedBuf.length) {\n98\t    return null;\n99\t  }\n100\t\n101\t  if (!timingSafeEqual(sigBuf, expectedBuf)) {\n102\t    return null; // Signature mismatch - token may have been tampered with\n103\t  }\n104\t\n105\t  // Decode payload\n106\t  let decoded: string;\n107\t  try {\n108\t    decoded = Buffer.from(encodedPayload, 'base64url').toString();\n109\t  } catch {\n110\t    return null; // Invalid base64url encoding\n111\t  }\n112\t\n113\t  // Parse payload components\n114\t  const parts = decoded.split(':');\n115\t  if (parts.length !== 3) {\n116\t    return null; // Invalid payload structure\n117\t  }\n118\t\n119\t  const [userB64, timestampStr, filenameB64] = parts;\n120\t\n121\t  // Decode each component\n122\t  let user: string;\n123\t  let filename: string;\n124\t  let timestamp: number;\n125\t\n126\t  try {\n127\t    user = Buffer.from(userB64, 'base64').toString();\n128\t    filename = Buffer.from(filenameB64, 'base64').toString();\n129\t    timestamp = parseInt(timestampStr, 10);\n130\t\n131\t    if (isNaN(timestamp) || !user || !filename) {\n132\t      return null;\n133\t    }\n134\t  } catch {\n135\t    return null; // Invalid base64 encoding in components\n136\t  }\n137\t\n138\t  return { user, timestamp, filename };\n139\t}\n140\t\n141\t/**\n142\t * Check if an upload token has expired.\n143\t *\n144\t * A token is considered expired if:\n145\t * 1. It is older than maxAgeSeconds (too old)\n146\t * 2. Its timestamp is beyond now + CLOCK_SKEW_TOLERANCE (too far in the future)\n147\t *\n148\t * @param payload - The decoded upload payload\n149\t * @param maxAgeSeconds - Maximum age in seconds (default: 15 minutes)\n150\t * @returns true if the token has expired, false otherwise\n151\t */\n152\texport function isUploadTokenExpired(payload: UploadPayload, maxAgeSeconds: number = 15 * 60): boolean {\n153\t  const now = Math.floor(Date.now() / 1000);\n154\t  const age = now - payload.timestamp;\n155\t\n156\t  // Reject tokens older than maxAge\n157\t  if (age > maxAgeSeconds) {\n158\t    return true;\n159\t  }\n160\t\n161\t  // Reject tokens with timestamps too far in the future (clock skew defense)\n162\t  // Negative age means timestamp is in the future\n163\t  if (age < -CLOCK_SKEW_TOLERANCE) {\n164\t    return true;\n165\t  }\n166\t\n167\t  return false;\n168\t}\n169\t\n170\t// Known placeholder secrets from .env.example that must not be used in production\n171\tconst DEFAULT_SECRETS = [\n172\t  'development-secret-change-in-production',\n173\t  'change-this-to-a-random-32-byte-string',\n174\t  'change-this-to-a-different-random-32-byte-string',\n175\t];\n176\t\n177\t/**\n178\t * Get the HMAC secret for signing upload tokens.\n179\t * Throws if UPLOAD_HMAC_SECRET is not set or if using the default value in production.\n180\t *\n181\t * @throws {Error} If UPLOAD_HMAC_SECRET environment variable is not set\n182\t * @throws {Error} If using a known placeholder secret in production mode (NODE_ENV=production)\n183\t * @returns The HMAC secret\n184\t */\n185\t\n186\texport function getHmacSecret(): string {\n187\t  const secret = process.env.UPLOAD_HMAC_SECRET;\n188\t  if (!secret) {\n189\t    throw new Error(\n190\t      'UPLOAD_HMAC_SECRET environment variable is required. ' +\n191\t      'Set it in your environment or .env file. ' +\n192\t      'Generate with: openssl rand -base64 32'\n193\t    );\n194\t  }\n195\t\n196\t  // Security: Fail closed outside development/test environments\n197\t  // This prevents HMAC token forgery in staging, preview, or unset NODE_ENV scenarios\n198\t  const nodeEnv = process.env.NODE_ENV;\n199\t  const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n200\t\n201\t  if (!isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n202\t    throw new Error(\n203\t      'UPLOAD_HMAC_SECRET is set to a known placeholder value. ' +\n204\t      'This is insecure outside development/test environments. ' +\n205\t      'Generate a secure random value with: openssl rand -base64 32'\n206\t    );\n207\t  }\n208\t\n209\t  // Warn if using a default development value (development/test only)\n210\t  if (isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n211\t    console.warn(\n212\t      'WARNING: Using default UPLOAD_HMAC_SECRET. ' +\n213\t      'This is insecure for production. Generate a secure random value.'\n214\t    );\n215\t  }\n216\t\n217\t  return secret;\n218\t}\n219\t\n220\t/**\n221\t * Get the HMAC secret for signing session tokens.\n222\t * Throws if SESSION_HMAC_SECRET is not set and UPLOAD_HMAC_SECRET is also not set,\n223\t * or if using the default value in production.\n224\t *\n225\t * Falls back to UPLOAD_HMAC_SECRET for backward compatibility if SESSION_HMAC_SECRET\n226\t * is not set. This allows existing deployments to continue working while encouraging\n227\t * separation of session and upload token secrets for defense in depth.\n228\t *\n229\t * @throws {Error} If neither SESSION_HMAC_SECRET nor UPLOAD_HMAC_SECRET is set\n230\t * @throws {Error} If using the default secret in production mode (NODE_ENV=production)\n231\t * @returns The HMAC secret for session tokens\n232\t */\n233\texport function getSessionHmacSecret(): string {\n234\t  const secret = process.env.SESSION_HMAC_SECRET;\n235\t  if (secret) {\n236\t    // Validate SESSION_HMAC_SECRET if set\n237\t\n238\t    // Security: Fail closed outside development/test environments\n239\t    // This prevents session token forgery in staging, preview, or unset NODE_ENV scenarios\n240\t    const nodeEnv = process.env.NODE_ENV;\n241\t    const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n242\t\n243\t    if (!isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n244\t      throw new Error(\n245\t        'SESSION_HMAC_SECRET is set to a known placeholder value. ' +\n246\t        'This is insecure outside development/test environments. ' +\n247\t        'Generate a secure random value with: openssl rand -base64 32'\n248\t      );\n249\t    }\n250\t\n251\t    // Warn if using a default development value (development/test only)\n252\t    if (isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n253\t      console.warn(\n254\t        'WARNING: Using default SESSION_HMAC_SECRET. ' +\n255\t        'This is insecure for production. Generate a secure random value.'\n256\t      );\n257\t    }\n258\t\n259\t    return secret;\n260\t  }\n261\t\n262\t  // Fall back to UPLOAD_HMAC_SECRET for backward compatibility\n263\t  console.warn(\n264\t    'WARNING: SESSION_HMAC_SECRET not set, falling back to UPLOAD_HMAC_SECRET. ' +\n265\t    'For better security, set a separate SESSION_HMAC_SECRET environment variable.'\n266\t  );\n267\t  return getHmacSecret();\n268\t}\n269\t"}]},"parent_tool_use_id":null,"session_id":"21b9bbd8-6878-4a2c-9d2e-2206e80b3232","uuid":"f6a216fd-26ab-42d6-b1a2-df6f7a93299c","timestamp":"2026-04-06T09:52:18.667Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/crypto.ts","content":"/**\n * Cryptographic utilities for secure token generation and verification.\n * Provides HMAC-signed tokens to prevent forgery and information leakage.\n */\n\nimport { createHmac, timingSafeEqual } from 'crypto';\n\n/**\n * Clock skew tolerance for token timestamp validation.\n *\n * Tokens with timestamps beyond `now + CLOCK_SKEW_TOLERANCE` are rejected to prevent\n * extended validity from crafted future timestamps or clock skew.\n *\n * Value: 300 seconds (5 minutes) - common NTP/RTC drift tolerance.\n *\n * @see CLOCK_SKEW_TOLERANCE in auth.ts - should match across token types\n */\nexport const CLOCK_SKEW_TOLERANCE = 300;\n\n/**\n * Payload structure for upload tokens.\n */\nexport interface UploadPayload {\n  user: string;\n  timestamp: number;\n  filename: string;\n}\n\n/**\n * Generate a cryptographically signed token for upload tracking.\n *\n * Token format: base64url(payload) + \".\" + base64url(hmac_sha256(secret, payload))\n *\n * The payload is double-encoded:\n * 1. Each component is base64-encoded to prevent delimiter confusion\n * 2. The entire payload string is base64url-encoded\n * 3. An HMAC signature is appended\n *\n * This prevents:\n * - Token forgery (signature verification required)\n * - Information leakage (payload is encoded, not plaintext)\n *\n * @param payload - The upload payload containing user, timestamp, and filename\n * @param secret - The HMAC secret key (use environment variable in production)\n * @returns A signed token in the format: encodedPayload.signature\n */\nexport function generateUploadToken(payload: UploadPayload, secret: string): string {\n  // Encode each component to base64 to handle special characters and prevent delimiter collision\n  const encodedUser = Buffer.from(payload.user).toString('base64');\n  const encodedFilename = Buffer.from(payload.filename).toString('base64');\n\n  // Create the payload string with encoded components\n  const payloadString = `${encodedUser}:${payload.timestamp}:${encodedFilename}`;\n\n  // Double-encode the payload (base64url) for the token format\n  const encodedPayload = Buffer.from(payloadString).toString('base64url');\n\n  // Generate HMAC signature\n  const signature = createHmac('sha256', secret)\n    .update(encodedPayload)\n    .digest('base64url');\n\n  return `${encodedPayload}.${signature}`;\n}\n\n/**\n * Verify an upload token signature and decode the payload.\n *\n * @param token - The signed token to verify\n * @param secret - The HMAC secret key used to sign the token\n * @returns The decoded payload if valid, null if invalid or expired\n */\nexport function verifyUploadToken(token: string, secret: string): UploadPayload | null {\n  // Split token into payload and signature\n  const lastDotIndex = token.lastIndexOf('.');\n  if (lastDotIndex === -1) {\n    return null; // Invalid format\n  }\n\n  const encodedPayload = token.substring(0, lastDotIndex);\n  const signature = token.substring(lastDotIndex + 1);\n\n  if (!encodedPayload || !signature) {\n    return null;\n  }\n\n  // Verify signature using constant-time comparison to prevent timing attacks\n  const expectedSignature = createHmac('sha256', secret)\n    .update(encodedPayload)\n    .digest('base64url');\n\n  // Convert base64url strings to Buffers for timing-safe comparison\n  const sigBuf = Buffer.from(signature, 'base64url');\n  const expectedBuf = Buffer.from(expectedSignature, 'base64url');\n\n  // Length check is acceptable here since HMAC-SHA256 always produces 32 bytes (43 chars base64url)\n  if (sigBuf.length !== expectedBuf.length) {\n    return null;\n  }\n\n  if (!timingSafeEqual(sigBuf, expectedBuf)) {\n    return null; // Signature mismatch - token may have been tampered with\n  }\n\n  // Decode payload\n  let decoded: string;\n  try {\n    decoded = Buffer.from(encodedPayload, 'base64url').toString();\n  } catch {\n    return null; // Invalid base64url encoding\n  }\n\n  // Parse payload components\n  const parts = decoded.split(':');\n  if (parts.length !== 3) {\n    return null; // Invalid payload structure\n  }\n\n  const [userB64, timestampStr, filenameB64] = parts;\n\n  // Decode each component\n  let user: string;\n  let filename: string;\n  let timestamp: number;\n\n  try {\n    user = Buffer.from(userB64, 'base64').toString();\n    filename = Buffer.from(filenameB64, 'base64').toString();\n    timestamp = parseInt(timestampStr, 10);\n\n    if (isNaN(timestamp) || !user || !filename) {\n      return null;\n    }\n  } catch {\n    return null; // Invalid base64 encoding in components\n  }\n\n  return { user, timestamp, filename };\n}\n\n/**\n * Check if an upload token has expired.\n *\n * A token is considered expired if:\n * 1. It is older than maxAgeSeconds (too old)\n * 2. Its timestamp is beyond now + CLOCK_SKEW_TOLERANCE (too far in the future)\n *\n * @param payload - The decoded upload payload\n * @param maxAgeSeconds - Maximum age in seconds (default: 15 minutes)\n * @returns true if the token has expired, false otherwise\n */\nexport function isUploadTokenExpired(payload: UploadPayload, maxAgeSeconds: number = 15 * 60): boolean {\n  const now = Math.floor(Date.now() / 1000);\n  const age = now - payload.timestamp;\n\n  // Reject tokens older than maxAge\n  if (age > maxAgeSeconds) {\n    return true;\n  }\n\n  // Reject tokens with timestamps too far in the future (clock skew defense)\n  // Negative age means timestamp is in the future\n  if (age < -CLOCK_SKEW_TOLERANCE) {\n    return true;\n  }\n\n  return false;\n}\n\n// Known placeholder secrets from .env.example that must not be used in production\nconst DEFAULT_SECRETS = [\n  'development-secret-change-in-production',\n  'change-this-to-a-random-32-byte-string',\n  'change-this-to-a-different-random-32-byte-string',\n];\n\n/**\n * Get the HMAC secret for signing upload tokens.\n * Throws if UPLOAD_HMAC_SECRET is not set or if using the default value in production.\n *\n * @throws {Error} If UPLOAD_HMAC_SECRET environment variable is not set\n * @throws {Error} If using a known placeholder secret in production mode (NODE_ENV=production)\n * @returns The HMAC secret\n */\n\nexport function getHmacSecret(): string {\n  const secret = process.env.UPLOAD_HMAC_SECRET;\n  if (!secret) {\n    throw new Error(\n      'UPLOAD_HMAC_SECRET environment variable is required. ' +\n      'Set it in your environment or .env file. ' +\n      'Generate with: openssl rand -base64 32'\n    );\n  }\n\n  // Security: Fail closed outside development/test environments\n  // This prevents HMAC token forgery in staging, preview, or unset NODE_ENV scenarios\n  const nodeEnv = process.env.NODE_ENV;\n  const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n\n  if (!isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n    throw new Error(\n      'UPLOAD_HMAC_SECRET is set to a known placeholder value. ' +\n      'This is insecure outside development/test environments. ' +\n      'Generate a secure random value with: openssl rand -base64 32'\n    );\n  }\n\n  // Warn if using a default development value (development/test only)\n  if (isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n    console.warn(\n      'WARNING: Using default UPLOAD_HMAC_SECRET. ' +\n      'This is insecure for production. Generate a secure random value.'\n    );\n  }\n\n  return secret;\n}\n\n/**\n * Get the HMAC secret for signing session tokens.\n * Throws if SESSION_HMAC_SECRET is not set and UPLOAD_HMAC_SECRET is also not set,\n * or if using the default value in production.\n *\n * Falls back to UPLOAD_HMAC_SECRET for backward compatibility if SESSION_HMAC_SECRET\n * is not set. This allows existing deployments to continue working while encouraging\n * separation of session and upload token secrets for defense in depth.\n *\n * @throws {Error} If neither SESSION_HMAC_SECRET nor UPLOAD_HMAC_SECRET is set\n * @throws {Error} If using the default secret in production mode (NODE_ENV=production)\n * @returns The HMAC secret for session tokens\n */\nexport function getSessionHmacSecret(): string {\n  const secret = process.env.SESSION_HMAC_SECRET;\n  if (secret) {\n    // Validate SESSION_HMAC_SECRET if set\n\n    // Security: Fail closed outside development/test environments\n    // This prevents session token forgery in staging, preview, or unset NODE_ENV scenarios\n    const nodeEnv = process.env.NODE_ENV;\n    const isDevelopment = nodeEnv === 'development' || nodeEnv === 'test';\n\n    if (!isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n      throw new Error(\n        'SESSION_HMAC_SECRET is set to a known placeholder value. ' +\n        'This is insecure outside development/test environments. ' +\n        'Generate a secure random value with: openssl rand -base64 32'\n      );\n    }\n\n    // Warn if using a default development value (development/test only)\n    if (isDevelopment && DEFAULT_SECRETS.includes(secret)) {\n      console.warn(\n        'WARNING: Using default SESSION_HMAC_SECRET. ' +\n        'This is insecure for production. Generate a secure random value.'\n      );\n    }\n\n    return secret;\n  }\n\n  // Fall back to UPLOAD_HMAC_SECRET for backward compatibility\n  console.warn(\n    'WARNING: SESSION_HMAC_SECRET not set, falling back to UPLOAD_HMAC_SECRET. ' +\n    'For better security, set a separate SESSION_HMAC_SECRET environment variable.'\n  );\n  return getHmacSecret();\n}\n","numLines":269,"startLine":1,"totalLines":269}}}
