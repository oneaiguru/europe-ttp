rce.toLowerCase();\n    target = target.toLowerCase();\n  }\n  if (source.length < target.length) {\n    return levenshteinB(target, source, maxDistance, caseInsensitive);\n  }\n  // So now we have len(source) >= len(target).\n  const previousRow: number[] = [];\n  for (let i = 0; i <= target.length; i++) {\n    previousRow.push(i);\n  }\n  for (const s of source) {\n    const currentRow: number[] = [previousRow[0] + 1];\n    for (let j = 1; j <= target.length; j++) {\n      const subCost = previousRow[j - 1] + (target[j - 1] !== s ? 1 : 0);\n      const insertCost = previousRow[j] + 1;\n      const delCost = currentRow[j - 1] + 1;\n      currentRow[j] = Math.min(subCost, insertCost, delCost);\n    }\n    for (let i = 0; i < previousRow.length; i++) {\n      previousRow[i] = currentRow[i];\n    }\n  }\n\n  return previousRow[target.length] <= maxDistance;\n}\n```\n\nLet me verify the algorithm step by step:\n\nPython uses numpy operations:\n1. `previous_row = np.arange(target.size + 1)` — initializes to [0, 1, 2, ..., target.size]\n2. For each character `s` in source:\n   - `current_row = previous_row + 1` — starts as all elements +1\n   - `current_row[1:] = np.minimum(current_row[1:], np.add(previous_row[:-1], target != s))` — for indices 1 onwards, take min of current value and previous_row[j-1] + (target[j-1] != s)\n   - `current_row[1:] = np.minimum(current_row[1:], current_row[0:-1] + 1)` — for indices 1 onwards, take min of current value and current_row[j-1] + 1\n\nTypeScript:\n1. `previousRow` initialized to [0, 1, 2, ..., target.length] — same\n2. For each character `s` in source:\n   - `currentRow[0] = previousRow[0] + 1` — same as numpy `current_row = previous_row + 1` for index 0\n   - For j from 1 to target.length:\n     - `subCost = previousRow[j - 1] + (target[j - 1] !== s ? 1 : 0)` — same as `np.add(previous_row[:-1], target != s)`\n     - `insertCost = previousRow[j] + 1` — same as `current_row[j]` after `current_row = previous_row + 1`\n     - `delC