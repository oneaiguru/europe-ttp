{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_1574adc5861c461695eb5f71","type":"tool_result","content":"1\t/**\n2\t * Bounded Levenshtein distance check.\n3\t * Returns true if the edit distance between str1 and str2 is <= maxDistance.\n4\t *\n5\t * Port of pyutils.utils.levenshteinB\n6\t *\n7\t * @param str1 - First string\n8\t * @param str2 - Second string\n9\t * @param maxDistance - Maximum allowed edit distance (1 for TTC evals, 2 for post-TTC)\n10\t * @param caseInsensitive - If true, compare lowercase versions\n11\t */\n12\texport function levenshteinB(\n13\t  str1: string,\n14\t  str2: string,\n15\t  maxDistance: number,\n16\t  caseInsensitive: boolean = false,\n17\t): boolean {\n18\t  let source = str1.trim();\n19\t  let target = str2.trim();\n20\t\n21\t  if (!source || !target || source.length === 0 || target.length === 0) {\n22\t    return false;\n23\t  }\n24\t\n25\t  // If tolerance is greater than length of either string\n26\t  // then levenshtein is not that useful\n27\t  if (maxDistance >= source.length || maxDistance >= target.length) {\n28\t    return false;\n29\t  }\n30\t\n31\t  if (caseInsensitive) {\n32\t    source = source.toLowerCase();\n33\t    target = target.toLowerCase();\n34\t  }\n35\t\n36\t  if (source.length < target.length) {\n37\t    return levenshteinB(target, source, maxDistance, caseInsensitive);\n38\t  }\n39\t  // So now we have len(source) >= len(target).\n40\t\n41\t  // We use a dynamic programming algorithm, but with the\n42\t  // added optimization that we only need the last two rows\n43\t  // of the matrix.\n44\t  const previousRow: number[] = [];\n45\t  for (let i = 0; i <= target.length; i++) {\n46\t    previousRow.push(i);\n47\t  }\n48\t\n49\t  for (const s of source) {\n50\t    // Insertion (target grows longer than source):\n51\t    const currentRow: number[] = [previousRow[0] + 1];\n52\t\n53\t    for (let j = 1; j <= target.length; j++) {\n54\t      // Substitution or matching:\n55\t      // Target and source items are aligned, and either\n56\t      // are different (cost of 1), or are the same (cost of 0).\n57\t      const subCost = previousRow[j - 1] + (target[j - 1] !== s ? 1 : 0);\n58\t      const insertCost = previousRow[j] + 1;\n59\t      const delCost = currentRow[j - 1] + 1;\n60\t\n61\t      currentRow[j] = Math.min(subCost, insertCost, delCost);\n62\t    }\n63\t\n64\t    for (let i = 0; i < previousRow.length; i++) {\n65\t      previousRow[i] = currentRow[i];\n66\t    }\n67\t  }\n68\t\n69\t  return previousRow[target.length] <= maxDistance;\n70\t}\n71\t"}]},"parent_tool_use_id":null,"session_id":"558604e9-273e-47d7-8444-83b4de31c853","uuid":"245dc8b1-d2f3-4c9d-b671-5d6d177cd50f","timestamp":"2026-04-06T09:52:18.668Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/m/ttp-split-experiment/app/utils/reporting/matching.ts","content":"/**\n * Bounded Levenshtein distance check.\n * Returns true if the edit distance between str1 and str2 is <= maxDistance.\n *\n * Port of pyutils.utils.levenshteinB\n *\n * @param str1 - First string\n * @param str2 - Second string\n * @param maxDistance - Maximum allowed edit distance (1 for TTC evals, 2 for post-TTC)\n * @param caseInsensitive - If true, compare lowercase versions\n */\nexport function levenshteinB(\n  str1: string,\n  str2: string,\n  maxDistance: number,\n  caseInsensitive: boolean = false,\n): boolean {\n  let source = str1.trim();\n  let target = str2.trim();\n\n  if (!source || !target || source.length === 0 || target.length === 0) {\n    return false;\n  }\n\n  // If tolerance is greater than length of either string\n  // then levenshtein is not that useful\n  if (maxDistance >= source.length || maxDistance >= target.length) {\n    return false;\n  }\n\n  if (caseInsensitive) {\n    source = source.toLowerCase();\n    target = target.toLowerCase();\n  }\n\n  if (source.length < target.length) {\n    return levenshteinB(target, source, maxDistance, caseInsensitive);\n  }\n  // So now we have len(source) >= len(target).\n\n  // We use a dynamic programming algorithm, but with the\n  // added optimization that we only need the last two rows\n  // of the matrix.\n  const previousRow: number[] = [];\n  for (let i = 0; i <= target.length; i++) {\n    previousRow.push(i);\n  }\n\n  for (const s of source) {\n    // Insertion (target grows longer than source):\n    const currentRow: number[] = [previousRow[0] + 1];\n\n    for (let j = 1; j <= target.length; j++) {\n      // Substitution or matching:\n      // Target and source items are aligned, and either\n      // are different (cost of 1), or are the same (cost of 0).\n      const subCost = previousRow[j - 1] + (target[j - 1] !== s ? 1 : 0);\n      const insertCost = previousRow[j] + 1;\n      const delCost = currentRow[j - 1] + 1;\n\n      currentRow[j] = Math.min(subCost, insertCost, delCost);\n    }\n\n    for (let i = 0; i < previousRow.length; i++) {\n      previousRow[i] = currentRow[i];\n    }\n  }\n\n  return previousRow[target.length] <= maxDistance;\n}\n","numLines":71,"startLine":1,"totalLines":71}}}
