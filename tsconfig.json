{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    // skipLibCheck: true required for large codebases with @types/node to avoid type conflicts in third-party modules
    // These conflicts are expected and cannot be fixed in application code
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "test/bdd/**/*.ts",
    "test/typescript/**/*.ts",
    "test/utils/**/*.ts",
    "test/fixtures/**/*.ts",
    "test/playwright/**/*.ts",
    "test/javascript/**/*.ts",
    "test/scripts/**/*.ts",
    "scripts/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "test/typescript/node_modules"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "moduleTypes": {
      "test/typescript/**/*.ts": "cjs",
      "scripts/**/*.ts": "cjs"
    }
  }
}
