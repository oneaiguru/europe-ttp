{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "jsx": "react"
  },
  "include": ["test/typescript/**/*.ts", "scripts/**/*.ts", "app/**/*.tsx", "app/**/*.ts"],
  "exclude": ["node_modules", "test/typescript/node_modules"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "moduleTypes": {
      "test/typescript/**/*.ts": "cjs",
      "scripts/**/*.ts": "cjs"
    }
  }
}
