# Environment Variables Template
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to the repository

# Environment Mode
# IMPORTANT: NODE_ENV must be explicitly set to 'development' or 'test' for
# development defaults. Unset or other values (staging, preview, etc.) are
# treated as production-like with fail-closed security behavior.
# - NODE_ENV=development: Enables development defaults and relaxed security
# - NODE_ENV=test: Same as development, for automated testing
# - NODE_ENV=production (or unset/staging/preview): Strict security, rejects default secrets
NODE_ENV=development

# SendGrid Configuration
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Harmony Search API
# Contact your Harmony Search provider for the API key
HARMONY_SEARCH_API_KEY=your_harmony_search_api_key_here

# Google Maps API
# Get your API keys from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PUBLIC_API_KEY=your_google_public_api_key_here

# Google Cloud Storage
# Required for signed URL generation in /api/upload/signed-url
# If not configured, the endpoint returns HTTP 501 (Not Implemented)

# Option A: Service Account JSON (inline)
# Set GCS_CREDENTIALS to a JSON string of your service account
# GCS_CREDENTIALS='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}'

# Option B: Application Default Credentials (ADC)
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS='/path/to/service-account.json'

# Bucket name (required for all GCS operations)
GCS_BUCKET_NAME=artofliving-ttcdesk.appspot.com

# GCS Emulator (for local development without real GCS credentials)
# When set, all GCS reads use the JSON REST API against this host.
# Start with: docker run -d -p 4443:4443 fsouza/fake-gcs-server -scheme http
# Or use docker-compose.yml which includes the emulator automatically.
# STORAGE_EMULATOR_HOST=http://localhost:4443

# Upload Token HMAC Secret
# Used to sign upload tokens to prevent forgery and information leakage.
# WARNING: When NODE_ENV=production, using the default value
# 'development-secret-change-in-production' will cause the application to fail.
# Always use a secure random value in production.
# Generate with: openssl rand -base64 32
UPLOAD_HMAC_SECRET=change-this-to-a-random-32-byte-string

# Session Token HMAC Secret
# Used to sign session tokens to prevent replay attacks and token-type confusion.
# Separating session and upload token secrets provides defense in depth:
# even if an upload key leaks, it cannot be replayed as a session token.
# Falls back to UPLOAD_HMAC_SECRET if not set (backward compatible).
# WARNING: When NODE_ENV=production, using the default value
# 'development-secret-change-in-production' will cause the application to fail.
# Always use a secure random value in production, distinct from UPLOAD_HMAC_SECRET.
# Generate with: openssl rand -base64 32
SESSION_HMAC_SECRET=change-this-to-a-different-random-32-byte-string

# Authentication Mode
# Controls how API routes authenticate users
# - platform: Trust x-user-email header (App Engine with IAP)
# - session: Require bearer token with HMAC signature (standalone deployment)
# Default: session (fail-secure for non-App Engine deployments)
# Set AUTH_MODE=platform explicitly when using App Engine with IAP
AUTH_MODE=session

# Login credentials for local/test session mode (development only)
# Either provide a single DEV_LOGIN_PASSWORD (applies to any email),
# or DEV_LOGIN_CREDENTIALS as JSON map { "email": "password", ... }.
# If both are set, DEV_LOGIN_CREDENTIALS takes precedence.
# Examples:
# DEV_LOGIN_PASSWORD='change-me'
# DEV_LOGIN_CREDENTIALS='{"akshay.ponda@artofliving.org":"change-me"}'
# DEV_LOGIN_CREDENTIALS='{"akshay.ponda@artofliving.org":"pw1","admin@artofliving.org":"pw2"}'
# Leave unset to keep current email-only behavior.
DEV_LOGIN_PASSWORD=
DEV_LOGIN_CREDENTIALS=

# Optional: Enable strict IAP JWT verification in platform mode
# When enabled, platform mode requires a verified x-goog-iap-jwt-assertion
# and ignores client-supplied x-user-email (rejects mismatches).
# AUTH_MODE_PLATFORM_STRICT=true

# IAP JWT verification (required for strict mode)
# IAP_JWT_AUDIENCE='your-iap-audience'
# IAP_JWT_PUBLIC_KEY='-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----'
# Optional: Customize issuer (defaults to https://cloud.google.com/iap)
# IAP_JWT_ISSUER='https://cloud.google.com/iap'

# TEST IAP Private Key (for testing ONLY - NEVER use in production)
# Optional: Override the hardcoded test key in test/fixtures/test-config.ts
# For CI/CD systems, inject this via secrets to avoid committing test keys
# WARNING: This key is for TESTING ONLY. Using it in production is a security risk.
# TEST_IAP_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----'

# Session Token Max Age (seconds)
# How long session tokens remain valid in session mode
# Default: 3600 (1 hour)
SESSION_MAX_AGE_SECONDS=3600

# Upload API Rate Limiting
# Per-user rate limit for upload endpoints (signed-url and verify)
# Limits apply per-user within each time window
# UPLOAD_RATE_LIMIT_MAX: Maximum requests allowed per window
# UPLOAD_RATE_LIMIT_WINDOW_MS: Time window in milliseconds
# Default: 10 requests per 60 seconds
UPLOAD_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
